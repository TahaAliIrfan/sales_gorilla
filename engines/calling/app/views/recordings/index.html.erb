<%# Call recordings — relay DS. Serves both #index (all recordings) and
    #my_recordings (renders :index). Preserves the JS contracts exactly:
      - audio-player controller (data-audio-player-url-value, click->audio-player#play)
        + the #audio-player-modal / #audio-player elements it targets by id;
      - transcript-modal controller (data-transcript-modal-id-value, click->transcript-modal#open)
        + the #transcript-modal / #transcript-content / #debug-section / #debug-content
        / #toggle-debug / #copy-transcript elements and the inline script it relies on.
    The filter form keeps the start_date/end_date/customer_id/caller_id GET params
    and the transcript/download endpoints are unchanged. %>
<% mine = params[:action] == "my_recordings" %>
<% content_for :title, "#{mine ? "My recordings" : "Recordings"} — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title"><%= mine ? "My recordings" : "Recordings" %></div>
      <div class="pagehead__sub"><%= mine ? "Your call recordings." : "All call recordings." %></div>
    </div>
  </div>

  <div class="sect" style="margin-bottom:var(--space-4)">
    <div class="sect__body">
      <%= form_with url: (mine ? my_recordings_recordings_path : recordings_path), method: :get, class: "col", html: { style: "gap:var(--space-3)" } do |form| %>
        <div class="grid <%= mine ? "grid-3" : "grid-4" %>">
          <div class="rl-field">
            <label class="rl-label">Start date</label>
            <%= form.date_field :start_date, value: params[:start_date], class: "rl-input" %>
          </div>
          <div class="rl-field">
            <label class="rl-label">End date</label>
            <%= form.date_field :end_date, value: params[:end_date], class: "rl-input" %>
          </div>
          <div class="rl-field">
            <label class="rl-label">Customer</label>
            <%= form.collection_select :customer_id, Customer.order(:name), :id, :name,
                  { include_blank: "All customers", selected: params[:customer_id] }, { class: "rl-select" } %>
          </div>
          <% unless mine %>
            <div class="rl-field">
              <label class="rl-label">Caller</label>
              <%= form.collection_select :caller_id, User.order(:name), :id, :name,
                    { include_blank: "All callers", selected: params[:caller_id] }, { class: "rl-select" } %>
            </div>
          <% end %>
        </div>
        <div class="row" style="justify-content:flex-end;gap:8px">
          <%= link_to "Clear filters", (mine ? my_recordings_recordings_path : recordings_path), class: "rl-btn rl-btn--secondary" %>
          <%= form.submit "Filter", class: "rl-btn rl-btn--primary" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="sect">
    <div class="sect__body--flush">
      <div class="rl-table-scroll">
        <table class="rl-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Customer</th>
              <th>Caller</th>
              <th>Duration</th>
              <th>Audio</th>
              <th>Transcript</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if @recordings.empty? %>
              <tr><td colspan="7" class="muted rl-sm" style="text-align:center;padding:32px">No recordings found</td></tr>
            <% else %>
              <% @recordings.each do |recording| %>
                <tr>
                  <td class="rl-sm"><%= recording.date&.strftime("%b %-d, %Y %H:%M") %></td>
                  <td><%= link_to recording.customer.name, customer_path(recording.customer), class: "rl-cell-strong", style: "color:var(--brand-primary)" %></td>
                  <td class="rl-sm"><%= recording.user&.name || "Unknown" %></td>
                  <td class="rl-sm tnum"><%= pluralize(recording.duration.to_i / 60, "minute") %> <%= recording.duration.to_i % 60 > 0 ? "#{recording.duration.to_i % 60} seconds" : "" %></td>
                  <td>
                    <% if recording.audio_file.attached? %>
                      <button data-controller="audio-player" data-audio-player-url-value="<%= rails_blob_url(recording.audio_file) %>"
                              data-action="click->audio-player#play" class="rl-iconbtn rl-iconbtn--sm" title="Play">
                        <%= relay_icon("play", size: 15) %>
                      </button>
                    <% else %>
                      <span class="muted"><%= relay_icon("x-circle", size: 15) %></span>
                    <% end %>
                  </td>
                  <td>
                    <% if recording.transcribed? %>
                      <button data-controller="transcript-modal" data-transcript-modal-id-value="<%= recording.id %>"
                              data-action="click->transcript-modal#open" class="rl-badge rl-badge--success" style="cursor:pointer;border:none">
                        <%= relay_icon("file-text", size: 12) %>View transcript
                      </button>
                    <% else %>
                      <span class="rl-badge rl-badge--neutral"><%= relay_icon("x-circle", size: 12) %>Not available</span>
                    <% end %>
                  </td>
                  <td>
                    <div class="row" style="gap:6px;justify-content:flex-end">
                      <%= link_to recording_path(recording), class: "rl-iconbtn rl-iconbtn--sm", title: "View details" do %>
                        <%= relay_icon("eye", size: 15) %>
                      <% end %>
                      <%= link_to download_recording_path(recording), class: "rl-iconbtn rl-iconbtn--sm", title: "Download recording" do %>
                        <%= relay_icon("download", size: 15) %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <% if @recordings.respond_to?(:total_pages) && @recordings.total_pages > 1 %>
    <div class="rl-pagebtns" style="margin-top:var(--space-4)"><%= paginate @recordings, theme: "relay" %></div>
  <% end %>
</div>

<%# ── Audio player modal (id-targeted by audio_player_controller) ──────────── %>
<div id="audio-player-modal" class="hidden ce-overlay" data-controller="modal"
     data-action="click@window->modal#closeBackground keyup@window->modal#closeWithKeyboard">
  <div class="ce-modal sect" data-modal-target="container">
    <div class="sect__head">
      <div class="sect__title grow">Recording player</div>
      <button type="button" class="rl-iconbtn rl-iconbtn--sm" data-action="modal#close" title="Close"><%= relay_icon("x", size: 16) %></button>
    </div>
    <div class="sect__body">
      <audio id="audio-player" controls style="width:100%"></audio>
    </div>
  </div>
</div>

<%# ── Transcript modal (id-targeted by transcript_modal_controller + inline JS) %>
<div id="transcript-modal" class="hidden ce-overlay" data-controller="modal"
     data-action="click->modal#closeBackground keyup@window->modal#closeWithKeyboard">
  <div class="ce-modal sect" style="max-width:56rem" data-modal-target="container">
    <div class="sect__head">
      <div class="sect__title grow row" style="gap:8px"><%= relay_icon("file-text", size: 16) %>Call transcript</div>
      <div class="row" style="gap:4px">
        <button type="button" id="toggle-debug" class="rl-iconbtn rl-iconbtn--sm" title="Toggle debugging info"><%= relay_icon("settings", size: 15) %></button>
        <button type="button" id="copy-transcript" class="rl-iconbtn rl-iconbtn--sm" title="Copy transcript to clipboard"><%= relay_icon("copy", size: 15) %></button>
        <button type="button" class="rl-iconbtn rl-iconbtn--sm" data-action="modal#close" title="Close"><%= relay_icon("x", size: 16) %></button>
      </div>
    </div>
    <div class="sect__body col" style="gap:var(--space-3)">
      <div id="debug-section" class="hidden">
        <div style="background:#1f2937;color:#fff;padding:12px;border-radius:var(--radius-md);overflow:auto;max-height:10rem">
          <div class="rl-sm" style="margin-bottom:6px">Debug information</div>
          <pre id="debug-content" style="font-size:11px;white-space:pre-wrap"></pre>
        </div>
      </div>
      <div id="transcript-content" class="col" style="max-height:24rem;overflow-y:auto;gap:var(--space-3)">
        <div style="text-align:center;padding:32px">
          <div class="muted rl-sm">Loading transcript…</div>
        </div>
      </div>
    </div>
    <div class="sect__body" style="border-top:1px solid var(--color-border)">
      <div class="row" style="justify-content:flex-end">
        <button type="button" class="rl-btn rl-btn--secondary" data-action="modal#close">Close</button>
      </div>
    </div>
  </div>
</div>

<style>
  .ce-overlay { position: fixed; inset: 0; z-index: 60; background: rgba(0,0,0,.4); display: flex; align-items: flex-start; justify-content: center; padding: 48px 16px; overflow:auto; }
  .ce-overlay.hidden { display: none; }
  .ce-modal { width: 100%; max-width: 640px; box-shadow: var(--shadow-lg); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var toggle = document.getElementById('toggle-debug');
    if (toggle) toggle.addEventListener('click', function() {
      const debugSection = document.getElementById('debug-section');
      debugSection.classList.toggle('hidden');
      if (!debugSection.classList.contains('hidden')) {
        const recordingId = document.querySelector('[data-transcript-modal-id-value]')?.dataset.transcriptModalIdValue;
        if (recordingId) {
          fetch(`/recordings/${recordingId}/transcript`)
            .then(response => response.json())
            .then(data => { document.getElementById('debug-content').textContent = JSON.stringify(data, null, 2); })
            .catch(error => { document.getElementById('debug-content').textContent = `Error: ${error.message}`; });
        } else {
          document.getElementById('debug-content').textContent = 'No recording ID found';
        }
      }
    });

    var copyBtn = document.getElementById('copy-transcript');
    if (copyBtn) copyBtn.addEventListener('click', function() {
      const transcriptContent = document.getElementById('transcript-content');
      const tempElement = document.createElement('div');
      tempElement.innerHTML = transcriptContent.innerHTML;
      const text = Array.from(tempElement.querySelectorAll('p')).map(p => p.textContent.trim()).join('\n\n');
      navigator.clipboard.writeText(text).then(
        function() { alert('Transcript copied to clipboard!'); },
        function() { alert('Could not copy transcript'); }
      );
    });
  });
</script>
