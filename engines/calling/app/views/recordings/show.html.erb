<%# Recording details — relay DS. Preserves the page-transcript controller
    contract (#transcript-container + data-page-transcript-id-value), the
    download endpoint, the AI analysis generate/regenerate POST, and the inline
    copyToClipboard() script the followup copy buttons call. %>
<% content_for :title, "Recording — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Recording details</div>
      <div class="pagehead__sub">Call recording from <%= @recording.date&.strftime("%b %-d, %Y %H:%M") %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to recordings_path, class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to recordings
      <% end %>
    </div>
  </div>

  <div class="grid grid-2" style="gap:var(--space-4);align-items:start">
    <div class="sect">
      <div class="sect__head"><div class="sect__title">Recording information</div></div>
      <div class="sect__body col" style="gap:var(--space-4)">
        <div class="grid grid-2" style="gap:var(--space-3)">
          <div><div class="micro">Date</div><div class="rl-sm" style="margin-top:2px"><%= @recording.date&.strftime("%b %-d, %Y %H:%M") %></div></div>
          <div><div class="micro">Duration</div><div class="rl-sm" style="margin-top:2px"><%= pluralize(@recording.duration.to_i / 60, "minute") %> <%= @recording.duration.to_i % 60 > 0 ? "#{@recording.duration.to_i % 60} seconds" : "" %></div></div>
          <div><div class="micro">Customer</div><div class="rl-sm" style="margin-top:2px"><%= link_to @recording.customer.name, customer_path(@recording.customer), style: "color:var(--brand-primary)" %></div></div>
          <div><div class="micro">Caller</div><div class="rl-sm" style="margin-top:2px"><%= @recording.user&.name || "Unknown" %></div></div>
          <div><div class="micro">Recording SID</div><div class="rl-sm mono" style="margin-top:2px;word-break:break-all"><%= @recording.sid %></div></div>
          <div><div class="micro">Call SID</div><div class="rl-sm mono" style="margin-top:2px;word-break:break-all"><%= @recording.call_sid %></div></div>
        </div>
        <div class="row">
          <%= link_to download_recording_path(@recording), class: "rl-btn rl-btn--secondary" do %>
            <%= relay_icon("download", size: 15) %>Download recording
          <% end %>
        </div>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Audio player</div></div>
      <div class="sect__body">
        <% if @recording.audio_file.attached? %>
          <audio controls style="width:100%">
            <source src="<%= rails_blob_url(@recording.audio_file) %>" type="audio/mpeg">
            Your browser does not support the audio element.
          </audio>
        <% else %>
          <div class="rl-sm row" style="gap:10px;padding:12px;background:var(--color-warning-subtle);border-radius:var(--radius-md);color:var(--color-warning-text)">
            <%= relay_icon("alert-triangle", size: 16) %>Audio file not available
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if feature_enabled?(:transcription) %>
    <div class="sect" style="margin-top:var(--space-4)">
      <div class="sect__head"><div class="sect__title">Transcript</div></div>
      <div class="sect__body">
        <% if @recording.transcribed? %>
          <div id="transcript-container" style="max-height:24rem;overflow-y:auto;padding:14px;background:var(--color-surface-2);border-radius:var(--radius-md)"
               data-controller="page-transcript" data-page-transcript-id-value="<%= @recording.id %>">
            <div style="text-align:center;padding:32px"><div class="muted rl-sm">Loading transcript…</div></div>
          </div>
        <% else %>
          <p class="muted rl-sm" style="text-align:center;padding:24px 0">Transcript is not available for this recording.</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="sect" style="margin-top:var(--space-4)">
    <div class="sect__head">
      <div class="sect__title grow">AI analysis</div>
      <% if @recording.transcribed? && (@latest_analysis.nil? || @analyses.count < 3) %>
        <%= button_to recording_ai_analyses_path(@recording), method: :post, class: "rl-btn rl-btn--primary rl-btn--sm" do %>
          <%= relay_icon("sparkles", size: 14) %><%= @latest_analysis.nil? ? "Generate AI analysis" : "Regenerate analysis" %>
        <% end %>
      <% end %>
    </div>
    <div class="sect__body">
      <% if @latest_analysis.present? %>
        <div class="col" style="gap:var(--space-4)">
          <div><div class="micro">Summary</div><div class="rl-sm" style="margin-top:4px"><%= @latest_analysis.summary %></div></div>

          <div>
            <div class="micro">Interest score</div>
            <div class="row" style="gap:3px;margin-top:6px;align-items:center">
              <% 5.times do |i| %>
                <span style="width:18px;height:8px;border-radius:3px;background:<%= i < @latest_analysis.interest_score.to_i ? "#f5a623" : "var(--color-border-strong)" %>"></span>
              <% end %>
              <span class="rl-sm tnum" style="margin-left:8px"><%= @latest_analysis.interest_score %>/5</span>
            </div>
          </div>

          <div><div class="micro">Improvement points</div><div class="rl-sm" style="margin-top:4px;white-space:pre-line"><%= @latest_analysis.improvement_points %></div></div>
          <div><div class="micro">Next steps</div><div class="rl-sm" style="margin-top:4px;white-space:pre-line"><%= @latest_analysis.next_steps %></div></div>

          <div>
            <div class="micro">Follow-up message (WhatsApp/Text)</div>
            <div class="rl-sm" style="margin-top:4px;white-space:pre-line;padding:12px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-md)">
              <%= @latest_analysis.followup_message %>
              <div class="row" style="margin-top:10px">
                <button type="button" onclick="copyToClipboard('<%= j(@latest_analysis.followup_message) %>')" class="rl-btn rl-btn--secondary rl-btn--sm">
                  <%= relay_icon("copy", size: 14) %>Copy
                </button>
              </div>
            </div>
          </div>

          <div>
            <div class="micro">Follow-up email</div>
            <div class="rl-sm" style="margin-top:4px;white-space:pre-line;padding:12px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-md)">
              <%= @latest_analysis.followup_email %>
              <div class="row" style="margin-top:10px">
                <button type="button" onclick="copyToClipboard('<%= j(@latest_analysis.followup_email) %>')" class="rl-btn rl-btn--secondary rl-btn--sm">
                  <%= relay_icon("copy", size: 14) %>Copy
                </button>
              </div>
            </div>
          </div>

          <% if @analyses.count > 1 %>
            <div style="border-top:1px solid var(--color-border);padding-top:var(--space-3)">
              <div class="micro" style="margin-bottom:8px">Previous analyses</div>
              <div class="col" style="gap:6px">
                <% @analyses.offset(1).each do |analysis| %>
                  <%= link_to recording_ai_analysis_path(@recording, analysis), class: "rl-sm", style: "color:var(--brand-primary)" do %>
                    Analysis from <%= analysis.created_at.strftime("%b %-d, %Y %H:%M") %> (Interest score: <%= analysis.interest_score %>/5)
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="muted rl-sm" style="text-align:center;padding:24px 0">
          <% if @recording.transcribed? %>
            No AI analysis has been generated yet. Click "Generate AI analysis" to create one.
          <% else %>
            AI analysis requires a transcript. Once the transcript is available, you can generate an AI analysis.
          <% end %>
        </p>
      <% end %>
    </div>
  </div>
</div>

<script>
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(function() {
      alert('Copied to clipboard!');
    }, function(err) {
      console.error('Could not copy text: ', err);
    });
  }
</script>
