<%# Relay-styled browser dialer. The markup contract with
    app/javascript/controllers/calling_controller.js is unchanged: every
    data-calling-* target/action and the #customer-search / #caller-id /
    #phone-number ids are identical to the previous (Tailwind) version. %>
<% content_for :title, "Calling — #{current_organization&.name}" %>

<%# Get the Twilio SDK warming up as soon as the browser parses this. %>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link rel="preload" as="script" href="https://cdn.jsdelivr.net/npm/@twilio/voice-sdk@2.15.0/dist/twilio.min.js" crossorigin>

<div class="page" data-controller="calling" data-calling-token-value="<%= @access_token %>"
     style="max-width:720px">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Make a call</div>
      <div class="pagehead__sub">Browser-based phone — calls are recorded and transcribed automatically.</div>
    </div>
  </div>

  <%# Live status pill — fed by the Stimulus controller. %>
  <div data-calling-target="callStatus" class="sect row"
       style="gap:10px;padding:12px 16px;margin-bottom:var(--space-4)">
    <span class="pulse-dot" style="background:var(--color-primary)"></span>
    <span data-calling-target="statusMessage" class="muted rl-sm">Initializing phone system…</span>
  </div>

  <%# Main phone card. %>
  <div class="sect">
    <div class="sect__head">
      <div class="sect__title"><%= relay_icon("phone", size: 18) %>Virtual caller</div>
      <span class="mono muted" style="font-size:11px;letter-spacing:var(--tracking-caps);text-transform:uppercase">Twilio · <%= current_organization.name %></span>
    </div>

    <div class="sect__body col" style="gap:var(--space-5)">
      <%# ── Customer picker ─────────────────────────────────────────────── %>
      <div class="col" style="gap:10px">
        <label class="rl-label" for="customer-search">Customer</label>
        <input type="text"
               id="customer-search"
               placeholder="Search by name…"
               class="rl-input"
               data-action="input->calling#filterCustomers">
        <select data-calling-target="customerSelect"
                data-action="calling#onCustomerSelect"
                class="rl-select">
          <option value="">Select a customer…</option>
          <% @customers.each do |customer| %>
            <option value="<%= customer.id %>"
                    data-phone="<%= customer.phone %>"
                    data-customer-name="<%= customer.name.downcase %>"
                    <%= 'selected' if @selected_customer&.id == customer.id %>>
              <%= customer.name %> — <%= customer.phone %>
            </option>
          <% end %>
        </select>
      </div>

      <%# ── Caller ID + phone + dial ────────────────────────────────────── %>
      <div class="rl-field">
        <label for="caller-id" class="rl-label">Caller ID</label>
        <select id="caller-id" data-calling-target="callerId" class="rl-select">
          <% if @twilio_numbers.present? %>
            <% @twilio_numbers.each do |number| %>
              <% country_label = get_country_label(number[:phone_number]) %>
              <option value="<%= number[:phone_number] %>"><%= country_label %> · <%= number[:phone_number] %></option>
            <% end %>
          <% else %>
            <option value="+447897021964">UK · +447897021964</option>
          <% end %>
        </select>
      </div>

      <div class="rl-field">
        <label for="phone-number" class="rl-label">Call to</label>
        <div class="row" style="gap:8px">
          <input type="tel"
                 id="phone-number"
                 data-calling-target="phoneNumber"
                 data-action="input->calling#onPhoneNumberInput"
                 class="rl-input mono grow"
                 placeholder="+92 300 1234567"
                 value="<%= @phone_to_call %>">
          <button data-calling-target="callButton"
                  data-action="calling#makeCall"
                  disabled
                  class="rl-btn rl-btn--primary" style="flex:none">
            <%= relay_icon("phone", size: 15) %>Call
          </button>
        </div>
      </div>

      <%# ── Active call panel: hangup + dialpad ─────────────────────────── %>
      <div data-calling-target="callControls" class="hidden col"
           style="gap:var(--space-4);border-top:1px solid var(--color-divider);padding-top:var(--space-5)">
        <button data-calling-target="hangupButton"
                data-action="calling#hangUp"
                class="rl-btn rl-btn--destructive" style="width:100%;justify-content:center">
          <%= relay_icon("phone-off", size: 15) %>Hang up
        </button>

        <div>
          <div class="rl-label" style="margin-bottom:8px">Dialpad</div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">
            <% [
              [ "1", "" ],     [ "2", "ABC" ], [ "3", "DEF" ],
              [ "4", "GHI" ],  [ "5", "JKL" ], [ "6", "MNO" ],
              [ "7", "PQRS" ], [ "8", "TUV" ], [ "9", "WXYZ" ],
              [ "*", "" ],     [ "0", "+" ],   [ "#", "" ]
            ].each do |digit, letters| %>
              <button type="button"
                      data-calling-target="dtmf"
                      data-action="calling#sendDigit"
                      data-digit="<%= digit %>"
                      class="callbar__key col"
                      style="height:56px;gap:1px">
                <span style="font-family:var(--font-display);font-size:var(--text-lg);font-weight:600"><%= digit %></span>
                <span class="mono muted" style="font-size:9px;letter-spacing:.12em"><%= letters %></span>
              </button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Footer hint. %>
  <p class="mono muted" style="text-align:center;font-size:11px;margin-top:var(--space-4)">
    Calls dial out via your organization's Twilio number. Recordings are auto-stored and transcribed.
  </p>
</div>

<%# Twilio Voice SDK loaded from CDN — required by app/javascript/controllers/calling_controller.js. %>
<%= javascript_include_tag "https://cdn.jsdelivr.net/npm/@twilio/voice-sdk@2.15.0/dist/twilio.min.js", "data-turbo-track": "reload" %>
