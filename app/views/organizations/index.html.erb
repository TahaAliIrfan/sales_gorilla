<% content_for :title, "Your workspaces · Sales Gorilla" %>

<!-- Top bar -->
<header class="border-b border-[var(--color-line-2)] bg-paper/80 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/sales_gorilla_black.png" alt="Sales Gorilla" class="h-8 w-8 shrink-0 object-contain">
      <span class="font-display text-lg font-bold tracking-tight text-ink">Sales Gorilla<span class="text-accent-bright">.</span></span>
    </a>
    <div class="flex items-center gap-4 text-sm">
      <% if current_user&.name.present? %>
        <span class="hidden text-ink-soft sm:inline">Signed in as <span class="font-semibold text-ink"><%= current_user.name %></span></span>
      <% end %>
      <%= link_to "Sign out", signout_path, class: "font-medium text-ink-soft transition hover:text-accent" %>
    </div>
  </div>
</header>

<div class="mx-auto max-w-5xl px-6 py-14 motion-safe:animate-rise">
  <!-- Page header -->
  <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="micro mb-2">Account</p>
      <h1 class="font-display text-4xl font-bold tracking-tight text-ink">
        <%= current_user&.name.present? ? "Welcome back, #{current_user.name.split.first}" : "Your workspaces" %>
      </h1>
      <p class="mt-2 text-ink-soft">
        <% if @organizations.any? %>
          You have <%= pluralize(@organizations.size, "workspace") %>. Pick one to jump in, or spin up a new one.
        <% else %>
          Create your first workspace to get started.
        <% end %>
      </p>
    </div>
    <% if @organizations.any? %>
      <%= link_to new_organization_path,
            class: "inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-on-accent shadow-card transition hover:-translate-y-0.5 hover:bg-accent-dim" do %>
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
        New workspace
      <% end %>
    <% end %>
  </div>

  <% if @organizations.any? %>
    <div class="grid gap-5 sm:grid-cols-2">
      <% @organizations.each_with_index do |org, i| %>
        <%
          role         = @roles_by_org[org.id]
          member_count = @members_count_by_org[org.id] || 1
        %>
        <%= link_to tenant_root_url(host: tenant_host_for(org.subdomain)),
              data: { turbo: false },
              style: "animation-delay: #{i * 60}ms",
              class: "group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-line-2)] bg-paper p-5 shadow-card transition hover:-translate-y-1 hover:border-accent/40 hover:shadow-lg motion-safe:animate-fade" do %>
          <!-- accent edge -->
          <span class="absolute inset-x-0 top-0 h-1" style="background: linear-gradient(90deg, <%= org.primary_color %>, <%= org.accent_color %>)"></span>

          <div class="flex items-start gap-4">
            <% if org.logo.attached? %>
              <%= image_tag org.logo, alt: org.name,
                    class: "h-12 w-12 shrink-0 rounded-xl object-cover ring-1 ring-[var(--color-line-2)]" %>
            <% else %>
              <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl font-display text-lg font-bold text-white shadow-sm"
                    style="background: linear-gradient(135deg, <%= org.primary_color %>, <%= org.accent_color %>)"><%= org.initial %></span>
            <% end %>

            <div class="min-w-0 flex-1">
              <p class="truncate font-display text-lg font-bold leading-tight text-ink"><%= org.name %></p>
              <p class="mono mt-0.5 flex items-center gap-1 truncate text-xs text-ink-soft">
                <svg class="h-3 w-3 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="10" cy="10" r="7.5"/><path d="M2.5 10h15M10 2.5c2 2.4 2 12.6 0 15M10 2.5c-2 2.4-2 12.6 0 15"/></svg>
                <span class="truncate"><%= org.subdomain %>.<%= root_host_for_request %></span>
              </p>
            </div>

            <% if role.present? %>
              <span class="shrink-0 rounded-full px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide <%= role.to_s == 'owner' ? 'bg-accent/10 text-accent' : 'bg-[var(--color-line)] text-ink-soft' %>"><%= role %></span>
            <% end %>
          </div>

          <!-- footer -->
          <div class="mt-5 flex items-center justify-between border-t border-[var(--color-line)] pt-3.5 text-xs text-ink-soft">
            <span class="flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="7" cy="6.5" r="2.8"/><path d="M2.5 15c0-2.5 2-4 4.5-4s4.5 1.5 4.5 4"/><path d="M13 4.5a2.6 2.6 0 0 1 0 5M14 15c0-2-1-3.4-2.5-4"/></svg>
              <%= pluralize(member_count, "member") %>
            </span>
            <span class="flex items-center gap-1 font-semibold text-ink-soft/70 transition group-hover:text-accent">
              Open workspace
              <span class="transition group-hover:translate-x-0.5">→</span>
            </span>
          </div>
        <% end %>
      <% end %>

      <!-- Create new workspace card -->
      <%= link_to new_organization_path,
            class: "group flex min-h-[148px] flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-[var(--color-line-2)] bg-panel/40 p-5 text-center transition hover:border-accent/50 hover:bg-panel" do %>
        <span class="grid h-11 w-11 place-items-center rounded-full bg-accent/10 text-accent transition group-hover:bg-accent group-hover:text-on-accent">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
        </span>
        <span class="font-display text-base font-bold text-ink">New workspace</span>
        <span class="text-xs text-ink-soft">Spin up a fresh CRM space</span>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border-2 border-dashed border-[var(--color-line-2)] bg-panel/40 px-6 py-20 text-center">
      <span class="mx-auto mb-4 grid h-14 w-14 place-items-center rounded-2xl bg-accent/10 text-accent">
        <svg class="h-6 w-6" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
      </span>
      <p class="font-display text-xl font-bold text-ink">No workspaces yet</p>
      <p class="mx-auto mt-1 max-w-sm text-ink-soft">Workspaces keep each team's customers, pipeline and calls separate. Create your first to get started.</p>
      <%= link_to "Create workspace", new_organization_path,
            class: "mt-6 inline-block rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-on-accent shadow-card transition hover:-translate-y-0.5 hover:bg-accent-dim" %>
    </div>
  <% end %>
</div>
