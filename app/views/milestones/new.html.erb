<% content_for :title, "New milestone — #{@customer.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_milestones_path(@customer), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to milestones
        <% end %>
      </div>
      <div class="pagehead__title">New milestone</div>
      <div class="pagehead__sub">Add a payment milestone for <%= @customer.name %>.</div>
    </div>
  </div>

  <%= render "form", milestone: @milestone, customer: @customer %>
</div>
