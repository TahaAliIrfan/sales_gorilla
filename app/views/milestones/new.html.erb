<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <%= link_to customer_milestones_path(@customer), class: "text-sm text-gray-600 hover:text-gray-900 flex items-center mb-2" do %>
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Milestones
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900">New Milestone</h1>
    <p class="text-gray-600 mt-1">Add a payment milestone for <%= @customer.name %></p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= render "form", milestone: @milestone, customer: @customer %>
  </div>
</div>
