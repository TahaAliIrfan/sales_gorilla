<% content_for :title, "Edit milestone — #{@customer.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_milestone_path(@customer, @milestone), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to milestone
        <% end %>
      </div>
      <div class="pagehead__title">Edit milestone</div>
    </div>
  </div>

  <%= render "form", milestone: @milestone, customer: @customer %>
</div>
