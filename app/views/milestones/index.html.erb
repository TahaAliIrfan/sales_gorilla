<%# Per-customer milestones — relay DS. Keeps mark_paid / mark_unpaid, Edit /
    View / Create-invoice / Delete actions and the per-milestone schedule items. %>
<% content_for :title, "Milestones — #{@customer.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_path(@customer), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to <%= @customer.name %>
        <% end %>
      </div>
      <div class="pagehead__title">Milestones</div>
      <div class="pagehead__sub">Payment schedule for <%= @customer.name %>.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_customer_milestone_path(@customer), class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>New milestone
      <% end %>
    </div>
  </div>

  <% if @milestones.any? %>
    <div class="col" style="gap:var(--space-4)">
      <% @milestones.each do |milestone| %>
        <div class="sect">
          <div class="sect__body">
            <div class="spread" style="flex-wrap:wrap;gap:12px">
              <div class="row" style="gap:14px;align-items:center">
                <div>
                  <div class="rl-cell-strong"><%= milestone.name %></div>
                  <div class="muted rl-sm"><%= relay_money(milestone.total_amount) %> · <%= milestone.schedule_type.titleize %></div>
                </div>
                <% if milestone.paid? %>
                  <span class="rl-badge rl-badge--success"><%= relay_icon("check-circle-2", size: 11) %>Paid</span>
                <% else %>
                  <span class="rl-badge rl-badge--info"><%= relay_icon("hourglass", size: 11) %><%= milestone.status.titleize %></span>
                <% end %>
              </div>
              <div class="row" style="gap:6px;flex-wrap:wrap;justify-content:flex-end">
                <% if milestone.paid? %>
                  <%= button_to mark_unpaid_customer_milestone_path(@customer, milestone), method: :patch, class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                    <%= relay_icon("hourglass", size: 14) %>Mark unpaid
                  <% end %>
                <% else %>
                  <%= button_to mark_paid_customer_milestone_path(@customer, milestone), method: :patch, class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                    <%= relay_icon("check", size: 14) %>Mark paid
                  <% end %>
                <% end %>
                <%= link_to edit_customer_milestone_path(@customer, milestone), class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                  <%= relay_icon("pencil", size: 14) %>Edit
                <% end %>
                <%= link_to customer_milestone_path(@customer, milestone), class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                  <%= relay_icon("eye", size: 14) %>View
                <% end %>
                <%= link_to new_customer_invoice_path(@customer, milestone_id: milestone.id), class: "rl-btn rl-btn--secondary rl-btn--sm" do %>
                  <%= relay_icon("receipt", size: 14) %>Create invoice
                <% end %>
                <%= button_to customer_milestone_path(@customer, milestone), method: :delete,
                      form: { data: { turbo_confirm: "Are you sure? This will delete all milestone items." } },
                      class: "rl-iconbtn rl-iconbtn--sm", title: "Delete milestone" do %>
                  <%= relay_icon("trash-2", size: 15) %>
                <% end %>
              </div>
            </div>
          </div>
          <% if milestone.milestone_items.any? %>
            <div class="sect__body" style="border-top:1px solid var(--color-border);background:var(--color-surface-2)">
              <div class="micro" style="margin-bottom:8px">Schedule</div>
              <div class="col" style="gap:6px">
                <% milestone.milestone_items.each do |item| %>
                  <div class="spread rl-sm">
                    <span><%= item.description %></span>
                    <span class="mono"><%= relay_money(item.amount) %><%= " · Due #{item.due_date.strftime('%b %-d')}" if item.due_date.present? %></span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
      <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-fg-3)"><%= relay_icon("dollar-sign", size: 22) %></span>
      <div class="rl-h4">No milestones</div>
      <div class="muted rl-sm" style="margin-top:6px">Create a milestone to track payments and generate invoices.</div>
      <div style="margin-top:16px">
        <%= link_to new_customer_milestone_path(@customer), class: "rl-btn rl-btn--primary rl-btn--sm" do %>
          <%= relay_icon("plus", size: 14) %>New milestone
        <% end %>
      </div>
    </div></div>
  <% end %>
</div>
