<%# Milestone form — relay DS. Preserves the milestone params (name, total_amount,
    schedule_type, currency, notes) and the nested milestone_items fields_for with
    its add/remove vanilla-JS contract: #milestone-items container, #add-milestone-item
    button, #milestone-item-template, .milestone-item-row / .remove-milestone-item /
    .destroy-checkbox hooks. The script is kept verbatim. %>
<%= form_with model: [customer, milestone],
      url: milestone.persisted? ? customer_milestone_path(customer, milestone) : customer_milestones_path(customer),
      method: milestone.persisted? ? :patch : :post,
      class: "col", html: { style: "gap:var(--space-5)" } do |f| %>
  <% if milestone.errors.any? %>
    <%= render "settings/errors", record: milestone %>
  <% end %>

  <div class="sect">
    <div class="sect__head"><div class="sect__title">Milestone details</div></div>
    <div class="sect__body">
      <div class="grid grid-2">
        <%= render "shared/relay_field", f: f, field: :name, placeholder: "e.g. Project Alpha", autofocus: milestone.new_record? %>
        <div class="rl-field">
          <%= f.label :total_amount, class: "rl-label" %>
          <%= f.number_field :total_amount, step: 0.01, class: "rl-input mono", placeholder: "0.00" %>
        </div>
        <%= render "shared/relay_field", f: f, field: :schedule_type, type: "select",
              options: Milestone::SCHEDULE_TYPES.map { |k, v| [v, k] } %>
        <%= render "shared/relay_field", f: f, field: :currency, placeholder: "USD" %>
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: f, field: :notes, type: "textarea", rows: 3 %>
        </div>
      </div>
    </div>
  </div>

  <div class="sect">
    <div class="sect__head">
      <div class="sect__title grow">Payment schedule items</div>
      <button type="button" id="add-milestone-item" class="rl-btn rl-btn--secondary rl-btn--sm">
        <%= relay_icon("plus", size: 14) %>Add item
      </button>
    </div>
    <div class="sect__body">
      <div id="milestone-items" class="col" style="gap:10px">
        <%= f.fields_for :milestone_items do |item_f| %>
          <div class="milestone-item-row row" style="gap:12px;align-items:flex-end;padding:12px;background:var(--color-surface-2);border-radius:var(--radius-md)">
            <div class="grow">
              <%= item_f.label :description, "Description", class: "rl-label" %>
              <%= item_f.text_field :description, class: "rl-input", placeholder: "e.g. Design Phase" %>
            </div>
            <div style="width:140px">
              <%= item_f.label :amount, class: "rl-label" %>
              <%= item_f.number_field :amount, step: 0.01, class: "rl-input mono", placeholder: "0" %>
            </div>
            <div style="width:170px">
              <%= item_f.label :due_date, "Due date", class: "rl-label" %>
              <%= item_f.date_field :due_date, class: "rl-input mono" %>
            </div>
            <div class="row" style="align-items:center;height:38px">
              <% if milestone.persisted? %>
                <%= item_f.check_box :_destroy, class: "hidden destroy-checkbox" %>
              <% end %>
              <button type="button" class="remove-milestone-item rl-btn rl-btn--destructive-ghost rl-btn--sm">Remove</button>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <template id="milestone-item-template">
    <%= f.fields_for :milestone_items, MilestoneItem.new, child_index: "NEW_ITEM_INDEX" do |item_f| %>
      <div class="milestone-item-row row" style="gap:12px;align-items:flex-end;padding:12px;background:var(--color-surface-2);border-radius:var(--radius-md)">
        <%= item_f.hidden_field :position, value: "NEW_POSITION" %>
        <div class="grow">
          <%= item_f.label :description, "Description", class: "rl-label" %>
          <%= item_f.text_field :description, class: "rl-input", placeholder: "e.g. Design Phase" %>
        </div>
        <div style="width:140px">
          <%= item_f.label :amount, class: "rl-label" %>
          <%= item_f.number_field :amount, step: 0.01, class: "rl-input mono", placeholder: "0" %>
        </div>
        <div style="width:170px">
          <%= item_f.label :due_date, "Due date", class: "rl-label" %>
          <%= item_f.date_field :due_date, class: "rl-input mono" %>
        </div>
        <div class="row" style="align-items:center;height:38px">
          <button type="button" class="remove-milestone-item rl-btn rl-btn--destructive-ghost rl-btn--sm">Remove</button>
        </div>
      </div>
    <% end %>
  </template>

  <script>
  (function() {
    const container = document.getElementById('milestone-items');
    const addBtn = document.getElementById('add-milestone-item');
    const template = document.getElementById('milestone-item-template');
    if (!container || !addBtn || !template) return;

    addBtn.addEventListener('click', function() {
      const index = new Date().getTime();
      const position = container.querySelectorAll('.milestone-item-row').length;
      const html = template.innerHTML
        .replace(/NEW_ITEM_INDEX/g, index)
        .replace(/NEW_POSITION/g, position);
      container.insertAdjacentHTML('beforeend', html);
    });

    container.addEventListener('click', function(e) {
      if (e.target.classList.contains('remove-milestone-item')) {
        const row = e.target.closest('.milestone-item-row');
        const destroyCheckbox = row && row.querySelector('.destroy-checkbox');
        if (destroyCheckbox) {
          destroyCheckbox.checked = true;
          row.style.display = 'none';
        } else {
          row.remove();
        }
      }
    });
  })();
  </script>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", milestone.persisted? ? customer_milestone_path(customer, milestone) : customer_milestones_path(customer),
          class: "rl-btn rl-btn--secondary" %>
    <%= f.submit (milestone.persisted? ? "Update milestone" : "Create milestone"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
