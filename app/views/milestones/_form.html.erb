<%= form_with model: [customer, milestone], url: milestone.persisted? ? customer_milestone_path(customer, milestone) : customer_milestones_path(customer), method: milestone.persisted? ? :patch : :post, class: "space-y-6" do |f| %>
  <% if milestone.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
      <ul class="list-disc list-inside">
        <% milestone.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "e.g., Project Alpha" %>
    </div>
    <div>
      <%= f.label :total_amount, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :total_amount, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "0.00" %>
    </div>
    <div>
      <%= f.label :schedule_type, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :schedule_type, Milestone::SCHEDULE_TYPES.map { |k, v| [v, k] }, {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :currency, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :currency, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "USD" %>
    </div>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :notes, rows: 3, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>

  <div>
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-medium text-gray-700">Payment Schedule Items</h3>
      <button type="button" id="add-milestone-item" class="text-sm text-blue-600 hover:text-blue-800 font-medium">+ Add Item</button>
    </div>
    <div id="milestone-items" class="space-y-3">
      <%= f.fields_for :milestone_items do |item_f| %>
        <div class="milestone-item-row flex gap-4 items-end p-3 bg-gray-50 rounded-lg">
          <div class="flex-1">
            <%= item_f.label :description, "Description", class: "block text-xs font-medium text-gray-500 mb-1" %>
            <%= item_f.text_field :description, class: "block w-full rounded-lg border-gray-300 shadow-sm", placeholder: "e.g., Design Phase" %>
          </div>
          <div class="w-32">
            <%= item_f.label :amount, class: "block text-xs font-medium text-gray-500 mb-1" %>
            <%= item_f.number_field :amount, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm", placeholder: "0" %>
          </div>
          <div class="w-40">
            <%= item_f.label :due_date, "Due Date", class: "block text-xs font-medium text-gray-500 mb-1" %>
            <%= item_f.date_field :due_date, class: "block w-full rounded-lg border-gray-300 shadow-sm" %>
          </div>
          <div class="flex items-center">
            <% if milestone.persisted? %>
              <%= item_f.check_box :_destroy, class: "rounded border-gray-300 hidden destroy-checkbox" %>
            <% end %>
            <button type="button" class="remove-milestone-item text-sm text-red-600 hover:text-red-800 font-medium">Remove</button>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <template id="milestone-item-template">
    <%= f.fields_for :milestone_items, MilestoneItem.new, child_index: "NEW_ITEM_INDEX" do |item_f| %>
      <div class="milestone-item-row flex gap-4 items-end p-3 bg-gray-50 rounded-lg">
        <%= item_f.hidden_field :position, value: "NEW_POSITION" %>
        <div class="flex-1">
          <%= item_f.label :description, "Description", class: "block text-xs font-medium text-gray-500 mb-1" %>
          <%= item_f.text_field :description, class: "block w-full rounded-lg border-gray-300 shadow-sm", placeholder: "e.g., Design Phase" %>
        </div>
        <div class="w-32">
          <%= item_f.label :amount, class: "block text-xs font-medium text-gray-500 mb-1" %>
          <%= item_f.number_field :amount, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm", placeholder: "0" %>
        </div>
        <div class="w-40">
          <%= item_f.label :due_date, "Due Date", class: "block text-xs font-medium text-gray-500 mb-1" %>
          <%= item_f.date_field :due_date, class: "block w-full rounded-lg border-gray-300 shadow-sm" %>
        </div>
        <div class="flex items-center">
          <button type="button" class="remove-milestone-item text-sm text-red-600 hover:text-red-800 font-medium">Remove</button>
        </div>
      </div>
    <% end %>
  </template>

  <script>
  (function() {
    const container = document.getElementById('milestone-items');
    const addBtn = document.getElementById('add-milestone-item');
    const template = document.getElementById('milestone-item-template');
    if (!container || !addBtn || !template) return;

    addBtn.addEventListener('click', function() {
      const index = new Date().getTime();
      const position = container.querySelectorAll('.milestone-item-row').length;
      const html = template.innerHTML
        .replace(/NEW_ITEM_INDEX/g, index)
        .replace(/NEW_POSITION/g, position);
      container.insertAdjacentHTML('beforeend', html);
    });

    container.addEventListener('click', function(e) {
      if (e.target.classList.contains('remove-milestone-item')) {
        const row = e.target.closest('.milestone-item-row');
        const destroyCheckbox = row && row.querySelector('.destroy-checkbox');
        if (destroyCheckbox) {
          destroyCheckbox.checked = true;
          row.style.display = 'none';
        } else {
          row.remove();
        }
      }
    });
  })();
  </script>

  <div class="flex gap-3 pt-4">
    <%= f.submit milestone.persisted? ? "Update Milestone" : "Create Milestone", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium cursor-pointer" %>
    <%= link_to "Cancel", milestone.persisted? ? customer_milestone_path(customer, milestone) : customer_milestones_path(customer), class: "px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 font-medium" %>
  </div>
<% end %>
