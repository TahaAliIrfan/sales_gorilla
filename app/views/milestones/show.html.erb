<%# Milestone detail — relay DS. Keeps mark_paid / mark_unpaid, Edit and
    Create-invoice actions, and the payment-schedule items table. %>
<% content_for :title, "#{@milestone.name} — #{@customer.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_milestones_path(@customer), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to milestones
        <% end %>
      </div>
      <div class="pagehead__title row" style="gap:10px;align-items:center">
        <%= @milestone.name %>
        <% if @milestone.paid? %>
          <span class="rl-badge rl-badge--success"><%= relay_icon("check-circle-2", size: 11) %>Paid</span>
        <% else %>
          <span class="rl-badge rl-badge--info"><%= relay_icon("hourglass", size: 11) %><%= @milestone.status.titleize %></span>
        <% end %>
      </div>
      <div class="pagehead__sub"><%= @milestone.schedule_type.titleize %></div>
    </div>
    <div class="pagehead__actions">
      <% if @milestone.paid? %>
        <%= button_to mark_unpaid_customer_milestone_path(@customer, @milestone), method: :patch, class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("hourglass", size: 15) %>Mark unpaid
        <% end %>
      <% else %>
        <%= button_to mark_paid_customer_milestone_path(@customer, @milestone), method: :patch, class: "rl-btn rl-btn--primary" do %>
          <%= relay_icon("check", size: 15) %>Mark paid
        <% end %>
      <% end %>
      <%= link_to edit_customer_milestone_path(@customer, @milestone), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit
      <% end %>
      <%= link_to new_customer_invoice_path(@customer, milestone_id: @milestone.id), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("receipt", size: 15) %>Create invoice
      <% end %>
    </div>
  </div>

  <div class="sect">
    <div class="sect__body">
      <div class="rl-h2 mono"><%= relay_money(@milestone.total_amount) %></div>
      <% if @milestone.paid_at.present? %>
        <div class="muted rl-sm" style="margin-top:4px">Paid on <%= @milestone.paid_at.strftime("%B %-d, %Y") %></div>
      <% end %>

      <% if @milestone.notes.present? %>
        <div style="margin-top:16px;padding:14px;background:var(--color-surface-2);border-radius:var(--radius-md)">
          <p class="rl-sm"><%= @milestone.notes %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="sect">
    <div class="sect__head"><div class="sect__title">Payment schedule</div></div>
    <% if @milestone.milestone_items.any? %>
      <div class="sect__body--flush">
        <div class="rl-table-scroll">
          <table class="rl-table">
            <thead><tr><th>Description</th><th>Due date</th><th style="text-align:right">Amount</th></tr></thead>
            <tbody>
              <% @milestone.milestone_items.each do |item| %>
                <tr>
                  <td><%= item.description %></td>
                  <td class="mono rl-sm"><%= item.due_date&.strftime("%b %-d, %Y") || "—" %></td>
                  <td class="rl-cell-num"><%= relay_money(item.amount) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="sect__body"><p class="muted rl-sm">No items yet. Edit this milestone to add payment schedule items.</p></div>
    <% end %>
  </div>
</div>
