<%# Odoo proposal detail — relay DS. Preserves the full AI-narrative UX:
    generate_narrative (POST), per-section regenerate_section (POST, section=…),
    and update_narrative (PATCH) with the claude_summary / claude_rationale /
    claude_next_steps fields and the claude_module_justifications[<key>] map.
    Edit / Download-PDF / Delete keep their endpoints. %>
<% content_for :title, "Proposal — #{@proposal.display_name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to odoo_proposals_path, class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Odoo proposals
        <% end %>
      </div>
      <div class="pagehead__title">Proposal for <%= @proposal.display_name %></div>
      <div class="pagehead__sub">Created <%= @proposal.created_at.strftime("%B %-d, %Y") %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to edit_odoo_proposal_path(@proposal), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit
      <% end %>
      <%= link_to download_pdf_odoo_proposal_path(@proposal), class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("download", size: 15) %>Download PDF proposal
      <% end %>
      <%= button_to odoo_proposal_path(@proposal), method: :delete,
            form: { data: { turbo_confirm: "Delete this proposal?" } }, class: "rl-btn rl-btn--destructive" do %>
        <%= relay_icon("trash-2", size: 15) %>Delete
      <% end %>
    </div>
  </div>

  <div class="grid" style="grid-template-columns:2fr 1fr;gap:var(--space-4);align-items:start">
    <%# ── LEFT ─────────────────────────────────────────────────────────── %>
    <div class="col" style="gap:var(--space-4)">
      <%# Project overview %>
      <div class="sect"><div class="sect__body">
        <div class="micro" style="margin-bottom:16px">Project overview</div>
        <div class="grid grid-3">
          <div>
            <div class="micro" style="margin-bottom:4px">Client</div>
            <div class="rl-cell-strong"><%= @proposal.display_name %></div>
            <% if @proposal.customer %><div class="muted rl-sm"><%= @proposal.customer.email %></div><% end %>
          </div>
          <div>
            <div class="micro" style="margin-bottom:4px">Deployment</div>
            <span class="rl-badge rl-badge--info"><%= @proposal.deployment_label %></span>
          </div>
          <div>
            <div class="micro" style="margin-bottom:4px">Users</div>
            <div class="rl-cell-strong"><%= @proposal.num_users %> users</div>
          </div>
        </div>

        <% if (tier_info = @proposal.current_tier_info) %>
          <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--color-border)">
            <div class="micro" style="margin-bottom:8px"><%= @proposal.deployment_type == "sh" ? "Odoo.sh platform plan" : "Hosting tier" %></div>
            <div class="row" style="gap:14px;align-items:center">
              <div style="padding:8px 14px;background:var(--color-primary-subtle);border-radius:var(--radius-md)">
                <div class="rl-sm" style="font-weight:700;color:var(--color-primary-text)"><%= tier_info[:label] %></div>
                <div class="rl-sm" style="color:var(--color-primary-text)"><%= tier_info[:specs] %></div>
              </div>
              <div class="muted rl-sm"><%= tier_info[:users] %></div>
            </div>
          </div>
        <% end %>

        <% if @proposal.industry.present? || @proposal.company_size.present? || @proposal.pain_points_array.any? %>
          <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--color-border)">
            <div class="micro" style="margin-bottom:12px">Business context</div>
            <div class="grid grid-2" style="margin-bottom:12px">
              <% if @proposal.industry.present? %>
                <div><div class="muted rl-sm">Industry</div><div class="rl-sm" style="font-weight:600"><%= @proposal.industry %></div></div>
              <% end %>
              <% if @proposal.company_size.present? %>
                <div><div class="muted rl-sm">Company size</div><div class="rl-sm" style="font-weight:600"><%= @proposal.company_size %></div></div>
              <% end %>
            </div>
            <% if @proposal.pain_points_array.any? %>
              <div class="muted rl-sm" style="margin-bottom:6px">Pain points</div>
              <div class="row row--wrap" style="gap:6px">
                <% @proposal.pain_points_array.each do |pp| %><span class="rl-chip"><%= pp %></span><% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div></div>

      <%# Selected modules %>
      <div class="sect"><div class="sect__body">
        <div class="spread" style="margin-bottom:16px">
          <div class="micro">Selected modules</div>
          <span class="rl-badge rl-badge--primary"><%= @proposal.selected_modules.size + @proposal.custom_module_details.size %></span>
        </div>
        <% OdooProposal::MODULES.each do |category, mods| %>
          <% selected_in_cat = mods.select { |m| @proposal.selected_modules.include?(m[:key]) } %>
          <% next if selected_in_cat.empty? %>
          <div style="margin-bottom:16px">
            <div class="micro" style="margin-bottom:10px"><%= category %></div>
            <div class="grid grid-2">
              <% selected_in_cat.each do |mod| %>
                <div class="row" style="gap:10px;align-items:flex-start;padding:10px;background:var(--color-primary-subtle);border-radius:var(--radius-md)">
                  <span class="ic" style="color:var(--color-primary-text);flex:none"><%= relay_icon("circle-check", size: 16) %></span>
                  <div class="grow">
                    <div class="spread"><span class="rl-sm" style="font-weight:600"><%= mod[:label] %></span><span class="mono rl-sm" style="color:var(--color-primary-text)">PKR <%= number_with_delimiter(mod[:impl_cost]) %></span></div>
                    <div class="muted rl-sm" style="margin-top:2px"><%= mod[:description] %></div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @proposal.custom_module_details.any? %>
          <div>
            <div class="micro row" style="gap:8px;margin-bottom:10px">Custom modules <span class="rl-badge rl-badge--neutral">AI / Custom dev</span></div>
            <div class="grid grid-2">
              <% @proposal.custom_module_details.each do |cm| %>
                <div class="row" style="gap:10px;align-items:flex-start;padding:10px;background:var(--color-surface-2);border-radius:var(--radius-md)">
                  <span class="ic" style="flex:none"><%= relay_icon("plus", size: 16) %></span>
                  <div class="grow">
                    <div class="spread">
                      <span class="rl-sm" style="font-weight:600"><%= cm[:label] %></span>
                      <div style="text-align:right">
                        <span class="mono rl-sm">PKR <%= number_with_delimiter(cm[:impl_cost]) %></span>
                        <% if cm[:hours].to_i.positive? %><div class="muted rl-sm">~<%= cm[:hours] %> hrs</div><% end %>
                      </div>
                    </div>
                    <% if cm[:description].present? %><div class="muted rl-sm" style="margin-top:2px"><%= cm[:description] %></div><% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div></div>

      <% if @proposal.notes.present? %>
        <div class="sect"><div class="sect__body">
          <div class="micro" style="margin-bottom:8px">Notes</div>
          <p class="rl-sm"><%= @proposal.notes %></p>
        </div></div>
      <% end %>

      <%# AI narrative %>
      <div class="sect"><div class="sect__body">
        <div class="row" style="gap:10px;align-items:center;margin-bottom:16px">
          <span class="iccircle" style="background:var(--color-primary-subtle);color:var(--color-primary-text)"><%= relay_icon("sparkles", size: 18) %></span>
          <div>
            <div class="micro">AI-generated narrative</div>
            <% if @proposal.narrative_generated? %>
              <div class="muted rl-sm">Last generated <%= time_ago_in_words(@proposal.narrative_generated_at) %> ago — powered by Claude</div>
            <% else %>
              <div class="muted rl-sm">Generate a personalised proposal narrative using Claude AI</div>
            <% end %>
          </div>
        </div>

        <% if @proposal.narrative_generated? %>
          <%= form_with url: update_narrative_odoo_proposal_path(@proposal), method: :patch do |f| %>
            <% [["claude_summary", "Executive summary", "summary", 4],
                ["claude_rationale", "Recommendation rationale", "rationale", 5]].each do |field, label, section, rows| %>
              <div class="rl-field">
                <div class="spread" style="margin-bottom:6px">
                  <label class="rl-label" style="margin:0"><%= label %></label>
                  <%= button_to regenerate_section_odoo_proposal_path(@proposal, section: section), method: :post,
                        form: { data: { turbo_confirm: "Regenerate the #{label.downcase}? Unsaved edits will be lost." } },
                        class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                    <%= relay_icon("refresh-cw", size: 13) %>Regenerate
                  <% end %>
                </div>
                <%= f.text_area field, rows: rows, value: @proposal.public_send(field), class: "rl-textarea" %>
              </div>
            <% end %>

            <div class="rl-field">
              <div class="spread" style="margin-bottom:6px">
                <label class="rl-label" style="margin:0">Module justifications</label>
                <%= button_to regenerate_section_odoo_proposal_path(@proposal, section: "module_justifications"), method: :post,
                      form: { data: { turbo_confirm: "Regenerate all module justifications? Unsaved edits will be lost." } },
                      class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                  <%= relay_icon("refresh-cw", size: 13) %>Regenerate all
                <% end %>
              </div>
              <div class="col" style="gap:8px">
                <% @proposal.selected_module_details.each do |mod| %>
                  <div class="row" style="gap:12px;align-items:flex-start;padding:10px;background:var(--color-surface-2);border-radius:var(--radius-md)">
                    <div style="width:120px;flex:none">
                      <div class="rl-sm" style="font-weight:700"><%= mod[:label] %></div>
                      <div class="muted rl-sm"><%= mod[:key] %></div>
                    </div>
                    <%= text_area_tag "odoo_proposal[claude_module_justifications][#{mod[:key]}]",
                          @proposal.module_justification_for(mod[:key]), rows: 2, class: "rl-textarea grow" %>
                  </div>
                <% end %>
              </div>
            </div>

            <div class="rl-field">
              <div class="spread" style="margin-bottom:6px">
                <label class="rl-label" style="margin:0">Customised next steps</label>
                <%= button_to regenerate_section_odoo_proposal_path(@proposal, section: "next_steps"), method: :post,
                      form: { data: { turbo_confirm: "Regenerate next steps? Unsaved edits will be lost." } },
                      class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                  <%= relay_icon("refresh-cw", size: 13) %>Regenerate
                <% end %>
              </div>
              <%= f.text_area :claude_next_steps, rows: 6, value: @proposal.claude_next_steps, class: "rl-textarea mono" %>
              <p class="rl-help">One step per line. Each line becomes a numbered bullet in the PDF.</p>
            </div>

            <div class="spread" style="padding-top:14px;border-top:1px solid var(--color-border)">
              <p class="muted rl-sm">Edits are kept until you regenerate. The PDF uses whatever is saved here.</p>
              <%= f.submit "Save narrative edits", class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
            </div>
          <% end %>
        <% else %>
          <div style="text-align:center;padding:32px 24px;background:var(--color-primary-subtle);border-radius:var(--radius-lg)">
            <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface);color:var(--color-primary-text)"><%= relay_icon("sparkles", size: 22) %></span>
            <div class="rl-h4">Generate a personalised narrative</div>
            <p class="muted rl-sm" style="margin:8px auto 16px;max-width:440px">
              Claude will write an executive summary, per-module justifications, and customised next steps based on
              <%= @proposal.industry.presence || "this client" %>'s context and the selected modules.
            </p>
            <% if @proposal.industry.blank? && @proposal.company_size.blank? && @proposal.pain_points_array.empty? %>
              <p class="rl-help" style="margin-bottom:16px">Tip: the narrative is much better when industry, size and pain points are filled in. You can still generate without them.</p>
            <% end %>
            <%= button_to generate_narrative_odoo_proposal_path(@proposal), method: :post, class: "rl-btn rl-btn--primary" do %>
              <%= relay_icon("zap", size: 15) %>Generate with Claude
            <% end %>
          </div>
        <% end %>
      </div></div>
    </div>

    <%# ── RIGHT — cost breakdown ───────────────────────────────────────── %>
    <div class="col" style="gap:var(--space-4)">
      <% sub_info = @proposal.odoo_subscription_info %>
      <div class="sect" style="overflow:hidden">
        <div style="background:var(--color-primary);padding:20px;color:#fff">
          <div class="rl-sm" style="opacity:.85;text-transform:uppercase;letter-spacing:.06em;font-weight:700">Year 1 total investment</div>
          <div class="mono" style="font-size:var(--text-h2);font-weight:800;margin-top:4px">PKR <%= number_with_delimiter(@proposal.year_1_total) %></div>
          <div class="rl-sm" style="opacity:.85;margin-top:4px">Setup + Year 1 hosting + Year 1 Odoo subscription</div>
        </div>
        <div class="sect__body col" style="gap:10px">
          <div class="spread"><span class="muted rl-sm">Implementation fee <span class="muted">(one-time)</span></span><span class="mono rl-sm">PKR <%= number_with_delimiter(@proposal.implementation_fee.to_i) %></span></div>
          <% if @proposal.annual_hosting_cost > 0 %>
            <div class="spread"><span class="muted rl-sm">Annual hosting</span><span class="mono rl-sm">PKR <%= number_with_delimiter(@proposal.annual_hosting_cost.to_i) %></span></div>
          <% end %>
          <div style="padding-top:10px;border-top:1px solid var(--color-border)">
            <div class="spread"><span class="muted rl-sm">Odoo subscription <span class="muted">(yearly)</span></span><span class="mono rl-sm">PKR <%= number_with_delimiter(@proposal.subscription_yearly_total) %></span></div>
            <div class="spread" style="margin-top:4px"><span class="muted rl-sm"><%= sub_info[:plan] %> · $<%= sub_info[:usd_monthly] %>/user/mo × <%= @proposal.num_users %></span><span class="muted rl-sm">Paid to Odoo</span></div>
          </div>
          <div class="spread" style="padding-top:10px;border-top:1px solid var(--color-border)"><span class="rl-sm" style="font-weight:600">Year 2+ recurring / year</span><span class="mono rl-sm" style="font-weight:700;color:var(--color-primary-text)">PKR <%= number_with_delimiter(@proposal.year_2_recurring_yearly) %></span></div>
        </div>
      </div>

      <div class="sect"><div class="sect__body">
        <div class="micro" style="margin-bottom:12px">What's included</div>
        <ul style="list-style:none;margin:0;padding:0" class="col">
          <% [
            ["Full module configuration", "All selected modules set up and configured to your workflow"],
            ["Workflow customisation", "Tailored processes, approval flows and automations"],
            ["Data migration", "Assistance migrating your existing data into Odoo"],
            ["User training", "Hands-on training sessions for your team"],
            ["2 weeks post-go-live support", "Dedicated support after launch to ensure smooth adoption"]
          ].each do |title, desc| %>
            <li class="row" style="gap:10px;align-items:flex-start;padding:6px 0">
              <span class="ic" style="color:var(--color-success);flex:none"><%= relay_icon("check", size: 15) %></span>
              <div><div class="rl-sm" style="font-weight:600"><%= title %></div><div class="muted rl-sm"><%= desc %></div></div>
            </li>
          <% end %>
        </ul>
      </div></div>

      <div class="sect"><div class="sect__body" style="text-align:center">
        <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-primary-text)"><%= relay_icon("file-text", size: 22) %></span>
        <div class="rl-cell-strong">Professional PDF proposal</div>
        <div class="muted rl-sm" style="margin:4px 0 16px">Ready to send to <%= @proposal.display_name %></div>
        <%= link_to download_pdf_odoo_proposal_path(@proposal), class: "rl-btn rl-btn--primary rl-btn--sm" do %>
          <%= relay_icon("download", size: 14) %>Download proposal PDF
        <% end %>
      </div></div>
    </div>
  </div>
</div>
