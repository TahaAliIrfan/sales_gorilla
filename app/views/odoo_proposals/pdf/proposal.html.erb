<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Odoo Proposal — <%= @proposal.display_name %></title>
<%= render "shared/pdf/report_styles" %>
</head>
<body>

<%
  proposal   = @proposal
  customer   = proposal.display_name
  date       = Date.current.strftime('%d %B %Y')
  year       = Date.current.year
  fmt        = ->(n) { ActiveSupport::NumberHelper.number_to_delimited(n.to_i) }
  pkr        = ->(n) { "PKR #{fmt.call(n)}" }

  modules    = proposal.selected_module_details
  customs    = (proposal.custom_module_details rescue [])
  all_mods   = modules + customs
  justifs    = proposal.claude_module_justifications.is_a?(Hash) ? proposal.claude_module_justifications : {}
  justify    = ->(m) { justifs[m[:label]].presence || justifs[m[:key].to_s].presence || m[:description].presence }

  summary    = proposal.claude_summary.presence
  rationale  = proposal.claude_rationale.presence
  next_steps = proposal.claude_next_steps.presence
  pains      = Array(proposal.pain_points).reject(&:blank?)

  tier       = proposal.current_tier_info
  hosting    = proposal.annual_hosting_cost.to_i

  booking_url     = 'https://cal.com/tecaudex/discovery-call?duration=30'
  booking_display = 'cal.com/tecaudex/discovery-call'

  logo_svg = <<~SVG.html_safe
    <svg viewBox="0 0 301 300" xmlns="http://www.w3.org/2000/svg" class="mark">
      <rect x="0.236816" width="300" height="300" rx="150" fill="white"/>
      <path d="M202.544 133.219L189.464 155.491L204.901 182.892H173.099L160.104 206.382H244.237L202.544 133.219Z" fill="black"/>
      <path d="M97.9295 133.219L111.009 155.491L95.5727 182.892H127.374L140.37 206.382H56.2368L97.9295 133.219Z" fill="black"/>
      <path d="M84.7654 93.6182H215.509L199.82 120.784H163.696V182.802L150.369 206.382L136.524 182.892L136.53 120.784H100.654L84.7654 93.6182Z" fill="#ED1A3B"/>
    </svg>
  SVG
%>

<!-- COVER -->
<section class="page cover">
  <div class="top">
    <div class="logo-row"><%= logo_svg %><div class="name">Tecaudex</div></div>
    <div class="meta">Confidential<br><%= date %></div>
  </div>

  <div class="hero">
    <div class="eyebrow">Odoo ERP Proposal &amp; Investment</div>
    <h1><%= customer %></h1>
    <div class="subname"><%= proposal.deployment_label %> · <%= proposal.num_users %> users</div>
    <p class="deck">
      A plain summary of the Odoo ERP we'd put in place for <%= customer %> —
      the modules that fit how they work, why Odoo is the right platform, and
      exactly what it costs to implement.
    </p>
  </div>

  <div class="meta-grid">
    <div class="cell"><div class="k">Prepared by</div><div class="w">Tecaudex</div></div>
    <div class="cell"><div class="k">Prepared for</div><div class="w"><%= customer %></div></div>
    <div class="cell"><div class="k">Deployment</div><div class="w"><%= proposal.deployment_label %></div></div>
    <div class="cell"><div class="k">Total investment</div><div class="w num"><%= pkr.call(proposal.total_cost) %></div></div>
  </div>

  <div class="band">
    <div class="wordmark">TECAUDEX</div>
    <div class="tag">Odoo implementation for the modern enterprise</div>
  </div>
</section>

<!-- 00 · THE SHORT VERSION -->
<section class="page">
  <div class="sec-head">
    <div class="kicker"><span class="chip-no">00</span><span class="eyebrow">The short version</span></div>
    <h2>Where things stand</h2>
    <% if summary %><p class="lead"><%= summary %></p><% end %>
  </div>

  <div class="grid2">
    <div class="card">
      <div class="card-label">The business</div>
      <p style="margin:0;">
        <% if proposal.industry.present? %><strong>Industry:</strong> <%= proposal.industry %><br><% end %>
        <% if proposal.company_size.present? %><strong>Size:</strong> <%= proposal.company_size %><br><% end %>
        <strong>Users:</strong> <%= proposal.num_users %> &nbsp;·&nbsp; <strong>Deployment:</strong> <%= proposal.deployment_label %>
      </p>
    </div>
    <div class="card">
      <div class="card-label">What we're solving</div>
      <% if pains.any? %>
        <ul class="bullets" style="margin:0; padding-left:14pt;"><% pains.first(5).each do |p| %><li><%= p %></li><% end %></ul>
      <% else %>
        <p class="muted" style="margin:0;">Streamlining core operations onto one connected system.</p>
      <% end %>
    </div>
  </div>
</section>

<!-- 01 · WHY ODOO -->
<% if rationale %>
<section class="page">
  <div class="sec-head">
    <div class="kicker"><span class="chip-no">01</span><span class="eyebrow">The case for it</span></div>
    <h2>Why Odoo, and why now</h2>
  </div>
  <div class="card"><p style="margin:0; white-space:pre-line;"><%= rationale %></p></div>
</section>
<% end %>

<!-- 02 · MODULES -->
<section class="page">
  <div class="sec-head">
    <div class="kicker"><span class="chip-no">02</span><span class="eyebrow">Scope</span></div>
    <h2>The modules we'll implement</h2>
    <p class="lead"><strong><%= all_mods.size %></strong> modules, chosen to fit how <%= customer %> actually works. Each is set up, configured and handed over ready to use.</p>
  </div>

  <% all_mods.each do |m| %>
    <div class="card vgap">
      <table><tr>
        <td>
          <div style="font-weight:600; font-size:11pt;"><%= m[:label] %><% if m[:custom] %> <span class="chip">Custom</span><% end %></div>
          <% if (j = justify.call(m)).present? %><p style="margin:1.5mm 0 0; color:var(--slate); font-size:9pt;"><%= j %></p><% end %>
        </td>
        <td class="r" style="width:26%; white-space:nowrap; vertical-align:middle;">
          <span class="num" style="font-weight:600;"><%= pkr.call(m[:impl_cost]) %></span>
        </td>
      </tr></table>
    </div>
  <% end %>
</section>

<!-- 03 · PRICING -->
<section class="page">
  <div class="sec-head">
    <div class="kicker"><span class="chip-no">03</span><span class="eyebrow">Investment</span></div>
    <h2>One transparent number</h2>
    <p class="lead">A one-time implementation fee to get <%= customer %> live on Odoo, plus any platform hosting. No surprises.</p>
  </div>

  <div class="card">
    <div class="card-label">Implementation — paid to Tecaudex</div>
    <table class="tbl">
      <thead><tr><th style="width:60%">Item</th><th class="r" style="width:40%">Amount</th></tr></thead>
      <tbody>
        <% all_mods.each do |m| %>
          <tr><td><span class="t"><%= m[:label] %></span></td><td class="r"><%= pkr.call(m[:impl_cost]) %></td></tr>
        <% end %>
        <tr class="total"><td>Total implementation, one-time</td><td class="r"><%= pkr.call(proposal.implementation_fee) %></td></tr>
      </tbody>
    </table>
  </div>

  <div class="grid2 vgap">
    <div class="card" style="background:var(--ink); border-color:var(--ink);">
      <div class="card-label" style="color:#9C9B93;">You pay Tecaudex</div>
      <div class="num" style="font-size:16pt; font-weight:600; color:#fff;"><%= pkr.call(proposal.implementation_fee) %> <span style="font-size:8pt; color:#9C9B93;">one-time</span></div>
      <div style="margin-top:2mm; font-size:8pt; color:#B9B8B0;">Setup, configuration &amp; handover across all modules.</div>
    </div>
    <div class="card">
      <div class="card-label">Platform &amp; hosting</div>
      <% if hosting > 0 %>
        <div class="num" style="font-size:16pt; font-weight:600;"><%= pkr.call(hosting) %> <span style="font-size:8pt; color:var(--mid);">/ year</span></div>
        <div style="margin-top:2mm; font-size:8pt; color:var(--mid);"><%= tier && tier[:label] ? tier[:label] : proposal.deployment_label %> hosting, billed yearly.</div>
      <% else %>
        <div class="num" style="font-size:16pt; font-weight:600;">Odoo Online</div>
        <div style="margin-top:2mm; font-size:8pt; color:var(--mid);">Odoo's cloud subscription, billed per user by Odoo.</div>
      <% end %>
    </div>
  </div>
</section>

<!-- 04 · NEXT STEPS + CTA -->
<section class="page">
  <div class="sec-head">
    <div class="kicker"><span class="chip-no">04</span><span class="eyebrow">From here</span></div>
    <h2>From idea to go-live</h2>
  </div>

  <% if next_steps %>
    <div class="card vgap"><p style="margin:0; white-space:pre-line;"><%= next_steps %></p></div>
  <% end %>

  <div class="cta-card">
    <h3>Ready to get <%= customer %> on Odoo?</h3>
    <p>Pick a slot that suits you and we'll walk through the modules, timeline and any open questions in a free 30-minute call — no commitment needed.</p>
    <a class="cta-btn" href="<%= booking_url %>">Schedule a call <span class="url"><%= booking_display %></span></a>
    <div class="contact">
      <span>sales@tecaudex.com</span>
      <span>www.tecaudex.com</span>
      <span>© <%= year %> Tecaudex · Confidential</span>
    </div>
  </div>
</section>

</body>
</html>
