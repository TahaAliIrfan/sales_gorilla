<%# Odoo proposals — relay DS card grid. Keeps View / PDF / Delete actions and the
    module chips, deployment pill, and PKR cost summary. %>
<% content_for :title, "Odoo proposals — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Odoo proposals</div>
      <div class="pagehead__sub">Manage Odoo ERP proposals for your clients.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_odoo_proposal_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>New proposal
      <% end %>
    </div>
  </div>

  <% if @proposals.empty? %>
    <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
      <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-primary-subtle);color:var(--color-primary-text)"><%= relay_icon("file-text", size: 22) %></span>
      <div class="rl-h4">No proposals yet</div>
      <div class="muted rl-sm" style="margin-top:6px">Create your first Odoo ERP proposal using the calculator.</div>
      <div style="margin-top:16px">
        <%= link_to new_odoo_proposal_path, class: "rl-btn rl-btn--primary rl-btn--sm" do %>
          <%= relay_icon("plus", size: 14) %>Create proposal
        <% end %>
      </div>
    </div></div>
  <% else %>
    <div class="grid grid-3">
      <% @proposals.each do |proposal| %>
        <div class="sect"><div class="sect__body">
          <div class="spread" style="margin-bottom:12px">
            <div class="row" style="gap:10px;align-items:center">
              <span class="iccircle" style="background:var(--color-primary-subtle);color:var(--color-primary-text)"><%= relay_icon("building-2", size: 18) %></span>
              <div>
                <div class="rl-cell-strong"><%= proposal.display_name %></div>
                <div class="muted rl-sm"><%= proposal.created_at.strftime("%b %-d, %Y") %></div>
              </div>
            </div>
            <span class="rl-badge rl-badge--info"><%= proposal.deployment_label %></span>
          </div>

          <div class="row row--wrap" style="gap:6px;margin-bottom:14px">
            <% proposal.selected_modules.first(5).each do |mod_key| %>
              <% mod = OdooProposal::MODULES.values.flatten.find { |m| m[:key] == mod_key } %>
              <% if mod %><span class="rl-chip"><%= mod[:label] %></span><% end %>
            <% end %>
            <% extra = proposal.selected_modules.size - 5 %>
            <% if extra > 0 %><span class="rl-chip muted">+<%= extra %> more</span><% end %>
          </div>

          <div style="padding:12px 14px;background:var(--color-surface-2);border-radius:var(--radius-md);margin-bottom:14px">
            <div class="spread"><span class="muted rl-sm">Total investment</span><span class="mono" style="font-weight:700;color:var(--color-primary-text)">PKR <%= number_with_delimiter(proposal.total_cost) %></span></div>
            <div class="spread" style="margin-top:4px"><span class="muted rl-sm">Implementation</span><span class="mono rl-sm">PKR <%= number_with_delimiter(proposal.implementation_fee) %></span></div>
            <% if proposal.annual_hosting_cost > 0 %>
              <div class="spread" style="margin-top:4px"><span class="muted rl-sm">Annual hosting</span><span class="mono rl-sm">PKR <%= number_with_delimiter(proposal.annual_hosting_cost) %></span></div>
            <% end %>
          </div>

          <div class="row" style="gap:6px">
            <%= link_to odoo_proposal_path(proposal), class: "rl-btn rl-btn--primary rl-btn--sm grow", style: "justify-content:center" do %>
              <%= relay_icon("eye", size: 14) %>View details
            <% end %>
            <%= link_to download_pdf_odoo_proposal_path(proposal), class: "rl-iconbtn rl-iconbtn--sm", title: "Download PDF" do %>
              <%= relay_icon("download", size: 15) %>
            <% end %>
            <%= button_to odoo_proposal_path(proposal), method: :delete,
                  form: { data: { turbo_confirm: "Delete this proposal?" } },
                  class: "rl-iconbtn rl-iconbtn--sm", title: "Delete" do %>
              <%= relay_icon("trash-2", size: 15) %>
            <% end %>
          </div>
        </div></div>
      <% end %>
    </div>
  <% end %>
</div>
