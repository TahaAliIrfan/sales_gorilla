<%# Odoo ERP cost calculator form — relay DS. This is a heavy odoo_calculator
    Stimulus surface; EVERY data-controller / data-*-target / data-action / input
    name / data-module-* / data-deploy-key / data-tier-key / data-tier-cost /
    data-pain attribute and the customModuleTemplate are preserved verbatim so the
    calculator JS keeps working. Only the chrome is reskinned to DS classes; the
    controller's JS-toggled Tailwind classes (selected / border-red-500 / bg-red-50
    / border-gray-100 / opacity-50 / cursor-*) are shimmed in shell.css. %>
<%
  sub_data     = OdooProposal::ODOO_SUBSCRIPTION.transform_values { |v| { plan: v[:plan], pkr_monthly: v[:pkr_monthly] } }.to_json
  tier_data    = OdooProposal::HOSTING_TIERS.transform_values { |v| { annual: v[:annual_pkr], monthly: v[:monthly_pkr] } }.to_json
  sh_tier_data = OdooProposal::SH_TIERS.transform_values { |v| { annual: v[:annual_pkr], monthly: v[:monthly_pkr] } }.to_json

  submit_label  ||= proposal.persisted? ? "Update proposal →" : "Save & generate proposal →"
  header_title  ||= proposal.persisted? ? "Edit Odoo proposal" : "Odoo ERP cost calculator"
  header_sub    ||= proposal.persisted? ? "Adjust modules, hosting or business context. Saving regenerates the Claude narrative." : "Select modules and deployment to generate a client proposal"
  current_dep     = proposal.deployment_type.presence || "online"
  current_tier    = proposal.hosting_tier.to_s
  current_users   = proposal.num_users.to_i.positive? ? proposal.num_users : 5
%>

<div class="page page--wide"
     data-controller="odoo-calculator"
     data-odoo-calculator-sub-data-value="<%= sub_data %>"
     data-odoo-calculator-tier-data-value="<%= tier_data %>"
     data-odoo-calculator-sh-tier-data-value="<%= sh_tier_data %>"
     data-odoo-calculator-analyze-url-value="<%= analyze_odoo_proposals_path %>">

  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to (proposal.persisted? ? odoo_proposal_path(proposal) : odoo_proposals_path), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back
        <% end %>
      </div>
      <div class="pagehead__title"><%= header_title %></div>
      <div class="pagehead__sub"><%= header_sub %></div>
    </div>
    <div class="pagehead__actions">
      <span class="rl-badge rl-badge--primary">Tecaudex × Odoo Partner</span>
    </div>
  </div>

  <%= form_with model: proposal,
        url: (proposal.persisted? ? odoo_proposal_path(proposal) : odoo_proposals_path),
        method: (proposal.persisted? ? :patch : :post),
        html: { class: "oc-grid" } do |f| %>

    <%# ════ LEFT — module grid ════ %>
    <div class="col" style="gap:var(--space-4);min-width:0">
      <% if proposal.errors.any? %>
        <%= render "settings/errors", record: proposal %>
      <% end %>

      <%# Smart Detect — AI requirements analysis %>
      <div class="sect">
        <div class="sect__head">
          <span class="iccircle" style="background:var(--color-primary-subtle);color:var(--color-primary-text)"><%= relay_icon("zap", size: 16) %></span>
          <div class="grow">
            <div class="sect__title">Smart Detect</div>
            <div class="muted rl-sm">Paste a requirements brief or upload an RFP / screenshot — Claude will pick the modules.</div>
          </div>
          <button type="button"
                  data-odoo-calculator-target="analyzeBtn"
                  data-action="click->odoo-calculator#runAnalyze"
                  class="rl-btn rl-btn--primary rl-btn--sm">
            <%= relay_icon("sparkles", size: 14) %>
            <span data-odoo-calculator-target="analyzeLabel">Analyze</span>
          </button>
        </div>
        <div class="sect__body">
          <div class="grid" style="grid-template-columns:2fr 1fr;gap:12px">
            <div class="rl-field" style="margin:0">
              <label class="rl-label">Paste requirements (text)</label>
              <textarea data-odoo-calculator-target="analyzeText" rows="4" class="rl-textarea"
                        placeholder="e.g. We are a manufacturing company in Lahore with 80 employees. We need stock tracking across two warehouses, an online portal for distributors, custom Pakistani sales tax invoicing, and integration with our existing HRMS over SOAP…"></textarea>
            </div>
            <div class="rl-field" style="margin:0">
              <label class="rl-label">…or upload a file</label>
              <label class="oc-drop" style="cursor:pointer">
                <%= relay_icon("upload", size: 20) %>
                <span class="rl-sm" style="font-weight:600" data-odoo-calculator-target="analyzeFileName">Choose file</span>
                <span class="muted rl-sm">PDF · Image · .docx · .txt (max 12 MB)</span>
                <input type="file" class="hidden"
                       accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.docx,.txt,.md"
                       data-odoo-calculator-target="analyzeFile"
                       data-action="change->odoo-calculator#analyzeFilePicked">
              </label>
            </div>
          </div>
          <div data-odoo-calculator-target="analyzeStatus" class="hidden mx-4 mb-4 px-3 py-2 rounded-lg text-xs font-medium" style="margin-top:12px"></div>
        </div>
      </div>

      <%# Client %>
      <div class="sect">
        <div class="sect__head"><div class="sect__title">Client</div></div>
        <div class="sect__body">
          <div class="grid grid-2">
            <div class="rl-field">
              <label class="rl-label">Existing customer</label>
              <%= f.select :customer_id,
                    options_for_select([["— Select customer —", ""]] + customers.map { |c| [c.name, c.id] }, proposal.customer_id),
                    {}, class: "rl-select",
                    "data-action": "change->odoo-calculator#customerChanged",
                    "data-odoo-calculator-target": "customerSelect" %>
            </div>
            <div class="rl-field">
              <label class="rl-label">Or type name</label>
              <%= f.text_field :customer_name, placeholder: "e.g. Al-Faisal Enterprises",
                    class: "rl-input", "data-odoo-calculator-target": "customerName" %>
            </div>
          </div>
        </div>
      </div>

      <%# Module categories %>
      <% OdooProposal::MODULES.each do |category, mods| %>
        <div class="sect">
          <div class="sect__head">
            <span class="ic" style="color:var(--color-primary-text)"><%= relay_icon("layers", size: 15) %></span>
            <div class="sect__title grow"><%= category %></div>
            <span class="muted rl-sm"><%= mods.size %> modules</span>
          </div>
          <div class="sect__body">
            <div class="grid grid-3">
              <% mods.each do |mod| %>
                <% selected = Array(proposal.selected_modules).include?(mod[:key]) %>
                <label class="module-card oc-card<%= ' selected' if selected %>"
                       data-module-key="<%= mod[:key] %>"
                       data-module-cost="<%= mod[:impl_cost] %>"
                       data-action="click->odoo-calculator#toggleModule">
                  <input type="checkbox" name="odoo_proposal[selected_modules][]" value="<%= mod[:key] %>"
                         <%= "checked" if selected %>
                         data-odoo-calculator-target="moduleCheckbox"
                         data-module-key="<%= mod[:key] %>" data-module-cost="<%= mod[:impl_cost] %>">
                  <div class="grow">
                    <div class="rl-sm" style="font-weight:600"><%= mod[:label] %></div>
                    <div class="muted rl-sm" style="margin-top:2px"><%= mod[:description] %></div>
                    <div class="rl-sm" style="font-weight:700;color:var(--color-primary-text);margin-top:6px">PKR <%= number_with_delimiter(mod[:impl_cost]) %></div>
                  </div>
                </label>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <%# Custom Modules %>
      <div class="sect">
        <div class="sect__head">
          <span class="ic" style="color:var(--color-primary-text)"><%= relay_icon("plus", size: 15) %></span>
          <div class="sect__title grow">Custom modules</div>
          <span class="muted rl-sm">Anything outside the catalog — custom dev, integrations, bespoke screens</span>
        </div>
        <div class="sect__body">
          <div class="col" style="gap:10px" data-odoo-calculator-target="customModulesList">
            <% Array(proposal.custom_module_details).each do |cm| %>
              <div class="custom-module-row" data-odoo-calculator-target="customModuleRow"
                   style="padding:12px;border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface-2)">
                <div class="row" style="gap:8px;align-items:flex-start">
                  <input type="text" name="odoo_proposal[custom_modules][][label]" value="<%= cm[:label] %>"
                         placeholder="Custom module name" class="rl-input rl-input--sm" style="width:24%"
                         data-action="input->odoo-calculator#recalculate">
                  <input type="text" name="odoo_proposal[custom_modules][][description]" value="<%= cm[:description] %>"
                         placeholder="One-line description of what it does for this client" class="rl-input rl-input--sm grow">
                  <div class="rl-inputwrap" style="width:140px">
                    <span class="rl-affix">PKR</span>
                    <input type="number" min="0" step="1000" name="odoo_proposal[custom_modules][][impl_cost]" value="<%= cm[:impl_cost] %>"
                           placeholder="0" class="custom-module-cost rl-input rl-input--sm mono" style="text-align:right"
                           data-odoo-calculator-target="customModuleCost" data-action="input->odoo-calculator#recalculate">
                  </div>
                  <button type="button" class="rl-iconbtn rl-iconbtn--sm" data-action="click->odoo-calculator#removeCustomModule" title="Remove">
                    <%= relay_icon("trash-2", size: 14) %>
                  </button>
                </div>
                <input type="hidden" name="odoo_proposal[custom_modules][][hours]"
                       value="<%= cm[:hours].to_i.positive? ? cm[:hours] : "" %>"
                       data-odoo-calculator-target="customModuleHours">
                <p class="custom-module-hours-hint rl-help<%= ' hidden' unless cm[:hours].to_i.positive? %>" style="margin-top:6px">
                  ~<%= cm[:hours] %> hrs effort
                </p>
              </div>
            <% end %>
          </div>

          <div data-odoo-calculator-target="customModulesEmpty" style="<%= "display:none" if Array(proposal.custom_module_details).any? %>;margin-top:8px">
            <p class="muted rl-sm">No custom modules yet. Use Smart Detect or add manually.</p>
          </div>

          <button type="button" data-action="click->odoo-calculator#addCustomModule" class="rl-btn rl-btn--secondary rl-btn--sm" style="margin-top:12px">
            <%= relay_icon("plus", size: 14) %>Add custom module
          </button>
        </div>
      </div>

      <%# Business Context %>
      <div class="sect">
        <div class="sect__head">
          <span class="ic" style="color:var(--color-primary-text)"><%= relay_icon("sparkles", size: 15) %></span>
          <div class="sect__title grow">Business context</div>
          <span class="muted rl-sm">Powers the AI proposal narrative</span>
        </div>
        <div class="sect__body">
          <div class="grid grid-2" style="margin-bottom:14px">
            <div class="rl-field" style="margin:0">
              <label class="rl-label">Industry</label>
              <%= f.select :industry,
                    options_for_select([["— Select industry —", ""]] + OdooProposal::INDUSTRIES.map { |i| [i, i] }, proposal.industry),
                    {}, class: "rl-select", "data-odoo-calculator-target": "industrySelect" %>
            </div>
            <div class="rl-field" style="margin:0">
              <label class="rl-label">Company size</label>
              <%= f.select :company_size,
                    options_for_select([["— Select size —", ""]] + OdooProposal::COMPANY_SIZES, proposal.company_size),
                    {}, class: "rl-select", "data-odoo-calculator-target": "sizeSelect" %>
            </div>
          </div>
          <div class="rl-field" style="margin:0">
            <label class="rl-label">Pain points <span class="muted">(select all that apply)</span></label>
            <div class="grid grid-2" style="gap:6px">
              <% OdooProposal::PAIN_POINTS.each do |pp| %>
                <label class="rl-check">
                  <%= check_box_tag "odoo_proposal[pain_points][]", pp, Array(proposal.pain_points).include?(pp),
                        "data-odoo-calculator-target": "painPointCheckbox", "data-pain": pp %>
                  <span class="rl-box"><%= relay_icon("check", size: 13) %></span>
                  <span class="rl-sm"><%= pp %></span>
                </label>
              <% end %>
            </div>
            <%= hidden_field_tag "odoo_proposal[pain_points][]", "" %>
          </div>
        </div>
      </div>

      <%# Notes %>
      <div class="sect">
        <div class="sect__head"><div class="sect__title">Notes</div></div>
        <div class="sect__body">
          <%= f.text_area :notes, rows: 3, class: "rl-textarea",
                placeholder: "Any special requirements, custom integrations or scope notes…" %>
        </div>
      </div>
    </div>

    <%# ════ RIGHT — config + live summary (sticky) ════ %>
    <div class="oc-side">
      <div class="sect">
        <%# Deployment %>
        <div class="sect__body" style="border-bottom:1px solid var(--color-border)">
          <div class="micro" style="margin-bottom:10px">Deployment type</div>
          <div class="col" style="gap:6px">
            <% OdooProposal::DEPLOYMENT_OPTIONS.each do |opt| %>
              <% selected = current_dep == opt[:key] %>
              <label class="oc-opt<%= ' border-red-500 bg-red-50' if selected %>"
                     data-odoo-calculator-target="deployLabel" data-deploy-key="<%= opt[:key] %>">
                <%= f.radio_button :deployment_type, opt[:key], checked: selected,
                      data: { "odoo-calculator-target": "deployRadio", action: "change->odoo-calculator#deploymentChanged", "deploy-key": opt[:key] } %>
                <div class="grow">
                  <div class="row" style="gap:6px;align-items:center">
                    <span class="rl-sm" style="font-weight:600"><%= opt[:label] %></span>
                    <span class="rl-chip rl-sm"><%= opt[:plan] %></span>
                  </div>
                  <div class="muted rl-sm" style="margin-top:2px"><%= opt[:desc] %></div>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <%# Odoo.sh Platform Plan %>
        <div class="sect__body" data-odoo-calculator-target="shSection" style="border-bottom:1px solid var(--color-border);<%= "display:none" unless current_dep == "sh" %>">
          <div class="micro" style="margin-bottom:2px">Odoo.sh platform</div>
          <div class="muted rl-sm" style="margin-bottom:10px">Worker-based infrastructure hosted by Odoo</div>
          <div class="col" style="gap:6px">
            <% OdooProposal::SH_TIERS.each do |key, tier| %>
              <label class="oc-opt<%= ' border-red-500 bg-red-50' if current_tier == key.to_s %>"
                     data-odoo-calculator-target="shTierLabel" data-tier-key="<%= key %>">
                <%= f.radio_button :hosting_tier, key, checked: current_tier == key.to_s,
                      data: { "odoo-calculator-target": "shTierRadio", action: "change->odoo-calculator#shTierChanged", "tier-key": key } %>
                <div class="grow">
                  <div class="spread"><span class="rl-sm" style="font-weight:600"><%= tier[:label] %></span><span class="mono rl-sm" style="font-weight:700;color:var(--color-primary-text)">PKR <%= number_with_delimiter(tier[:annual_pkr]) %>/yr</span></div>
                  <div class="muted rl-sm" style="margin-top:2px"><%= tier[:specs] %></div>
                  <div class="muted rl-sm"><%= tier[:users] %></div>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <%# On-Premise Hosting Tier %>
        <div class="sect__body" data-odoo-calculator-target="hostingSection" style="border-bottom:1px solid var(--color-border);<%= "display:none" unless current_dep == "on_premise" %>">
          <div class="micro" style="margin-bottom:2px">Server hosting tier</div>
          <div class="muted rl-sm" style="margin-bottom:10px">AWS-based self-hosted infrastructure</div>
          <div class="col" style="gap:6px">
            <% OdooProposal::HOSTING_TIERS.each do |key, tier| %>
              <label class="oc-opt<%= ' border-red-500 bg-red-50' if current_tier == key.to_s %>"
                     data-odoo-calculator-target="tierLabel" data-tier-key="<%= key %>">
                <%= f.radio_button :hosting_tier, key, checked: current_tier == key.to_s,
                      data: { "odoo-calculator-target": "tierRadio", action: "change->odoo-calculator#tierChanged", "tier-key": key, "tier-cost": tier[:annual_pkr] } %>
                <div class="grow">
                  <div class="spread"><span class="rl-sm" style="font-weight:600"><%= tier[:label] %></span><span class="mono rl-sm" style="font-weight:700;color:var(--color-primary-text)">PKR <%= number_with_delimiter(tier[:annual_pkr]) %>/yr</span></div>
                  <div class="muted rl-sm" style="margin-top:2px"><%= tier[:specs] %></div>
                  <div class="muted rl-sm"><%= tier[:users] %></div>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <%# Users %>
        <div class="sect__body" style="border-bottom:1px solid var(--color-border)">
          <div class="micro" style="margin-bottom:10px">Number of users</div>
          <div class="row" style="gap:8px;align-items:center">
            <button type="button" class="rl-iconbtn rl-iconbtn--sm" data-action="click->odoo-calculator#decrementUsers"><%= relay_icon("minus", size: 15) %></button>
            <%= f.number_field :num_users, value: current_users, min: 1, max: 500,
                  class: "rl-input mono", style: "width:64px;text-align:center",
                  data: { "odoo-calculator-target": "numUsers", action: "input->odoo-calculator#usersChanged" } %>
            <button type="button" class="rl-iconbtn rl-iconbtn--sm" data-action="click->odoo-calculator#incrementUsers"><%= relay_icon("plus", size: 15) %></button>
            <span class="muted rl-sm">users</span>
          </div>
        </div>

        <%# Live Cost Summary %>
        <div class="sect__body">
          <div style="background:var(--color-primary);border-radius:var(--radius-lg);padding:16px;color:#fff">
            <div class="spread" style="margin-bottom:6px">
              <span class="rl-sm" style="opacity:.85;text-transform:uppercase;letter-spacing:.05em;font-weight:600">Year 1 total</span>
              <span class="rl-badge rl-badge--solid" data-odoo-calculator-target="moduleCount">0</span>
            </div>
            <div class="mono" style="font-size:var(--text-h3);font-weight:800" data-odoo-calculator-target="year1Total">PKR 0</div>
            <div class="rl-sm" style="opacity:.85;margin-top:4px">Setup + 12-mo subscription + hosting</div>
          </div>

          <div class="col" style="gap:10px;margin-top:14px">
            <div class="spread"><span class="muted rl-sm">Implementation (one-time)</span><span class="mono rl-sm" style="font-weight:700" data-odoo-calculator-target="implFee">PKR 0</span></div>

            <div style="padding:10px;background:var(--color-surface-2);border-radius:var(--radius-md)">
              <div class="spread"><span class="rl-sm" style="font-weight:600">Odoo subscription / yr</span><span class="mono rl-sm" style="font-weight:700" data-odoo-calculator-target="subYearly">PKR 0</span></div>
              <div class="spread muted rl-sm" style="margin-top:4px"><span data-odoo-calculator-target="subPerUserLabel">— × — users</span><span data-odoo-calculator-target="subMonthly">PKR 0/mo</span></div>
              <div class="spread muted rl-sm" style="margin-top:4px"><span>Plan</span><span data-odoo-calculator-target="subPlanLabel">Standard</span></div>
            </div>

            <div class="spread" data-odoo-calculator-target="hostingRow" style="display:none">
              <span class="muted rl-sm" data-odoo-calculator-target="hostingRowLabel">Hosting / yr</span>
              <span class="mono rl-sm" style="font-weight:700" data-odoo-calculator-target="hostingCost">PKR 0</span>
            </div>

            <div style="padding-top:10px;border-top:1px dashed var(--color-border)">
              <div class="spread"><span class="rl-sm" style="font-weight:600">Year 2+ / month</span><span class="mono rl-sm" style="font-weight:700;color:var(--color-primary-text)" data-odoo-calculator-target="recurringMonthly">PKR 0</span></div>
              <div class="spread muted rl-sm" style="margin-top:4px"><span>Year 2+ / year</span><span class="mono" data-odoo-calculator-target="recurringYearly">PKR 0</span></div>
            </div>
          </div>

          <div style="margin-top:12px;padding:10px;background:var(--color-warning-subtle);border:1px solid var(--color-warning);border-radius:var(--radius-md)">
            <div class="rl-sm" style="font-weight:600;color:var(--color-warning-text)">Odoo License (paid directly to Odoo)</div>
            <div class="rl-sm" style="color:var(--color-warning-text);margin-top:2px">Prices shown are <strong>annual billing</strong> rates. Standard: $7.25/user/mo · Custom: $10.90/user/mo</div>
          </div>

          <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--color-border)">
            <div class="micro" style="margin-bottom:8px">Included in setup</div>
            <ul style="list-style:none;margin:0;padding:0" class="col">
              <% ["Module configuration", "Workflow customisation", "Data migration", "User training", "2-week post-launch support"].each do |item| %>
                <li class="row" style="gap:8px;align-items:center"><span class="ic" style="color:var(--color-success);flex:none"><%= relay_icon("check", size: 14) %></span><span class="rl-sm"><%= item %></span></li>
              <% end %>
            </ul>
          </div>

          <div style="margin-top:14px">
            <%= f.submit submit_label, class: "rl-btn rl-btn--primary rl-btn--block",
                  data: { "odoo-calculator-target": "submitBtn" } %>
            <p class="rl-help" style="text-align:center;margin-top:6px">
              <% if proposal.persisted? %>Claude will regenerate the proposal narrative on save.<% else %>PDF proposal ready on the next page<% end %>
            </p>
          </div>
        </div>
      </div>
    </div>

  <% end %>

  <template data-odoo-calculator-target="customModuleTemplate">
    <div class="custom-module-row" data-odoo-calculator-target="customModuleRow"
         style="padding:12px;border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface-2)">
      <div class="row" style="gap:8px;align-items:flex-start">
        <input type="text" name="odoo_proposal[custom_modules][][label]" placeholder="Custom module name"
               class="rl-input rl-input--sm" style="width:24%" data-action="input->odoo-calculator#recalculate">
        <input type="text" name="odoo_proposal[custom_modules][][description]"
               placeholder="One-line description of what it does for this client" class="rl-input rl-input--sm grow">
        <div class="rl-inputwrap" style="width:140px">
          <span class="rl-affix">PKR</span>
          <input type="number" min="0" step="1000" name="odoo_proposal[custom_modules][][impl_cost]" placeholder="0"
                 class="custom-module-cost rl-input rl-input--sm mono" style="text-align:right"
                 data-odoo-calculator-target="customModuleCost" data-action="input->odoo-calculator#recalculate">
        </div>
        <button type="button" class="rl-iconbtn rl-iconbtn--sm" data-action="click->odoo-calculator#removeCustomModule" title="Remove">
          <%= relay_icon("trash-2", size: 14) %>
        </button>
      </div>
      <input type="hidden" name="odoo_proposal[custom_modules][][hours]" value="" data-odoo-calculator-target="customModuleHours">
      <p class="custom-module-hours-hint rl-help hidden" style="margin-top:6px"></p>
    </div>
  </template>
</div>

<style>
  .oc-grid { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: var(--space-4); align-items: start; }
  .oc-side { position: sticky; top: var(--space-4); }
