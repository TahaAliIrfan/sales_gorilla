<% content_for :title, "Team managers — #{current_organization&.name}" %>
<% total_associates = @users.sum { |u| u.associates.count } %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Team managers</div>
      <div class="pagehead__sub">All users with the manager role who lead teams.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to users_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to users
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>

  <div class="rl-sm" style="background:var(--color-info-subtle, var(--color-bg-2));border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:12px 14px;margin-bottom:var(--space-5)">
    <b>Manager permissions.</b> Only administrators can assign associates to managers or modify manager-associate relationships. Managers can view and manage their assigned team members.
  </div>

  <div class="grid grid-3" style="margin-bottom:var(--space-5)">
    <%= render "user_dashboard/stat", label: "Total managers", value: @users.count, sub: "team leads", icon: "building-2" %>
    <%= render "user_dashboard/stat", label: "Total associates", value: total_associates, sub: "managed", icon: "users" %>
    <%= render "user_dashboard/stat", label: "Avg team size",
          value: (@users.count > 0 ? (total_associates.to_f / @users.count).round(1) : 0), sub: "per manager", icon: "bar-chart-3" %>
  </div>

  <div class="sect">
    <div class="sect__head">
      <div class="sect__title">Managers list</div>
      <div class="muted rl-sm">View and manage team leaders</div>
    </div>
    <div class="sect__body--flush">
      <% if @users.any? %>
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Manager</th>
                <th>Contact</th>
                <th>Team size</th>
                <th>Performance</th>
                <th>Assigned by</th>
                <th style="text-align:right"></th>
              </tr>
            </thead>
            <tbody>
              <% @users.each_with_index do |user, i| %>
                <% assignment = user.role_assignments.find_by(role: Role.manager) %>
                <% associates_count = user.associates.count %>
                <% team_customers = user.associates.sum { |a| a.customers.count } %>
                <% team_deals = user.associates.sum { |a| a.deals.count } %>
                <tr>
                  <td>
                    <div class="row" style="gap:10px">
                      <span class="rl-avatar rl-avatar--sm rl-avatar--c<%= (i % 6) + 1 %>"><%= (user.name.presence || user.email).first.upcase %></span>
                      <div>
                        <div class="rl-cell-strong"><%= link_to (user.name.presence || user.email), user_path(user), style: "color:inherit" %></div>
                        <div class="muted" style="font-size:11px">ID: <%= user.id %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="rl-sm"><%= user.email %></div>
                    <% if user.phone_number.present? %><div class="muted" style="font-size:11px"><%= user.phone_number %></div><% end %>
                  </td>
                  <td>
                    <span class="rl-badge <%= associates_count > 0 ? "rl-badge--primary" : "rl-badge--neutral" %>">
                      <%= associates_count %> <%= "associate".pluralize(associates_count) %>
                    </span>
                  </td>
                  <td>
                    <div class="col" style="gap:4px">
                      <span class="rl-badge rl-badge--info"><%= team_customers %> customers</span>
                      <span class="rl-badge rl-badge--success"><%= team_deals %> deals</span>
                    </div>
                  </td>
                  <td class="rl-sm">
                    <% if assignment&.assigned_by %>
                      <%= link_to (assignment.assigned_by.name.presence || assignment.assigned_by.email), user_path(assignment.assigned_by), style: "color:var(--color-primary-text)" %>
                    <% else %>
                      <span class="rl-badge rl-badge--neutral">System</span>
                    <% end %>
                  </td>
                  <td style="text-align:right">
                    <div class="row" style="gap:6px;justify-content:flex-end">
                      <%= link_to "View", user_path(user), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                      <% if current_user.admin? %>
                        <%= link_to "Team", manage_associates_user_path(user), class: "rl-btn rl-btn--primary rl-btn--sm" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="muted rl-sm" style="text-align:center;padding:var(--space-8)">There are no managers in the system yet.</div>
      <% end %>
    </div>
  </div>
</div>
