<div class="container mx-auto px-4 py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Managers</h1>
    <div class="flex space-x-2">
      <%= link_to "View Team Hierarchy", team_hierarchy_path, class: "bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded mr-2" %>
      <%= link_to "Back to Users", users_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-3 py-1 rounded" %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= notice %>
    </div>
  <% end %>

  <div class="bg-blue-100 border border-blue-400 text-blue-700 px-4 py-3 rounded mb-4">
    <p class="font-medium">Note:</p>
    <p>Only administrators can assign associates to managers or remove associates from managers.</p>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="px-4 py-4 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium leading-6 text-gray-900">All Managers</h3>
      <p class="mt-1 text-sm text-gray-500">All users with manager role who can manage associates</p>
    </div>
    
    <% if @users.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Associates Count</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned By</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @users.each do |user| %>
            <% assignment = user.role_assignments.find_by(role: Role.manager) %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= link_to user.name, user_path(user), class: "text-blue-600 hover:text-blue-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  <%= user.associates.count %> associates
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if assignment&.assigned_by %>
                  <%= link_to assignment.assigned_by.name, user_path(assignment.assigned_by), class: "text-blue-600 hover:text-blue-900" %>
                <% else %>
                  <span class="text-gray-400">System</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "View", user_path(user), class: "text-blue-600 hover:text-blue-900 mr-3" %>
                <% if current_user.admin? %>
                  <%= link_to "Manage Roles", user_path(user), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
                  <%= link_to "Manage Associates", manage_associates_user_path(user), class: "text-green-600 hover:text-green-800" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-4 text-gray-500">
        No managers found.
      </div>
    <% end %>
  </div>
</div>
