<% content_for :title, "#{current_user.admin? ? "All associates" : "My associates"} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title"><%= current_user.admin? ? "All associates" : "My associates" %></div>
      <div class="pagehead__sub"><%= current_user.admin? ? "All users with the associate role." : "Team members assigned to you as a manager." %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to users_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to users
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>

  <div class="grid grid-3" style="margin-bottom:var(--space-5)">
    <%= render "user_dashboard/stat", label: "Total associates", value: @users.count, sub: "with associate role", icon: "users" %>
  </div>

  <div class="sect">
    <div class="sect__head">
      <div class="sect__title">Associates list</div>
      <div class="muted rl-sm">View and manage associate team members</div>
    </div>
    <div class="sect__body--flush">
      <% if @users.any? %>
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Associate</th>
                <th>Contact</th>
                <th>Manager</th>
                <th>Performance</th>
                <th>Member since</th>
                <th style="text-align:right"></th>
              </tr>
            </thead>
            <tbody>
              <% @users.each_with_index do |user, i| %>
                <% membership = user.membership_for(current_organization) %>
                <% manager = membership&.reports_to&.user %>
                <tr>
                  <td>
                    <div class="row" style="gap:10px">
                      <span class="rl-avatar rl-avatar--sm rl-avatar--c<%= (i % 6) + 1 %>"><%= (user.name.presence || user.email).first.upcase %></span>
                      <div>
                        <div class="rl-cell-strong"><%= link_to (user.name.presence || user.email), user_path(user), style: "color:inherit" %></div>
                        <div class="muted" style="font-size:11px">ID: <%= user.id %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="rl-sm"><%= user.email %></div>
                    <% if user.phone_number.present? %><div class="muted" style="font-size:11px"><%= user.phone_number %></div><% end %>
                  </td>
                  <td class="rl-sm">
                    <% if manager %>
                      <%= link_to (manager.name.presence || manager.email), user_path(manager), style: "color:var(--color-primary-text)" %>
                    <% else %>
                      <span class="rl-badge rl-badge--neutral">No manager</span>
                    <% end %>
                  </td>
                  <td>
                    <div class="row" style="gap:6px">
                      <span class="rl-badge rl-badge--info"><%= user.customers.count %> customers</span>
                      <span class="rl-badge rl-badge--success"><%= user.deals.count %> deals</span>
                    </div>
                  </td>
                  <td class="muted rl-sm"><%= membership ? "#{time_ago_in_words(membership.created_at)} ago" : "-" %></td>
                  <td style="text-align:right">
                    <%= link_to "View", user_path(user), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="muted rl-sm" style="text-align:center;padding:var(--space-8)">
          <%= current_user.admin? ? "There are no associates in the system yet." : "You don't have any associates assigned to you yet." %>
        </div>
      <% end %>
    </div>
  </div>
</div>
