<div class="container mx-auto px-4 py-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold">Manage Team Members for <%= @user.name %></h1>
      <p class="text-sm text-gray-600 mt-1">Only administrators can assign or remove associates to managers.</p>
    </div>
    <div class="flex space-x-2">
      <%= link_to "View Team Hierarchy", team_hierarchy_path, class: "bg-emerald-500 hover:bg-emerald-600 text-white px-3 py-1 rounded mr-2" %>
      <%= link_to "Back to User", user_path(@user), class: "bg-gray-500 hover:bg-gray-600 text-white px-3 py-1 rounded" %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= notice %>
    </div>
  <% end %>
  
  <% if alert.present? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <%= alert %>
    </div>
  <% end %>

  <!-- Main Team Management Interface -->
  <div class="bg-white shadow-md rounded-lg overflow-hidden mb-6" data-controller="team-management">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-xl font-semibold">Team Members</h2>
      <p class="text-sm text-gray-500">Drag and drop associates between lists to manage team members</p>
    </div>
    
    <div class="p-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Current Team Members -->
        <div class="bg-emerald-50 rounded-lg p-4 border border-emerald-200">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-medium text-emerald-800">Current Team Members (<span id="current-count"><%= @current_associates.count %></span>)</h3>
            <button type="button" class="text-emerald-600 hover:text-emerald-800 text-sm" data-action="team-management#expandAll">
              Expand All
            </button>
          </div>
          
          <div id="current-team-list" class="team-drop-area min-h-[200px] p-2" data-team-management-target="currentTeam">
            <% if @current_associates.any? %>
              <% @current_associates.each do |associate| %>
                <% assignment = associate.role_assignments.find_by(role: Role.associate, assigned_by: @user) %>
                <div class="associate-card bg-white rounded-md shadow-sm p-3 mb-2 cursor-move border-l-4 border-emerald-500" 
                     data-team-management-target="associateCard"
                     data-associate-id="<%= associate.id %>"
                     data-associate-name="<%= associate.name.present? ? associate.name.downcase : '' %>" 
                     data-associate-email="<%= associate.email.present? ? associate.email.downcase : '' %>">
                  <div class="flex justify-between items-center">
                    <div>
                      <h4 class="font-medium text-gray-900"><%= associate.name.present? ? associate.name : 'No Name' %></h4>
                      <p class="text-sm text-gray-500"><%= associate.email.present? ? associate.email : 'No Email' %></p>
                    </div>
                    <div class="flex items-center space-x-2">
                      <span class="text-xs bg-emerald-100 text-emerald-800 rounded-full px-2 py-1">Team Member</span>
                      <button type="button" class="ml-2 text-red-600 hover:text-red-800 focus:outline-none" 
                              data-action="team-management#unassignAssociate" data-associate-id="<%= associate.id %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      </button>
                    </div>
                  </div>
                  <button type="button" class="text-sm text-emerald-600 hover:text-emerald-800 mt-2 w-full text-left focus:outline-none" 
                          data-action="team-management#toggleDetails">
                    Show Details
                  </button>
                  <div class="associate-details hidden mt-2 pt-2 border-t border-gray-100 text-sm">
                    <div class="grid grid-cols-2 gap-2">
                      <div>
                        <p class="text-gray-500">Assigned On:</p>
                        <p class="font-medium"><%= assignment&.created_at&.strftime("%b %d, %Y") || "N/A" %></p>
                      </div>
                      <div>
                        <p class="text-gray-500">Assigned By:</p>
                        <p class="font-medium"><%= assignment&.assigned_by&.name || "System" %></p>
                      </div>
                    </div>
                    <div class="mt-2">
                      <p class="text-gray-500">Recent Activity:</p>
                      <div class="flex space-x-4 mt-1">
                        <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                          <%= associate.customers.count %> customers
                        </span>
                        <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                          <%= associate.tasks.where(completed: false).count %> pending tasks
                        </span>
                        <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                          <%= associate.deals.where.not(status: ['won', 'lost']).count %> active deals
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="text-center py-12 text-gray-500" id="current-empty-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <p>No team members assigned yet.</p>
                <p class="text-sm mt-2">Drag associates from the right panel to add them to the team.</p>
              </div>
            <% end %>
          </div>
        </div>
        
        <!-- Available Associates -->
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-medium text-gray-700">Available Associates (<span id="available-count"><%= @available_associates.count %></span>)</h3>
            <div class="flex space-x-2">
              <input type="text" placeholder="Search associates..." class="border border-gray-300 rounded px-2 py-1 text-sm" 
                     data-team-management-target="searchInput" data-action="input->team-management#searchAssociates">
              <button type="button" class="text-emerald-600 hover:text-emerald-800 text-sm" data-action="team-management#clearSearch">
                Clear
              </button>
            </div>
          </div>
          
          <div id="available-associates-list" class="team-drop-area min-h-[200px] p-2" data-team-management-target="availableAssociates">
            <% if @available_associates.any? %>
              <% @available_associates.each do |associate| %>
                <div class="associate-card bg-white rounded-md shadow-sm p-3 mb-2 cursor-move border-l-4 border-gray-300" 
                     data-team-management-target="associateCard"
                     data-associate-id="<%= associate.id %>" 
                     data-associate-name="<%= associate.name.present? ? associate.name.downcase : '' %>" 
                     data-associate-email="<%= associate.email.present? ? associate.email.downcase : '' %>">
                  <div class="flex justify-between items-center">
                    <div>
                      <h4 class="font-medium text-gray-900"><%= associate.name.present? ? associate.name : 'No Name' %></h4>
                      <p class="text-sm text-gray-500"><%= associate.email.present? ? associate.email : 'No Email' %></p>
                    </div>
                    <div class="flex items-center">
                      <span class="text-xs bg-gray-100 text-gray-800 rounded-full px-2 py-1">Available</span>
                      <button type="button" class="ml-2 text-green-600 hover:text-green-800 focus:outline-none" 
                              data-action="team-management#quickAssign" data-associate-id="<%= associate.id %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                      </button>
                    </div>
                  </div>
                  <button type="button" class="text-sm text-emerald-600 hover:text-emerald-800 mt-2 w-full text-left focus:outline-none" 
                          data-action="team-management#toggleDetails">
                    Show Details
                  </button>
                  <div class="associate-details hidden mt-2 pt-2 border-t border-gray-100 text-sm">
                    <div class="grid grid-cols-2 gap-2">
                      <div>
                        <p class="text-gray-500">Role Assigned:</p>
                        <p class="font-medium"><%= associate.role_assignments.find_by(role: Role.associate)&.created_at&.strftime("%b %d, %Y") || "N/A" %></p>
                      </div>
                      <div>
                        <p class="text-gray-500">Current Manager:</p>
                        <p class="font-medium">None</p>
                      </div>
                    </div>
                    <div class="mt-2">
                      <p class="text-gray-500">Recent Activity:</p>
                      <div class="flex space-x-4 mt-1">
                        <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                          <%= associate.customers.count %> customers
                        </span>
                        <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                          <%= associate.tasks.where(completed: false).count %> pending tasks
                        </span>
                        <span class="px-2 py-1 bg-gray-100 rounded text-xs">
                          <%= associate.deals.where.not(status: ['won', 'lost']).count %> active deals
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="text-center py-12 text-gray-500" id="available-empty-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <p>No available associates to assign.</p>
                <p class="text-sm mt-2">All associates with the associate role have been assigned.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    
    <div class="border-t border-gray-200 px-6 py-4 bg-gray-50">
      <div class="flex justify-between">
        <div class="flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm text-gray-600">Drag and drop associates between lists, or use the quick add button. Changes are saved automatically.</span>
        </div>
      </div>
    </div>
  </div>
</div> 