<%# Relay team management — drag/drop associate assignment. Preserves the
    team-management Stimulus controller contract: targets (currentTeam,
    availableAssociates, associateCard, searchInput), data-associate-id/name/email,
    .associate-card / .associate-details hooks, the .text-xs status pill the JS
    rewrites, and the #current-count / #available-count / *-empty-placeholder ids.
    POSTs to UsersController#assign_associate / #remove_associate (unchanged). %>
<% content_for :title, "Manage team — #{@user.name} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Manage team for <%= @user.name %></div>
      <div class="pagehead__sub">Only administrators can assign or remove associates. Changes save automatically.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to user_path(@user), class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to user
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="rl-sm" style="background:var(--color-danger-subtle);border:1px solid var(--color-danger-border);color:var(--color-danger-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= alert %></div>
  <% end %>

  <div class="sect" data-controller="team-management">
    <div class="sect__head">
      <div class="sect__title"><%= relay_icon("users", size: 18) %>Team members</div>
      <div class="muted rl-sm">Drag associates between lists, or use the quick add button.</div>
    </div>
    <div class="sect__body">
      <div class="grid grid-2" style="gap:var(--space-5);align-items:start">
        <%# Current team %>
        <div>
          <div class="spread" style="margin-bottom:10px">
            <b>Current team members (<span id="current-count"><%= @current_associates.count %></span>)</b>
            <button type="button" class="rl-btn rl-btn--ghost rl-btn--sm" data-action="team-management#expandAll">Expand all</button>
          </div>
          <div id="current-team-list" class="team-drop-area col" style="gap:8px;min-height:200px;padding:8px;border:1px dashed var(--color-border);border-radius:var(--radius-lg)"
               data-team-management-target="currentTeam">
            <% if @current_associates.any? %>
              <% @current_associates.each do |associate| %>
                <div class="associate-card rl-card" style="padding:12px;cursor:move"
                     data-team-management-target="associateCard"
                     data-associate-id="<%= associate.id %>"
                     data-associate-name="<%= associate.name.present? ? associate.name.downcase : "" %>"
                     data-associate-email="<%= associate.email.present? ? associate.email.downcase : "" %>">
                  <div class="spread">
                    <div>
                      <div class="rl-cell-strong"><%= associate.name.presence || "No name" %></div>
                      <div class="muted rl-sm"><%= associate.email.presence || "No email" %></div>
                    </div>
                    <div class="row" style="gap:8px;align-items:center">
                      <span class="text-xs rl-badge rl-badge--primary">Team member</span>
                      <button type="button" class="rl-iconbtn rl-iconbtn--sm" style="color:var(--color-danger-text)"
                              data-action="team-management#unassignAssociate" data-associate-id="<%= associate.id %>" title="Remove">
                        <%= relay_icon("trash-2", size: 16) %>
                      </button>
                    </div>
                  </div>
                  <button type="button" class="rl-btn rl-btn--ghost rl-btn--sm" style="margin-top:8px" data-action="team-management#toggleDetails">Show details</button>
                  <div class="associate-details hidden rl-sm" style="margin-top:8px;padding-top:8px;border-top:1px solid var(--color-border)">
                    <div class="row" style="gap:16px">
                      <div><span class="muted">Reports to:</span> <b><%= @user.name.presence || @user.email %></b></div>
                      <div><span class="muted">Role:</span> <b style="text-transform:capitalize"><%= associate.primary_role&.key || "member" %></b></div>
                    </div>
                    <div class="row" style="gap:8px;margin-top:8px">
                      <span class="rl-badge rl-badge--neutral"><%= associate.customers.count %> customers</span>
                      <span class="rl-badge rl-badge--neutral"><%= associate.tasks.where(completed: false).count %> pending tasks</span>
                      <span class="rl-badge rl-badge--neutral"><%= associate.deals.where.not(status: [ "won", "lost" ]).count %> active deals</span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="muted rl-sm" style="text-align:center;padding:var(--space-6)" id="current-empty-placeholder">
                No team members assigned yet. Drag associates from the right panel to add them.
              </div>
            <% end %>
          </div>
        </div>

        <%# Available associates %>
        <div>
          <div class="spread" style="margin-bottom:10px">
            <b>Available associates (<span id="available-count"><%= @available_associates.count %></span>)</b>
            <div class="row" style="gap:6px">
              <input type="text" placeholder="Search…" class="rl-input rl-input--sm" style="width:160px"
                     data-team-management-target="searchInput" data-action="input->team-management#searchAssociates">
              <button type="button" class="rl-btn rl-btn--ghost rl-btn--sm" data-action="team-management#clearSearch">Clear</button>
            </div>
          </div>
          <div id="available-associates-list" class="team-drop-area col" style="gap:8px;min-height:200px;padding:8px;border:1px dashed var(--color-border);border-radius:var(--radius-lg)"
               data-team-management-target="availableAssociates">
            <% if @available_associates.any? %>
              <% @available_associates.each do |associate| %>
                <div class="associate-card rl-card" style="padding:12px;cursor:move"
                     data-team-management-target="associateCard"
                     data-associate-id="<%= associate.id %>"
                     data-associate-name="<%= associate.name.present? ? associate.name.downcase : "" %>"
                     data-associate-email="<%= associate.email.present? ? associate.email.downcase : "" %>">
                  <div class="spread">
                    <div>
                      <div class="rl-cell-strong"><%= associate.name.presence || "No name" %></div>
                      <div class="muted rl-sm"><%= associate.email.presence || "No email" %></div>
                    </div>
                    <div class="row" style="gap:8px;align-items:center">
                      <span class="text-xs rl-badge rl-badge--neutral">Available</span>
                      <button type="button" class="rl-iconbtn rl-iconbtn--sm" style="color:var(--color-success)"
                              data-action="team-management#quickAssign" data-associate-id="<%= associate.id %>" title="Assign">
                        <%= relay_icon("plus", size: 16) %>
                      </button>
                    </div>
                  </div>
                  <button type="button" class="rl-btn rl-btn--ghost rl-btn--sm" style="margin-top:8px" data-action="team-management#toggleDetails">Show details</button>
                  <div class="associate-details hidden rl-sm" style="margin-top:8px;padding-top:8px;border-top:1px solid var(--color-border)">
                    <div class="row" style="gap:16px">
                      <div><span class="muted">Role:</span> <b style="text-transform:capitalize"><%= associate.primary_role&.key || "member" %></b></div>
                      <div><span class="muted">Current manager:</span> <b>None</b></div>
                    </div>
                    <div class="row" style="gap:8px;margin-top:8px">
                      <span class="rl-badge rl-badge--neutral"><%= associate.customers.count %> customers</span>
                      <span class="rl-badge rl-badge--neutral"><%= associate.tasks.where(completed: false).count %> pending tasks</span>
                      <span class="rl-badge rl-badge--neutral"><%= associate.deals.where.not(status: [ "won", "lost" ]).count %> active deals</span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="muted rl-sm" style="text-align:center;padding:var(--space-6)" id="available-empty-placeholder">
                No available associates to assign. All associates have been assigned.
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
