<% content_for :title, "#{@user.name.presence || @user.email} — #{current_organization&.name}" %>
<% role_key = @user.admin? ? "admin" : (@user.manager? ? "manager" : "associate") %>

<div class="page">
  <div class="pagehead">
    <div class="row" style="gap:14px">
      <span class="rl-avatar rl-avatar--lg <%= relay_avatar_class(@user.name.presence || @user.email) %>">
        <%= (@user.name.presence || @user.email).first.upcase %>
      </span>
      <div>
        <div class="pagehead__title"><%= @user.name.presence || @user.email %></div>
        <div class="pagehead__sub"><%= @user.email %><%= " · #{@user.phone_number}" if @user.phone_number.present? %></div>
      </div>
    </div>
    <div class="pagehead__actions">
      <%= link_to users_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to users
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="rl-sm" style="background:var(--color-danger-subtle);border:1px solid var(--color-danger-border);color:var(--color-danger-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= alert %></div>
  <% end %>

  <div class="grid grid-4" style="margin-bottom:var(--space-5)">
    <%= render "user_dashboard/stat", label: "Customers", value: @user.customers.count, sub: "owned", icon: "users" %>
    <%= render "user_dashboard/stat", label: "Deals", value: @user.deals.count, sub: "all time", icon: "circle-dollar-sign" %>
    <%= render "user_dashboard/stat", label: "Tasks", value: @user.tasks.count, sub: "assigned", icon: "list-checks" %>
    <%= render "user_dashboard/stat", label: "Recordings", value: @user.recordings.count, sub: "calls", icon: "mic" %>
  </div>

  <div class="grid" style="grid-template-columns:1.6fr 1fr;align-items:start;gap:var(--space-5);margin-bottom:var(--space-5)">
    <div class="sect">
      <div class="sect__head"><div class="sect__title"><%= relay_icon("info", size: 18) %>User information</div></div>
      <div class="sect__body">
        <div class="kvline"><dt>Full name</dt><dd><%= @user.name.presence || @user.email %></dd></div>
        <div class="kvline"><dt>Email</dt><dd><%= @user.email %></dd></div>
        <div class="kvline"><dt>Phone</dt><dd><%= @user.phone_number.presence || content_tag(:span, "Not set", class: "muted") %></dd></div>
        <div class="kvline"><dt>User ID</dt><dd class="mono"><%= @user.id %></dd></div>
        <div class="kvline">
          <dt>Account role</dt>
          <dd><span class="rl-badge <%= settings_role_badge(role_key) %>" style="text-transform:capitalize"><%= role_key %></span></dd>
        </div>
        <div class="kvline">
          <dt>Highest role</dt>
          <dd>
            <% if @user.highest_role %>
              <%= @user.highest_role.name %> <span class="muted" style="font-size:11px">(Level <%= @user.highest_role.hierarchy_level %>)</span>
            <% else %>
              <span class="muted">No role assigned</span>
            <% end %>
          </dd>
        </div>
        <% if @user.manager? %>
          <div class="kvline"><dt>Manages associates</dt><dd><span class="rl-badge rl-badge--info"><%= @user.associates.count %> team members</span></dd></div>
        <% end %>
      </div>
    </div>

    <%# The legacy "Assign new role" / per-assignment "Remove" controls posted to
        RoleAssignmentsController, which has no routes in this app — the legacy
        markup referenced undefined helpers (role_assignments_path) and ivars
        (@available_roles/@resources) and never worked. Role changes are made via
        the working update_role endpoint on the users list / Settings → Team. %>
    <div class="sect">
      <div class="sect__head"><div class="sect__title"><%= relay_icon("user-cog", size: 18) %>Manage role</div></div>
      <div class="sect__body">
        <div class="muted rl-sm">Change this user's role from the <%= link_to "user list", users_path, style: "color:var(--color-primary-text)" %> or the Team tab in Settings.</div>
      </div>
    </div>
  </div>

  <div class="sect">
    <div class="sect__head"><div class="sect__title"><%= relay_icon("shield", size: 18) %>Current role assignments</div></div>
    <div class="sect__body--flush">
      <% if @role_assignments.any? %>
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Role</th>
                <th>Scope</th>
                <th>Assigned by</th>
                <th>Assigned at</th>
              </tr>
            </thead>
            <tbody>
              <% @role_assignments.each do |assignment| %>
                <tr>
                  <td><span class="rl-badge <%= settings_role_badge(assignment.role.key) %>"><%= assignment.role.name %></span></td>
                  <td class="rl-sm">
                    <% if assignment.resource.present? %>
                      <span class="muted"><%= assignment.resource_type %>:</span> <%= assignment.resource.name %>
                    <% else %>
                      <span class="rl-badge rl-badge--neutral">Global</span>
                    <% end %>
                  </td>
                  <td class="rl-sm">
                    <% if assignment.assigned_by %>
                      <%= link_to assignment.assigned_by.name, user_path(assignment.assigned_by), style: "color:var(--color-primary-text)" %>
                    <% else %>
                      <span class="muted">System</span>
                    <% end %>
                  </td>
                  <td class="muted rl-sm"><%= time_ago_in_words(assignment.created_at) %> ago</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="muted rl-sm" style="text-align:center;padding:var(--space-6)">This user doesn't have any role assignments yet.</div>
      <% end %>
    </div>
  </div>
</div>
