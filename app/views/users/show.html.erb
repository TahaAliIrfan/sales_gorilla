<div class="px-4 sm:px-6 lg:px-8 py-8 bg-gray-50 min-h-screen">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <div class="h-16 w-16 rounded-full bg-gradient-to-br from-emerald-400 to-purple-500 flex items-center justify-center text-white font-bold text-2xl mr-4">
          <%= @user.name.present? ? @user.name.first.upcase : @user.email.first.upcase %>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-gray-900"><%= @user.name.presence || @user.email %></h1>
          <p class="text-sm text-gray-600 mt-1">
            <%= @user.email %>
            <% if @user.phone_number.present? %>
              • <%= @user.phone_number %>
            <% end %>
          </p>
        </div>
      </div>
      <div>
        <%= link_to users_path, class: "inline-flex items-center px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium" do %>
          <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Users
        <% end %>
      </div>
    </div>
  </div>

  <% if notice.present? %>
    <div class="mb-6 bg-green-50 border-l-4 border-green-400 p-4 rounded-lg">
      <div class="flex">
        <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <p class="ml-3 text-sm text-green-700 font-medium"><%= notice %></p>
      </div>
    </div>
  <% end %>
  
  <% if alert.present? %>
    <div class="mb-6 bg-red-50 border-l-4 border-red-400 p-4 rounded-lg">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
        <p class="ml-3 text-sm text-red-700 font-medium"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- User Stats -->
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-8">
    <!-- Total Customers -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-emerald-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Customers</dt>
              <dd class="text-3xl font-bold text-gray-900"><%= @user.customers.count %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Deals -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-green-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Deals</dt>
              <dd class="text-3xl font-bold text-gray-900"><%= @user.deals.count %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Tasks -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-orange-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12l2 2 4-4" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Tasks</dt>
              <dd class="text-3xl font-bold text-gray-900"><%= @user.tasks.count %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Recordings -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-purple-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Recordings</dt>
              <dd class="text-3xl font-bold text-gray-900"><%= @user.recordings.count %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3 mb-8">
    <!-- User Information Card -->
    <div class="lg:col-span-2">
      <div class="bg-white shadow-lg rounded-xl overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-emerald-50 to-purple-50">
          <h2 class="text-xl font-semibold text-gray-900 flex items-center">
            <svg class="h-6 w-6 text-emerald-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            User Information
          </h2>
        </div>
        <div class="p-6">
          <dl class="grid grid-cols-1 gap-x-6 gap-y-6 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-semibold text-gray-600 uppercase tracking-wider">Full Name</dt>
              <dd class="mt-2 text-base text-gray-900 font-medium"><%= @user.name.presence || @user.email %></dd>
            </div>
            
            <div>
              <dt class="text-sm font-semibold text-gray-600 uppercase tracking-wider">Email Address</dt>
              <dd class="mt-2 text-base text-gray-900"><%= @user.email %></dd>
            </div>
            
            <div>
              <dt class="text-sm font-semibold text-gray-600 uppercase tracking-wider">Phone Number</dt>
              <dd class="mt-2 text-base text-gray-900">
                <% if @user.phone_number.present? %>
                  <%= @user.phone_number %>
                <% else %>
                  <span class="text-gray-400 italic">Not set</span>
                <% end %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-semibold text-gray-600 uppercase tracking-wider">User ID</dt>
              <dd class="mt-2 text-base text-gray-900 font-mono"><%= @user.id %></dd>
            </div>
            
            <div>
              <dt class="text-sm font-semibold text-gray-600 uppercase tracking-wider">Account Status</dt>
              <dd class="mt-2">
                <% if @user.admin? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-red-500 to-red-600 text-white">
                    <svg class="h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    Administrator
                  </span>
                <% elsif @user.manager? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-purple-500 to-purple-600 text-white">
                    <svg class="h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z" />
                    </svg>
                    Manager
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-green-500 to-green-600 text-white">
                    <svg class="h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" />
                    </svg>
                    Associate
                  </span>
                <% end %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-semibold text-gray-600 uppercase tracking-wider">Highest Role</dt>
              <dd class="mt-2">
                <% if @user.highest_role %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold 
                    <%= case @user.highest_role.key
                      when 'admin' then 'bg-red-100 text-red-700 border-2 border-red-200'
                      when 'manager' then 'bg-purple-100 text-purple-700 border-2 border-purple-200'
                      when 'associate' then 'bg-green-100 text-green-700 border-2 border-green-200'
                      else 'bg-gray-100 text-gray-700 border-2 border-gray-200'
                      end %>">
                    <%= @user.highest_role.name %> 
                    <span class="ml-2 text-xs opacity-75">(Level: <%= @user.highest_role.hierarchy_level %>)</span>
                  </span>
                <% else %>
                  <span class="text-gray-400 italic">No role assigned</span>
                <% end %>
              </dd>
            </div>

            <% if @user.manager? %>
              <div class="sm:col-span-2">
                <dt class="text-sm font-semibold text-gray-600 uppercase tracking-wider">Manages Associates</dt>
                <dd class="mt-2">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-emerald-100 text-emerald-700">
                    <%= @user.associates.count %> team members
                  </span>
                </dd>
              </div>
            <% end %>
          </dl>
        </div>
      </div>
    </div>

    <!-- Role Assignment Card -->
    <% if current_user.admin? || (current_user.manager? && current_user.associates.include?(@user)) %>
      <div class="bg-white shadow-lg rounded-xl overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-green-50 to-emerald-50">
          <h2 class="text-xl font-semibold text-gray-900 flex items-center">
            <svg class="h-6 w-6 text-green-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            Assign New Role
          </h2>
        </div>
        <div class="p-6">
          <%= form_with(url: role_assignments_path, method: :post, class: "space-y-4") do |form| %>
            <%= form.hidden_field :user_id, value: @user.id %>

            <div>
              <%= form.label :role_id, "Role", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= form.select :role_id, 
                  @available_roles
                    .select { |r| current_user.can_assign_role?(r) }
                    .map { |r| [r.name, r.id] }, 
                  { include_blank: "Select a role" }, 
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring focus:ring-emerald-500 focus:ring-opacity-50" %>
            </div>

            <div>
              <%= form.label :resource_type, "Scope (Optional)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= form.select :resource_type, 
                  [["Global (No Scope)", ""], ["User", "User"]], 
                  { include_blank: false }, 
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring focus:ring-emerald-500 focus:ring-opacity-50",
                  id: "resource_type_select" %>
            </div>

            <div id="resource_user_section" class="hidden">
              <%= form.label :resource_id, "User", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= form.select :resource_id, 
                  @resources.map { |r| [r.name, r.id] }, 
                  { include_blank: "Select a user" }, 
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring focus:ring-emerald-500 focus:ring-opacity-50" %>
            </div>

            <div class="pt-4">
              <%= form.submit "Assign Role", class: "w-full inline-flex justify-center items-center rounded-lg border border-transparent shadow-sm px-4 py-3 bg-gradient-to-r from-emerald-600 to-emerald-700 text-base font-semibold text-white hover:from-emerald-700 hover:to-emerald-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-all" %>
            </div>
          <% end %>
          
          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const resourceTypeSelect = document.getElementById('resource_type_select');
              const resourceUserSection = document.getElementById('resource_user_section');
              
              function updateResourceSections() {
                const selectedValue = resourceTypeSelect.value;
                resourceUserSection.classList.add('hidden');
                
                if (selectedValue === 'User') {
                  resourceUserSection.classList.remove('hidden');
                }
              }
              
              resourceTypeSelect.addEventListener('change', updateResourceSections);
              updateResourceSections();
            });
          </script>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Current Roles Card -->
  <div class="bg-white shadow-lg rounded-xl overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-purple-50 to-pink-50">
      <h2 class="text-xl font-semibold text-gray-900 flex items-center">
        <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
        </svg>
        Current Role Assignments
      </h2>
    </div>
    
    <% if @role_assignments.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Role</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Scope</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Assigned By</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Assigned At</th>
              <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @role_assignments.each do |assignment| %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold 
                    <%= case assignment.role.key
                      when 'admin' then 'bg-red-100 text-red-700 border border-red-200'
                      when 'manager' then 'bg-purple-100 text-purple-700 border border-purple-200'
                      when 'associate' then 'bg-green-100 text-green-700 border border-green-200'
                      else 'bg-gray-100 text-gray-700 border border-gray-200'
                      end %>">
                    <%= assignment.role.name %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <% if assignment.resource.present? %>
                    <span class="font-medium"><%= assignment.resource_type %>:</span> <%= assignment.resource.name %>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                      Global
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <% if assignment.assigned_by %>
                    <%= link_to assignment.assigned_by.name, user_path(assignment.assigned_by), class: "text-emerald-600 hover:text-emerald-800 font-medium" %>
                  <% else %>
                    <span class="text-gray-400 italic">System</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= time_ago_in_words(assignment.created_at) %> ago
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <% if current_user.admin? || assignment.assigned_by == current_user %>
                    <%= link_to role_assignment_path(assignment), 
                        data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to remove this role assignment?" }, 
                        class: "inline-flex items-center px-3 py-1.5 bg-red-50 text-red-700 rounded-lg hover:bg-red-100 transition-colors text-xs font-medium" do %>
                      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                      Remove
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No roles assigned</h3>
        <p class="mt-1 text-sm text-gray-500">This user doesn't have any role assignments yet.</p>
      </div>
    <% end %>
  </div>
</div>
