<%# Relay user management — deeper admin surface. Inline role change and
    activate/deactivate POST to UsersController#update_role / #toggle_active via
    the relay--user-admin Stimulus controller (same JSON contract as Settings → Team). %>
<% content_for :title, "User management — #{current_organization&.name}" %>
<%
  admins     = @users.select(&:admin?).count
  managers   = @users.select { |u| u.manager? && !u.admin? }.count
  associates = @users.count - admins - managers
%>

<div class="page" data-controller="relay--user-admin">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">User management</div>
      <div class="pagehead__sub">Manage all users, roles, and access control in one place.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to managers_users_path, class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("building-2", size: 15) %>Managers
      <% end %>
      <%= link_to associates_users_path, class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("users", size: 15) %>Associates
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>

  <div class="grid grid-4" style="margin-bottom:var(--space-5)">
    <%= render "user_dashboard/stat", label: "Total users", value: @users.count, sub: "all roles", icon: "users" %>
    <%= render "user_dashboard/stat", label: "Admins", value: admins, sub: "full access", icon: "shield" %>
    <%= render "user_dashboard/stat", label: "Managers", value: managers, sub: "team leads", icon: "building-2" %>
    <%= render "user_dashboard/stat", label: "Associates", value: associates, sub: "reps", icon: "user" %>
  </div>

  <div class="sect">
    <div class="sect__head">
      <div class="sect__title">All users</div>
      <div class="muted rl-sm">Manage user accounts, roles, and access control</div>
    </div>
    <div class="sect__body--flush">
      <% if @users.any? %>
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Contact</th>
                <th>Role</th>
                <th>Status</th>
                <th>Stats</th>
                <th style="text-align:right"></th>
              </tr>
            </thead>
            <tbody>
              <% @users.each_with_index do |user, i| %>
                <% role_key = user.admin? ? "admin" : (user.manager? ? "manager" : "associate") %>
                <tr data-user-id="<%= user.id %>">
                  <td>
                    <div class="row" style="gap:10px">
                      <span class="rl-avatar rl-avatar--sm rl-avatar--c<%= (i % 6) + 1 %>">
                        <%= (user.name.presence || user.email).first.upcase %>
                      </span>
                      <div>
                        <div class="rl-cell-strong"><%= link_to (user.name.presence || user.email), user_path(user), style: "color:inherit" %></div>
                        <div class="muted" style="font-size:11px">ID: <%= user.id %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="rl-sm"><%= user.email %></div>
                    <% if user.phone_number.present? %>
                      <div class="muted" style="font-size:11px"><%= user.phone_number %></div>
                    <% end %>
                  </td>
                  <td>
                    <% if user == current_user %>
                      <span class="rl-badge <%= settings_role_badge(role_key) %>" style="text-transform:capitalize"><%= role_key %></span>
                      <div class="muted" style="font-size:11px;margin-top:2px">Can't change own role</div>
                    <% else %>
                      <select class="rl-select" style="width:auto;height:32px;padding-top:0;padding-bottom:0"
                              data-action="change->relay--user-admin#changeRole"
                              data-relay--user-admin-id-param="<%= user.id %>"
                              data-current="<%= role_key %>">
                        <% @roles.each do |r| %>
                          <option value="<%= r[:key] %>" <%= "selected" if r[:key] == role_key %>><%= r[:name] %></option>
                        <% end %>
                      </select>
                    <% end %>
                  </td>
                  <td>
                    <% if user.active? %>
                      <span class="rl-pill rl-pill--success"><i class="rl-dot"></i>Active</span>
                    <% else %>
                      <span class="rl-pill"><i class="rl-dot" style="background:var(--color-fg-4)"></i>Inactive</span>
                    <% end %>
                  </td>
                  <td>
                    <div class="row" style="gap:6px">
                      <span class="rl-badge rl-badge--info"><%= user.customers.count %> customers</span>
                      <span class="rl-badge rl-badge--success"><%= user.deals.count %> deals</span>
                    </div>
                  </td>
                  <td style="text-align:right">
                    <% unless user == current_user %>
                      <button type="button" class="rl-btn rl-btn--ghost rl-btn--sm"
                              data-action="relay--user-admin#toggleActive"
                              data-relay--user-admin-id-param="<%= user.id %>"
                              data-active="<%= user.active? %>">
                        <%= user.active? ? "Deactivate" : "Activate" %>
                      </button>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="muted rl-sm" style="text-align:center;padding:var(--space-8)">There are no users in the system yet.</div>
      <% end %>
    </div>
  </div>
</div>
