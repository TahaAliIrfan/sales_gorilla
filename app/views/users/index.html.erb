<% role_pill = lambda do |user|
     if user.admin?
       ['ADMIN', 'color:#059669;border-color:rgba(5,150,105,.35)']
     elsif user.manager?
       ['MANAGER', 'color:#0D9488;border-color:rgba(13,148,136,.3)']
     else
       ['ASSOCIATE', 'color:#64748B;border-color:rgba(100,116,139,.3)']
     end
   end %>

<div class="px-4 sm:px-6 lg:px-8 py-8 min-h-screen max-w-[1240px] mx-auto">

  <!-- Header -->
  <div class="mb-7 flex items-end justify-between">
    <div>
      <div class="cb-eyebrow mb-1">overview // user_management</div>
      <h1 class="text-[26px] font-bold tracking-tight text-[#0F172A]">User Management</h1>
    </div>
    <div class="cb-mono text-[11px] text-[#94A3B8] hidden sm:block"><%= @users.size %> ACCOUNTS</div>
  </div>

  <% if notice.present? %>
    <div class="mb-5 cb-panel px-4 py-3 text-[13px]" style="border-color:rgba(5,150,105,.35);color:#059669;"><%= notice %></div>
  <% end %>

  <!-- Stats strip -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="cb-panel p-5">
      <div class="cb-eyebrow">total_users</div>
      <div class="cb-mono text-[30px] font-semibold text-[#0F172A] mt-1.5 leading-none"><%= @users.size %></div>
    </div>
    <div class="cb-panel p-5">
      <div class="cb-eyebrow">admins</div>
      <div class="cb-mono text-[30px] font-semibold text-[#059669] mt-1.5 leading-none"><%= @users.count(&:admin?) %></div>
    </div>
    <div class="cb-panel p-5">
      <div class="cb-eyebrow">managers</div>
      <div class="cb-mono text-[30px] font-semibold text-[#0D9488] mt-1.5 leading-none"><%= @users.count(&:manager?) %></div>
    </div>
    <div class="cb-panel p-5">
      <div class="cb-eyebrow">associates</div>
      <div class="cb-mono text-[30px] font-semibold text-[#0F172A] mt-1.5 leading-none"><%= @users.count { |u| !u.admin? && !u.manager? } %></div>
    </div>
  </div>

  <!-- Roster -->
  <div class="cb-panel overflow-hidden">
    <div class="px-5 py-4 border-b border-[#E9ECF1] flex items-center justify-between">
      <span class="cb-eyebrow">roster // roles &amp; access</span>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead>
          <tr class="border-b border-[#E9ECF1] bg-[#F8FAFC] text-left">
            <th class="px-5 py-3 text-[#94A3B8]">User</th>
            <th class="px-5 py-3 text-[#94A3B8]">Role</th>
            <th class="px-5 py-3 text-[#94A3B8]">Status</th>
            <th class="px-5 py-3 text-[#94A3B8]">Book</th>
            <th class="px-5 py-3 text-[#94A3B8] text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr class="border-b border-[#EEF0F3] last:border-0 hover:bg-[#059669]/[.03] transition-colors" data-user-id="<%= user.id %>">
              <!-- User -->
              <td class="px-5 py-4 whitespace-nowrap">
                <div class="flex items-center gap-3">
                  <div class="h-9 w-9 rounded-lg grid place-items-center cb-mono text-[12px] font-semibold shrink-0
                              <%= user.active? ? 'bg-[#0D9488]/15 text-[#0D9488]' : 'bg-[#F1F5F9] text-[#94A3B8]' %>">
                    <%= (user.name.presence || user.email).first.upcase %>
                  </div>
                  <div class="min-w-0">
                    <div class="text-[13.5px] font-medium text-[#0F172A]">
                      <%= link_to (user.name.presence || user.email), user_path(user), class: "hover:text-[#059669] transition-colors" %>
                      <% if user == current_user %><span class="cb-mono text-[9.5px] text-[#94A3B8] ml-1">YOU</span><% end %>
                    </div>
                    <div class="cb-mono text-[10.5px] text-[#94A3B8] truncate"><%= user.email %></div>
                  </div>
                </div>
              </td>

              <!-- Role -->
              <td class="px-5 py-4 whitespace-nowrap">
                <% label, style = role_pill.call(user) %>
                <div class="flex items-center gap-2.5">
                  <span class="cb-pill" style="<%= style %>"><%= label %></span>
                  <select
                    class="role-selector rounded-md bg-[#FFFFFF] border border-[#DCE0E6] text-[12px] text-[#334155] py-1 pl-2 pr-7 focus:outline-none focus:border-[#059669]"
                    data-user-id="<%= user.id %>"
                    data-current-role="<%= user.admin? ? 'admin' : (user.manager? ? 'manager' : 'associate') %>"
                    <%= 'disabled' if user == current_user %>>
                    <% @roles.each do |role| %>
                      <option value="<%= role[:key] %>"
                        <%= 'selected' if (role[:key] == 'admin' && user.admin?) || (role[:key] == 'manager' && user.manager?) || (role[:key] == 'associate' && !user.admin? && !user.manager?) %>>
                        <%= role[:name] %>
                      </option>
                    <% end %>
                  </select>
                </div>
              </td>

              <!-- Status -->
              <td class="px-5 py-4 whitespace-nowrap">
                <% if user.active? %>
                  <span class="cb-pill" style="color:#059669;border-color:rgba(5,150,105,.35)">● ACTIVE</span>
                <% else %>
                  <span class="cb-pill" style="color:#E11D48;border-color:rgba(225,29,72,.3)">○ INACTIVE</span>
                <% end %>
              </td>

              <!-- Book of business -->
              <td class="px-5 py-4 whitespace-nowrap">
                <div class="cb-mono text-[11.5px] text-[#64748B]">
                  <span class="text-[#0D9488]"><%= @customer_counts[user.id] || 0 %></span> leads ·
                  <span class="text-[#059669]"><%= @deal_counts[user.id] || 0 %></span> deals
                </div>
              </td>

              <!-- Actions -->
              <td class="px-5 py-4 whitespace-nowrap text-right">
                <% if user != current_user %>
                  <div class="inline-flex items-center gap-1.5">
                    <% if user.manager? %>
                      <%= link_to manage_associates_user_path(user),
                            class: "px-2.5 py-1.5 rounded-md border border-[#DCE0E6] text-[11.5px] text-[#64748B] hover:text-[#0D9488] hover:border-[#0D9488]/50 transition-colors" do %>
                        Team
                      <% end %>
                    <% end %>
                    <button
                      class="toggle-active-btn px-2.5 py-1.5 rounded-md border border-[#DCE0E6] text-[11.5px] transition-colors
                             <%= user.active? ? 'text-[#64748B] hover:text-[#D97706] hover:border-[#D97706]/50' : 'text-[#64748B] hover:text-[#059669] hover:border-[#059669]/50' %>"
                      data-user-id="<%= user.id %>"
                      data-active="<%= user.active? %>">
                      <%= user.active? ? 'Deactivate' : 'Activate' %>
                    </button>
                    <button
                      class="remove-user-btn px-2.5 py-1.5 rounded-md border border-[#DCE0E6] text-[11.5px] text-[#64748B] hover:text-[#E11D48] hover:border-[#E11D48]/50 transition-colors"
                      data-user-id="<%= user.id %>"
                      data-user-name="<%= user.name.presence || user.email %>"
                      data-lead-count="<%= @customer_counts[user.id] || 0 %>">
                      Delete
                    </button>
                  </div>
                <% else %>
                  <span class="cb-mono text-[10px] text-[#94A3B8]">CURRENT USER</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @users.empty? %>
      <div class="px-6 py-12 text-center text-[13px] text-[#94A3B8]">No users in the system yet.</div>
    <% end %>
  </div>
</div>

<!-- Remove user modal -->
<div id="remove-user-modal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center p-4">
  <div class="cb-panel w-full max-w-md p-6" style="border-color:rgba(225,29,72,.3);">
    <div class="cb-eyebrow mb-3" style="color:#E11D48;">delete_user // reassign_leads</div>
    <h3 class="text-[18px] font-bold text-[#0F172A]">
      Delete <span id="remove-user-name" class="text-[#E11D48]"></span>?
    </h3>
    <p class="text-[13px] text-[#64748B] mt-2 leading-relaxed">
      They own <span id="remove-lead-count" class="cb-mono text-[#0D9488]">0</span> leads.
      Choose who inherits them — their open tasks move too, their roles are revoked,
      and they can no longer sign in. Call recordings and deal history stay attributed to them.
    </p>

    <div class="mt-4">
      <label class="cb-eyebrow block mb-1.5">reassign_leads_to</label>
      <select id="reassign-target"
              class="block w-full rounded-md bg-[#FFFFFF] border border-[#D5DAE1] text-[13px] text-[#0F172A] py-2.5 px-3 focus:outline-none focus:border-[#059669]">
        <% @users.select(&:active?).each do |u| %>
          <option value="<%= u.id %>" data-user-id="<%= u.id %>"><%= u.name.presence || u.email %><%= ' (you)' if u == current_user %></option>
        <% end %>
      </select>
    </div>

    <div class="flex justify-end gap-2.5 mt-6">
      <button type="button" id="cancel-remove-user"
              class="px-4 py-2 rounded-md border border-[#D5DAE1] text-[13px] text-[#334155] hover:bg-[#F1F5F9] transition-colors">
        Cancel
      </button>
      <button type="button" id="confirm-remove-user"
              class="px-4 py-2 rounded-md text-[13px] font-semibold text-[#FFFFFF] transition-all"
              style="background:#E11D48;">
        Delete &amp; Reassign
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    // ----- Role changes -----
    document.querySelectorAll('.role-selector').forEach(select => {
      select.addEventListener('change', function(e) {
        const userId = this.dataset.userId;
        const currentRole = this.dataset.currentRole;
        const newRole = this.value;

        if (newRole === currentRole) return;

        if (!confirm(`Are you sure you want to change this user's role to ${newRole}?`)) {
          this.value = currentRole;
          return;
        }

        fetch(`/users/${userId}/update_role`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: JSON.stringify({ role_key: newRole })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            this.dataset.currentRole = newRole;
            showNotification(data.message, 'success');
            setTimeout(() => window.location.reload(), 1200);
          } else {
            this.value = currentRole;
            showNotification(data.message || 'Failed to update role', 'error');
          }
        })
        .catch(error => {
          this.value = currentRole;
          showNotification('An error occurred', 'error');
          console.error('Error:', error);
        });
      });
    });

    // ----- Activate / deactivate -----
    document.querySelectorAll('.toggle-active-btn').forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        const userId = this.dataset.userId;
        const isActive = this.dataset.active === 'true';
        const action = isActive ? 'deactivate' : 'activate';

        if (!confirm(`Are you sure you want to ${action} this user?`)) return;

        this.disabled = true;

        fetch(`/users/${userId}/toggle_active`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            showNotification(data.message, 'success');
            setTimeout(() => window.location.reload(), 1200);
          } else {
            this.disabled = false;
            showNotification(data.message || 'Failed to update status', 'error');
          }
        })
        .catch(error => {
          this.disabled = false;
          showNotification('An error occurred: ' + error.message, 'error');
        });
      });
    });

    // ----- Remove user (reassign leads first) -----
    const removeModal = document.getElementById('remove-user-modal');
    const reassignSelect = document.getElementById('reassign-target');
    let removeTargetId = null;

    document.querySelectorAll('.remove-user-btn').forEach(button => {
      button.addEventListener('click', function() {
        removeTargetId = this.dataset.userId;
        document.getElementById('remove-user-name').textContent = this.dataset.userName;
        document.getElementById('remove-lead-count').textContent = this.dataset.leadCount;

        // The user being removed can't inherit their own leads
        reassignSelect.querySelectorAll('option').forEach(opt => {
          opt.hidden = opt.value === removeTargetId;
          if (opt.hidden && opt.selected) reassignSelect.value = '';
        });
        if (!reassignSelect.value) {
          const firstVisible = reassignSelect.querySelector('option:not([hidden])');
          if (firstVisible) reassignSelect.value = firstVisible.value;
        }

        removeModal.classList.remove('hidden');
      });
    });

    document.getElementById('cancel-remove-user').addEventListener('click', () => {
      removeModal.classList.add('hidden');
      removeTargetId = null;
    });
    removeModal.addEventListener('click', (e) => {
      if (e.target === removeModal) {
        removeModal.classList.add('hidden');
        removeTargetId = null;
      }
    });

    document.getElementById('confirm-remove-user').addEventListener('click', function() {
      if (!removeTargetId) return;
      const reassignTo = reassignSelect.value;
      if (!reassignTo) {
        showNotification('Please choose a user to reassign leads to.', 'error');
        return;
      }

      this.disabled = true;
      this.textContent = 'Deleting…';

      fetch(`/users/${removeTargetId}/remove`, {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({ reassign_to_user_id: reassignTo })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          removeModal.classList.add('hidden');
          showNotification(data.message, 'success');
          setTimeout(() => window.location.reload(), 1500);
        } else {
          this.disabled = false;
          this.textContent = 'Delete & Reassign';
          showNotification(data.message || 'Failed to remove user', 'error');
        }
      })
      .catch(error => {
        this.disabled = false;
        this.textContent = 'Remove & Reassign';
        showNotification('An error occurred: ' + error.message, 'error');
      });
    });

    // ----- Toast -----
    function showNotification(message, type) {
      const colors = {
        success: 'border-[#059669] text-[#059669]',
        error: 'border-[#E11D48] text-[#E11D48]'
      };
      const notification = document.createElement('div');
      notification.className = `fixed top-4 right-4 bg-[#FFFFFF] border ${colors[type]} px-4 py-3 rounded-lg shadow-xl z-50 max-w-md text-[13px] font-medium`;
      notification.textContent = message;
      document.body.appendChild(notification);
      setTimeout(() => notification.remove(), 5000);
    }
  });
</script>
