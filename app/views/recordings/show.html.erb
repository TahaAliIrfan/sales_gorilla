<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
    <div>
      <h2 class="text-2xl font-semibold text-gray-900">Recording Details</h2>
      <p class="mt-1 text-sm text-gray-500">
        Call recording from <%= @recording.date&.strftime("%b %d, %Y %H:%M") %>
      </p>
    </div>
    <div>
      <%= link_to recordings_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Recordings
      <% end %>
    </div>
  </div>

  <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Recording Information -->
      <div class="bg-gray-50 p-4 rounded-lg">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Recording Information</h3>
        
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Date</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @recording.date&.strftime("%b %d, %Y %H:%M") %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Duration</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <%= pluralize(@recording.duration.to_i / 60, "minute") %> 
              <%= @recording.duration.to_i % 60 > 0 ? "#{@recording.duration.to_i % 60} seconds" : "" %>
            </dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Customer</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <%= link_to @recording.customer.name, customer_path(@recording.customer), class: "text-blue-600 hover:text-blue-900" %>
            </dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Caller</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @recording.user&.name || "Unknown" %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Recording SID</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @recording.sid %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Call SID</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @recording.call_sid %></dd>
          </div>
        </dl>
        
        <div class="mt-6 flex space-x-3">
          <%= link_to download_recording_path(@recording), class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
            <svg class="mr-2 -ml-1 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Recording
          <% end %>
        </div>
      </div>
      
      <!-- Audio Player -->
      <div class="bg-gray-50 p-4 rounded-lg">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Audio Player</h3>
        
        <% if @recording.audio_file.attached? %>
          <div class="w-full">
            <audio controls class="w-full">
              <source src="<%= rails_blob_url(@recording.audio_file) %>" type="audio/mpeg">
              Your browser does not support the audio element.
            </audio>
          </div>
        <% else %>
          <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M8.257 3.099c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm text-yellow-700">
                  Audio file not available
                </p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Transcript Section -->
    <div class="mt-8">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Transcript</h3>
      
      <% if @recording.transcribed? %>
        <div id="transcript-container" class="bg-gray-50 p-4 rounded-lg max-h-96 overflow-y-auto" data-controller="page-transcript" data-page-transcript-id-value="<%= @recording.id %>">
          <div class="text-center py-8">
            <svg class="animate-spin h-10 w-10 text-blue-600 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="mt-2 text-sm text-gray-500">Loading transcript...</p>
          </div>
        </div>
      <% else %>
        <div class="bg-gray-50 p-4 rounded-lg">
          <p class="text-sm text-gray-500 text-center py-6">
            Transcript is not available for this recording.
          </p>
        </div>
      <% end %>
    </div>
    
    <!-- AI Analysis Section -->
    <div class="mt-8">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-medium text-gray-900">AI Analysis</h3>
        <% if @recording.transcribed? && (@latest_analysis.nil? || @analyses.count < 3) %>
          <%= button_to recording_ai_analyses_path(@recording), method: :post, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            <%= @latest_analysis.nil? ? "Generate AI Analysis" : "Regenerate Analysis" %>
          <% end %>
        <% end %>
      </div>
      
      <% if @latest_analysis.present? %>
        <div class="bg-gray-50 p-4 rounded-lg">
          <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Summary</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @latest_analysis.summary %></dd>
            </div>
            
            <div class="sm:col-span-1">
              <dt class="text-sm font-medium text-gray-500">Interest Score</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <div class="flex items-center">
                  <% @latest_analysis.interest_score.to_i.times do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  <% end %>
                  <% (5 - @latest_analysis.interest_score.to_i).times do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  <% end %>
                  <span class="ml-2"><%= @latest_analysis.interest_score %>/5</span>
                </div>
              </dd>
            </div>
            
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Improvement Points</dt>
              <dd class="mt-1 text-sm text-gray-900 whitespace-pre-line"><%= @latest_analysis.improvement_points %></dd>
            </div>
            
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Next Steps</dt>
              <dd class="mt-1 text-sm text-gray-900 whitespace-pre-line"><%= @latest_analysis.next_steps %></dd>
            </div>
            
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Follow-up Message (WhatsApp/Text)</dt>
              <dd class="mt-1 text-sm text-gray-900 whitespace-pre-line bg-white p-3 border border-gray-200 rounded">
                <%= @latest_analysis.followup_message %>
                
                <div class="mt-3 flex">
                  <button onclick="copyToClipboard('<%= j(@latest_analysis.followup_message) %>')" class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                  </button>
                </div>
              </dd>
            </div>
            
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Follow-up Email</dt>
              <dd class="mt-1 text-sm text-gray-900 whitespace-pre-line bg-white p-3 border border-gray-200 rounded">
                <%= @latest_analysis.followup_email %>
                
                <div class="mt-3 flex">
                  <button onclick="copyToClipboard('<%= j(@latest_analysis.followup_email) %>')" class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                  </button>
                </div>
              </dd>
            </div>
          </dl>
          
          <% if @analyses.count > 1 %>
            <div class="mt-6 border-t border-gray-200 pt-4">
              <h4 class="text-sm font-medium text-gray-500">Previous Analyses</h4>
              <ul class="mt-2 space-y-2">
                <% @analyses.offset(1).each do |analysis| %>
                  <li>
                    <%= link_to recording_ai_analysis_path(@recording, analysis), class: "text-sm text-indigo-600 hover:text-indigo-900" do %>
                      Analysis from <%= analysis.created_at.strftime("%b %d, %Y %H:%M") %> 
                      (Interest Score: <%= analysis.interest_score %>/5)
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-gray-50 p-4 rounded-lg">
          <p class="text-sm text-gray-500 text-center py-6">
            <% if @recording.transcribed? %>
              No AI analysis has been generated yet. Click the "Generate AI Analysis" button to create one.
            <% else %>
              AI analysis requires a transcript. Once the transcript is available, you can generate an AI analysis.
            <% end %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(function() {
      // Show toast or notification
      alert('Copied to clipboard!');
    }, function(err) {
      console.error('Could not copy text: ', err);
    });
  }
</script> 