<% content_for :title, "WhatsApp Web Chat" %>
<% content_for :page_header, "WhatsApp Web Chat" %>

<div class="whatsapp-web-chat-container h-full" 
     data-controller="whatsapp-web-chat" 
     data-whatsapp-web-chat-api-base-url-value="/api/v1">
     
  <!-- Main Chat Interface -->
  <div class="h-full flex bg-gray-100">
    
    <!-- Sidebar - Customer Selection -->
    <div class="w-1/3 bg-white flex flex-col border-r border-gray-300">
      
      <!-- Header -->
      <div class="flex items-center justify-between px-4 py-3 bg-green-600 text-white">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-white bg-opacity-20 rounded-full flex items-center justify-center mr-3">
            <i class="fab fa-whatsapp text-xl text-white"></i>
          </div>
          <div>
            <h1 class="font-medium text-white">WhatsApp Web Chat</h1>
            <p class="text-xs text-white text-opacity-90">Select customer to chat</p>
          </div>
        </div>
      </div>

      <!-- Search Bar -->
      <div class="p-3 border-b bg-gray-50">
        <div class="relative">
          <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-500"></i>
          <input data-whatsapp-web-chat-target="searchInput"
                 data-action="input->whatsapp-web-chat#handleSearch"
                 type="text" 
                 placeholder="Search conversations..." 
                 class="w-full pl-10 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
        </div>
      </div>

      <!-- Chat List -->
      <div class="flex-1 overflow-y-auto" data-whatsapp-web-chat-target="chatListContainer">
        <!-- Loading State -->
        <div data-whatsapp-web-chat-target="chatListLoader" class="p-4">
          <div class="flex items-center justify-center">
            <i class="fas fa-spinner fa-spin text-green-600 mr-2"></i>
            <span class="text-gray-600">Loading conversations...</span>
          </div>
        </div>
        
        <!-- Chat List Items -->
        <div data-whatsapp-web-chat-target="chatList" class="hidden">
          <!-- Chat items will be inserted here -->
        </div>

        <!-- No Chats -->
        <div data-whatsapp-web-chat-target="noChats" 
             class="hidden p-8 text-center text-gray-500">
          <i class="fas fa-comments text-4xl mb-4 text-gray-300"></i>
          <h3 class="font-medium text-gray-700 mb-2">No conversations yet</h3>
          <p class="text-sm">Start a conversation to see it here</p>
        </div>

        <!-- Chat Loading Error -->
        <div data-whatsapp-web-chat-target="chatError" 
             class="hidden p-4 bg-red-50 border border-red-200 m-4 rounded-lg">
          <div class="flex items-center text-red-700">
            <i class="fas fa-exclamation-triangle mr-2"></i>
            <span data-whatsapp-web-chat-target="chatErrorMessage">Error loading conversations</span>
          </div>
        </div>

        <!-- Load More Button -->
        <div data-whatsapp-web-chat-target="loadMoreContainer" 
             class="hidden p-4 text-center border-t">
          <button data-whatsapp-web-chat-target="loadMoreButton"
                  data-action="click->whatsapp-web-chat#loadMoreChats"
                  class="text-green-600 hover:text-green-700 text-sm font-medium">
            <i class="fas fa-chevron-down mr-1"></i>
            Load more conversations
          </button>
        </div>
      </div>
      
    </div>

    <!-- Chat Area -->
    <div class="flex-1 flex flex-col">
      
      <!-- Chat Header -->
      <div data-whatsapp-web-chat-target="chatHeader" 
           class="hidden flex items-center justify-between px-4 py-3 bg-gray-50 border-b">
        <div class="flex items-center">
          <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center mr-3">
            <i class="fas fa-user text-white"></i>
          </div>
          <div>
            <h3 data-whatsapp-web-chat-target="customerName" class="font-medium text-gray-900">Customer Name</h3>
            <p class="text-xs text-gray-500">WhatsApp Chat</p>
          </div>
        </div>
        <div class="flex items-center space-x-1">
          <button data-whatsapp-web-chat-target="refreshButton"
                  data-action="click->whatsapp-web-chat#refresh"
                  class="p-2 hover:bg-gray-200 rounded-full transition-colors" 
                  title="Refresh Messages">
            <i class="fas fa-sync text-gray-600"></i>
          </button>
        </div>
      </div>

      <!-- Welcome Screen -->
      <div id="welcomeScreen" class="flex-1 flex items-center justify-center bg-gray-50">
        <div class="text-center max-w-md mx-auto px-8">
          <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-green-100 flex items-center justify-center">
            <i class="fab fa-whatsapp text-4xl text-green-600"></i>
          </div>
          <h2 class="text-2xl font-light text-gray-700 mb-3">WhatsApp Web Chat</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Select a customer from the sidebar to start chatting. Send and receive WhatsApp messages directly from your CRM.
          </p>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="flex items-center justify-center mb-4">
              <div class="w-12 h-12 rounded-full bg-green-600 flex items-center justify-center">
                <i class="fas fa-comments text-white text-lg"></i>
              </div>
            </div>
            <h3 class="font-medium text-gray-800 mb-2">Real-time Messaging</h3>
            <p class="text-sm text-gray-600">
              Messages are automatically synced and updated in real-time for seamless communication.
            </p>
          </div>
        </div>
      </div>

      <!-- Messages Container -->
      <div id="messagesContainer" class="hidden flex-1 flex flex-col">
        
        <!-- Loader -->
        <div data-whatsapp-web-chat-target="loader" 
             class="hidden flex items-center justify-center p-4">
          <div class="flex items-center space-x-2">
            <i class="fas fa-spinner fa-spin text-green-600"></i>
            <span class="text-gray-600">Loading messages...</span>
          </div>
        </div>

        <!-- Error Display -->
        <div data-whatsapp-web-chat-target="error" 
             class="hidden bg-red-50 border border-red-200 p-4 m-4 rounded-lg">
          <div class="flex items-center">
            <i class="fas fa-exclamation-triangle text-red-500 mr-2"></i>
            <span data-whatsapp-web-chat-target="errorMessage" class="text-red-700">Error message</span>
          </div>
        </div>

        <!-- No Messages -->
        <div data-whatsapp-web-chat-target="noMessages" 
             class="hidden flex-1 flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
              <i class="fas fa-comments text-2xl text-green-600"></i>
            </div>
            <p class="text-gray-600 mb-2">No messages yet</p>
            <p class="text-sm text-gray-500 mb-3">Start the conversation by sending a message</p>
            <div class="text-xs text-gray-400 border-t pt-3">
              <i class="fas fa-paperclip mr-1"></i>
              Drag & drop files here or use the attach button to send media
            </div>
          </div>
        </div>

        <!-- Messages List -->
        <div data-whatsapp-web-chat-target="messages" 
             class="flex-1 overflow-y-auto px-4 py-4 bg-gray-50 scrollbar-thin">
          <div data-whatsapp-web-chat-target="messageContainer">
            <!-- Messages will be inserted here -->
          </div>
        </div>

        <!-- Message Input Area -->
        <div class="bg-white border-t p-4">
          
          <!-- Send Error -->
          <div data-whatsapp-web-chat-target="sendError" 
               class="hidden bg-red-50 border border-red-200 p-3 mb-4 rounded-lg">
            <div class="flex items-center">
              <i class="fas fa-exclamation-triangle text-red-500 mr-2"></i>
              <span data-whatsapp-web-chat-target="sendErrorMessage" class="text-red-700">Error message</span>
            </div>
          </div>

          <div class="flex items-end space-x-2">
            <!-- Attach Button -->
            <button data-whatsapp-web-chat-target="attachButton"
                    data-action="click->whatsapp-web-chat#showAttachMenu"
                    class="bg-gray-500 text-white p-3 rounded-lg hover:bg-gray-600 transition-colors"
                    title="Attach File">
              <i class="fas fa-paperclip"></i>
            </button>

            <!-- Message Input -->
            <div class="flex-1 relative">
              <textarea data-whatsapp-web-chat-target="messageInput"
                        data-action="keypress->whatsapp-web-chat#handleKeyPress"
                        placeholder="Type a message..." 
                        rows="1"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg resize-none focus:outline-none focus:ring-2 focus:ring-green-500 max-h-32"></textarea>
            </div>

            <!-- Send Button -->
            <button data-whatsapp-web-chat-target="sendButton"
                    data-action="click->whatsapp-web-chat#sendMessage"
                    class="bg-green-600 text-white p-3 rounded-lg hover:bg-green-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    title="Send Message">
              <i class="fas fa-paper-plane"></i>
            </button>
          </div>

          <!-- File Upload Input (Hidden) -->
          <input data-whatsapp-web-chat-target="fileInput"
                 data-action="change->whatsapp-web-chat#handleFileSelect"
                 type="file" 
                 class="hidden" 
                 accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.txt,.xlsx,.csv">

          <!-- Media Preview -->
          <div data-whatsapp-web-chat-target="mediaPreview" 
               class="hidden mt-4 p-4 bg-gray-50 border border-gray-200 rounded-lg">
            
            <!-- Preview Content -->
            <div class="flex items-start space-x-3">
              <!-- File Icon/Preview -->
              <div data-whatsapp-web-chat-target="mediaPreviewIcon" 
                   class="flex-shrink-0 w-16 h-16 bg-gray-200 rounded-lg flex items-center justify-center">
                <i class="fas fa-file text-gray-500 text-xl"></i>
              </div>
              
              <!-- File Info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-2">
                  <h4 data-whatsapp-web-chat-target="mediaFileName" 
                      class="font-medium text-gray-900 truncate">filename.jpg</h4>
                  <button data-whatsapp-web-chat-target="removeMediaButton"
                          data-action="click->whatsapp-web-chat#removeMedia"
                          class="text-red-500 hover:text-red-700 p-1">
                    <i class="fas fa-times"></i>
                  </button>
                </div>
                <p data-whatsapp-web-chat-target="mediaFileSize" 
                   class="text-sm text-gray-500 mb-3">1.2 MB</p>
                
                <!-- Caption Input -->
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Caption (optional)</label>
                  <input data-whatsapp-web-chat-target="mediaCaptionInput"
                         type="text" 
                         placeholder="Add a caption..."
                         class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
              </div>
            </div>

            <!-- Send Media Button -->
            <div class="mt-4 flex justify-end">
              <button data-whatsapp-web-chat-target="sendMediaButton"
                      data-action="click->whatsapp-web-chat#sendMediaMessage"
                      class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors disabled:opacity-50">
                <i class="fas fa-paper-plane mr-2"></i>
                Send Media
              </button>
            </div>
          </div>

          <!-- Sending Indicator -->
          <div data-whatsapp-web-chat-target="sendingIndicator" 
               class="hidden flex items-center justify-center mt-2">
            <div class="flex items-center space-x-2 text-green-600">
              <i class="fas fa-spinner fa-spin"></i>
              <span class="text-sm">Sending message...</span>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</div>

<!-- Custom Styles -->
<style>
  .whatsapp-web-chat-container {
    height: calc(100vh - 140px);
  }

  .scrollbar-thin::-webkit-scrollbar {
    width: 6px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(0,0,0,0.2);
    border-radius: 3px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(0,0,0,0.4);
  }

  /* Message bubbles */
  .message-bubble {
    max-width: 80%;
    word-wrap: break-word;
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 8px;
  }

  .message-outbound {
    background-color: #dcf8c6;
    margin-left: auto;
  }

  .message-inbound {
    background-color: #ffffff;
    margin-right: auto;
    border: 1px solid #e0e0e0;
  }

  /* Auto-resize textarea */
  textarea {
    min-height: 44px;
    max-height: 120px;
    transition: height 0.2s;
  }

  /* Drag & Drop styles */
  .drag-over {
    border-color: #16a34a !important;
    background-color: #f0fdf4 !important;
  }

  /* Media preview styles */
  .media-preview img {
    max-width: 200px;
    max-height: 200px;
  }

  /* File type icons */
  .file-icon {
    width: 64px;
    height: 64px;
  }
</style>