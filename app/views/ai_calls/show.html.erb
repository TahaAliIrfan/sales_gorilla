<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <div class="px-4 py-5 sm:px-6">
    <div class="flex justify-between items-start">
      <div>
        <h2 class="text-2xl font-semibold text-gray-900">AI Conversation Details</h2>
        <p class="mt-1 text-sm text-gray-500">Conversation ID: <%= @conversation.conversation_id %></p>
        <% if @conversation.customer %>
          <p class="mt-1 text-sm text-gray-500">Customer: <%= link_to @conversation.customer.name, customer_path(@conversation.customer), class: "text-blue-600 hover:text-blue-900" %></p>
        <% elsif @conversation.call_to %>
          <p class="mt-1 text-sm text-gray-500">Called: <%= @conversation.call_to %></p>
        <% end %>
        
        <!-- Call Status Badge -->
        <div class="mt-2">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
            <%= @conversation.status == 'completed' ? 'bg-green-100 text-green-800' : 
                @conversation.status == 'active' ? 'bg-blue-100 text-blue-800' : 
                @conversation.status == 'failed' ? 'bg-red-100 text-red-800' :
                'bg-gray-100 text-gray-800' %>">
            <svg class="w-1.5 h-1.5 mr-1.5" fill="currentColor" viewBox="0 0 8 8">
              <circle cx="4" cy="4" r="3" />
            </svg>
            <%= @conversation.status&.humanize || 'Unknown' %>
          </span>
          
          <% if @conversation.duration_seconds %>
            <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <%= @conversation.formatted_duration %>
            </span>
          <% end %>
        </div>
      </div>
      
      <div class="flex space-x-2">
        <% if @conversation.has_audio? %>
          <button data-controller="audio-player" 
                  data-audio-player-url-value="<%= audio_ai_call_path(@conversation.conversation_id) %>" 
                  data-action="click->audio-player#play" 
                  class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Play Audio
          </button>
        <% end %>
        
        <%= link_to ai_calls_path, class: "inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Conversations
        <% end %>
      </div>
    </div>
  </div>

  <!-- Call Details -->
  <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Call Information</h3>
    <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-3">
      <div>
        <dt class="text-sm font-medium text-gray-500">Date & Time</dt>
        <dd class="mt-1 text-sm text-gray-900">
          <%= @conversation.conversation_date&.strftime("%B %d, %Y") || @conversation.created_at.strftime("%B %d, %Y") %>
          <br>
          <span class="text-xs text-gray-500">
            <%= @conversation.conversation_date&.strftime("%I:%M %p") || @conversation.created_at.strftime("%I:%M %p") %>
          </span>
        </dd>
      </div>
      
      <div>
        <dt class="text-sm font-medium text-gray-500">Agent Number</dt>
        <dd class="mt-1 text-sm text-gray-900">
          <%= @conversation.call_from || 'N/A' %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-500">Customer Number</dt>
        <dd class="mt-1 text-sm text-gray-900">
          <%= @conversation.call_to || 'N/A' %>
        </dd>
      </div>
    </dl>
  </div>

  <!-- Main Transcript Section -->
  <% if @conversation.has_transcript? %>
  <div class="border-t border-gray-200">
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-medium text-gray-900 flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Conversation Transcript
          <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
            <%= @conversation.transcript.length %> messages
          </span>
        </h3>
        
        <% if @conversation.has_audio? %>
          <button data-controller="audio-player" 
                  data-audio-player-url-value="<%= audio_ai_call_path(@conversation.conversation_id) %>" 
                  data-action="click->audio-player#play" 
                  class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 9H4a1 1 0 00-1 1v4a1 1 0 001 1h1.586l4.707 4.707C10.923 20.337 12 19.939 12 19V5c0-.939-1.077-1.337-1.707-.707L5.586 9z" />
            </svg>
            Listen to Audio
          </button>
        <% end %>
      </div>

      <!-- Transcript Messages -->
      <div class="bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
        <div class="max-h-96 overflow-y-auto p-4 space-y-4">
          <% @conversation.transcript.each_with_index do |message, index| %>
            <div class="flex <%= message['role'] == 'user' ? 'justify-end' : 'justify-start' %> group">
              <div class="flex flex-col max-w-xs lg:max-w-lg">
                <!-- Message metadata -->
                <div class="text-xs text-gray-500 mb-1 <%= message['role'] == 'user' ? 'text-right' : 'text-left' %>">
                  <span class="font-medium <%= message['role'] == 'user' ? 'text-blue-600' : 'text-green-600' %>">
                    <%= message['role'] == 'user' ? 'Customer' : 'AI Agent' %>
                  </span>
                  <% if message['time_in_call_secs'] %>
                    • <%= Time.at(message['time_in_call_secs']).utc.strftime("%M:%S") %>
                  <% end %>
                </div>
                
                <!-- Message bubble -->
                <div class="px-4 py-2 rounded-lg shadow-sm <%= message['role'] == 'user' ? 'bg-blue-500 text-white' : 'bg-white border border-gray-200 text-gray-900' %>">
                  <p class="text-sm leading-relaxed">
                    <%= message['message'] %>
                  </p>
                  
                  <% if message['interrupted'] == true %>
                    <div class="text-xs mt-1 <%= message['role'] == 'user' ? 'text-blue-100' : 'text-gray-500' %> italic">
                      (Interrupted)
                    </div>
                  <% end %>
                </div>
                
                <!-- Additional message info (for debugging in development) -->
                <% if Rails.env.development? && message['source_medium'] %>
                  <div class="text-xs text-gray-400 mt-1 <%= message['role'] == 'user' ? 'text-right' : 'text-left' %>">
                    Source: <%= message['source_medium'] %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- Transcript summary if available -->
      <% if @conversation.raw_data.dig('transcript_summary') %>
      <div class="mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
        <h4 class="text-sm font-medium text-blue-900 mb-2">AI Summary</h4>
        <p class="text-sm text-blue-800">
          <%= @conversation.raw_data['transcript_summary'] %>
        </p>
      </div>
      <% end %>
    </div>
  </div>
  <% else %>
  <div class="border-t border-gray-200 px-4 py-8 text-center">
    <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <h3 class="mt-2 text-sm font-medium text-gray-900">No transcript available</h3>
    <p class="mt-1 text-sm text-gray-500">This conversation doesn't have a transcript yet.</p>
  </div>
  <% end %>

  <!-- Raw Data (Debug) -->
  <% if Rails.env.development? %>
  <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Raw Data (Debug)</h3>
    <div class="bg-gray-800 text-white p-4 rounded-lg overflow-auto max-h-60">
      <pre class="text-xs whitespace-pre-wrap"><%= JSON.pretty_generate(@conversation.raw_data) if @conversation.raw_data %></pre>
    </div>
  </div>
  <% end %>
</div>

<!-- Audio Player Modal -->
<div id="audio-player-modal" class="hidden fixed inset-0 bg-gray-500 bg-opacity-75 flex items-center justify-center z-50" data-controller="modal" data-action="click@window->modal#closeBackground keyup@window->modal#closeWithKeyboard">
  <div class="bg-white rounded-lg shadow-xl max-w-lg w-full p-6" data-modal-target="container">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-medium text-gray-900">AI Conversation Audio</h3>
      <button data-action="modal#close" class="text-gray-400 hover:text-gray-500">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div>
      <audio id="audio-player" controls class="w-full"></audio>
    </div>
  </div>
</div>