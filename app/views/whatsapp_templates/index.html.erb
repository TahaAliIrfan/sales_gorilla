<%# WhatsApp templates — relay DS. Read-only browse of approved Twilio Content
    templates. The Sync from Twilio button keeps the existing POST endpoint and
    its turbo_confirm prompt. %>
<% content_for :title, "WhatsApp templates — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">WhatsApp templates</div>
      <div class="pagehead__sub">
        Approved Twilio Content templates. Use these to message customers outside the 24-hour reply window.
        <% if @last_synced_at %>· Last synced <%= time_ago_in_words(@last_synced_at) %> ago.<% end %>
      </div>
    </div>
    <div class="pagehead__actions">
      <%= button_to sync_whatsapp_templates_path, method: :post,
            form: { data: { turbo_confirm: "Pull the latest approved templates from Twilio?" } },
            class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("refresh-cw", size: 15) %>Sync from Twilio
      <% end %>
    </div>
  </div>

  <div class="row" style="gap:var(--space-4);margin-bottom:var(--space-5)">
    <span class="rl-badge rl-badge--success"><%= @approved_count %> approved</span>
    <span class="rl-badge rl-badge--neutral"><%= @templates.size %> total stored</span>
  </div>

  <% if @templates.empty? %>
    <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
      <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-fg-3)"><%= relay_icon("message-circle", size: 22) %></span>
      <div class="rl-h4">No templates yet</div>
      <div class="muted rl-sm" style="margin-top:6px">Click "Sync from Twilio" to pull approved Content templates.</div>
    </div></div>
  <% else %>
    <div class="grid grid-2" style="gap:var(--space-4)">
      <% @templates.each do |t| %>
        <% approved = t.approval_status.to_s.downcase == "approved" %>
        <div class="sect">
          <div class="sect__head">
            <div class="grow" style="min-width:0">
              <div class="row" style="gap:8px">
                <b style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= t.friendly_name.presence || t.content_sid %></b>
                <% if t.has_media? %>
                  <span class="rl-badge rl-badge--info"><%= t.requires_media_upload? ? "Media (upload)" : "Media (fixed)" %></span>
                <% end %>
              </div>
              <div class="muted rl-sm mono" style="margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= t.content_sid %></div>
            </div>
            <span class="rl-badge <%= approved ? "rl-badge--success" : "rl-badge--warning" %>"><%= t.approval_status.presence&.titleize || "Unknown" %></span>
          </div>
          <div class="sect__body col" style="gap:var(--space-3)">
            <div class="row row--wrap muted rl-sm" style="gap:14px">
              <% if t.language.present? %><span>Language: <b style="color:var(--color-fg-1)"><%= t.language %></b></span><% end %>
              <% if t.category.present? %><span>Category: <b style="color:var(--color-fg-1)"><%= t.category %></b></span><% end %>
              <% if t.last_synced_at %><span>Synced: <b style="color:var(--color-fg-1)"><%= t.last_synced_at.strftime("%b %-d, %Y %H:%M") %></b></span><% end %>
            </div>

            <% if t.body.present? %>
              <div style="padding:10px 12px;background:var(--color-surface-2);border-radius:var(--radius-md);white-space:pre-wrap;word-break:break-word" class="rl-sm"><%= t.body %></div>
            <% end %>

            <% if t.variable_keys.any? %>
              <div>
                <div class="micro" style="margin-bottom:6px">Variables</div>
                <div class="row row--wrap" style="gap:6px">
                  <% t.variable_keys.each do |k| %>
                    <% is_media = t.media_variable_keys.include?(k) %>
                    <span class="rl-badge <%= is_media ? "rl-badge--info" : "rl-badge--neutral" %>">{{<%= k %>}}<%= is_media ? " (media)" : "" %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
