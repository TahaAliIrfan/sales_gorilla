<%#
  Landing page — green-airhive aesthetic (matches the app-wide .ah design
  language): light canvas, a dark "blueprint" hero panel, Geist type, mono
  eyebrows, emerald accent. Runs under the application layout (theme-carbon).
%>
<div class="lp-root">

  <!-- Atmosphere: light canvas + faint emerald glow -->
  <div aria-hidden="true" class="lp-glow"></div>

  <div style="position: relative; z-index: 1;">

    <!-- Navigation -->
    <nav class="lp-nav">
      <div class="lp-wrap" style="display:flex; align-items:center; justify-content:space-between; padding-top:18px; padding-bottom:18px;">
        <a href="/" style="display:flex; align-items:center; gap:11px; text-decoration:none;">
          <span style="display:inline-grid; place-items:center; width:34px; height:34px; border-radius:10px; background:linear-gradient(135deg,#059669,#10B981); color:#fff; font-family:'Geist Mono',monospace; font-weight:700; font-size:16px; box-shadow:0 6px 16px -6px rgba(5,150,105,.7);">T</span>
          <span style="font-size:18px; font-weight:600; letter-spacing:-.03em; color:#0F172A;">tecaudex<span style="color:#059669;">_crm</span></span>
        </a>
        <div style="display:flex; align-items:center; gap:16px;">
          <% if session[:user_id] %>
            <%= link_to "Dashboard", dashboard_path, class: "ah-ghost", style: "text-decoration:none;" %>
            <%= button_to "Sign out", signout_path, method: :get, class: "ah-pill-dark", style: "border:none; cursor:pointer;" %>
          <% else %>
            <%= link_to "Sign in", '/auth/google_oauth2', class: "ah-pill", style: "text-decoration:none;" %>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <main class="lp-wrap" style="padding-top:40px; padding-bottom:24px;">
      <section class="ah-panel lp-rise" style="--d:0ms; border-radius:32px; padding:0; overflow:hidden;">
        <div style="padding:clamp(40px,7vw,88px) clamp(24px,5vw,72px) clamp(36px,5vw,56px); text-align:center;">

          <div class="ah-eyebrow lp-rise" style="--d:80ms; color:var(--ah-mint); display:inline-block;">// enterprise crm platform</div>

          <h1 class="lp-rise" style="--d:140ms; margin:20px auto 0; max-width:16ch; font-family:'Geist',sans-serif; font-weight:500; letter-spacing:-.04em; line-height:1.02; font-size:clamp(2.6rem,7vw,5rem); color:var(--ah-on-dark);">
            Customer relationships,
            <span style="background:linear-gradient(100deg,#34D399,#6EE7B7); -webkit-background-clip:text; background-clip:text; color:transparent;">cultivated.</span>
          </h1>

          <p class="lp-rise" style="--d:200ms; margin:22px auto 0; max-width:52ch; font-size:clamp(15px,2vw,18px); line-height:1.6; color:var(--ah-muted-dk);">
            Manage contacts across phone, email &amp; WhatsApp, record and transcribe every call, and move deals through the pipeline — one modern CRM for teams that move fast.
          </p>

          <div class="lp-rise" style="--d:270ms; margin-top:34px; display:flex; flex-wrap:wrap; justify-content:center; gap:14px;">
            <% unless session[:user_id] %>
              <%= link_to '/auth/google_oauth2', class: "ah-pill lp-cta", style: "text-decoration:none; padding:.85rem 1.5rem; font-size:.95rem;" do %>
                <svg width="18" height="18" viewBox="0 0 24 24" style="margin-right:2px;">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#fff"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#fff"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#fff"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#fff"/>
                </svg>
                Sign in with Google
              <% end %>
              <% if Rails.env.development? %>
                <%= link_to "Dev login", dev_login_path, class: "lp-ghost-dark", style: "text-decoration:none;" %>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Trust strip inside the panel -->
        <div class="lp-rise lp-trust" style="--d:340ms;">
          <% [['multi_channel','phone · email · whatsapp'], ['ai_transcription','every call, analyzed'], ['role_based','admin · manager · associate']].each do |label, sub| %>
            <div class="lp-trust-cell">
              <div class="ah-mono" style="font-size:11px; color:var(--ah-mint); letter-spacing:.06em;"><%= label %></div>
              <div class="ah-mono" style="font-size:11px; color:rgba(238,251,244,.45); margin-top:3px;"><%= sub %></div>
            </div>
          <% end %>
        </div>
      </section>

      <!-- Features -->
      <div class="lp-features">
        <% [
             { n: '01', title: 'Multi-channel CRM', body: 'Contacts, conversations and history across phone, email, WhatsApp and LinkedIn — unified in one record.',
               path: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
             { n: '02', title: 'Call & record', body: 'Browser-based calling with AI transcription and analysis on every conversation, saved to the customer.',
               path: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z' },
             { n: '03', title: 'Pipeline & reports', body: 'Move deals through stages with role-based dashboards, reporting and follow-up scheduling built in.',
               path: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' }
           ].each_with_index do |f, i| %>
          <div class="ah-card lp-card lp-rise" style="--d:<%= 400 + i * 90 %>ms;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <span style="display:inline-grid; place-items:center; width:44px; height:44px; border-radius:13px; background:linear-gradient(135deg,rgba(5,150,105,.14),rgba(16,185,129,.07)); border:1px solid rgba(5,150,105,.20);">
                <svg width="22" height="22" fill="none" stroke="#047857" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= f[:path] %>"/>
                </svg>
              </span>
              <span class="ah-mono" style="font-size:12px; color:var(--ah-faint);"><%= f[:n] %></span>
            </div>
            <h3 style="margin:18px 0 8px; font-size:17px; font-weight:600; letter-spacing:-.02em; color:var(--ah-ink);"><%= f[:title] %></h3>
            <p style="margin:0; font-size:14px; line-height:1.55; color:var(--ah-muted);"><%= f[:body] %></p>
          </div>
        <% end %>
      </div>
    </main>

    <!-- Footer -->
    <footer class="lp-foot">
      <div class="lp-wrap" style="display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap;">
        <a href="/" style="display:flex; align-items:center; gap:9px; text-decoration:none;">
          <span style="display:inline-grid; place-items:center; width:26px; height:26px; border-radius:8px; background:linear-gradient(135deg,#059669,#10B981); color:#fff; font-family:'Geist Mono',monospace; font-weight:700; font-size:13px;">T</span>
          <span style="font-size:14px; font-weight:600; color:var(--ah-ink); letter-spacing:-.02em;">tecaudex_crm</span>
        </a>
        <p class="ah-mono" style="margin:0; font-size:11.5px; color:var(--ah-faint);">© <%= Date.current.year %> TECAUDEX · ALL RIGHTS RESERVED</p>
      </div>
    </footer>
  </div>
</div>

<style>
  .lp-root { position:relative; min-height:100vh; overflow:hidden; background:var(--ah-bg); }
  .lp-wrap { max-width:1120px; margin:0 auto; padding-left:24px; padding-right:24px; }
  .lp-glow {
    position:absolute; inset:0; z-index:0; pointer-events:none;
    background:
      radial-gradient(ellipse 60% 45% at 50% -8%, rgba(5,150,105,.14) 0%, transparent 55%),
      radial-gradient(ellipse 40% 40% at 90% 6%, rgba(16,185,129,.08) 0%, transparent 60%);
  }
  .lp-nav { position:sticky; top:0; z-index:50; background:rgba(246,247,249,.72); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border-bottom:1px solid var(--ah-line); }

  /* Trust strip inside the dark hero panel */
  .lp-trust { display:grid; grid-template-columns:1fr; border-top:1px solid rgba(238,251,244,.10); }
  .lp-trust-cell { padding:18px 24px; text-align:center; }
  .lp-trust-cell + .lp-trust-cell { border-top:1px solid rgba(238,251,244,.10); }

  .lp-features { display:grid; grid-template-columns:1fr; gap:18px; margin-top:20px; padding-bottom:88px; }
  .lp-card { position:relative; }

  /* Dark ghost button (on the hero panel) */
  .lp-ghost-dark {
    display:inline-flex; align-items:center; gap:.4rem; border-radius:9999px;
    padding:.85rem 1.4rem; font-size:.95rem; font-weight:500;
    color:var(--ah-on-dark); border:1px solid rgba(238,251,244,.22);
    background:rgba(238,251,244,.04); transition:background .2s ease, border-color .2s ease;
  }
  .lp-ghost-dark:hover { background:rgba(238,251,244,.09); border-color:rgba(238,251,244,.4); }

  /* Staggered entrance */
  .lp-rise { opacity:0; transform:translateY(14px); animation:lpRise .7s cubic-bezier(.2,.7,.2,1) forwards; animation-delay:var(--d,0ms); }
  @keyframes lpRise { to { opacity:1; transform:translateY(0); } }
  .lp-card { transition:transform .25s cubic-bezier(.2,.7,.2,1), box-shadow .25s ease, border-color .25s ease; }
  .lp-card:hover { transform:translateY(-4px); border-color:rgba(5,150,105,.35); box-shadow:0 22px 48px -28px rgba(5,150,105,.30); }

  @media (min-width:560px) { .lp-trust { grid-template-columns:repeat(3,1fr); } .lp-trust-cell + .lp-trust-cell { border-top:none; border-left:1px solid rgba(238,251,244,.10); } }
  @media (min-width:720px) { .lp-features { grid-template-columns:repeat(3,1fr); gap:22px; } }
  @media (prefers-reduced-motion:reduce) { .lp-rise { animation:none; opacity:1; transform:none; } .lp-card:hover { transform:none; } }
</style>
