<div class="max-w-4xl mx-auto px-4 py-6">
  <div data-controller="admin-assistant"
       data-admin-assistant-history-value="<%= @history.to_json %>"
       class="flex flex-col h-[calc(100vh-8rem)] bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">

    <!-- Header -->
    <div class="flex items-center gap-3 px-5 py-3 bg-white border-b border-gray-200">
      <div class="flex items-center justify-center h-9 w-9 rounded-lg bg-emerald-100 text-emerald-600">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-gray-900">CRM Assistant</p>
        <p class="text-xs text-gray-500">Ask across every lead, deal, message and call. Read-only, powered by your CRM data.</p>
      </div>
      <button type="button" data-action="admin-assistant#reset"
              class="text-xs font-medium text-gray-500 hover:text-gray-700 border border-gray-200 rounded-md px-2.5 py-1 hover:bg-gray-50">
        New chat
      </button>
    </div>

    <!-- Messages -->
    <div data-admin-assistant-target="messages" class="flex-1 overflow-y-auto px-5 py-4 space-y-4">
      <div data-admin-assistant-target="empty" class="h-full flex flex-col items-center justify-center text-center px-6">
        <div class="flex items-center justify-center h-12 w-12 rounded-full bg-emerald-100 text-emerald-600 mb-3">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 3v-3z" />
          </svg>
        </div>
        <p class="text-sm font-medium text-gray-700">What do you want to know?</p>
        <p class="text-xs text-gray-500 mt-1 max-w-md">I can search leads, find who's worth re-engaging, dig through call transcripts, and roll up your pipeline. Try a prompt below.</p>
      </div>
    </div>

    <!-- Composer -->
    <div class="border-t border-gray-200 bg-white px-4 py-3">
      <div class="flex flex-wrap items-center gap-2 mb-2.5">
        <button type="button" data-action="admin-assistant#ask" data-prompt="Which leads can I still reach out to? Give me the top 10 with the reason and best channel for each." class="px-3 py-1.5 rounded-full bg-emerald-50 border border-emerald-200 text-xs font-medium text-emerald-700 hover:bg-emerald-100">Who can I reach out to?</button>
        <button type="button" data-action="admin-assistant#ask" data-prompt="Show me our pipeline: deal counts and value by status, and won value by rep this year." class="px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs text-gray-700 hover:bg-gray-50 hover:border-gray-300">Pipeline summary</button>
        <button type="button" data-action="admin-assistant#ask" data-prompt="Which leads mentioned budget on a call? Give me their names and the snippet." class="px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs text-gray-700 hover:bg-gray-50 hover:border-gray-300">Budget mentions</button>
        <button type="button" data-action="admin-assistant#ask" data-prompt="Find high-scoring leads that have gone quiet in the last 30 days." class="px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs text-gray-700 hover:bg-gray-50 hover:border-gray-300">Quiet hot leads</button>
      </div>
      <form data-admin-assistant-target="form" data-action="submit->admin-assistant#send" class="flex items-end gap-2">
        <textarea data-admin-assistant-target="input"
                  data-action="keydown->admin-assistant#handleKeydown input->admin-assistant#autoGrow"
                  rows="1"
                  placeholder="Ask about leads, deals, calls, or who to follow up with…"
                  class="flex-1 resize-none rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 max-h-40"></textarea>
        <button type="submit" data-admin-assistant-target="sendButton"
                class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-emerald-600 text-white hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed shrink-0">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </form>
      <p class="mt-1.5 text-[11px] text-gray-400">AI can make mistakes and this is read-only. Verify anything important before acting on it.</p>
    </div>
  </div>
</div>
