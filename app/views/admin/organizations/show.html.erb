<div class="mb-6">
  <%= link_to "← Organizations", admin_organizations_path, class: "text-sm text-ink-soft hover:text-ink" %>
</div>

<div class="mb-8 flex items-center gap-4">
  <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl text-lg font-bold text-white" style="background: <%= @organization.primary_color.presence || 'var(--brand-primary)' %>"><%= @organization.initial %></span>
  <div>
    <h1 class="font-display text-2xl font-bold text-ink"><%= @organization.name %></h1>
    <p class="mono text-sm text-ink-soft"><%= @organization.subdomain %></p>
  </div>
</div>

<div class="grid gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 space-y-6">
    <%= render "shared/panel", eyebrow: "Details", title: "Organization" do %>
      <dl class="grid gap-2 text-sm sm:grid-cols-2">
        <% [
             [ "ID", @organization.id ],
             [ "Subdomain", @organization.subdomain ],
             [ "Created", @organization.created_at.strftime("%b %-d, %Y %H:%M") ],
             [ "Primary color", @organization.primary_color ]
           ].each do |k, v| %>
          <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
            <dt class="text-ink-soft"><%= k %></dt>
            <dd class="mono truncate text-xs text-ink" title="<%= v %>"><%= v %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>

    <%= render "shared/panel", eyebrow: "Access", title: "Members (#{@members.size})" do %>
      <% if @members.any? %>
        <ul class="divide-y divide-[var(--color-line)]">
          <% @members.each do |m| %>
            <li class="flex items-center justify-between py-2.5 text-sm">
              <%= link_to (m.user&.name.presence || m.user&.email || "—"), (m.user ? admin_user_path(m.user) : "#"), class: "min-w-0 truncate font-medium text-ink hover:text-[var(--brand-primary)]" %>
              <span class="text-xs text-ink-soft"><%= m.access_role&.name %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-ink-soft">No members.</p>
      <% end %>
    <% end %>
  </div>

  <div class="space-y-6">
    <%= render "shared/panel", eyebrow: "Data", title: "Records" do %>
      <dl class="space-y-2 text-sm">
        <% @stats.each do |label, count| %>
          <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
            <dt class="capitalize text-ink-soft"><%= label %></dt>
            <dd class="font-semibold text-ink"><%= count %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>

    <div class="rounded-xl bg-panel p-6 shadow-card ring-1 ring-[#dc2626]/30">
      <p class="micro" style="color:#991b1b">Danger zone</p>
      <p class="mt-1 font-display text-base font-bold text-ink">Delete organization</p>
      <p class="mt-2 text-sm text-ink-soft">This permanently deletes the organization and its memberships, roles, and feature settings. It can only succeed once leftover records (customers, deals, recordings) are gone.</p>
      <%= form_with url: admin_organization_path(@organization), method: :delete, class: "mt-4 space-y-3" do |f| %>
        <label class="block text-xs font-medium text-ink-soft">Type <span class="mono text-ink"><%= @organization.name %></span> to confirm</label>
        <%= f.text_field :confirm_name, autocomplete: "off", class: "w-full rounded-md border border-[var(--color-line)] bg-paper px-3 py-2 text-sm text-ink focus:border-[var(--brand-primary)] focus:outline-none" %>
        <%= f.submit "Delete organization",
              class: "w-full cursor-pointer rounded-md bg-[#dc2626] px-3 py-2 text-sm font-semibold text-white hover:bg-[#b91c1c]",
              data: { turbo_confirm: "Permanently delete #{@organization.name}? This cannot be undone." } %>
      <% end %>
    </div>
  </div>
</div>
