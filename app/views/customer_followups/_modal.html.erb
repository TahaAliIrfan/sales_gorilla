<%# Follow-up scheduling modal. Driven by followup_modal_controller (targets:
    modal/form/error/date/time/notes/calendar; actions: open/close/submit).
    Restyled to relay DS; the controller toggles .hidden which the shell defines. %>
<div id="followup-modal-container">
  <div data-followup-modal-target="modal" class="hidden rl-scrim" style="position:fixed;inset:0;padding:16px">
    <div class="rl-modal" style="max-width:480px;width:100%;padding:var(--space-5)">
      <div class="spread" style="margin-bottom:var(--space-4)">
        <div class="rl-h4">Schedule follow-up for <%= @customer.name %></div>
        <button type="button" class="rl-iconbtn" data-action="followup-modal#close" title="Close">
          <%= relay_icon("x", size: 18) %>
        </button>
      </div>

      <div data-followup-modal-target="error" class="hidden rl-sm"
           style="margin-bottom:var(--space-3);background:var(--color-danger-subtle);border:1px solid var(--color-danger-border);color:var(--color-danger-text);border-radius:var(--radius-md);padding:10px 12px"></div>

      <%= form_with url: customer_followups_path(@customer), method: :post,
            data: { followup_modal_target: "form", action: "submit->followup-modal#submit" },
            class: "col", html: { id: "followup-form", style: "gap:var(--space-4)" } do |form| %>
        <div class="grid grid-2">
          <div class="rl-field">
            <label class="rl-label" for="followup_date">Follow-up date</label>
            <%= form.date_field "followup[date]", data: { followup_modal_target: "date" }, class: "rl-input" %>
          </div>
          <div class="rl-field">
            <label class="rl-label" for="followup_time">Follow-up time</label>
            <%= form.time_field "followup[time]", data: { followup_modal_target: "time" }, class: "rl-input" %>
          </div>
        </div>

        <div class="rl-field">
          <label class="rl-label" for="followup_notes">Notes</label>
          <%= form.text_area "followup[notes]", data: { followup_modal_target: "notes" }, rows: 4, class: "rl-textarea" %>
          <p class="rl-help">Notes are included in the calendar event and the to-do.</p>
        </div>

        <% if current_user&.google_auth_configured? %>
          <label class="rl-check">
            <%= form.check_box "followup[add_to_calendar]", { checked: true, data: { followup_modal_target: "calendar" } } %>
            <span class="rl-box"><%= relay_icon("check", size: 13) %></span>
            <span>
              <span class="rl-label" style="display:inline">Add to Google Calendar</span>
              <span class="rl-help" style="display:block;margin-top:2px">Add this follow-up to your Google Calendar.</span>
            </span>
          </label>
        <% end %>

        <div class="row" style="justify-content:flex-end;gap:8px">
          <button type="button" data-action="followup-modal#close" class="rl-btn rl-btn--secondary">Cancel</button>
          <%= form.submit "Schedule follow-up", id: "follow-up-submit-btn", class: "rl-btn rl-btn--primary" %>
        </div>
      <% end %>

      <% if current_user && !current_user.google_auth_configured? %>
        <div class="rl-sm" style="margin-top:var(--space-4);background:var(--color-warning-subtle);border:1px solid var(--color-warning-border);color:var(--color-warning-text);border-radius:var(--radius-md);padding:12px 14px">
          <b>Google Calendar integration</b>
          <div style="margin-top:4px">Your Google account is not yet configured for calendar integration. The follow-up will be created as a task only.</div>
        </div>
      <% end %>
    </div>
  </div>
</div>
