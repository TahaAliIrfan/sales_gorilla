<!-- Followup Modal -->
<div id="followup-modal-container">
  <div 
    data-followup-modal-target="modal"
    class="hidden fixed inset-0 z-10 overflow-y-auto bg-gray-500 bg-opacity-75 flex items-center justify-center"
  >
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-auto p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-medium text-gray-900">Schedule Follow-up for <%= @customer.name %></h2>
        <button type="button" data-action="followup-modal#close" class="text-gray-400 hover:text-gray-500">
          <span class="sr-only">Close</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div data-followup-modal-target="error" class="hidden mb-4 bg-red-50 border border-red-200 text-red-800 rounded p-3 text-sm"></div>
      
      <%= form_with url: customer_followups_path(@customer), method: :post, data: { followup_modal_target: "form", action: "submit->followup-modal#submit" }, class: "space-y-4", id: "followup-form" do |form| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="followup_date" class="block text-sm font-medium text-gray-700 mb-1">Follow-up Date</label>
            <%= form.date_field 'followup[date]', data: { followup_modal_target: "date" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          </div>
          
          <div>
            <label for="followup_time" class="block text-sm font-medium text-gray-700 mb-1">Follow-up Time</label>
            <%= form.time_field 'followup[time]', data: { followup_modal_target: "time" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          </div>
        </div>
        
        <div>
          <label for="followup_notes" class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
          <%= form.text_area 'followup[notes]', data: { followup_modal_target: "notes" }, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <p class="text-sm text-gray-500 mt-1">Enter any notes about this follow-up that will be included in the calendar event and todo.</p>
        </div>
        
        <% if current_user && current_user.google_auth_configured? %>
        <div class="flex items-start mt-4">
          <div class="flex items-center h-5">
            <%= form.check_box 'followup[add_to_calendar]', { checked: true, data: { followup_modal_target: "calendar" }, class: "h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" } %>
          </div>
          <div class="ml-3 text-sm">
            <label for="followup_add_to_calendar" class="font-medium text-gray-700">Add to Google Calendar</label>
            <p class="text-gray-500">Check this option to add this follow-up to your Google Calendar</p>
          </div>
        </div>
        <% end %>
        
        <div class="flex items-center justify-between pt-4">
          <button 
            type="button" 
            data-action="followup-modal#close"
            class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          >
            Cancel
          </button>
          
          <%= form.submit "Schedule Follow-up", id: "follow-up-submit-btn", class: "inline-flex items-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
        </div>
      <% end %>
      
      <% if current_user && !current_user.google_auth_configured? %>
        <div class="mt-6 p-4 bg-yellow-50 rounded-md border border-yellow-200">
          <div class="flex">
            <div class="shrink-0">
              <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-yellow-800">Google Calendar Integration</h3>
              <div class="mt-2 text-sm text-yellow-700">
                <p>Your Google account is not yet configured for calendar integration. The follow-up will be created as a task only.</p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div> 