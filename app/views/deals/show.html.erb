<div class="min-h-screen bg-gray-50">
  <!-- Modern Header Section -->
  <div class="bg-white border-b border-gray-200 sticky top-0 z-10 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <%= link_to deals_path, class: "text-gray-600 hover:text-gray-900 flex items-center text-sm font-medium" do %>
          <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Deals
        <% end %>
        
        <div class="flex items-center space-x-3">
          <%= link_to edit_deal_path(@deal), class: "inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors font-medium text-sm shadow-sm" do %>
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit Deal
          <% end %>
          
          <% if current_user.admin? %>
            <%= button_to deal_path(@deal), method: :delete, data: { confirm: "Are you sure you want to delete this deal?" }, class: "inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium text-sm shadow-sm" do %>
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Delete
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Deal Header Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <h1 class="text-3xl font-bold text-gray-900"><%= @deal.title %></h1>
          <div class="flex flex-wrap gap-2 mt-3">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= @deal.status == 'active' ? 'bg-emerald-100 text-emerald-800' : @deal.status == 'won' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
              <%= @deal.status&.titleize %>
            </span>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
              <%= @deal.deal_stage.name %>
            </span>
          </div>
        </div>
        
        <div class="text-right ml-6">
          <div class="text-4xl font-bold text-green-600"><%= number_to_currency(@deal.amount) %></div>
          <% if @deal.expected_close_date %>
            <div class="text-sm text-gray-500 mt-2">
              Expected: <%= @deal.expected_close_date.strftime("%b %d, %Y") %>
            </div>
          <% end %>
          <% if @deal.closing_date %>
            <div class="text-sm text-gray-500 mt-1">
              Closed: <%= @deal.closing_date.strftime("%b %d, %Y") %>
            </div>
          <% end %>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
        <div class="flex items-center space-x-3">
          <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <div class="text-sm">
            <div class="text-gray-500">Customer</div>
            <div class="font-medium text-gray-900">
              <% if @deal.customer.present? %>
                <%= link_to @deal.customer.name, customer_path(@deal.customer), class: "text-emerald-600 hover:text-emerald-800" %>
              <% else %>
                <span class="text-gray-500">No customer assigned</span>
              <% end %>
            </div>
          </div>
        </div>
        
        <div class="flex items-center space-x-3">
          <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <div class="text-sm">
            <div class="text-gray-500">Owner</div>
            <div class="font-medium text-gray-900"><%= @deal.user.name %></div>
          </div>
        </div>
        
        <div class="flex items-center space-x-3">
          <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          <div class="text-sm">
            <div class="text-gray-500">Pipeline</div>
            <div class="font-medium text-gray-900"><%= @deal.pipeline.name %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions Section for Active Deals -->
    <% if @deal.status == 'active' %>
      <div class="bg-gradient-to-r from-emerald-50 to-emerald-50 rounded-xl shadow-sm border border-emerald-200 p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Deal Actions</h3>
        <div class="flex flex-wrap gap-3">
          <button type="button" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium shadow-sm" onclick="openModal('won')">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Mark as Won
          </button>
          
          <button type="button" class="inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium shadow-sm" onclick="openModal('lost')">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Mark as Lost
          </button>
        </div>
        
        <!-- Stage Update -->
        <div class="mt-4">
          <h4 class="text-sm font-medium text-gray-700 mb-2">Update Stage:</h4>
          <div class="flex flex-wrap gap-2">
            <% DealStage.all.each do |stage| %>
              <% if stage.id == @deal.deal_stage_id %>
                <span class="px-3 py-1 bg-emerald-600 text-white rounded-full text-sm font-medium">
                  <%= stage.name %>
                </span>
              <% else %>
                <%= button_to update_stage_deal_path(@deal, deal_stage_id: stage.id), method: :patch, class: "px-3 py-1 bg-white hover:bg-gray-50 text-gray-700 rounded-full text-sm font-medium border border-gray-300 transition-colors" do %>
                  <%= stage.name %>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Main Content Tabs -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" data-controller="tabs">
      <div class="border-b border-gray-200">
        <nav class="flex -mb-px overflow-x-auto" aria-label="Tabs">
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="overview" class="tab-button active group inline-flex items-center py-4 px-6 border-b-2 border-emerald-500 font-medium text-sm text-emerald-600 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
            Overview
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="customer" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Customer Info
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="activity" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Activity Timeline
          </button>
        </nav>
      </div>

      <!-- Tab Contents -->
      <div class="p-6">
        <!-- Overview Tab -->
        <div data-tabs-target="content" data-tab-id="overview" class="tab-content">
          <div class="space-y-6">
            <!-- Description with Inline Editor -->
            <div class="bg-emerald-50 rounded-lg p-6" data-controller="deal-description-editor" data-deal-description-editor-deal-id-value="<%= @deal.id %>">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-lg font-semibold text-gray-900">Description</h3>
                <button type="button" 
                        data-action="click->deal-description-editor#toggleEdit"
                        data-deal-description-editor-target="editButton"
                        class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                  <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                  </svg>
                  <span data-deal-description-editor-target="editButtonText">Edit</span>
                </button>
              </div>
              
              <!-- View Mode -->
              <div data-deal-description-editor-target="viewMode">
                <% if @deal.description.present? %>
                  <p class="text-gray-700 whitespace-pre-wrap"><%= @deal.description %></p>
                <% else %>
                  <p class="text-gray-500 italic">No description yet. Click "Edit" to add a description.</p>
                <% end %>
              </div>
              
              <!-- Edit Mode -->
              <div data-deal-description-editor-target="editMode" class="hidden">
                <textarea 
                  data-deal-description-editor-target="textarea"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-gray-700"
                  rows="6"
                  placeholder="Add a description for this deal..."><%= @deal.description %></textarea>
                
                <div class="flex items-center justify-end space-x-3 mt-3">
                  <button type="button" 
                          data-action="click->deal-description-editor#cancel"
                          class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                    Cancel
                  </button>
                  <button type="button" 
                          data-action="click->deal-description-editor#save"
                          data-deal-description-editor-target="saveButton"
                          class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-emerald-600 rounded-lg hover:bg-emerald-700 transition-colors">
                    <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Save Description
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Customer Info Tab -->
        <div data-tabs-target="content" data-tab-id="customer" class="tab-content hidden">
          <% if @deal.customer.present? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Contact Information</h3>
                <div class="space-y-4">
                  <div>
                    <div class="text-sm text-gray-600">Name</div>
                    <div class="font-medium text-gray-900 mt-1"><%= @deal.customer.name %></div>
                  </div>
                  
                  <div>
                    <div class="text-sm text-gray-600">Email</div>
                    <div class="font-medium text-gray-900 mt-1">
                      <% if @deal.customer.email.present? %>
                        <%= mail_to @deal.customer.email, @deal.customer.email, class: "text-emerald-600 hover:text-emerald-800" %>
                      <% else %>
                        <span class="text-gray-500">No email provided</span>
                      <% end %>
                    </div>
                  </div>
                  
                  <div>
                    <div class="text-sm text-gray-600">Phone</div>
                    <div class="font-medium text-gray-900 mt-1">
                      <% if @deal.customer.phone.present? %>
                        <div class="flex items-center space-x-2">
                          <span><%= @deal.customer.phone %></span>
                          <%= link_to calling_path(phone: @deal.customer.phone, customer_id: @deal.customer.id), class: "text-emerald-600 hover:text-emerald-800", title: "Call #{@deal.customer.name}" do %>
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                          <% end %>
                        </div>
                      <% else %>
                        <span class="text-gray-500">No phone provided</span>
                      <% end %>
                    </div>
                  </div>
                  
                  <% if @deal.customer.company.present? %>
                    <div>
                      <div class="text-sm text-gray-600">Company</div>
                      <div class="font-medium text-gray-900 mt-1"><%= @deal.customer.company %></div>
                    </div>
                  <% end %>
                </div>
              </div>
              
              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h3>
                <div class="space-y-3">
                  <%= link_to customer_path(@deal.customer), class: "flex items-center justify-between p-3 bg-white rounded-lg hover:shadow-md transition-shadow border border-gray-200" do %>
                    <span class="text-sm font-medium text-gray-900">View Customer Profile</span>
                    <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  <% end %>
                  
                  <% if @deal.customer.email.present? %>
                    <%= mail_to @deal.customer.email, class: "flex items-center justify-between p-3 bg-white rounded-lg hover:shadow-md transition-shadow border border-gray-200" do %>
                      <span class="text-sm font-medium text-gray-900">Send Email</span>
                      <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% else %>
            <div class="text-center py-12 bg-gray-50 rounded-lg">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No customer assigned</h3>
              <p class="mt-1 text-sm text-gray-500">Assign a customer to this deal to see their information</p>
              <div class="mt-6">
                <%= link_to "Edit Deal", edit_deal_path(@deal), class: "inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700" %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Activity Timeline Tab -->
        <div data-tabs-target="content" data-tab-id="activity" class="tab-content hidden">
          <% if @deal.deal_activities.any? %>
            <div class="flow-root">
              <ul class="-mb-8">
                <% @deal.deal_activities.order(created_at: :desc).each_with_index do |activity, index| %>
                  <li>
                    <div class="relative pb-8">
                      <% if index < @deal.deal_activities.size - 1 %>
                        <span class="absolute top-5 left-5 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                      <% end %>
                      <div class="relative flex items-start space-x-3">
                        <div>
                          <div class="relative px-1">
                            <div class="h-10 w-10 <%= activity_color_class(activity.action) %> rounded-full ring-8 ring-white flex items-center justify-center">
                              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                            </div>
                          </div>
                        </div>
                        <div class="min-w-0 flex-1 py-1.5">
                          <div class="text-sm text-gray-900 font-medium"><%= format_activity_action(activity.action) %></div>
                          <% if activity.details.present? %>
                            <p class="text-sm text-gray-500 mt-1"><%= activity.details %></p>
                          <% end %>
                          <div class="mt-2 text-xs text-gray-400">
                            <%= activity.created_at.strftime("%b %d, %Y at %I:%M %p") %>
                            • by <%= activity.user.name %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </li>
                <% end %>
                
                <!-- Deal Creation Entry -->
                <li>
                  <div class="relative pb-8">
                    <div class="relative flex items-start space-x-3">
                      <div>
                        <div class="relative px-1">
                          <div class="h-10 w-10 bg-green-500 rounded-full ring-8 ring-white flex items-center justify-center">
                            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                          </div>
                        </div>
                      </div>
                      <div class="min-w-0 flex-1 py-1.5">
                        <div class="text-sm text-gray-900 font-medium">Deal Created</div>
                        <p class="text-sm text-gray-500 mt-1">Deal was created in the system</p>
                        <div class="mt-2 text-xs text-gray-400">
                          <%= @deal.created_at.strftime("%b %d, %Y at %I:%M %p") %>
                          • by <%= @deal.user.name %>
                        </div>
                      </div>
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          <% else %>
            <div class="text-center py-12 bg-gray-50 rounded-lg">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No activities</h3>
              <p class="mt-1 text-sm text-gray-500">Activity history will appear here</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modals -->
<!-- Won Deal Modal -->
<div id="wonDealModal" class="fixed inset-0 bg-gray-800 bg-opacity-75 flex items-center justify-center z-50 hidden">
  <div class="bg-white rounded-lg shadow-xl p-6 w-full max-w-md">
    <h3 class="text-lg font-bold mb-4">Mark Deal as Won</h3>
    <%= form_with url: mark_as_won_deal_path(@deal), method: :patch, data: { turbo: false } do |form| %>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">Closing Date</label>
        <%= form.date_field :closing_date, class: "w-full rounded-md border-gray-300 shadow-sm p-2", value: Date.today.strftime('%Y-%m-%d') %>
      </div>
      <div class="flex justify-end space-x-3">
        <button type="button" class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" onclick="closeModal('won')">
          Cancel
        </button>
        <%= form.submit "Mark as Won", class: "bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded" %>
      </div>
    <% end %>
  </div>
</div>

<!-- Lost Deal Modal -->
<div id="lostDealModal" class="fixed inset-0 bg-gray-800 bg-opacity-75 flex items-center justify-center z-50 hidden">
  <div class="bg-white rounded-lg shadow-xl p-6 w-full max-w-md">
    <h3 class="text-lg font-bold mb-4">Mark Deal as Lost</h3>
    <%= form_with url: mark_as_lost_deal_path(@deal), method: :patch, data: { turbo: false } do |form| %>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">Closing Date</label>
        <%= form.date_field :closing_date, class: "w-full rounded-md border-gray-300 shadow-sm p-2", value: Date.today.strftime('%Y-%m-%d') %>
      </div>
      <div class="flex justify-end space-x-3">
        <button type="button" class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" onclick="closeModal('lost')">
          Cancel
        </button>
        <%= form.submit "Mark as Lost", class: "bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded" %>
      </div>
    <% end %>
  </div>
</div>

<style>
.tab-content {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.tab-button {
  transition: all 0.2s ease-in-out;
}

.tab-button:hover {
  transform: translateY(-1px);
}
</style>

<script>
  function openModal(type) {
    document.getElementById(type + 'DealModal').classList.remove('hidden');
  }
  
  function closeModal(type) {
    document.getElementById(type + 'DealModal').classList.add('hidden');
  }
</script>
