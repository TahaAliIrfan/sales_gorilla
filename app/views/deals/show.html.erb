<% content_for :title, "#{@deal.title || 'Deal'} — #{current_organization&.name}" %>

<div class="space-y-6">
  <%# === Top bar / breadcrumb === %>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <%= link_to deals_path, class: "inline-flex items-center gap-1.5 text-sm font-medium text-ink-soft transition hover:text-ink" do %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to deals
    <% end %>

    <div class="flex items-center gap-2">
      <%= link_to edit_deal_path(@deal),
            class: "inline-flex items-center gap-2 rounded-md px-3.5 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5",
            style: "background: var(--brand-primary)" do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg>
        Edit deal
      <% end %>
      <% if current_user.admin? %>
        <%= button_to deal_path(@deal),
              method: :delete,
              data: { confirm: "Delete this deal?" },
              form: { class: "inline-block" },
              class: "inline-flex items-center gap-2 rounded-md px-3.5 py-2 text-sm font-semibold text-[#c0492f] ring-1 ring-[#c0492f]/30 transition hover:bg-[#c0492f]/10" do %>
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
          Delete
        <% end %>
      <% end %>
    </div>
  </div>

  <%# === Hero card === %>
  <div class="rounded-xl bg-panel p-6 shadow-card ring-1 ring-[var(--color-line-2)]">
    <div class="flex flex-wrap items-start justify-between gap-6">
      <div class="min-w-0 flex-1">
        <p class="micro mb-2">Deal</p>
        <h1 class="font-display text-3xl font-bold leading-tight tracking-tight text-ink"><%= @deal.title.presence || "Untitled deal" %></h1>
        <div class="mt-3 flex flex-wrap gap-2">
          <% tone = @deal.status == "won" ? "ok" : (@deal.status == "lost" ? "bad" : "info") %>
          <%= render "shared/status_pill", label: (@deal.status || "active").titleize, tone: tone %>
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium"
                style="background: var(--brand-primary-soft); color: var(--brand-primary)">
            <%= @deal.deal_stage.name %>
          </span>
        </div>
      </div>

      <div class="text-right">
        <p class="micro">Amount</p>
        <p class="mono mt-1 text-4xl font-semibold leading-none" style="color: var(--brand-accent)">
          <%= number_to_currency(@deal.amount, precision: 0) %>
        </p>
        <% if @deal.expected_close_date %>
          <p class="mono mt-3 text-xs text-ink-soft">Expected: <%= @deal.expected_close_date.strftime("%b %-d, %Y") %></p>
        <% end %>
        <% if @deal.closing_date %>
          <p class="mono mt-1 text-xs text-ink-soft">Closed: <%= @deal.closing_date.strftime("%b %-d, %Y") %></p>
        <% end %>
      </div>
    </div>

    <%# Metadata strip %>
    <div class="mt-6 grid gap-4 border-t border-dashed border-[var(--color-line-2)] pt-5 sm:grid-cols-3">
      <div>
        <p class="micro mb-1">Customer</p>
        <% if @deal.customer.present? %>
          <%= link_to @deal.customer.name, customer_path(@deal.customer),
                class: "text-sm font-medium text-ink transition hover:text-accent" %>
        <% else %>
          <p class="text-sm text-ink-soft">No customer</p>
        <% end %>
      </div>
      <div>
        <p class="micro mb-1">Owner</p>
        <p class="text-sm font-medium text-ink"><%= @deal.user.name %></p>
      </div>
      <div>
        <p class="micro mb-1">Pipeline</p>
        <p class="text-sm font-medium text-ink"><%= @deal.pipeline.name %></p>
      </div>
    </div>
  </div>

  <%# === Active deal actions === %>
  <% if @deal.status == "active" %>
    <div class="rounded-xl p-5 ring-1 ring-[var(--color-line-2)]" style="background: var(--brand-primary-soft)">
      <p class="micro" style="color: var(--brand-primary)">Deal actions</p>

      <div class="mt-3 flex flex-wrap gap-2">
        <button type="button" onclick="openModal('won')"
                class="inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5"
                style="background: var(--color-accent)">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Mark as won
        </button>
        <button type="button" onclick="openModal('lost')"
                class="inline-flex items-center gap-2 rounded-md bg-paper px-4 py-2 text-sm font-semibold text-[#c0492f] ring-1 ring-[#c0492f]/30 transition hover:bg-[#c0492f]/10">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
          Mark as lost
        </button>
      </div>

      <div class="mt-5">
        <p class="micro mb-2">Move to stage</p>
        <div class="flex flex-wrap gap-1.5">
          <% DealStage.all.each do |stage| %>
            <% if stage.id == @deal.deal_stage_id %>
              <span class="mono inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold text-white"
                    style="background: var(--brand-primary)"><%= stage.name %></span>
            <% else %>
              <%= button_to stage.name, update_stage_deal_path(@deal, deal_stage_id: stage.id),
                    method: :patch,
                    form: { class: "inline-block" },
                    class: "mono inline-flex items-center rounded-full bg-paper px-3 py-1 text-xs font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]" %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# === Tabbed content === %>
  <div class="overflow-hidden rounded-xl bg-panel shadow-card ring-1 ring-[var(--color-line-2)]" data-controller="tabs">
    <nav class="flex overflow-x-auto border-b border-[var(--color-line)]" aria-label="Tabs">
      <% [
        [ "overview", "Overview",         "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z", true  ],
        [ "customer", "Customer info",    "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",                                                                                                                                                                                                                                                                                                                                                                                                                                              false ],
        [ "activity", "Activity timeline","M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",                                                                                                                                                                                                                                                                                                                                                                                                                                                                       false ]
      ].each do |id, label, path, active| %>
        <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="<%= id %>"
                class="tab-button <%= 'active' if active %> inline-flex items-center gap-2 whitespace-nowrap border-b-2 px-5 py-3.5 text-sm font-medium transition <%= active ? 'border-[var(--brand-primary)] text-ink' : 'border-transparent text-ink-soft hover:border-[var(--color-line-2)] hover:text-ink' %>">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="<%= path %>"/></svg>
          <%= label %>
        </button>
      <% end %>
    </nav>

    <div class="p-6">
      <%# Overview === %>
      <div data-tabs-target="content" data-tab-id="overview" class="tab-content">
        <div class="rounded-xl p-5 ring-1 ring-[var(--color-line-2)]" style="background: var(--brand-primary-soft)"
             data-controller="deal-description-editor" data-deal-description-editor-deal-id-value="<%= @deal.id %>">
          <div class="flex items-center justify-between">
            <p class="micro" style="color: var(--brand-primary)">Description</p>
            <button type="button"
                    data-action="click->deal-description-editor#toggleEdit"
                    data-deal-description-editor-target="editButton"
                    class="inline-flex items-center gap-1.5 rounded-md bg-paper px-3 py-1.5 text-xs font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg>
              <span data-deal-description-editor-target="editButtonText">Edit</span>
            </button>
          </div>

          <div data-deal-description-editor-target="viewMode" class="mt-3">
            <% if @deal.description.present? %>
              <p class="whitespace-pre-wrap text-sm leading-relaxed text-ink"><%= @deal.description %></p>
            <% else %>
              <p class="text-sm italic text-ink-soft">No description yet. Click "Edit" to add one.</p>
            <% end %>
          </div>

          <div data-deal-description-editor-target="editMode" class="mt-3 hidden">
            <textarea data-deal-description-editor-target="textarea"
                      rows="6"
                      class="block w-full rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]"
                      placeholder="Add a description for this deal…"><%= @deal.description %></textarea>
            <div class="mt-3 flex items-center justify-end gap-2">
              <button type="button" data-action="click->deal-description-editor#cancel"
                      class="rounded-md px-3.5 py-1.5 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
                Cancel
              </button>
              <button type="button" data-action="click->deal-description-editor#save"
                      data-deal-description-editor-target="saveButton"
                      class="inline-flex items-center gap-1.5 rounded-md px-3.5 py-1.5 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5"
                      style="background: var(--brand-primary)">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
                Save
              </button>
            </div>
          </div>
        </div>
      </div>

      <%# Customer === %>
      <div data-tabs-target="content" data-tab-id="customer" class="tab-content hidden">
        <% if @deal.customer.present? %>
          <div class="grid gap-5 md:grid-cols-2">
            <div class="rounded-xl p-5 ring-1 ring-[var(--color-line-2)]" style="background: var(--brand-primary-soft)">
              <p class="micro mb-4" style="color: var(--brand-primary)">Contact information</p>
              <dl class="space-y-4 text-sm">
                <div>
                  <dt class="text-xs text-ink-soft">Name</dt>
                  <dd class="mt-1 font-medium text-ink"><%= @deal.customer.name %></dd>
                </div>
                <div>
                  <dt class="text-xs text-ink-soft">Email</dt>
                  <dd class="mt-1 font-medium text-ink">
                    <% if @deal.customer.email.present? %>
                      <%= mail_to @deal.customer.email, @deal.customer.email,
                            class: "transition hover:text-accent" %>
                    <% else %>
                      <span class="text-ink-soft">No email</span>
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-xs text-ink-soft">Phone</dt>
                  <dd class="mono mt-1 flex items-center gap-2 font-medium text-ink">
                    <% if @deal.customer.phone.present? %>
                      <%= @deal.customer.phone %>
                      <%= link_to calling_path(phone: @deal.customer.phone, customer_id: @deal.customer.id),
                            title: "Call #{@deal.customer.name}",
                            class: "text-ink-soft transition hover:text-accent" do %>
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
                      <% end %>
                    <% else %>
                      <span class="text-ink-soft">No phone</span>
                    <% end %>
                  </dd>
                </div>
                <% if @deal.customer.company.present? %>
                  <div>
                    <dt class="text-xs text-ink-soft">Company</dt>
                    <dd class="mt-1 font-medium text-ink"><%= @deal.customer.company %></dd>
                  </div>
                <% end %>
              </dl>
            </div>

            <div class="rounded-xl p-5 ring-1 ring-[var(--color-line-2)]" style="background: var(--brand-primary-soft)">
              <p class="micro mb-4" style="color: var(--brand-primary)">Quick actions</p>
              <div class="space-y-2">
                <%= link_to customer_path(@deal.customer),
                      class: "flex items-center justify-between rounded-md bg-paper px-4 py-3 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]" do %>
                  View customer profile
                  <svg class="h-4 w-4 text-ink-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m9 5 7 7-7 7"/></svg>
                <% end %>
                <% if @deal.customer.email.present? %>
                  <%= mail_to @deal.customer.email,
                        class: "flex items-center justify-between rounded-md bg-paper px-4 py-3 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]" do %>
                    Send email
                    <svg class="h-4 w-4 text-ink-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="rounded-xl py-12 text-center ring-1 ring-[var(--color-line-2)]" style="background: var(--brand-primary-soft)">
            <p class="font-display text-base font-semibold text-ink">No customer assigned</p>
            <p class="mt-1 text-sm text-ink-soft">Assign a customer to see their info here.</p>
            <%= link_to "Edit deal", edit_deal_path(@deal),
                  class: "mt-5 inline-flex items-center rounded-md px-4 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5",
                  style: "background: var(--brand-primary)" %>
          </div>
        <% end %>
      </div>

      <%# Activity timeline === %>
      <div data-tabs-target="content" data-tab-id="activity" class="tab-content hidden">
        <% if @deal.deal_activities.any? %>
          <ol class="relative space-y-6 border-l-2 border-[var(--color-line)] pl-6">
            <% @deal.deal_activities.order(created_at: :desc).each do |activity| %>
              <li class="relative">
                <span class="absolute -left-[34px] grid h-6 w-6 place-items-center rounded-full bg-panel ring-2 ring-[var(--color-line-2)]"
                      style="color: var(--brand-primary)">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4" fill="currentColor"/></svg>
                </span>
                <p class="text-sm font-semibold text-ink"><%= format_activity_action(activity.action) %></p>
                <% if activity.details.present? %>
                  <p class="mt-1 text-sm text-ink-soft"><%= activity.details %></p>
                <% end %>
                <p class="mono mt-2 text-[11px] text-ink-soft/80">
                  <%= activity.created_at.strftime("%b %-d, %Y · %-I:%M %p") %> · by <%= activity.user.name %>
                </p>
              </li>
            <% end %>
            <li class="relative">
              <span class="absolute -left-[34px] grid h-6 w-6 place-items-center rounded-full bg-panel ring-2 ring-[var(--color-line-2)]"
                    style="color: var(--brand-accent)">
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
              <p class="text-sm font-semibold text-ink">Deal created</p>
              <p class="mono mt-2 text-[11px] text-ink-soft/80">
                <%= @deal.created_at.strftime("%b %-d, %Y · %-I:%M %p") %> · by <%= @deal.user.name %>
              </p>
            </li>
          </ol>
        <% else %>
          <div class="rounded-xl py-12 text-center ring-1 ring-[var(--color-line-2)]" style="background: var(--brand-primary-soft)">
            <p class="font-display text-base font-semibold text-ink">No activity yet</p>
            <p class="mt-1 text-sm text-ink-soft">Activity history will appear here as the deal progresses.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# === Won / Lost modals === %>
<% [
  [ "won",  "Mark deal as won",  mark_as_won_deal_path(@deal),  "var(--color-accent)" ],
  [ "lost", "Mark deal as lost", mark_as_lost_deal_path(@deal), "#c0492f" ]
].each do |key, title, path, btn_color| %>
  <div id="<%= key %>DealModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 p-4">
    <div class="w-full max-w-md rounded-xl bg-panel p-6 shadow-lift ring-1 ring-[var(--color-line-2)]">
      <h3 class="font-display text-lg font-bold text-ink"><%= title %></h3>
      <%= form_with url: path, method: :patch, data: { turbo: false }, class: "mt-4" do |form| %>
        <label class="micro mb-1 block">Closing date</label>
        <%= form.date_field :closing_date,
              value: Date.today.strftime("%Y-%m-%d"),
              class: "mono block w-full rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink ring-1 ring-[var(--color-line-2)] focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]" %>
        <div class="mt-5 flex justify-end gap-2">
          <button type="button" onclick="closeModal('<%= key %>')"
                  class="rounded-md px-3.5 py-2 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
            Cancel
          </button>
          <%= form.submit title,
                class: "rounded-md px-4 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5 cursor-pointer",
                style: "background: #{btn_color}" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<style>
  .tab-content { animation: tabFadeIn 0.25s ease-out both; }
  @keyframes tabFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
</style>
<script>
  function openModal(type) {
    const el = document.getElementById(type + "DealModal");
    if (!el) return;
    el.classList.remove("hidden");
    el.classList.add("flex");
  }
  function closeModal(type) {
    const el = document.getElementById(type + "DealModal");
    if (!el) return;
    el.classList.add("hidden");
    el.classList.remove("flex");
  }
</script>
