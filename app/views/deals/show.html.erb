<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Deals", deals_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="p-6 border-b border-gray-200">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= @deal.title %></h1>
          <p class="text-gray-600 mt-1">
            <span class="font-medium">Customer:</span> 
            <% if @deal.customer.present? %>
              <%= link_to @deal.customer.name, customer_path(@deal.customer), class: "text-blue-600 hover:text-blue-800" %>
            <% else %>
              <span class="text-gray-500">No customer assigned</span>
            <% end %>
          </p>
        </div>
        <div class="text-right">
          <p class="text-2xl font-bold text-green-600"><%= number_to_currency(@deal.amount) %></p>
          <p class="text-sm text-gray-600">
            <% if @deal.expected_close_date %>
              Expected close: <%= @deal.expected_close_date.strftime("%B %d, %Y") %>
            <% end %>
          </p>
        </div>
      </div>
    </div>

    <div class="p-6 bg-gray-50 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">Current Stage: <span class="font-bold"><%= @deal.deal_stage.name %></span></h3>
        </div>
        <div class="flex space-x-2">
          <% if @deal.status == 'active' %>
            <!-- Mark as Won button with modal trigger -->
            <button type="button" class="bg-green-500 hover:bg-green-600 text-white py-2 px-4 rounded" onclick="openModal('won')">
              Mark as Won
            </button>
            
            <!-- Mark as Lost button with modal trigger -->
            <button type="button" class="bg-red-500 hover:bg-red-600 text-white py-2 px-4 rounded" onclick="openModal('lost')">
              Mark as Lost
            </button>
            
            <!-- Won Deal Modal -->
            <div id="wonDealModal" class="fixed inset-0 bg-gray-800 bg-opacity-75 flex items-center justify-center z-50 hidden">
              <div class="bg-white rounded-lg shadow-xl p-6 w-full max-w-md">
                <h3 class="text-lg font-bold mb-4">Mark Deal as Won</h3>
                <%= form_with url: mark_as_won_deal_path(@deal), method: :patch do |form| %>
                  <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Closing Date</label>
                    <%= form.date_field :closing_date, class: "w-full rounded-md border-gray-300 shadow-sm p-2", value: Date.today.strftime('%Y-%m-%d') %>
                  </div>
                  <div class="flex justify-end space-x-3">
                    <button type="button" class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" onclick="closeModal('won')">
                      Cancel
                    </button>
                    <%= form.submit "Mark as Won", class: "bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded" %>
                  </div>
                <% end %>
              </div>
            </div>
            
            <!-- Lost Deal Modal -->
            <div id="lostDealModal" class="fixed inset-0 bg-gray-800 bg-opacity-75 flex items-center justify-center z-50 hidden">
              <div class="bg-white rounded-lg shadow-xl p-6 w-full max-w-md">
                <h3 class="text-lg font-bold mb-4">Mark Deal as Lost</h3>
                <%= form_with url: mark_as_lost_deal_path(@deal), method: :patch do |form| %>
                  <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Closing Date</label>
                    <%= form.date_field :closing_date, class: "w-full rounded-md border-gray-300 shadow-sm p-2", value: Date.today.strftime('%Y-%m-%d') %>
                  </div>
                  <div class="flex justify-end space-x-3">
                    <button type="button" class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" onclick="closeModal('lost')">
                      Cancel
                    </button>
                    <%= form.submit "Mark as Lost", class: "bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% else %>
            <span class="px-4 py-2 rounded text-white <%= @deal.status == 'won' ? 'bg-green-500' : 'bg-red-500' %>">
              <%= @deal.status&.capitalize %>
            </span>
            <% if @deal.closing_date %>
              <span class="px-4 py-2 text-gray-600">
                Closed on: <%= @deal.closing_date.strftime("%B %d, %Y") %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>

      <% if @deal.status == 'active' %>
        <div class="mt-4">
          <h4 class="text-sm font-medium text-gray-700 mb-2">Update Stage:</h4>
          <div class="flex flex-wrap gap-2">
            <% DealStage.all.each do |stage| %>
              <% if stage.id == @deal.deal_stage_id %>
                <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-medium">
                  <%= stage.name %>
                </span>
              <% else %>
                <%= button_to update_stage_deal_path(@deal, deal_stage_id: stage.id), method: :patch, class: "px-3 py-1 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-full text-sm font-medium" do %>
                  <%= stage.name %>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h3 class="text-lg font-medium text-gray-900 mb-3">Deal Details</h3>
        
        <div class="bg-white p-4 rounded border border-gray-200">
          <div class="mb-4">
            <h4 class="text-sm font-medium text-gray-700">Description</h4>
            <p class="mt-1 text-gray-600"><%= @deal.description.present? ? @deal.description : "No description provided" %></p>
          </div>
          
          <div class="mb-4">
            <h4 class="text-sm font-medium text-gray-700">Assigned To</h4>
            <p class="mt-1 text-gray-600"><%= @deal.user.name %></p>
          </div>
          
          <div>
            <h4 class="text-sm font-medium text-gray-700">Status</h4>
            <p class="mt-1">
              <span class="px-2 py-1 rounded-full text-xs font-medium
                <%= case @deal.status
                    when 'active' then 'bg-blue-100 text-blue-800'
                    when 'won' then 'bg-green-100 text-green-800'
                    when 'lost' then 'bg-red-100 text-red-800'
                    end %>">
                <%= @deal.status&.capitalize %>
              </span>
            </p>
          </div>
        </div>
      </div>
      
      <div>
        <h3 class="text-lg font-medium text-gray-900 mb-3">Customer Information</h3>
        
        <% if @deal.customer.present? %>
          <div class="bg-white p-4 rounded border border-gray-200">
            <div class="mb-4">
              <h4 class="text-sm font-medium text-gray-700">Name</h4>
              <p class="mt-1 text-gray-600"><%= @deal.customer.name %></p>
            </div>
            
            <div class="mb-4">
              <h4 class="text-sm font-medium text-gray-700">Email</h4>
              <p class="mt-1 text-gray-600">
                <% if @deal.customer.email.present? %>
                  <%= mail_to @deal.customer.email, @deal.customer.email, class: "text-blue-600 hover:text-blue-800" %>
                <% else %>
                  <span class="text-gray-500">No email provided</span>
                <% end %>
              </p>
            </div>
            
            <div class="mb-4">
              <h4 class="text-sm font-medium text-gray-700">Phone</h4>
              <p class="mt-1 text-gray-600">
                <% if @deal.customer.present? && @deal.customer.phone.present? %>
                  <div class="flex items-center">
                    <span><%= @deal.customer.phone %></span>
                    <%= link_to calling_path(phone: @deal.customer.phone), class: "text-blue-600 hover:text-blue-800 ml-2", title: "Call #{@deal.customer.name}" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-gray-500">No phone provided</span>
                <% end %>
              </p>
            </div>
            
            <% if @deal.customer.company.present? %>
              <div>
                <h4 class="text-sm font-medium text-gray-700">Company</h4>
                <p class="mt-1 text-gray-600"><%= @deal.customer.company %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-white p-4 rounded border border-gray-200">
            <p class="text-gray-500">No customer assigned to this deal.</p>
            <div class="mt-4">
              <%= link_to "Assign a Customer", edit_deal_path(@deal), class: "text-blue-600 hover:text-blue-800" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <div class="p-6 border-t border-gray-200 bg-gray-50 flex justify-between">
      <%= link_to "Edit Deal", edit_deal_path(@deal), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      <% if current_user.admin? %>
        <%= button_to "Delete Deal", deal_path(@deal), method: :delete, data: { confirm: "Are you sure you want to delete this deal?" }, class: "bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" %>
      <% end %>
    </div>
  </div>
  
  <!-- Deal History Section -->
  <div class="bg-white shadow-md rounded-lg overflow-hidden mt-8">
    <div class="p-6 border-b border-gray-200">
      <h2 class="text-xl font-bold">Deal History</h2>
      <p class="text-gray-600 mt-1">Complete timeline of this deal</p>
    </div>
    
    <div class="p-6">
      <% if @deal.deal_activities.any? %>
        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute left-5 top-0 bottom-0 w-0.5 bg-gray-200"></div>
          
          <div class="space-y-6">
            <% @deal.deal_activities.order(created_at: :desc).each do |activity| %>
              <div class="relative pl-10">
                <!-- Timeline Dot -->
                <div class="absolute left-4 top-1.5 -ml-1.5 h-3 w-3 rounded-full <%= activity_color_class(activity.action) %>"></div>
                
                <div class="bg-white p-4 rounded-lg border border-gray-200 shadow-sm">
                  <div class="flex justify-between items-start">
                    <div>
                      <h4 class="font-medium text-gray-900"><%= format_activity_action(activity.action) %></h4>
                      <p class="text-sm text-gray-600 mt-1"><%= activity.details %></p>
                    </div>
                    <div class="text-right">
                      <span class="text-xs text-gray-500"><%= activity.created_at.strftime("%b %d, %Y at %I:%M %p") %></span>
                      <p class="text-xs text-gray-500 mt-1">by <%= activity.user.name %></p>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
            
            <!-- Deal Creation Entry -->
            <div class="relative pl-10">
              <div class="absolute left-4 top-1.5 -ml-1.5 h-3 w-3 rounded-full bg-green-500"></div>
              <div class="bg-white p-4 rounded-lg border border-gray-200 shadow-sm">
                <div class="flex justify-between items-start">
                  <div>
                    <h4 class="font-medium text-gray-900">Deal Created</h4>
                    <p class="text-sm text-gray-600 mt-1">Deal was created in the system</p>
                  </div>
                  <div class="text-right">
                    <span class="text-xs text-gray-500"><%= @deal.created_at.strftime("%b %d, %Y at %I:%M %p") %></span>
                    <p class="text-xs text-gray-500 mt-1">by <%= @deal.user.name %></p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% else %>
        <div class="text-center py-8 text-gray-500">
          <p>No activity recorded for this deal yet.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  function openModal(type) {
    document.getElementById(type + 'DealModal').classList.remove('hidden');
  }
  
  function closeModal(type) {
    document.getElementById(type + 'DealModal').classList.add('hidden');
  }
</script>
