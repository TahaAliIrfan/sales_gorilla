<% content_for :title, "#{@deal.title || 'Deal'} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="row" style="gap:8px">
        <span class="iccircle" style="background:var(--color-primary-subtle);color:var(--color-primary-text)">
          <%= relay_icon("circle-dollar-sign", size: 18) %>
        </span>
        <div>
          <div class="pagehead__title" style="font-size:var(--text-h2)"><%= @deal.title.presence || "Untitled deal" %></div>
          <div class="pagehead__sub mono"><%= [@deal.customer&.company.presence || @deal.customer&.name, "DEAL-#{@deal.id}"].compact.join(" · ") %></div>
        </div>
      </div>
    </div>
    <div class="pagehead__actions">
      <%= link_to deals_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to deals
      <% end %>
      <%= link_to edit_deal_path(@deal), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit deal
      <% end %>
      <% if current_user.admin? %>
        <%= button_to deal_path(@deal), method: :delete,
              form: { data: { turbo_confirm: "Delete this deal?" } },
              class: "rl-btn rl-btn--destructive-ghost" do %>
          <%= relay_icon("trash-2", size: 15) %>Delete
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="sect">
    <%= render "deals/relay/detail", deal: @deal %>
  </div>
</div>
