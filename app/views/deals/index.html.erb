<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= action_name == 'my_deals' ? 'My Deals' : 'All Deals' %></h1>
      <p class="text-gray-600 mt-1">Manage your sales pipeline</p>
    </div>
    <div class="flex space-x-4">
      <% if action_name != 'my_deals' %>
        <%= link_to "My Deals", my_deals_deals_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded" %>
      <% else %>
        <%= link_to "All Deals", deals_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded" %>
      <% end %>
      <%= link_to "New Deal", new_deal_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>
  
  <!-- Filters Section -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <%= form_with url: action_name == 'my_deals' ? my_deals_deals_path : deals_path, method: :get, class: "space-y-6" do |form| %>
      <!-- Required Filters Section -->
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
        <h3 class="text-md font-medium mb-3">Filters</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Filter by User -->
          <% if (current_user.admin? || current_user.manager?) && action_name != 'my_deals' %>
            <div>
              <label for="user_id" class="block text-sm font-medium text-gray-700 mb-1">Assigned To</label>
              <%= form.select :user_id, 
                  options_for_select([['All Users', '']] + @users.map { |u| [u.name, u.id] }, params[:user_id]), 
                  {}, 
                  { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", id: "user_id" } 
              %>
            </div>
          <% end %>
          
          <!-- Filter by Deal Stage -->
          <div>
            <label for="deal_stage_id" class="block text-sm font-medium text-gray-700 mb-1">Deal Stage</label>
            <%= form.select :deal_stage_id, 
                options_for_select([['All Stages', '']] + @deal_stages.map { |s| [s.name, s.id] }, params[:deal_stage_id]), 
                {}, 
                { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", id: "deal_stage_id" } 
            %>
          </div>
          
          <!-- Filter by Closing Date (only for Won/Lost deals) -->
          <div>
            <label for="filter_range" class="block text-sm font-medium text-gray-700 mb-1">Closing Date <span class="text-xs text-gray-500">(for Won/Lost deals)</span></label>
            <%= form.select :filter_range, 
                options_for_select([
                  ['Last 30 Days', '30'], 
                  ['Last 90 Days', '90'], 
                  ['Custom Range', 'custom'],
                  ['All Dates', 'all']
                ], params[:filter_range] || '30'), 
                {}, 
                { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", 
                  id: "filter_range",
                  onchange: "toggleCustomDateFields(this.value)" } 
            %>
          </div>
          
          <!-- Hidden field to maintain filtering for won/lost status when needed -->
          <%= form.hidden_field :status, value: params[:status] %>
        </div>
      </div>
      
      <!-- Custom date fields - only shown when custom range is selected -->
      <div id="custom_date_fields" class="<%= (params[:filter_range] == 'custom' || (!params[:filter_range] && params[:start_date].present?)) ? '' : 'hidden' %> bg-blue-50 rounded-lg p-4 border border-blue-200">
        <h3 class="text-md font-medium mb-3 text-blue-800">Custom Date Range</h3>
        <div class="flex items-center space-x-3">
          <div class="flex-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">Start Date</label>
            <%= form.date_field :start_date, value: @custom_start_date&.strftime('%Y-%m-%d'), class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          </div>
          <div class="flex-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">End Date</label>
            <%= form.date_field :end_date, value: @custom_end_date&.strftime('%Y-%m-%d'), class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          </div>
        </div>
      </div>
      
      <div class="flex justify-end space-x-3 pt-4">
        <%= link_to action_name == 'my_deals' ? my_deals_deals_path : deals_path, class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
          Clear Filters
        <% end %>
        <%= form.submit "Apply Filters", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700" %>
      </div>
    <% end %>
    
    <% if !params.except(:controller, :action).empty? %>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="text-sm text-gray-600">Active filters:</span>
        <% params.except(:controller, :action).each do |key, value| %>
          <% next if value.blank? %>
          <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded">
            <% if key == 'filter_range' && value != 'custom' %>
              <% case value 
                 when '30' %> Last 30 Days
              <% when '90' %> Last 90 Days
              <% when 'all' %> All Dates
              <% end %>
            <% elsif key.include?('_id') %>
              <%= key.humanize %>: <%= key == 'deal_stage_id' ? DealStage.find_by(id: value)&.name : User.find_by(id: value)&.name %>
            <% elsif key == 'start_date' || key == 'end_date' %>
              <%= key.humanize %>: <%= value %>
            <% else %>
              <%= key.humanize %>: <%= value %>
            <% end %>
          </span>
        <% end %>
        <%= link_to action_name == 'my_deals' ? my_deals_deals_path : deals_path, class: "text-xs text-red-600 hover:text-red-800 ml-2" do %>
          Clear All
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @deals.any? %>
    <div class="flex overflow-x-auto pb-4 space-x-4" data-controller="drag">
      <% @deal_stages.each do |stage| %>
        <div class="flex-shrink-0 w-80 bg-gray-100 rounded-lg shadow">
          <div class="p-4 border-b border-gray-200 bg-gray-200 rounded-t-lg" data-stage-id="<%= stage.id %>">
            <h3 class="font-semibold text-gray-700"><%= stage.name %></h3>
            <% stage_deals = @deals.by_stage(stage).active %>
            <p class="text-sm text-gray-500"><span class="deal-count"><%= stage_deals.count %></span> deals - <%= number_to_currency(stage_deals.sum(:amount)) %></p>
          </div>
          <div class="p-2 min-h-[300px]" data-drag-target="stage" data-stage-id="<%= stage.id %>">
            <% if stage_deals.any? %>
              <% stage_deals.each do |deal| %>
                <div class="bg-white p-4 mb-2 rounded shadow hover:shadow-md transition-shadow" data-drag-target="deal" data-deal-id="<%= deal.id %>">
                  <div class="flex justify-between items-start">
                    <h4 class="font-medium text-blue-600 flex items-center">
                      <span class="drag-handle cursor-move mr-2 text-gray-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                      </span>
                      <%= link_to deal.title, deal_path(deal) %>
                    </h4>
                    <span class="text-sm font-semibold text-green-600"><%= number_to_currency(deal.amount) %></span>
                  </div>
                  <p class="text-sm text-gray-600 mt-1 truncate">
                    <% if deal.customer.present? %>
                      <%= deal.customer.name %>
                    <% else %>
                      <span class="text-gray-500">No customer</span>
                    <% end %>
                  </p>
                  <div class="flex justify-between items-center mt-3 text-xs text-gray-500">
                    <span>Assigned to: <%= deal.user.name %></span>
                    <% if deal.expected_close_date %>
                      <span>Close: <%= deal.expected_close_date.strftime("%b %d") %></span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="text-center py-8 text-gray-500 text-sm">
                No deals in this stage
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <!-- Won Deals Column -->
      <div class="flex-shrink-0 w-80 bg-green-50 rounded-lg shadow">
        <div class="p-4 border-b border-green-200 bg-green-100 rounded-t-lg">
          <h3 class="font-semibold text-green-700">Won Deals</h3>
          <% won_deals = @deals.won %>
          <p class="text-sm text-green-600"><%= won_deals.count %> deals - <%= number_to_currency(won_deals.sum(:amount)) %></p>
        </div>
        <div class="p-2 min-h-[300px]">
          <% if won_deals.any? %>
            <% won_deals.each do |deal| %>
              <div class="bg-white p-4 mb-2 rounded shadow hover:shadow-md transition-shadow border-l-4 border-green-500">
                <div class="flex justify-between items-start">
                  <h4 class="font-medium text-green-600">
                    <%= link_to deal.title, deal_path(deal) %>
                  </h4>
                  <span class="text-sm font-semibold text-green-600"><%= number_to_currency(deal.amount) %></span>
                </div>
                <p class="text-sm text-gray-600 mt-1 truncate">
                  <% if deal.customer.present? %>
                    <%= deal.customer.name %>
                  <% else %>
                    <span class="text-gray-500">No customer</span>
                  <% end %>
                </p>
                <div class="flex justify-between items-center mt-3 text-xs text-gray-500">
                  <span>Assigned to: <%= deal.user.name %></span>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-8 text-gray-500 text-sm">
              No won deals yet
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- Lost Deals Column -->
      <div class="flex-shrink-0 w-80 bg-red-50 rounded-lg shadow">
        <div class="p-4 border-b border-red-200 bg-red-100 rounded-t-lg">
          <h3 class="font-semibold text-red-700">Lost Deals</h3>
          <% lost_deals = @deals.lost %>
          <p class="text-sm text-red-600"><%= lost_deals.count %> deals - <%= number_to_currency(lost_deals.sum(:amount)) %></p>
        </div>
        <div class="p-2 min-h-[300px]">
          <% if lost_deals.any? %>
            <% lost_deals.each do |deal| %>
              <div class="bg-white p-4 mb-2 rounded shadow hover:shadow-md transition-shadow border-l-4 border-red-500">
                <div class="flex justify-between items-start">
                  <h4 class="font-medium text-red-600">
                    <%= link_to deal.title, deal_path(deal) %>
                  </h4>
                  <span class="text-sm font-semibold text-red-600"><%= number_to_currency(deal.amount) %></span>
                </div>
                <p class="text-sm text-gray-600 mt-1 truncate">
                  <% if deal.customer.present? %>
                    <%= deal.customer.name %>
                  <% else %>
                    <span class="text-gray-500">No customer</span>
                  <% end %>
                </p>
                <div class="flex justify-between items-center mt-3 text-xs text-gray-500">
                  <span>Assigned to: <%= deal.user.name %></span>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-8 text-gray-500 text-sm">
              No lost deals
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="bg-white shadow-md rounded p-8 my-6">
      <p class="text-gray-600">No deals found. <%= link_to "Create your first deal", new_deal_path, class: "text-blue-600 hover:text-blue-900" %>.</p>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Get the filter range select element
    const filterRangeSelect = document.getElementById('filter_range');
    
    // Set initial state for custom date fields
    toggleCustomDateFields(filterRangeSelect.value);
    
    // Add event listener for changes
    filterRangeSelect.addEventListener('change', function() {
      toggleCustomDateFields(this.value);
    });
  });
  
  // Toggle custom date fields visibility
  function toggleCustomDateFields(value) {
    const customFields = document.getElementById('custom_date_fields');
    if (value === 'custom') {
      customFields.classList.remove('hidden');
    } else {
      customFields.classList.add('hidden');
    }
  }
</script>
