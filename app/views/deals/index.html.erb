<%# Relay "Pipeline" — draggable kanban board honest to the DB.
    Mirrors docs/design/relay-app/project/app/view-pipeline.jsx. Columns are the
    selected pipeline's active stages; cards are real deals. Drag → update_stage. %>
<% content_for :title, (action_name == "my_deals" ? "My deals" : "Pipeline") + " — #{current_organization&.name}" %>
<% content_for :body_class, "app__body--full" %>
<%
  is_mine     = action_name == "my_deals"
  can_config  = current_user&.admin? # only admins manage pipeline stages (PipelinePolicy#update?)
  stages      = @deal_stages.to_a
  deals       = @deals.to_a
  by_stage    = deals.group_by(&:deal_stage_id)
  open_total  = deals.select { |d| d.status == "active" }.sum { |d| d.amount.to_f }
  won_total   = deals.select { |d| d.status == "won" }.sum { |d| d.amount.to_f }
  deals_count = deals.size

  base_params  = request.query_parameters.except("pipeline_id")
  switch_path  = is_mine ? deals_path(base_params) : my_deals_deals_path(base_params)
  new_path     = @selected_pipeline ? new_deal_path(pipeline_id: @selected_pipeline.id) : new_deal_path
%>

<div class="page page--flush pipeline-page"
     data-controller="relay--kanban relay--overlay"
     data-relay--kanban-url-value="<%= update_stage_deal_path(":id") %>">

  <div class="page" style="padding-bottom:0;max-width:none">
  <%# === Header === %>
  <div class="pagehead">
    <div>
      <div class="pagehead__title"><%= is_mine ? "My deals" : "Pipeline" %></div>
      <div class="pagehead__sub">
        drag deals across stages · <b><%= number_with_delimiter(deals_count) %></b> <%= "deal".pluralize(deals_count) %> · <%= relay_money(open_total) %> open
      </div>
    </div>
    <div class="pagehead__actions">
      <%# Pipeline selector — only when more than one pipeline is accessible. %>
      <% if @pipelines.to_a.size > 1 || current_user&.admin? %>
        <div data-controller="relay--dropdown" style="position:relative;display:inline-flex">
          <button type="button" class="rl-btn rl-btn--secondary"
                  data-action="relay--dropdown#toggle" data-relay--dropdown-target="trigger">
            <%= relay_icon("layers", size: 15) %>
            <%= @selected_pipeline&.name || "All pipelines" %>
            <%= relay_icon("chevron-down", size: 14) %>
          </button>
          <div class="menu-float pop" data-relay--dropdown-target="menu" hidden style="top:calc(100% + 6px);right:0">
            <div class="rl-menu" style="min-width:220px">
              <% if current_user&.admin? %>
                <%= link_to (is_mine ? my_deals_deals_path(base_params.merge(pipeline_id: "")) : deals_path(base_params.merge(pipeline_id: ""))),
                      class: "rl-menuitem", data: { turbo_frame: "_top" } do %>
                  <%= relay_icon("layers", size: 15) %>All pipelines
                <% end %>
              <% end %>
              <% @pipelines.each do |pl| %>
                <%= link_to (is_mine ? my_deals_deals_path(base_params.merge(pipeline_id: pl.id)) : deals_path(base_params.merge(pipeline_id: pl.id))),
                      class: ["rl-menuitem", ("is-active" if @selected_pipeline&.id == pl.id)].compact.join(" "),
                      data: { turbo_frame: "_top" } do %>
                  <i class="rl-dot" style="background:var(--color-primary)"></i><%= pl.name %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <%= link_to switch_path, class: "rl-btn rl-btn--secondary", data: { turbo_frame: "_top" } do %>
        <%= relay_icon(is_mine ? "users" : "user", size: 15) %><%= is_mine ? "All deals" : "My deals" %>
      <% end %>

      <% if can_config && @selected_pipeline %>
        <%= link_to edit_pipeline_path(@selected_pipeline), class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("sliders-horizontal", size: 15) %>Configure stages
        <% end %>
      <% end %>

      <%= link_to new_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>Create deal
      <% end %>
    </div>
  </div>

  <%# === Summary numerals === %>
  <div class="row" style="gap:20px;margin-bottom:4px">
    <div>
      <span class="rl-eyebrow">Open pipeline</span>
      <div class="mono" style="font-weight:800;font-size:22px"><%= relay_money(open_total) %></div>
    </div>
    <div style="width:1px;background:var(--color-border)"></div>
    <div>
      <span class="rl-eyebrow">Won (in range)</span>
      <div class="mono" style="font-weight:800;font-size:22px;color:var(--color-success-text)"><%= relay_money(won_total) %></div>
    </div>
  </div>
  </div><%# /.page %>

  <%# === Board === %>
  <% if stages.empty? %>
    <div class="empty" style="margin:0 var(--space-8)">
      <div class="empty__ic"><%= relay_icon("layers", size: 26) %></div>
      <div class="rl-h4" style="margin-bottom:4px">No pipeline stages</div>
      <div class="muted rl-sm" style="max-width:360px">
        <%= can_config ? "Create a pipeline with stages to start tracking deals." : "Ask an admin to set up a pipeline you can access." %>
      </div>
      <% if can_config %>
        <%= link_to "Create deal", new_path, class: "rl-btn rl-btn--primary rl-btn--sm", style: "margin-top:16px" %>
      <% end %>
    </div>
  <% else %>
    <div class="boardwrap grow">
      <div class="rl-board" style="height:100%">
        <% stages.each do |stage| %>
          <% list = (by_stage[stage.id] || []) %>
          <% col_total = list.sum { |d| d.amount.to_f } %>
          <% color = relay_stage_color(stage) %>
          <div class="rl-col">
            <div class="rl-col__head">
              <span class="rl-dotmark" style="background:<%= color %>"></span>
              <b><%= stage.name %></b>
              <span class="rl-count" data-kanban-count><%= list.size %></span>
            </div>
            <div style="padding:6px 14px;border-bottom:1px solid var(--color-divider)">
              <span class="mono muted" style="font-size:12px;font-weight:600" data-kanban-total><%= relay_money(col_total) %></span>
            </div>
            <div class="rl-col__body" style="min-height:120px"
                 data-relay--kanban-target="column"
                 data-stage-id="<%= stage.id %>"
                 data-stage-name="<%= stage.name %>">
              <% list.each do |deal| %>
                <%= render "deals/relay/card", deal: deal %>
              <% end %>
              <% if list.empty? %>
                <div class="rl-col__empty" style="text-align:center;padding:16px;color:var(--color-fg-4);font-size:12px">No deals</div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# === Lazy-loaded deal drawer ===
       Cards are links into the "deal_drawer" frame; clicking also opens the
       overlay panel (Escape / backdrop closes). deals#show renders the drawer
       partial for this frame. %>
  <div class="drawer drawer--wide" hidden
       data-relay--overlay-target="panel"
       data-action="click->relay--overlay#backdrop">
    <%= turbo_frame_tag "deal_drawer" do %>
      <div class="drawer__body" style="display:grid;place-items:center;color:var(--color-fg-4)">
        <%= relay_icon("circle-dollar-sign", size: 22) %>
      </div>
    <% end %>
  </div>
</div>
