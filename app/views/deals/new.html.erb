<% content_for :title, "New deal — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">
        New deal<% if current_user.admin? && @selected_pipeline %> <span class="muted">· <%= @selected_pipeline.name %></span><% end %>
      </div>
      <div class="pagehead__sub">
        <% if current_user.admin? && @selected_pipeline %>
          Create a new deal in <%= @selected_pipeline.name %>.
        <% else %>
          Create a new sales opportunity.
        <% end %>
      </div>
    </div>
    <div class="pagehead__actions">
      <%= link_to deals_path, class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to deals
      <% end %>
    </div>
  </div>

  <%= render "form", deal: @deal %>
</div>
