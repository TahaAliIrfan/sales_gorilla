<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Deals", deals_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="p-6 border-b border-gray-200">
      <h1 class="text-2xl font-bold text-gray-900">New Deal</h1>
      <p class="text-gray-600 mt-1">Create a new sales opportunity</p>
    </div>

    <div class="p-6">
      <%= render 'form', deal: @deal %>
    </div>
  </div>
</div>
