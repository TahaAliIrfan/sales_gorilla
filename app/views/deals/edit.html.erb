<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Deal", deal_path(@deal), class: "text-emerald-600 hover:text-emerald-800" %>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="p-6 border-b border-gray-200">
      <h1 class="text-2xl font-bold text-gray-900">Edit Deal: <%= @deal.title %></h1>
      <p class="text-gray-600 mt-1">Update deal information</p>
    </div>

    <div class="p-6">
      <%= render 'form', deal: @deal %>
    </div>
  </div>
</div>
