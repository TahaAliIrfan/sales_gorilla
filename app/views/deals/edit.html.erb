<% content_for :title, "Edit deal — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Edit deal</div>
      <div class="pagehead__sub"><%= @deal.title %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to deal_path(@deal), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to deal
      <% end %>
    </div>
  </div>

  <%= render "form", deal: @deal %>
</div>
