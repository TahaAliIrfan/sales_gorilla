<%= form_with(model: deal, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if deal.errors.any? %>
    <%= render "settings/errors", record: deal %>
  <% end %>

  <div class="grid grid-2" style="align-items:start">
    <div class="sect">
      <div class="sect__head"><div class="sect__title">Deal details</div></div>
      <div class="sect__body col" style="gap:var(--space-4)">
        <%= render "shared/relay_field", f: form, field: :title, autofocus: true, required: true %>
        <%= render "shared/relay_field", f: form, field: :description, type: "textarea", rows: 4 %>

        <div class="rl-field">
          <%= form.label :amount, class: "rl-label" %>
          <div class="rl-inputwrap">
            <span class="rl-affix">$</span>
            <%= form.number_field :amount, step: 0.01, min: 0, class: "rl-input mono" %>
          </div>
        </div>

        <%= render "shared/relay_field", f: form, field: :expected_close_date, type: "date",
              hint: "When you expect this deal to close." %>
        <%= render "shared/relay_field", f: form, field: :closing_date, type: "date",
              label: "Actual closing date", hint: "Set when a deal is won or lost." %>
        <%= render "shared/relay_field", f: form, field: :created_at, type: "datetime-local" %>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Assignment &amp; stage</div></div>
      <div class="sect__body col" style="gap:var(--space-4)">
        <div class="rl-field">
          <%= form.label :customer_id, class: "rl-label" %>
          <div class="row" style="gap:8px">
            <%= form.collection_select :customer_id, @customers, :id, :name,
                  { prompt: "Select a customer", include_blank: "No customer" },
                  { class: "rl-select mono grow" } %>
            <%= link_to new_customer_path, class: "rl-btn rl-btn--secondary rl-btn--sm", style: "white-space:nowrap" do %>
              <%= relay_icon("plus", size: 14) %>New
            <% end %>
          </div>
        </div>

        <div class="rl-field">
          <%= form.label :user_id, "Assigned to", class: "rl-label" %>
          <%= form.collection_select :user_id, @users, :id, :name,
                { prompt: "Select a user" }, { class: "rl-select" } %>
        </div>

        <div class="rl-field">
          <%= form.label :deal_stage_id, "Deal stage", class: "rl-label" %>
          <% if @deal_stages.any? %>
            <%= form.collection_select :deal_stage_id, @deal_stages, :id, :name,
                  { prompt: "Select a stage" }, { class: "rl-select" } %>
          <% else %>
            <div class="rl-sm" style="background:var(--color-danger-subtle);border:1px solid var(--color-danger-border);color:var(--color-danger-text);border-radius:var(--radius-md);padding:10px 12px">
              <% if current_user.admin? %>
                No deal stages available. <%= link_to "Create pipeline stages", pipelines_path, style: "text-decoration:underline" %> first.
              <% else %>
                No deal stages available. Contact your administrator.
              <% end %>
            </div>
          <% end %>
        </div>

        <%= render "shared/relay_field", f: form, field: :status, type: "select",
              options: Deal.statuses.keys.map { |s| [ s.capitalize, s ] } %>
      </div>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", deals_path, class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (deal.new_record? ? "Create deal" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
