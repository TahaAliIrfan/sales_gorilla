<%= form_with(model: task, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if task.errors.any? %>
    <%= render "settings/errors", record: task %>
  <% end %>

  <div class="sect">
    <div class="sect__body">
      <div class="grid grid-2">
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :title, required: true,
                placeholder: "Enter task title" %>
        </div>

        <%= render "shared/relay_field", f: form, field: :status, type: "select",
              options: Task::STATUSES.map { |k, v| [ v, k ] } %>
        <%= render "shared/relay_field", f: form, field: :priority, type: "select",
              options: Task::PRIORITIES.map { |k, v| [ v, k ] } %>

        <%= render "shared/relay_field", f: form, field: :due_date, type: "datetime-local",
              hint: "Set a deadline date and time for this task." %>

        <% if current_user.admin? %>
          <div class="rl-field">
            <%= form.label :user_id, "Assigned to", class: "rl-label" %>
            <%= form.collection_select :user_id, current_organization.users.order(:name), :id, :name, {}, class: "rl-select" %>
          </div>
        <% else %>
          <%= form.hidden_field :user_id, value: current_user.id %>
        <% end %>

        <div class="rl-field">
          <%= form.label :customer_id, "Related customer", class: "rl-label" %>
          <%= form.collection_select :customer_id,
                (current_user.admin? ? Customer.all : Customer.where(user_id: current_user.id)),
                :id, :name, { include_blank: "None" }, class: "rl-select" %>
          <p class="rl-help">Customer this task is associated with.</p>
        </div>

        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :description, type: "textarea", rows: 5,
                placeholder: "Describe the task in detail…",
                hint: "Add detailed description of what needs to be done for this task." %>
        </div>
      </div>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel",
          (params[:action] == "new" ? (params[:from] == "my_tasks" ? my_tasks_tasks_path : tasks_path) : (task.persisted? ? task_path(task) : tasks_path)),
          class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (task.new_record? ? "Create task" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
