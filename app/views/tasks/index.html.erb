<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="md:flex md:items-center md:justify-between mb-6">
    <div class="flex-1 min-w-0">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        <% if params[:action] == 'my_tasks' %>
          My Tasks
        <% else %>
          All Tasks
        <% end %>
      </h2>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4">
      <%= link_to new_task_path, class: "ml-3 inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        New Task
      <% end %>
    </div>
  </div>

  <!-- Filters Section -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Filters</h3>
    
    <%= form_with url: params[:action] == 'my_tasks' ? my_tasks_tasks_path : tasks_path, method: :get, data: { turbo_frame: "_top" }, class: "space-y-4 sm:flex sm:items-center sm:space-y-0 sm:space-x-6" do |f| %>
      <div class="w-full sm:w-1/4">
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :status, options_for_select(Task::STATUSES.map { |k, v| [v, k] }, params[:status]), { include_blank: "All Statuses" }, class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md" %>
      </div>
      
      <div class="w-full sm:w-1/4">
        <%= f.label :priority, "Priority", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :priority, options_for_select(Task::PRIORITIES.map { |k, v| [v, k] }, params[:priority]), { include_blank: "All Priorities" }, class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md" %>
      </div>
      
      <% if current_user.admin? && params[:action] == 'index' %>
        <div class="w-full sm:w-1/4">
          <%= f.label :user_id, "Assigned To", class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :user_id, options_from_collection_for_select(User.all, :id, :name, params[:user_id]), { include_blank: "All Users" }, class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md" %>
        </div>
      <% end %>
      
      <div class="w-full sm:w-1/4">
        <%= f.label :due_date, "Due Date", class: "block text-sm font-medium text-gray-700" %>
        <%= f.date_field :due_date, value: params[:due_date], class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md" %>
      </div>
      
      <div class="w-full sm:w-auto sm:self-end">
        <%= f.submit "Apply Filters", class: "w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:w-auto sm:text-sm" %>
        
        <% if params[:status].present? || params[:priority].present? || params[:user_id].present? || params[:due_date].present? %>
          <%= link_to params[:action] == 'my_tasks' ? my_tasks_tasks_path : tasks_path, class: "mt-3 sm:mt-0 sm:ml-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 sm:w-auto sm:text-sm" do %>
            Clear Filters
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Tasks List -->
  <div class="bg-white shadow overflow-hidden sm:rounded-md">
    <ul class="divide-y divide-gray-200">
      <% if @tasks.present? && @tasks.any? %>
        <% @tasks.each do |task| %>
          <li>
            <div class="px-4 py-4 sm:px-6 hover:bg-gray-50">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <div class="min-w-0 flex-1 flex items-center">
                    <div class="flex-shrink-0">
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                        <%= case task.priority
                            when 'High' then 'bg-red-100 text-red-800'
                            when 'Medium' then 'bg-yellow-100 text-yellow-800'
                            when 'Low' then 'bg-green-100 text-green-800'
                            end %>">
                        <%= task.priority %>
                      </span>
                    </div>
                    <div class="min-w-0 flex-1 px-4">
                      <div>
                        <div class="flex">
                          <p class="text-sm font-medium text-blue-600 truncate">
                            <%= link_to task.title, task_path(task) %>
                          </p>
                          <% if task.completed? %>
                            <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800 rounded-full">
                              Completed
                            </span>
                          <% elsif task.overdue? %>
                            <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800 rounded-full">
                              Overdue
                            </span>
                          <% elsif task.due_today? %>
                            <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">
                              Due Today
                            </span>
                          <% end %>
                        </div>
                        <p class="mt-1 text-sm text-gray-500">
                          Due: <%= task.due_date.strftime("%b %d, %Y at %I:%M %p") %>
                          <% if task.customer.present? %>
                            | Customer: <%= link_to task.customer.name, customer_path(task.customer), class: "text-blue-600 hover:text-blue-900" %>
                          <% end %>
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="ml-5 flex-shrink-0 flex">
                  <% unless task.completed? %>
                    <%= button_to complete_task_path(task), method: :patch, class: "mr-2 inline-flex items-center px-2.5 py-1.5 border border-transparent text-xs font-medium rounded text-green-700 bg-green-100 hover:bg-green-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
                      Complete
                    <% end %>
                  <% end %>
                  <%= link_to edit_task_path(task), class: "inline-flex items-center px-2.5 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                    Edit
                  <% end %>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      <% else %>
        <li class="px-4 py-6 sm:px-6 text-center text-gray-500">
          No tasks found matching your criteria.
        </li>
      <% end %>
    </ul>
  </div>
</div>
