<%
  my = params[:action] == "my_tasks"
  base_path = my ? my_tasks_tasks_path : tasks_path
  page_title = my ? "My tasks" : "All tasks"
  status_tabs = [ %w[pending Pending], %w[in_progress In\ progress], %w[completed Completed], %w[cancelled Cancelled] ]
%>
<% content_for :title, "#{page_title} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title"><%= page_title %></div>
      <div class="pagehead__sub">Track and complete your assigned work.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_task_path(from: (my ? "my_tasks" : nil)), class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>New task
      <% end %>
    </div>
  </div>

  <%# Status tabs — server-side links preserving the status/due_date contract %>
  <div class="rl-tabs" style="margin-bottom:var(--space-4)">
    <% status_tabs.each do |val, label| %>
      <%= link_to label,
            (my ? my_tasks_tasks_path(status: val) : tasks_path(status: val)),
            class: "rl-tab #{'is-active' if params[:status] == val}" %>
    <% end %>
  </div>

  <%# Filters — same params as legacy (priority, user_id for admin index, due_date) %>
  <%= form_with url: base_path, method: :get, data: { turbo_frame: "_top" },
        class: "row row--wrap", html: { style: "margin-bottom:var(--space-4);gap:8px" } do |f| %>
    <% if params[:status].present? %><%= f.hidden_field :status, value: params[:status] %><% end %>
    <% if params[:due_date].present? %><%= f.hidden_field :due_date, value: params[:due_date] %><% end %>

    <%= f.select :priority, options_for_select(Task::PRIORITIES.map { |k, v| [ v, k ] }, params[:priority]),
          { include_blank: "Priority" }, class: "rl-select rl-input--sm", style: "width:auto" %>

    <% if current_user.admin? && params[:action] == "index" %>
      <%= f.select :user_id, options_from_collection_for_select(current_organization.users.order(:name), :id, :name, params[:user_id]),
            { include_blank: "Assignee" }, class: "rl-select rl-input--sm", style: "width:auto" %>
    <% end %>

    <% unless params[:due_date] == "today" && my && params[:status].blank? %>
      <%= f.select :due_date,
            options_for_select([ %w[Today today], %w[Upcoming upcoming], %w[Overdue overdue] ], params[:due_date]),
            { include_blank: "Due date" }, class: "rl-select rl-input--sm", style: "width:auto" %>
    <% end %>

    <%= f.button type: "submit", class: "rl-btn rl-btn--secondary rl-btn--sm" do %>
      <%= relay_icon("filter", size: 14) %>Filter
    <% end %>

    <% if params[:priority].present? || params[:user_id].present? || (params[:due_date].present? && !(params[:due_date] == "today" && my && params[:status].blank?)) %>
      <%= link_to (params[:status].present? ? base_path + "?status=#{params[:status]}" : base_path),
            class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
        <%= relay_icon("x", size: 14) %>Clear
      <% end %>
    <% end %>
  <% end %>

  <div class="sect">
    <div class="sect__body--flush">
      <% if @tasks.present? && @tasks.any? %>
        <div class="rl-list">
          <% @tasks.each do |task| %>
            <%= render "tasks/row", task: task, return_to: "current_page" %>
          <% end %>
        </div>
      <% else %>
        <div class="muted" style="text-align:center;padding:var(--space-8)">
          No tasks found matching your criteria.
        </div>
      <% end %>
    </div>
  </div>
</div>
