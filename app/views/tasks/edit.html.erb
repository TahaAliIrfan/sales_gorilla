<% content_for :title, "Edit task — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Edit task</div>
      <div class="pagehead__sub"><%= @task.title %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to task_path(@task), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to task
      <% end %>
    </div>
  </div>

  <%= render "form", task: @task %>
</div>
