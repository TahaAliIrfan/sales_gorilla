<% content_for :title, "#{@task.title} — #{current_organization&.name}" %>
<% pill = relay_priority_pill(@task.priority) %>
<% state = relay_task_state_pill(@task) %>
<% can_manage = current_user.admin? || @task.user_id == current_user.id %>
<% back_path = params[:from] == "my_tasks" ? my_tasks_tasks_path : tasks_path %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title"><%= @task.title %></div>
      <div class="pagehead__sub">Assigned to <%= @task.user.name %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to back_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
      <% if can_manage %>
        <% unless @task.completed? %>
          <%= button_to complete_task_path(@task), method: :patch, class: "rl-btn rl-btn--primary",
                style: "background:var(--color-success);border-color:var(--color-success)" do %>
            <%= relay_icon("check", size: 15) %>Mark complete
          <% end %>
        <% end %>
        <%= link_to edit_task_path(@task), class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("pencil", size: 15) %>Edit
        <% end %>
        <%= button_to task_path(@task), method: :delete,
              form: { data: { turbo_confirm: "Are you sure you want to delete this task?" } },
              class: "rl-btn rl-btn--destructive-ghost" do %>
          <%= relay_icon("trash-2", size: 15) %>Delete
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="sect" style="max-width:760px">
    <div class="sect__head">
      <div class="sect__title"><%= @task.title %></div>
      <div class="row" style="gap:8px">
        <span class="rl-pill <%= state[:klass] %>"><i class="rl-dot"></i><%= state[:label] %></span>
        <span class="rl-badge" style="background:transparent">
          <i style="width:7px;height:7px;border-radius:9px;background:<%= pill[:dot] %>"></i><%= pill[:label] %> priority
        </span>
      </div>
    </div>
    <div class="sect__body">
      <div class="kvline"><dt>Due date</dt><dd class="mono"><%= @task.due_date.strftime("%B %d, %Y at %I:%M %p") %></dd></div>
      <div class="kvline"><dt>Status</dt><dd><%= @task.status_display %></dd></div>
      <div class="kvline"><dt>Assigned to</dt><dd><%= @task.user.name %></dd></div>
      <% if @task.customer.present? %>
        <div class="kvline">
          <dt>Related customer</dt>
          <dd><%= link_to @task.customer.name, customer_path(@task.customer), style: "color:var(--color-primary-text)" %></dd>
        </div>
      <% end %>
      <div class="kvline"><dt>Created</dt><dd class="mono"><%= @task.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd></div>
      <div class="kvline"><dt>Last updated</dt><dd class="mono"><%= @task.updated_at.strftime("%B %d, %Y at %I:%M %p") %></dd></div>

      <div style="margin-top:var(--space-4)">
        <div class="rl-eyebrow" style="margin-bottom:6px">Description</div>
        <% if @task.description.present? %>
          <div class="rl-sm" style="white-space:pre-wrap;line-height:1.6"><%= simple_format @task.description %></div>
        <% else %>
          <div class="muted rl-sm">No description provided.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
