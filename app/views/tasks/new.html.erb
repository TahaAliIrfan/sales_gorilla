<% content_for :title, "New task — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">New task</div>
      <div class="pagehead__sub">Create a task and assign a due date.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to (params[:from] == "my_tasks" ? my_tasks_tasks_path : tasks_path), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to tasks
      <% end %>
    </div>
  </div>

  <%= render "form", task: @task %>
</div>
