<%# New invoice from a milestone — relay DS. Preserves the milestone_id select,
    project_name, issue_date, due_date, tax_rate, payment_link_label, payment_link
    params and the customer_invoices POST endpoint. %>
<% content_for :title, "New invoice — #{@customer.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_invoices_path(@customer), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to invoices
        <% end %>
      </div>
      <div class="pagehead__title">New invoice</div>
      <div class="pagehead__sub">Create an invoice from a milestone for <%= @customer.name %>.</div>
    </div>
  </div>

  <%= form_with model: [:customer, @customer, @invoice], url: customer_invoices_path(@customer), method: :post,
        class: "col", html: { style: "gap:var(--space-5)" } do |f| %>
    <% if @invoice.errors.any? %>
      <%= render "settings/errors", record: @invoice %>
    <% end %>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Invoice details</div></div>
      <div class="sect__body">
        <div class="rl-field">
          <%= f.label :milestone_id, "Select milestone", class: "rl-label" %>
          <%= f.collection_select :milestone_id, @milestones, :id,
                lambda { |m| "#{m.name} — #{relay_money(m.total_amount)}" },
                { prompt: "Choose a milestone…" }, { class: "rl-select", required: true } %>
          <% if @milestones.empty? %>
            <p class="rl-help rl-help--error">No milestones found.
              <%= link_to "Create a milestone", new_customer_milestone_path(@customer), style: "text-decoration:underline" %> first.</p>
          <% end %>
        </div>

        <div class="grid grid-2">
          <%= render "shared/relay_field", f: f, field: :project_name, label: "Project name", placeholder: "Optional" %>
          <div class="rl-field">
            <%= f.label :tax_rate, "Tax rate (%)", class: "rl-label" %>
            <%= f.number_field :tax_rate, step: 0.01, value: @invoice.tax_rate || 0, class: "rl-input mono" %>
          </div>
          <%= render "shared/relay_field", f: f, field: :issue_date, type: "date", required: true %>
          <%= render "shared/relay_field", f: f, field: :due_date, type: "date", required: true %>
        </div>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Payment</div></div>
      <div class="sect__body">
        <div class="grid grid-2">
          <%= render "shared/relay_field", f: f, field: :payment_link_label, label: "Payment link label",
                type: "select", include_blank: "Select…",
                options: [["Stripe", "Stripe"], ["Payoneer", "Payoneer"], ["PayPal", "PayPal"], ["Bank Transfer", "Bank Transfer"], ["Other", "Other"]] %>
          <%= render "shared/relay_field", f: f, field: :payment_link, type: "url", label: "Payment link URL",
                placeholder: "https://payment.stripe.com/…" %>
        </div>
        <p class="rl-help" style="margin-top:8px">Optional: add a label (Stripe, Payoneer, etc.) and payment link for the customer.</p>
      </div>
    </div>

    <div class="row" style="justify-content:flex-end;gap:8px">
      <%= link_to "Cancel", customer_invoices_path(@customer), class: "rl-btn rl-btn--secondary" %>
      <%= f.submit "Create invoice", class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
    </div>
  <% end %>
</div>
