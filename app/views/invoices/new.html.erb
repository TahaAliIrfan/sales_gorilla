<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <%= link_to customer_invoices_path(@customer), class: "text-sm text-gray-600 hover:text-gray-900 flex items-center mb-2" do %>
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Invoices
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900">New Invoice</h1>
    <p class="text-gray-600 mt-1">Create an invoice from a milestone for <%= @customer.name %></p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= form_with model: [:customer, @customer, @invoice], url: customer_invoices_path(@customer), method: :post, class: "space-y-6" do |f| %>
      <% if @invoice.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
          <ul class="list-disc list-inside">
            <% @invoice.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :milestone_id, "Select Milestone", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :milestone_id, @milestones, :id, lambda { |m| "#{m.name} - #{number_to_currency(m.total_amount)}" }, { prompt: "Choose a milestone..." }, { class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", required: true } %>
        <% if @milestones.empty? %>
          <p class="mt-2 text-sm text-amber-600">No milestones found. <%= link_to "Create a milestone", new_customer_milestone_path(@customer), class: "font-medium underline" %> first.</p>
        <% end %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :project_name, "Project Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :project_name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "Optional" %>
        </div>
        <div>
          <%= f.label :issue_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :issue_date, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", required: true %>
        </div>
        <div>
          <%= f.label :due_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :due_date, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", required: true %>
        </div>
        <div>
          <%= f.label :tax_rate, "Tax Rate (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :tax_rate, step: 0.01, value: @invoice.tax_rate || 0, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
      </div>

      <%= render "payment_options", f: f, bank_accounts: @bank_accounts %>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Create Invoice", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium cursor-pointer" %>
        <%= link_to "Cancel", customer_invoices_path(@customer), class: "px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
