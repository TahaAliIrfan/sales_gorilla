<%# Edit invoice — relay DS. Preserves project_name, status, description,
    issue_date, due_date, tax_rate, payment_link_label, payment_link, and the
    invoice_line_items fields_for (description + amount + position). %>
<% content_for :title, "Edit invoice #{@invoice.invoice_number}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_invoice_path(@customer, @invoice), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to invoice
        <% end %>
      </div>
      <div class="pagehead__title">Edit invoice <span class="mono muted">· <%= @invoice.invoice_number %></span></div>
    </div>
  </div>

  <%= form_with model: [:customer, @customer, @invoice], url: customer_invoice_path(@customer, @invoice), method: :patch,
        class: "col", html: { style: "gap:var(--space-5)" } do |f| %>
    <% if @invoice.errors.any? %>
      <%= render "settings/errors", record: @invoice %>
    <% end %>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Invoice details</div></div>
      <div class="sect__body">
        <div class="grid grid-2">
          <%= render "shared/relay_field", f: f, field: :project_name, label: "Project name" %>
          <%= render "shared/relay_field", f: f, field: :status, type: "select",
                options: [["Pending", "pending"], ["Paid", "paid"]] %>
          <div style="grid-column:1 / -1">
            <%= render "shared/relay_field", f: f, field: :description, type: "textarea", rows: 2 %>
          </div>
          <%= render "shared/relay_field", f: f, field: :issue_date, type: "date", required: true %>
          <%= render "shared/relay_field", f: f, field: :due_date, type: "date", required: true %>
          <div class="rl-field">
            <%= f.label :tax_rate, "Tax rate (%)", class: "rl-label" %>
            <%= f.number_field :tax_rate, step: 0.01, class: "rl-input mono" %>
          </div>
        </div>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Payment</div></div>
      <div class="sect__body">
        <div class="grid grid-2">
          <%= render "shared/relay_field", f: f, field: :payment_link_label, label: "Payment link label",
                type: "select", include_blank: "Select…",
                options: [["Stripe", "Stripe"], ["Payoneer", "Payoneer"], ["PayPal", "PayPal"], ["Bank Transfer", "Bank Transfer"], ["Other", "Other"]] %>
          <%= render "shared/relay_field", f: f, field: :payment_link, type: "url", label: "Payment link URL",
                placeholder: "https://payment.stripe.com/…" %>
        </div>
        <p class="rl-help" style="margin-top:8px">Optional: add a label (Stripe, Payoneer, etc.) and payment link for the customer.</p>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Line items</div></div>
      <div class="sect__body">
        <div id="invoice-line-items" class="col" style="gap:10px">
          <%= f.fields_for :invoice_line_items do |item_f| %>
            <div class="row" style="gap:12px;align-items:flex-start;padding:12px;background:var(--color-surface-2);border-radius:var(--radius-md)">
              <div class="grow">
                <%= item_f.text_field :description, class: "rl-input", placeholder: "Description" %>
              </div>
              <div style="width:140px">
                <%= item_f.number_field :amount, step: 0.01, class: "rl-input mono", placeholder: "Amount" %>
              </div>
              <%= item_f.hidden_field :position %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="row" style="justify-content:flex-end;gap:8px">
      <%= link_to "Cancel", customer_invoice_path(@customer, @invoice), class: "rl-btn rl-btn--secondary" %>
      <%= f.submit "Update invoice", class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
    </div>
  <% end %>
</div>
