<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <%= link_to customer_invoice_path(@customer, @invoice), class: "text-sm text-gray-600 hover:text-gray-900 flex items-center mb-2" do %>
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Invoice
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900">Edit Invoice <%= @invoice.invoice_number %></h1>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= form_with model: [:customer, @customer, @invoice], url: customer_invoice_path(@customer, @invoice), method: :patch, class: "space-y-6" do |f| %>
      <% if @invoice.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
          <ul class="list-disc list-inside">
            <% @invoice.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :project_name, "Project Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :project_name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
        <div>
          <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :status, [["Pending", "pending"], ["Paid", "paid"]], {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
        <div>
          <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :description, rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
        <div>
          <%= f.label :issue_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :issue_date, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", required: true %>
        </div>
        <div>
          <%= f.label :due_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :due_date, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", required: true %>
        </div>
        <div>
          <%= f.label :tax_rate, "Tax Rate (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :tax_rate, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :payment_link_label, "Payment Link Label", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <% payment_labels = [["Stripe", "Stripe"], ["Payoneer", "Payoneer"], ["PayPal", "PayPal"], ["Bank Transfer", "Bank Transfer"], ["Other", "Other"]] %>
          <%= f.select :payment_link_label, payment_labels, { include_blank: "Select..." }, { class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" } %>
        </div>
        <div>
          <%= f.label :payment_link, "Payment Link URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.url_field :payment_link, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "https://payment.stripe.com/..." %>
        </div>
      </div>
      <p class="text-xs text-gray-500">Optional: Add label (Stripe, Payoneer, etc.) and payment link for the customer</p>

      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-3">Line Items</h3>
        <div id="invoice-line-items" class="space-y-3">
          <%= f.fields_for :invoice_line_items do |item_f| %>
            <div class="flex gap-4 items-start p-3 bg-gray-50 rounded-lg">
              <div class="flex-1">
                <%= item_f.text_field :description, class: "block w-full rounded-lg border-gray-300 shadow-sm", placeholder: "Description" %>
              </div>
              <div class="w-32">
                <%= item_f.number_field :amount, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm", placeholder: "Amount" %>
              </div>
              <%= item_f.hidden_field :position %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Update Invoice", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium cursor-pointer" %>
        <%= link_to "Cancel", customer_invoice_path(@customer, @invoice), class: "px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
