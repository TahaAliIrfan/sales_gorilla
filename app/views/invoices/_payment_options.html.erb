<div class="space-y-6" data-controller="nested-form">
  <div>
    <%= f.label :bank_account_id, "Bank transfer account", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :bank_account_id, bank_accounts, :id, :label,
          { include_blank: "No bank transfer" },
          { class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" } %>
    <p class="mt-1 text-xs text-gray-500">
      Optional. Bank details (US / UK / AUS) are shown to the customer on the invoice.
      <% if bank_accounts.blank? %>
        No bank accounts configured yet.
      <% end %>
    </p>
  </div>

  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="block text-sm font-medium text-gray-700">Online payment links</label>
      <button type="button" data-action="nested-form#add"
              class="text-sm font-medium text-emerald-600 hover:text-emerald-800">+ Add link</button>
    </div>

    <div data-nested-form-target="list" class="space-y-3">
      <%= f.fields_for :invoice_payment_links do |link_f| %>
        <%= render "invoice_payment_link_fields", f: link_f %>
      <% end %>
    </div>

    <template data-nested-form-target="template">
      <%= f.fields_for :invoice_payment_links, InvoicePaymentLink.new, child_index: "NEW_RECORD" do |link_f| %>
        <%= render "invoice_payment_link_fields", f: link_f %>
      <% end %>
    </template>

    <p class="mt-2 text-xs text-gray-500">Optional: add one or more links (Stripe, Payoneer, PayPal, etc.) for the customer to pay online.</p>
  </div>
</div>
