<%# Invoice detail — relay DS. Keeps Edit / Download PDF / Mark Paid (mark_paid
    endpoint, pending? gate), the client public link + copy, payment proof, payment
    link, and the subtotal/tax/total summary. %>
<% content_for :title, "Invoice #{@invoice.invoice_number}" %>
<% paid = @invoice.paid? %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_invoices_path(@customer), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to invoices
        <% end %>
      </div>
      <div class="pagehead__title row" style="gap:10px;align-items:center">
        Invoice <span class="mono muted">· <%= @invoice.invoice_number %></span>
        <% if paid %>
          <span class="rl-badge rl-badge--success"><%= relay_icon("check-circle-2", size: 11) %>Paid</span>
        <% else %>
          <span class="rl-badge rl-badge--info"><%= relay_icon("hourglass", size: 11) %>Pending</span>
        <% end %>
      </div>
      <div class="pagehead__sub"><%= @invoice.project_name.presence || @invoice.milestone&.name %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to edit_customer_invoice_path(@customer, @invoice), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit
      <% end %>
      <%= link_to download_pdf_customer_invoice_path(@customer, @invoice), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("download", size: 15) %>Download PDF
      <% end %>
      <% if @invoice.pending? %>
        <%= button_to mark_paid_customer_invoice_path(@customer, @invoice), method: :patch, class: "rl-btn rl-btn--primary" do %>
          <%= relay_icon("check", size: 15) %>Mark paid
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="sect">
    <div class="sect__body">
      <div class="grid grid-2" style="margin-bottom:24px">
        <div>
          <div class="muted" style="margin-bottom:6px;font-size:var(--text-2xs);font-weight:700;letter-spacing:.06em;text-transform:uppercase">Bill to</div>
          <div class="rl-cell-strong"><%= @customer.name %></div>
          <div class="muted rl-sm">
            <%= @customer.company if @customer.company.present? %>
            <% if @customer.email.present? %><br><%= @customer.email %><% end %>
            <% if @customer.address.present? %><br><%= @customer.address %><% end %>
          </div>
        </div>
        <div style="text-align:right">
          <div class="rl-sm muted">Issue date <span class="mono" style="color:var(--color-fg)"><%= @invoice.issue_date.strftime("%B %-d, %Y") %></span></div>
          <div class="rl-sm muted" style="margin-top:4px">Due date <span class="mono" style="color:var(--color-fg)"><%= @invoice.due_date.strftime("%B %-d, %Y") %></span></div>
        </div>
      </div>

      <div class="rl-table-scroll">
        <table class="rl-table">
          <thead><tr><th>Description</th><th style="text-align:right">Amount</th></tr></thead>
          <tbody>
            <% @invoice.invoice_line_items.each do |item| %>
              <tr><td><%= item.description %></td><td class="rl-cell-num"><%= relay_money(item.amount) %></td></tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div style="margin-top:20px;margin-left:auto;width:260px">
        <div class="spread" style="padding:6px 0"><span class="muted rl-sm">Subtotal</span><span class="mono"><%= relay_money(@invoice.subtotal) %></span></div>
        <% if @invoice.tax_amount.to_f > 0 %>
          <div class="spread" style="padding:6px 0"><span class="muted rl-sm">Tax (<%= @invoice.tax_rate %>%)</span><span class="mono"><%= relay_money(@invoice.tax_amount) %></span></div>
        <% end %>
        <div class="spread" style="padding:12px 0 0;border-top:2px solid var(--color-border-strong);margin-top:6px">
          <span class="rl-h4">Total</span><span class="rl-h4 mono"><%= relay_money(@invoice.total) %></span>
        </div>
      </div>
    </div>
  </div>

  <% if @invoice.payment_proof.attached? %>
    <div class="sect"><div class="sect__body" style="background:var(--color-success-subtle);border-radius:var(--radius-lg)">
      <div class="rl-cell-strong" style="color:var(--color-success-text)">Payment proof submitted</div>
      <div class="muted rl-sm" style="margin-top:4px">Submitted on <%= @invoice.payment_proof.created_at.strftime("%B %-d, %Y at %l:%M %p") %></div>
      <%= link_to rails_blob_path(@invoice.payment_proof, disposition: "attachment"), target: "_blank",
            class: "rl-btn rl-btn--ghost rl-btn--sm", style: "margin-top:8px" do %>
        <%= relay_icon("download", size: 14) %>View / Download
      <% end %>
    </div></div>
  <% end %>

  <% if @invoice.public_token.present? %>
    <div class="sect"><div class="sect__body">
      <div class="rl-cell-strong">Client view link</div>
      <div class="muted rl-sm" style="margin:4px 0 12px">Share this link with the customer to view the invoice, download the PDF, and upload payment proof.</div>
      <div class="row" style="gap:8px;flex-wrap:wrap;align-items:center">
        <code class="rl-chip mono grow" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= public_invoice_url(@invoice.public_token) %></code>
        <button type="button" class="rl-btn rl-btn--secondary rl-btn--sm"
                data-url="<%= public_invoice_url(@invoice.public_token) %>"
                onclick="navigator.clipboard.writeText(this.dataset.url); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 2000)">Copy</button>
      </div>
    </div></div>
  <% end %>

  <% if @invoice.payment_link.present? %>
    <div class="sect"><div class="sect__body">
      <div class="rl-cell-strong">Pay online<% if @invoice.payment_link_label.present? %> — <%= @invoice.payment_link_label %><% end %></div>
      <%= link_to @invoice.payment_link, @invoice.payment_link, target: "_blank", rel: "noopener",
            class: "rl-sm", style: "color:var(--color-primary-text);word-break:break-all" %>
    </div></div>
  <% end %>
</div>
