<%# Per-customer invoices list — relay DS. Keeps the nested customer_invoices
    scope; Edit / Download PDF actions wired to the existing endpoints. %>
<% content_for :title, "Invoices — #{@customer.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to customer_path(@customer), class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Back to <%= @customer.name %>
        <% end %>
      </div>
      <div class="pagehead__title">Invoices</div>
      <div class="pagehead__sub">Manage invoices for <%= @customer.name %>.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_customer_invoice_path(@customer), class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>New invoice
      <% end %>
    </div>
  </div>

  <% if @invoices.any? %>
    <div class="sect">
      <div class="sect__body--flush">
        <div class="rl-table-scroll">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Invoice</th>
                <th>Project</th>
                <th>Issued</th>
                <th>Due</th>
                <th style="text-align:right">Total</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @invoices.each do |invoice| %>
                <tr>
                  <td class="rl-cell-strong mono"><%= invoice.invoice_number %></td>
                  <td class="muted"><%= invoice.project_name.presence || invoice.milestone&.name %></td>
                  <td class="mono rl-sm"><%= invoice.issue_date&.strftime("%b %-d, %Y") %></td>
                  <td class="mono rl-sm"><%= invoice.due_date&.strftime("%b %-d, %Y") %></td>
                  <td class="rl-cell-num"><%= relay_money(invoice.total) %></td>
                  <td>
                    <div class="row" style="gap:6px;justify-content:flex-end">
                      <%= link_to edit_customer_invoice_path(@customer, invoice), class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                        <%= relay_icon("pencil", size: 14) %>Edit
                      <% end %>
                      <%= link_to download_pdf_customer_invoice_path(@customer, invoice), class: "rl-iconbtn rl-iconbtn--sm", title: "Download PDF" do %>
                        <%= relay_icon("download", size: 15) %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
      <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-fg-3)"><%= relay_icon("receipt", size: 22) %></span>
      <div class="rl-h4">No invoices</div>
      <div class="muted rl-sm" style="margin-top:6px">Create an invoice from a milestone. First add a milestone with a payment schedule.</div>
      <div style="margin-top:16px">
        <%= link_to new_customer_invoice_path(@customer), class: "rl-btn rl-btn--primary rl-btn--sm" do %>
          <%= relay_icon("plus", size: 14) %>New invoice
        <% end %>
      </div>
    </div></div>
  <% end %>
</div>
