<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <%= link_to customer_path(@customer), class: "text-sm text-gray-600 hover:text-gray-900 flex items-center mb-2" do %>
        <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to <%= @customer.name %>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900">Invoices</h1>
      <p class="text-gray-600 mt-1">Manage invoices for <%= @customer.name %></p>
    </div>
    <%= link_to new_customer_invoice_path(@customer), class: "inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium text-sm shadow-sm" do %>
      <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      New Invoice
    <% end %>
  </div>

  <% if @invoices.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invoice #</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Project</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Issue Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Due Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @invoices.each do |invoice| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= invoice.invoice_number %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= invoice.project_name.presence || invoice.milestone.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= invoice.issue_date.strftime('%b %d, %Y') %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= invoice.due_date.strftime('%b %d, %Y') %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900"><%= number_to_currency(invoice.total) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <%= link_to "Edit", edit_customer_invoice_path(@customer, invoice), class: "text-emerald-600 hover:text-emerald-800 font-medium mr-3" %>
                <%= link_to "Download PDF", download_pdf_customer_invoice_path(@customer, invoice), class: "text-purple-600 hover:text-purple-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No invoices</h3>
      <p class="mt-1 text-sm text-gray-500">Create an invoice from a milestone. First add a milestone with payment schedule.</p>
      <div class="mt-6">
        <%= link_to new_customer_invoice_path(@customer), class: "inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium text-sm" do %>
          <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Invoice
        <% end %>
      </div>
    </div>
  <% end %>
</div>
