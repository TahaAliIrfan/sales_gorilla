<div>
  <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">From</h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <% CompanyInfo.entities.each do |entity| %>
      <div class="text-sm leading-5">
        <p class="font-semibold text-slate-900"><%= entity[:name] %></p>
        <p class="text-xs text-slate-500 mb-1"><%= entity[:subtitle] %></p>
        <% entity[:lines].each do |line| %>
          <p class="text-slate-600"><%= line %></p>
        <% end %>
        <% if entity[:reg_number].present? %>
          <p class="text-slate-600 mt-1"><span class="font-medium"><%= entity[:reg_label] %>:</span> <%= entity[:reg_number] %></p>
        <% end %>
      </div>
    <% end %>
  </div>
  <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-slate-500">
    <% CompanyInfo.phones.each do |phone| %>
      <span><span class="font-medium text-slate-600"><%= phone[:label] %>:</span> <%= phone[:number] %></span>
    <% end %>
    <span><%= CompanyInfo.email %></span>
    <span><%= CompanyInfo.website %></span>
  </div>
</div>
