<% content_for :title, "Notifications — #{current_organization&.name}" %>
<% filter_tabs = [ %w[all All], %w[unread Unread], %w[read Read] ] %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Notifications</div>
      <div class="pagehead__sub">Your notification history.</div>
    </div>
    <div class="pagehead__actions">
      <% if @unread_notifications.any? %>
        <%= button_to mark_all_as_read_notifications_path, method: :post, class: "rl-btn rl-btn--primary" do %>
          <%= relay_icon("check-check", size: 15) %>Mark all as read
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="rl-tabs" style="margin-bottom:var(--space-4)">
    <% filter_tabs.each do |val, label| %>
      <%= link_to label, notifications_path(filter: val),
            class: "rl-tab #{'is-active' if @filter == val}" %>
    <% end %>
  </div>

  <div class="sect">
    <div class="sect__body--flush">
      <% if @notifications.empty? %>
        <div class="empty">
          <span class="empty__ic"><%= relay_icon("bell", size: 26) %></span>
          <div class="rl-h4" style="margin-bottom:4px">No notifications</div>
          <div class="muted rl-sm" style="max-width:360px">You don't have any <%= @filter == "all" ? "" : @filter %> notifications yet.</div>
        </div>
      <% else %>
        <div class="rl-list">
          <% @notifications.each do |notification| %>
            <div class="rl-listitem" style="<%= "background:var(--color-brand-subtle, var(--color-bg-2))" unless notification.read? %>">
              <span class="rl-avatar rl-avatar--sm <%= notification.read? ? "rl-avatar--c4" : "rl-avatar--c1" %>">
                <%= relay_icon("bell", size: 15) %>
              </span>
              <div class="rl-listitem__main">
                <div class="rl-listitem__title">
                  <%= notification.notification_type.to_s.capitalize %>
                  <% unless notification.read? %><span class="rl-dot" style="background:var(--color-primary);margin-left:6px"></span><% end %>
                </div>
                <div class="rl-listitem__sub"><%= notification.content %></div>
                <div class="muted rl-xs" style="margin-top:4px">
                  <%= relay_icon("clock", size: 12) %> <%= time_ago_in_words(notification.created_at) %> ago
                </div>
              </div>
              <div class="row" style="gap:6px">
                <% if notification.resource.present? %>
                  <%= link_to "View", notification_path(notification), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                <% end %>
                <% unless notification.read? %>
                  <%= button_to mark_as_read_notification_path(notification), method: :post, class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                    Mark as read
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="rl-pagebtns" style="padding:var(--space-4)"><%= paginate @notifications, theme: "relay" %></div>
      <% end %>
    </div>
  </div>
</div>
