<div>
  <h1 class="text-2xl font-bold mb-6">My Tasks Dashboard</h1>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Pending Tasks Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Pending Tasks</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @pending_tasks_count %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_tasks_tasks_path(status: 'pending'), class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View pending tasks
          <% end %>
        </div>
      </div>
    </div>

    <!-- Today's Tasks Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Today's Tasks</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @today_tasks_count %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_tasks_tasks_path(due_date: 'today'), class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View today's tasks
          <% end %>
        </div>
      </div>
    </div>

    <!-- Overdue Tasks Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Overdue Tasks</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @overdue_tasks_count %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_tasks_tasks_path(due_date: 'overdue'), class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View overdue tasks
          <% end %>
        </div>
      </div>
    </div>

    <!-- Completed Tasks Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Completed Tasks</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @completed_tasks_count %></div>
                <% if @recent_completions_count > 0 %>
                  <div class="ml-2 text-sm font-medium text-green-600">
                    +<%= @recent_completions_count %> in last 7 days
                  </div>
                <% end %>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_tasks_tasks_path(status: 'completed'), class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View completed tasks
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Tasks by Priority and Status -->
  <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Tasks by Priority -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Tasks by Priority</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-around space-x-4">
          <div class="text-center">
            <div class="rounded-full h-16 w-16 flex items-center justify-center bg-green-100 mx-auto">
              <span class="text-2xl font-semibold text-green-700"><%= @tasks_by_priority['Low'] %></span>
            </div>
            <p class="mt-2 text-sm font-medium text-gray-500">Low</p>
          </div>
          <div class="text-center">
            <div class="rounded-full h-16 w-16 flex items-center justify-center bg-yellow-100 mx-auto">
              <span class="text-2xl font-semibold text-yellow-700"><%= @tasks_by_priority['Medium'] %></span>
            </div>
            <p class="mt-2 text-sm font-medium text-gray-500">Medium</p>
          </div>
          <div class="text-center">
            <div class="rounded-full h-16 w-16 flex items-center justify-center bg-red-100 mx-auto">
              <span class="text-2xl font-semibold text-red-700"><%= @tasks_by_priority['High'] %></span>
            </div>
            <p class="mt-2 text-sm font-medium text-gray-500">High</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Tasks by Status -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Tasks by Status</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-around space-x-4">
          <div class="text-center">
            <div class="rounded-full h-16 w-16 flex items-center justify-center bg-yellow-100 mx-auto">
              <span class="text-2xl font-semibold text-yellow-700"><%= @tasks_by_status['Pending'] %></span>
            </div>
            <p class="mt-2 text-sm font-medium text-gray-500">Pending</p>
          </div>
          <div class="text-center">
            <div class="rounded-full h-16 w-16 flex items-center justify-center bg-blue-100 mx-auto">
              <span class="text-2xl font-semibold text-blue-700"><%= @tasks_by_status['In Progress'] %></span>
            </div>
            <p class="mt-2 text-sm font-medium text-gray-500">In Progress</p>
          </div>
          <div class="text-center">
            <div class="rounded-full h-16 w-16 flex items-center justify-center bg-green-100 mx-auto">
              <span class="text-2xl font-semibold text-green-700"><%= @tasks_by_status['Completed'] %></span>
            </div>
            <p class="mt-2 text-sm font-medium text-gray-500">Completed</p>
          </div>
          <div class="text-center">
            <div class="rounded-full h-16 w-16 flex items-center justify-center bg-gray-100 mx-auto">
              <span class="text-2xl font-semibold text-gray-700"><%= @tasks_by_status['Cancelled'] %></span>
            </div>
            <p class="mt-2 text-sm font-medium text-gray-500">Cancelled</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- High Priority Tasks -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">High Priority Tasks</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @high_priority_tasks.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @high_priority_tasks.each_with_index do |task, index| %>
                <li class="py-4">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <div class="min-w-0 flex-1 flex items-center">
                        <div class="flex-shrink-0 mr-2">
                          <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-red-100 text-red-800 text-xs font-medium">
                            <%= index + 1 %>
                          </span>
                        </div>
                        <div class="min-w-0 flex-1 px-4">
                          <div>
                            <div class="flex">
                              <p class="text-sm font-medium text-red-600 truncate">
                                <%= link_to task.title, task_path(task) %>
                              </p>
                              <% if task.overdue? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800 rounded-full">
                                  Overdue
                                </span>
                              <% elsif task.due_today? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">
                                  Due Today
                                </span>
                              <% end %>
                            </div>
                            <p class="mt-1 text-sm text-gray-500">
                              Due: <%= task.due_date.strftime("%b %d, %I:%M %p") %>
                              <% if task.customer.present? %>
                                • Customer: <%= link_to task.customer.name, customer_path(task.customer), class: "text-blue-600 hover:text-blue-900" %>
                              <% end %>
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="flex-shrink-0 flex items-center">
                      <%= button_to complete_task_path(task, return_to: 'my_tasks_dashboard'), method: :patch, class: "mr-2 rounded-full p-1 bg-green-100 hover:bg-green-200 text-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      <% end %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center text-gray-500 py-4">
            No high priority tasks at the moment
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recently Completed Tasks -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Recently Completed Tasks</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @recently_completed_tasks.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @recently_completed_tasks.each_with_index do |task, index| %>
                <li class="py-4">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 mr-2">
                      <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-green-100 text-green-800 text-xs font-medium">
                        <%= index + 1 %>
                      </span>
                    </div>
                    <div class="flex-1">
                      <h4 class="text-sm font-medium text-gray-500 line-through">
                        <%= link_to task.title, task_path(task) %>
                        <span class="ml-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Completed</span>
                      </h4>
                      <p class="text-xs text-gray-500">
                        Completed <%= time_ago_in_words(task.updated_at) %> ago
                        <% if task.customer %>
                         • <%= task.customer.name %>
                        <% end %>
                      </p>
                    </div>
                    <div>
                      <span class="rounded-full p-1 bg-gray-100 text-gray-500">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-green-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </span>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center text-gray-500 py-4">
            No completed tasks recently
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Today's Tasks -->
  <div class="mt-8">
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Today's Tasks</h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">
          Tasks due today (including completed)
        </p>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @today_tasks.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @today_tasks.each_with_index do |task, index| %>
                <li class="py-4">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <div class="min-w-0 flex-1 flex items-center">
                        <div class="flex-shrink-0 mr-2">
                          <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-blue-100 text-blue-800 text-xs font-medium">
                            <%= index + 1 %>
                          </span>
                        </div>
                        <div class="flex-shrink-0">
                          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                            <%= case task.priority
                                when 'High' then 'bg-red-100 text-red-800'
                                when 'Medium' then 'bg-yellow-100 text-yellow-800'
                                when 'Low' then 'bg-green-100 text-green-800'
                                end %>">
                            <%= task.priority %>
                          </span>
                        </div>
                        <div class="min-w-0 flex-1 px-4">
                          <div>
                            <div class="flex">
                              <p class="text-sm font-medium <%= task.completed? ? 'text-gray-500 line-through' : 'text-blue-600' %> truncate">
                                <%= link_to task.title, task_path(task) %>
                              </p>
                              <% if task.completed? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-600 rounded-full">
                                  Completed
                                </span>
                              <% elsif task.in_progress? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-purple-100 text-purple-800 rounded-full">
                                  In Progress
                                </span>
                              <% elsif task.pending? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">
                                  Pending
                                </span>
                              <% elsif task.cancelled? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800 rounded-full">
                                  Cancelled
                                </span>
                              <% end %>
                            </div>
                            <p class="mt-1 text-sm text-gray-500">
                              Due: <%= task.due_date.strftime("%I:%M %p") %>
                              <% if task.customer.present? %>
                                • Customer: <%= link_to task.customer.name, customer_path(task.customer), class: "text-blue-600 hover:text-blue-900" %>
                              <% end %>
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="flex-shrink-0 flex items-center">
                      <% unless task.completed? || task.cancelled? %>
                        <%= button_to complete_task_path(task, return_to: 'my_tasks_dashboard'), method: :patch, class: "mr-2 rounded-full p-1 bg-green-100 hover:bg-green-200 text-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                          </svg>
                        <% end %>
                      <% else %>
                        <span class="mr-2 rounded-full p-1 bg-gray-100 text-gray-500">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-500">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                          </svg>
                        </span>
                      <% end %>
                      <%= link_to edit_task_path(task), class: "text-gray-500 hover:text-gray-700" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                        </svg>
                      <% end %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center text-gray-500 py-4">
            No tasks due today
          </div>
        <% end %>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to new_task_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            Create new task
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- All Tasks with Tabs -->
  <div class="mt-8">
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <div class="flex justify-between items-center mb-2">
          <h3 class="text-lg font-medium leading-6 text-gray-900">All My Tasks</h3>
          <%= link_to new_task_path, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
            <svg class="-ml-0.5 mr-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            New
          <% end %>
        </div>
        
        <!-- Status Tabs -->
        <nav class="-mb-px flex space-x-6" aria-label="Tabs">
          <%= link_to "Today", my_tasks_dashboard_index_path(tab: 'today'), class: "#{params[:tab] == 'today' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" %>
          
          <%= link_to "Pending", my_tasks_dashboard_index_path(tab: 'pending'), class: "#{params[:tab] == 'pending' ? 'border-yellow-500 text-yellow-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" %>
          
          <%= link_to "In Progress", my_tasks_dashboard_index_path(tab: 'in_progress'), class: "#{params[:tab] == 'in_progress' ? 'border-purple-500 text-purple-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" %>
          
          <%= link_to "Completed", my_tasks_dashboard_index_path(tab: 'completed'), class: "#{params[:tab] == 'completed' ? 'border-green-500 text-green-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" %>
          
          <%= link_to "Cancelled", my_tasks_dashboard_index_path(tab: 'cancelled'), class: "#{params[:tab] == 'cancelled' ? 'border-gray-500 text-gray-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" %>
        </nav>
      </div>
      
      <div class="px-4 py-5 sm:p-6">
        <% if @filtered_tasks.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @filtered_tasks.each_with_index do |task, index| %>
                <li class="py-4">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <div class="min-w-0 flex-1 flex items-center">
                        <div class="flex-shrink-0 mr-2">
                          <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-blue-100 text-blue-800 text-xs font-medium">
                            <%= index + 1 %>
                          </span>
                        </div>
                        <div class="flex-shrink-0">
                          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                            <%= case task.priority
                                when 'High' then 'bg-red-100 text-red-800'
                                when 'Medium' then 'bg-yellow-100 text-yellow-800'
                                when 'Low' then 'bg-green-100 text-green-800'
                                end %>">
                            <%= task.priority %>
                          </span>
                        </div>
                        <div class="min-w-0 flex-1 px-4">
                          <div>
                            <div class="flex">
                              <p class="text-sm font-medium <%= task.completed? ? 'text-gray-500 line-through' : 'text-blue-600' %> truncate">
                                <%= link_to task.title, task_path(task) %>
                              </p>
                              <% if task.completed? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800 rounded-full">
                                  Completed
                                </span>
                              <% elsif task.overdue? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800 rounded-full">
                                  Overdue
                                </span>
                              <% elsif task.due_today? && task.pending? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">
                                  Due Today
                                </span>
                              <% elsif task.pending? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">
                                  Pending
                                </span>
                              <% elsif task.in_progress? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-purple-100 text-purple-800 rounded-full">
                                  In Progress
                                </span>
                              <% elsif task.cancelled? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800 rounded-full">
                                  Cancelled
                                </span>
                              <% end %>
                            </div>
                            <p class="mt-1 text-sm text-gray-500">
                              Due: <%= task.due_date.strftime("%b %d, %Y at %I:%M %p") %>
                              <% if task.customer.present? %>
                                • Customer: <%= link_to task.customer.name, customer_path(task.customer), class: "text-blue-600 hover:text-blue-900" %>
                              <% end %>
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="flex-shrink-0 flex items-center">
                      <% unless task.completed? || task.cancelled? %>
                        <%= button_to complete_task_path(task, return_to: 'my_tasks_dashboard'), method: :patch, class: "mr-2 rounded-full p-1 bg-green-100 hover:bg-green-200 text-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                          </svg>
                        <% end %>
                      <% else %>
                        <span class="mr-2 rounded-full p-1 bg-gray-100 text-gray-500">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-500">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                          </svg>
                        </span>
                      <% end %>
                      <%= link_to edit_task_path(task), class: "text-gray-500 hover:text-gray-700" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                        </svg>
                      <% end %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center text-gray-500 py-4">
            No tasks found in this category
          </div>
        <% end %>
      </div>
      
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_tasks_tasks_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all tasks
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div> 