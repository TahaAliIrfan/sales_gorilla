<% content_for :title, "My tasks dashboard — #{current_organization&.name}" %>
<%
  tab_defs = [ %w[today Today], %w[pending Pending], %w[in_progress In\ progress], %w[completed Completed], %w[cancelled Cancelled] ]
  active_tab = params[:tab].presence || "today"
%>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">My tasks dashboard</div>
      <div class="pagehead__sub">Your workload at a glance.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_task_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>New task
      <% end %>
    </div>
  </div>

  <%# Stat tiles %>
  <div class="grid grid-4" style="margin-bottom:var(--space-6)">
    <%= link_to my_tasks_tasks_path(status: "pending"), style: "text-decoration:none;color:inherit" do %>
      <%= render "user_dashboard/stat", label: "Pending tasks", value: @pending_tasks_count, sub: "View pending tasks", icon: "clock" %>
    <% end %>
    <%= link_to my_tasks_tasks_path(due_date: "today"), style: "text-decoration:none;color:inherit" do %>
      <%= render "user_dashboard/stat", label: "Today's tasks", value: @today_tasks_count, sub: "View today's tasks", icon: "calendar" %>
    <% end %>
    <%= link_to my_tasks_tasks_path(due_date: "overdue"), style: "text-decoration:none;color:inherit" do %>
      <%= render "user_dashboard/stat", label: "Overdue tasks", value: @overdue_tasks_count, sub: "View overdue tasks", icon: "alert-triangle" %>
    <% end %>
    <%= link_to my_tasks_tasks_path(status: "completed"), style: "text-decoration:none;color:inherit" do %>
      <%= render "user_dashboard/stat", label: "Completed tasks", value: @completed_tasks_count,
            sub: (@recent_completions_count.to_i > 0 ? "+#{@recent_completions_count} in last 7 days" : "View completed tasks"), icon: "check-square" %>
    <% end %>
  </div>

  <%# By priority / by status %>
  <div class="grid grid-2" style="margin-bottom:var(--space-6)">
    <div class="sect">
      <div class="sect__head"><div class="sect__title">Tasks by priority</div></div>
      <div class="sect__body row" style="justify-content:space-around">
        <% [ [ "Low", "var(--color-fg-4)" ], [ "Medium", "var(--color-warning)" ], [ "High", "var(--color-danger)" ] ].each do |label, color| %>
          <div style="text-align:center">
            <div class="mono" style="font-size:28px;font-weight:800;color:<%= color %>"><%= @tasks_by_priority[label] %></div>
            <div class="muted rl-sm"><%= label %></div>
          </div>
        <% end %>
      </div>
    </div>
    <div class="sect">
      <div class="sect__head"><div class="sect__title">Tasks by status</div></div>
      <div class="sect__body row" style="justify-content:space-around">
        <% [ [ "Pending", "var(--color-warning)" ], [ "In Progress", "var(--color-primary)" ], [ "Completed", "var(--color-success)" ], [ "Cancelled", "var(--color-fg-4)" ] ].each do |label, color| %>
          <div style="text-align:center">
            <div class="mono" style="font-size:28px;font-weight:800;color:<%= color %>"><%= @tasks_by_status[label] %></div>
            <div class="muted rl-sm"><%= label %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# High priority / recently completed %>
  <div class="grid grid-2" style="margin-bottom:var(--space-6)">
    <div class="sect">
      <div class="sect__head"><div class="sect__title">High priority tasks</div></div>
      <div class="sect__body--flush">
        <% if @high_priority_tasks.any? %>
          <div class="rl-list">
            <% @high_priority_tasks.each do |task| %>
              <%= render "tasks/row", task: task, return_to: "my_tasks_dashboard", show_edit: false %>
            <% end %>
          </div>
        <% else %>
          <div class="muted" style="text-align:center;padding:var(--space-6)">No high priority tasks at the moment.</div>
        <% end %>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Recently completed tasks</div></div>
      <div class="sect__body--flush">
        <% if @recently_completed_tasks.any? %>
          <div class="rl-list">
            <% @recently_completed_tasks.each do |task| %>
              <%= render "tasks/row", task: task, return_to: "my_tasks_dashboard", show_edit: false %>
            <% end %>
          </div>
        <% else %>
          <div class="muted" style="text-align:center;padding:var(--space-6)">No completed tasks recently.</div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Today's tasks %>
  <div class="sect" style="margin-bottom:var(--space-6)">
    <div class="sect__head"><div class="sect__title">Today's tasks</div></div>
    <div class="sect__body--flush">
      <% if @today_tasks.any? %>
        <div class="rl-list">
          <% @today_tasks.each do |task| %>
            <%= render "tasks/row", task: task, return_to: "my_tasks_dashboard" %>
          <% end %>
        </div>
      <% else %>
        <div class="muted" style="text-align:center;padding:var(--space-6)">No tasks due today.</div>
      <% end %>
    </div>
  </div>

  <%# All my tasks with tabs %>
  <div class="sect">
    <div class="sect__head">
      <div class="sect__title">All my tasks</div>
    </div>
    <div class="rl-tabs" style="padding:0 var(--space-4)">
      <% tab_defs.each do |val, label| %>
        <%= link_to label, my_tasks_dashboard_path(tab: val),
              class: "rl-tab #{'is-active' if active_tab == val}" %>
      <% end %>
    </div>
    <div class="sect__body--flush">
      <% if @filtered_tasks.any? %>
        <div class="rl-list">
          <% @filtered_tasks.each do |task| %>
            <%= render "tasks/row", task: task, return_to: "my_tasks_dashboard" %>
          <% end %>
        </div>
      <% else %>
        <div class="muted" style="text-align:center;padding:var(--space-6)">No tasks found in this category.</div>
      <% end %>
    </div>
    <div class="sect__head" style="border-top:1px solid var(--color-divider);border-bottom:none">
      <%= link_to "View all tasks", my_tasks_tasks_path, class: "rl-btn rl-btn--ghost rl-btn--sm" %>
    </div>
  </div>
</div>
