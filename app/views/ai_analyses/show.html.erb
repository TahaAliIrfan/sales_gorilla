<%# Relay AI analysis detail. NOTE: this controller is currently unrouted (no
    resources :ai_analyses), so this page is not reachable in the app today — it
    is ported for DS-consistency in case a route is reintroduced. %>
<% content_for :title, "AI analysis — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">AI analysis</div>
      <div class="pagehead__sub">Analysis from <%= @analysis.created_at.strftime("%b %d, %Y %H:%M") %>.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to recording_path(@recording), class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to recording
      <% end %>
    </div>
  </div>

  <div class="sect" style="max-width:820px" data-controller="relay--copy">
    <div class="sect__body">
      <div style="margin-bottom:var(--space-5)">
        <div class="rl-eyebrow" style="margin-bottom:6px">Summary</div>
        <div class="rl-sm" style="line-height:1.6"><%= @analysis.summary %></div>
      </div>

      <div style="margin-bottom:var(--space-5)">
        <div class="rl-eyebrow" style="margin-bottom:6px">Interest score</div>
        <div class="row" style="gap:4px;align-items:center">
          <% @analysis.interest_score.to_i.times do %><span style="color:var(--color-warning, #eab308)"><%= relay_icon("award", size: 18) %></span><% end %>
          <% (5 - @analysis.interest_score.to_i).times do %><span style="color:var(--color-fg-4)"><%= relay_icon("award", size: 18) %></span><% end %>
          <span class="mono" style="margin-left:6px"><%= @analysis.interest_score %>/5</span>
        </div>
      </div>

      <div style="margin-bottom:var(--space-5)">
        <div class="rl-eyebrow" style="margin-bottom:6px">Improvement points</div>
        <div class="rl-sm" style="white-space:pre-line;line-height:1.6"><%= @analysis.improvement_points %></div>
      </div>

      <div style="margin-bottom:var(--space-5)">
        <div class="rl-eyebrow" style="margin-bottom:6px">Next steps</div>
        <div class="rl-sm" style="white-space:pre-line;line-height:1.6"><%= @analysis.next_steps %></div>
      </div>

      <% [ [ "Follow-up message (WhatsApp/Text)", @analysis.followup_message ], [ "Follow-up email", @analysis.followup_email ] ].each do |label, body| %>
        <div style="margin-bottom:var(--space-5)">
          <div class="rl-eyebrow" style="margin-bottom:6px"><%= label %></div>
          <div class="rl-card" style="padding:14px">
            <div class="rl-sm" style="white-space:pre-line;line-height:1.6" data-relay--copy-target="text"><%= body %></div>
            <button type="button" class="rl-btn rl-btn--secondary rl-btn--sm" style="margin-top:10px"
                    data-action="relay--copy#copy">
              <%= relay_icon("copy", size: 14) %>Copy to clipboard
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
