<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
    <div>
      <h2 class="text-2xl font-semibold text-gray-900">AI Analysis Details</h2>
      <p class="mt-1 text-sm text-gray-500">
        Analysis from <%= @analysis.created_at.strftime("%b %d, %Y %H:%M") %>
      </p>
    </div>
    <div>
      <%= link_to recording_path(@recording), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Recording
      <% end %>
    </div>
  </div>

  <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
    <div class="bg-gray-50 p-6 rounded-lg">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-8 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <dt class="text-lg font-medium text-gray-900">Summary</dt>
          <dd class="mt-1 text-base text-gray-900"><%= @analysis.summary %></dd>
        </div>
        
        <div class="sm:col-span-1">
          <dt class="text-lg font-medium text-gray-900">Interest Score</dt>
          <dd class="mt-1 text-base text-gray-900">
            <div class="flex items-center">
              <% @analysis.interest_score.to_i.times do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              <% end %>
              <% (5 - @analysis.interest_score.to_i).times do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              <% end %>
              <span class="ml-2 text-lg font-medium"><%= @analysis.interest_score %>/5</span>
            </div>
          </dd>
        </div>
        
        <div class="sm:col-span-2">
          <dt class="text-lg font-medium text-gray-900">Improvement Points</dt>
          <dd class="mt-1 text-base text-gray-900 whitespace-pre-line"><%= @analysis.improvement_points %></dd>
        </div>
        
        <div class="sm:col-span-2">
          <dt class="text-lg font-medium text-gray-900">Next Steps</dt>
          <dd class="mt-1 text-base text-gray-900 whitespace-pre-line"><%= @analysis.next_steps %></dd>
        </div>
        
        <div class="sm:col-span-2">
          <dt class="text-lg font-medium text-gray-900">Follow-up Message (WhatsApp/Text)</dt>
          <dd class="mt-1 text-base text-gray-900 whitespace-pre-line bg-white p-4 border border-gray-200 rounded">
            <%= @analysis.followup_message %>
            
            <div class="mt-4 flex">
              <button onclick="copyToClipboard('<%= j(@analysis.followup_message) %>')" class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Copy to Clipboard
              </button>
            </div>
          </dd>
        </div>
        
        <div class="sm:col-span-2">
          <dt class="text-lg font-medium text-gray-900">Follow-up Email</dt>
          <dd class="mt-1 text-base text-gray-900 whitespace-pre-line bg-white p-4 border border-gray-200 rounded">
            <%= @analysis.followup_email %>
            
            <div class="mt-4 flex">
              <button onclick="copyToClipboard('<%= j(@analysis.followup_email) %>')" class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Copy to Clipboard
              </button>
            </div>
          </dd>
        </div>
      </dl>
      
      <div class="mt-8 text-right">
        <%= link_to recording_path(@recording), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500" do %>
          Back to Recording
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(function() {
      // Show toast or notification
      alert('Copied to clipboard!');
    }, function(err) {
      console.error('Could not copy text: ', err);
    });
  }
</script> 