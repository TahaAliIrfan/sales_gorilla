<% content_for :title, "Manager dashboard — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Manager dashboard</div>
      <div class="pagehead__sub">Overview of your associates' performance over the last 30 days.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to root_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Today
      <% end %>
    </div>
  </div>

  <% if @associates.empty? %>
    <div class="sect">
      <div class="sect__body">
        <div class="empty">
          <span class="empty__ic"><%= relay_icon("users", size: 26) %></span>
          <div class="rl-h4" style="margin-bottom:4px">No associates assigned</div>
          <div class="muted rl-sm" style="max-width:360px">You don't have any associates assigned yet.</div>
          <% if current_user.admin? %>
            <div style="margin-top:16px"><%= link_to "Manage users", users_path, class: "rl-btn rl-btn--primary rl-btn--sm" %></div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="grid grid-3" style="margin-bottom:var(--space-5)">
      <%= render "user_dashboard/stat", label: "Total associates", value: @associates.count, sub: "on your team", icon: "users" %>
      <%= render "user_dashboard/stat", label: "Total customers", value: @total_customers, sub: "+#{@total_new_customers} in 30 days", icon: "user-check" %>
      <%= render "user_dashboard/stat", label: "Total recordings", value: @total_recordings, sub: "last 30 days", icon: "mic" %>
      <%= render "user_dashboard/stat", label: "Active deals", value: @total_active_deals, sub: "in pipeline", icon: "trending-up" %>
      <%= render "user_dashboard/stat", label: "Won deals", value: @total_won_deals, sub: "last 30 days", icon: "trophy" %>
      <%= render "user_dashboard/stat", label: "Deal value", value: relay_money(@total_deal_value), sub: "won · last 30 days", icon: "circle-dollar-sign" %>
    </div>

    <div class="sect">
      <div class="sect__head">
        <div class="sect__title">Associates performance</div>
        <div class="muted rl-sm">Key metrics for each associate in the last 30 days</div>
      </div>
      <div class="sect__body--flush">
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Associate</th>
                <th>Customers</th>
                <th>Activities</th>
                <th>Recordings</th>
                <th>Tasks</th>
                <th>Deals</th>
                <th style="text-align:right"></th>
              </tr>
            </thead>
            <tbody>
              <% @associates.each_with_index do |associate, i| %>
                <% metrics = @associate_metrics[associate.id] %>
                <tr>
                  <td>
                    <div class="row" style="gap:10px">
                      <span class="rl-avatar rl-avatar--sm rl-avatar--c<%= (i % 6) + 1 %>"><%= (associate.name.presence || associate.email).first.upcase %></span>
                      <div>
                        <div class="rl-cell-strong"><%= link_to associate.name, user_path(associate), style: "color:inherit" %></div>
                        <div class="muted" style="font-size:11px"><%= associate.email %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="rl-sm"><%= metrics[:customers_count] %> total</div>
                    <div class="rl-sm" style="color:var(--color-success-text)">+<%= metrics[:new_customers] %> new</div>
                  </td>
                  <td class="mono"><%= metrics[:recent_activities] %></td>
                  <td class="mono"><%= metrics[:recordings_count] %></td>
                  <td>
                    <div class="rl-sm"><%= metrics[:completed_tasks] %> completed</div>
                    <div class="rl-sm" style="color:var(--color-warning-text, var(--color-fg-3))"><%= metrics[:pending_tasks] %> pending</div>
                    <div class="rl-sm" style="color:var(--color-danger-text)"><%= metrics[:overdue_tasks] %> overdue</div>
                  </td>
                  <td>
                    <div class="rl-sm"><%= metrics[:active_deals] %> active</div>
                    <div class="rl-sm" style="color:var(--color-success-text)"><%= metrics[:won_deals] %> won (<%= relay_money(metrics[:deal_value]) %>)</div>
                  </td>
                  <td style="text-align:right">
                    <%= link_to "View", user_path(associate), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>
