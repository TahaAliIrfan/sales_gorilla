<%# Proposals tab — the current user's Odoo proposals (mirrors
    OdooProposalsController#index). Card grid per docs/design/relay-app/project/app/billing.jsx:
    client, deployment, status pill, updated date, with Open + PDF actions. %>
<% if @proposals.empty? %>
  <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
    <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-fg-3)"><%= relay_icon("file-text", size: 22) %></span>
    <div class="rl-h4">No proposals yet</div>
    <div class="muted rl-sm" style="margin-top:6px">Generate an AI-written, branded Odoo proposal for a client.</div>
    <div style="margin-top:16px"><%= link_to "New proposal", new_odoo_proposal_path, class: "rl-btn rl-btn--primary rl-btn--sm" %></div>
  </div></div>
<% else %>
  <div class="grid grid-3">
    <% @proposals.each do |proposal| %>
      <div class="sect"><div class="sect__body">
        <div class="spread" style="margin-bottom:12px">
          <span class="iccircle" style="background:var(--color-primary-subtle);color:var(--color-primary-text)"><%= relay_icon("file-text", size: 18) %></span>
          <span class="rl-badge rl-badge--info" style="text-transform:capitalize"><%= proposal.status.presence || "Draft" %></span>
        </div>
        <div class="rl-h4"><%= proposal.display_name %></div>
        <div class="muted rl-sm"><%= proposal.deployment_label %> · updated <%= proposal.updated_at.strftime("%b %-d, %Y") %></div>
        <div class="row" style="gap:6px;margin-top:14px">
          <%= link_to odoo_proposal_path(proposal), class: "rl-btn rl-btn--secondary rl-btn--sm" do %>
            <%= relay_icon("eye", size: 14) %>Open
          <% end %>
          <%= link_to download_pdf_odoo_proposal_path(proposal), class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
            <%= relay_icon("download", size: 14) %>PDF
          <% end %>
        </div>
      </div></div>
    <% end %>
  </div>
<% end %>
