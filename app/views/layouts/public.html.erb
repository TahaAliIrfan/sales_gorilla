<!DOCTYPE html>
<html class="h-full bg-slate-100">
  <head>
    <title>Invoice – Tecaudex</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "carbon_theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  </head>
  <body class="h-full theme-carbon antialiased">
    <% if flash[:error] %>
      <div class="fixed top-4 right-4 px-4 py-2 bg-red-100 border border-red-400 text-red-700 rounded-lg shadow z-50 max-w-md">
        <%= flash[:error] %>
      </div>
    <% end %>
    <main class="min-h-screen py-8 px-4">
      <%= yield %>
    </main>
  </body>
</html>
