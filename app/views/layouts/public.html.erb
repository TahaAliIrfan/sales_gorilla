<!DOCTYPE html>
<html class="h-full bg-slate-100">
  <head>
    <title>Invoice – Tecaudex</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" type="image/png" href="/sales_gorilla_white.png?v=4">
    <link rel="alternate icon" href="/sales_gorilla_white.png?v=4">
    <link rel="shortcut icon" type="image/png" href="/sales_gorilla_white.png?v=4">
    <link rel="apple-touch-icon" href="/sales_gorilla_white.png?v=4">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="h-full bg-slate-100 font-sans antialiased">
    <% if flash[:error] %>
      <div class="fixed top-4 right-4 px-4 py-2 bg-red-100 border border-red-400 text-red-700 rounded-lg shadow z-50 max-w-md">
        <%= flash[:error] %>
      </div>
    <% end %>
    <main class="min-h-screen py-8 px-4">
      <%= yield %>
    </main>
  </body>
</html>
