<%# app/views/layouts/relay.html.erb — Relay console shell %>
<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || current_organization&.name || "Sales Gorilla" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/png" href="/sales_gorilla_white.png?v=4">
    <link rel="alternate icon" href="/sales_gorilla_white.png?v=4">
    <link rel="shortcut icon" type="image/png" href="/sales_gorilla_white.png?v=4">
    <link rel="apple-touch-icon" href="/sales_gorilla_white.png?v=4">
    <%= stylesheet_link_tag "relay/fonts", "relay/colors_and_type", "relay/tokens",
                            "relay/components", "relay/components-data", "relay/components-nav",
                            "relay/app", "relay/shell", "data-turbo-track": "reload" %>
    <%= relay_brand_style_tag(current_organization) %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body data-controller="relay--command-palette"
        data-action="keydown@window->relay--command-palette#keydown">
    <div class="app" data-controller="relay--sidebar">
      <%= render "relay/shared/sidebar" %>
      <%# Mobile drawer scrim — tap to close the sidebar (CSS hides it on desktop). %>
      <div class="app__scrim" data-action="click->relay--sidebar#closeMobile"></div>
      <div class="app__main">
        <%= render "relay/shared/topbar" %>
        <main class="app__body <%= yield :body_class %>" id="relay_body"><%= yield %></main>
      </div>
    </div>

    <%= render "relay/shared/command_palette" %>
    <%= render "relay/shared/toasts" %>

    <% if feature_enabled?(:calling) %>
      <%# Global active-call bar — wired to the real Twilio Voice SDK. The SDK is
          loaded here (lazily used: the bar only inits a Device when a call
          starts) so calling works in-context from any relay page. %>
      <%= render "relay/shared/callbar" %>
      <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/@twilio/voice-sdk@2.15.0/dist/twilio.min.js", "data-turbo-track": "reload" %>
    <% end %>
  </body>
</html>
