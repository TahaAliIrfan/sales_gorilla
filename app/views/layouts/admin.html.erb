<!DOCTYPE html>
<html class="h-full bg-paper">
  <head>
    <title>Platform Admin · Sales Gorilla</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/png" href="/sales_gorilla_white.png?v=4">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>

  <body class="min-h-full bg-paper font-sans antialiased text-ink" style="font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif">
    <% nav = [
         [ "Dashboard", admin_root_path ],
         [ "Organizations", admin_organizations_path ],
         [ "Users", admin_users_path ]
       ] %>

    <header class="border-b border-[var(--color-line)] bg-panel">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-3">
        <div class="flex items-center gap-6">
          <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-md text-xs font-bold text-white" style="background: var(--brand-primary)">SG</span>
            <span class="font-display text-sm font-bold text-ink">Platform Admin</span>
          <% end %>
          <nav class="hidden items-center gap-1 sm:flex">
            <% nav.each do |label, path| %>
              <% active = request.path == path || (path != admin_root_path && request.path.start_with?(path)) %>
              <%= link_to label, path,
                    class: "rounded-md px-3 py-1.5 text-sm font-medium #{active ? 'bg-[var(--brand-primary-soft)] text-[var(--brand-primary)]' : 'text-ink-soft hover:bg-paper hover:text-ink'}" %>
            <% end %>
          </nav>
        </div>
        <div class="flex items-center gap-3 text-sm">
          <span class="hidden text-ink-soft md:inline"><%= current_user&.email %></span>
          <%= link_to "Sign out", signout_path, class: "rounded-md px-3 py-1.5 font-medium text-ink-soft hover:bg-paper hover:text-ink" %>
        </div>
      </div>
    </header>

    <% if flash[:error] %>
      <div class="mx-auto mt-4 max-w-6xl px-6">
        <div class="rounded-lg px-4 py-3 text-sm font-medium" style="background: rgba(220,38,38,0.10); color: #991b1b"><%= flash[:error] %></div>
      </div>
    <% end %>
    <% if flash[:success] %>
      <div class="mx-auto mt-4 max-w-6xl px-6">
        <div class="rounded-lg px-4 py-3 text-sm font-medium" style="background: rgba(16,148,104,0.10); color: var(--color-accent)"><%= flash[:success] %></div>
      </div>
    <% end %>

    <main class="mx-auto max-w-6xl px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
