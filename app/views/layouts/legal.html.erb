<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title).presence || "Sales Gorilla" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/png" href="/sales_gorilla_white.png?v=4">
    <link rel="shortcut icon" type="image/png" href="/sales_gorilla_white.png?v=4">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      .legal { color: var(--color-ink-soft, #44423d); line-height: 1.75; }
      .legal h2 { color: var(--color-ink, #1b1a17); font-weight: 700; font-size: 1.35rem; margin: 2.25rem 0 0.75rem; }
      .legal h3 { color: var(--color-ink, #1b1a17); font-weight: 600; font-size: 1.05rem; margin: 1.5rem 0 0.5rem; }
      .legal p, .legal li { margin: 0.5rem 0; }
      .legal ul { list-style: disc; padding-left: 1.4rem; margin: 0.5rem 0; }
      .legal a { color: var(--color-accent, #2563eb); text-decoration: underline; }
      .legal strong { color: var(--color-ink, #1b1a17); }
    </style>
  </head>

  <body class="h-full bg-paper font-sans text-ink antialiased">
    <%= render "shared/flash" %>

    <header class="border-b border-[var(--color-line-2)] bg-paper/70 backdrop-blur">
      <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/sales_gorilla_black.png" alt="Sales Gorilla" class="h-8 w-8 shrink-0 object-contain">
          <span class="font-display text-lg font-bold tracking-tight text-ink">Sales Gorilla<span class="text-accent-bright">.</span></span>
        </a>
        <a href="/" class="text-sm font-medium text-ink-soft transition hover:text-ink">← Back to site</a>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-12">
      <%= yield %>
    </main>

    <footer class="border-t border-[var(--color-line-2)] mt-8">
      <div class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-3 px-6 py-6 text-sm text-ink-soft">
        <span>© <%= Time.current.year %> Tecaudex · Sales Gorilla</span>
        <nav class="flex gap-5">
          <%= link_to "Privacy", privacy_path, class: "hover:text-ink" %>
          <%= link_to "Terms", terms_path, class: "hover:text-ink" %>
          <%= link_to "Data deletion", data_deletion_path, class: "hover:text-ink" %>
        </nav>
      </div>
    </footer>
  </body>
</html>
