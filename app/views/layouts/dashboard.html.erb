<!DOCTYPE html>
<html class="h-full" style="background:#F6F7F9">
  <head>
    <title>Tecaudex CRM - Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "carbon_theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  </head>

  <body class="h-full theme-carbon">
    <div class="min-h-full" data-controller="mobile-menu cost-calculator call-widget" data-call-widget-default-caller-id-value="<%= current_user&.default_caller_id %>">
      <!-- Mobile menu backdrop -->
      <div 
        data-mobile-menu-target="backdrop"
        class="fixed inset-0 bg-gray-600 bg-opacity-75 z-20 lg:hidden hidden" 
        data-action="click->mobile-menu#close">
      </div>

      <!-- Sidebar - hidden by default on mobile -->
      <div 
        data-mobile-menu-target="sidebar"
        class="fixed inset-y-0 left-0 z-30 w-64 ah-sidebar transform transition-transform duration-300 ease-in-out lg:translate-x-0 -translate-x-full">
        <!-- Logo section -->
        <div class="flex h-16 items-center justify-between px-6 ah-sidebar-brand">
          <span class="flex items-center gap-2.5 text-xl font-bold text-white">
            <span class="inline-grid place-items-center w-7 h-7 rounded-lg font-bold text-[15px]" style="background:linear-gradient(135deg,#059669,#10B981);color:#FFFFFF;font-family:'Geist Mono',monospace;box-shadow:0 6px 16px -6px rgba(5,150,105,.7);">T</span>
            <span style="letter-spacing:-.02em;">tecaudex<span style="color:#6EE7B7">_crm</span></span>
          </span>
          <!-- Close button for mobile -->
          <button 
            type="button" 
            class="lg:hidden text-gray-400 hover:text-white"
            data-action="mobile-menu#close">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        
        <!-- Navigation -->
        <nav class="mt-5 px-3 flex flex-col h-[calc(100vh-4rem)]">
          <div class="space-y-1 flex-grow overflow-y-auto overflow-x-hidden pb-4">
            <!-- My Dashboard - Available to Everyone -->
            <%= link_to dashboard_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{current_page?(dashboard_path) ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              My Dashboard
            <% end %>
            
            <% if current_user&.admin? %>
              <%= link_to reports_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{current_page?(reports_path) ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                Reports
              <% end %>
              
              <!-- User Management -->
              <%= link_to users_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'users' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                User Management
              <% end %>
              
              <!-- Team Management Section -->
              <div class="pt-2 border-t border-gray-700 mt-2 mb-2">
                <h3 class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Team Management</h3>
              </div>
              
              <%= link_to manager_dashboard_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'manager' && action_name == 'dashboard' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                Manager Dashboard
              <% end %>
              
              <%= link_to pipelines_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'pipelines' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
                Pipelines
              <% end %>
              
              <div class="pt-2 border-t border-gray-700 mt-2 mb-2">
                <h3 class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">CRM Tools</h3>
              </div>
            <% else %>
              <%= link_to my_reports_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{current_page?(my_reports_path) ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                My Reports
              <% end %>
              
              <% if current_user&.manager? %>
                <!-- Manager's Team Management Section -->
                <div class="pt-2 border-t border-gray-700 mt-2 mb-2">
                  <h3 class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Team Management</h3>
                </div>
                
                <%= link_to manager_dashboard_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'manager' && action_name == 'dashboard' ? 'bg-gray-800 text-white' : ''}" do %>
                  <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                  </svg>
                  Manager Dashboard
                <% end %>
              <% end %>
              
              <div class="pt-2 border-t border-gray-700 mt-2 mb-2">
                <h3 class="px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">CRM Tools</h3>
              </div>
            <% end %>

            <%= link_to customers_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'customers' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              Customers
            <% end %>

            <% if current_user&.admin? || current_user&.manager? %>
              <%= link_to deals_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'deals' && action_name != 'my_deals' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Deals
              <% end %>
            <% end %>

            <%= link_to my_deals_deals_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{current_user&.admin? ? 'ml-6 text-sm' : ''} #{controller_name == 'deals' && action_name == 'my_deals' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-3 h-5 w-5 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              My Deals
            <% end %>

            <% if current_user&.admin? %>
              <%= link_to tasks_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'tasks' && action_name != 'my_tasks' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12l2 2 4-4" />
                </svg>
                Tasks
              <% end %>
            <% end %>

            <%= link_to my_tasks_tasks_path(status: 'pending'), class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{current_user&.admin? ? 'ml-6 text-sm' : ''} #{controller_name == 'tasks' && action_name == 'my_tasks' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-3 h-5 w-5 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12l2 2 4-4" />
              </svg>
              My Tasks
            <% end %>

            <% if current_user&.admin? %>
              <%= link_to recordings_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'recordings' && action_name != 'my_recordings' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
                </svg>
                Recordings
              <% end %>
            <% end %>
            
            <%= link_to my_recordings_recordings_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{current_user&.admin? ? 'ml-6 text-sm' : ''} #{controller_name == 'recordings' && action_name == 'my_recordings' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-3 h-5 w-5 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
              </svg>
              My Recordings
            <% end %>

            <%= link_to calling_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{current_page?(calling_path) ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Calling
            <% end %>

            <%= link_to customer_groups_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'customer_groups' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              Customer Groups
            <% end %>

            <%= link_to campaigns_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'campaigns' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
              </svg>
              Campaigns
            <% end %>

            <%= link_to cost_estimates_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'cost_estimates' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Proposal Generator
            <% end %>

            <%= link_to odoo_proposals_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'odoo_proposals' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              Odoo Calculator
            <% end %>

            <%= link_to invoices_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'all_invoices' ? 'bg-gray-800 text-white' : ''}" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Invoices
            <% end %>

            <% if current_user&.admin? %>
              <%= link_to admin_assistant_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'assistant' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
                AI Assistant
              <% end %>

              <%= link_to whatsapp_templates_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'whatsapp_templates' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
                WhatsApp Templates
              <% end %>

              <%= link_to lead_webhooks_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md #{controller_name == 'lead_webhooks' ? 'bg-gray-800 text-white' : ''}" do %>
                <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/>
                </svg>
                Lead Webhooks
              <% end %>
            <% end %>
          </div>

          <!-- User actions section at bottom -->
          <div class="border-t border-gray-700 pt-4 pb-3 mt-auto">
            <%= link_to settings_path, class: "text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Settings
            <% end %>

            <%= button_to signout_path, method: :get, class: "w-full text-left text-gray-300 hover:bg-gray-800 hover:text-white group flex items-center px-2 py-2 text-base font-medium rounded-md" do %>
              <svg class="mr-4 h-6 w-6 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
              Sign out
            <% end %>
          </div>
        </nav>
      </div>

      <!-- Main content - responsive padding for sidebar -->
      <div class="lg:pl-64" data-controller="customer-navigation" data-current-controller="<%= controller_name %>">
        <!-- Top navigation -->
        <div class="sticky top-0 z-10" style="background:rgba(255,255,255,.85);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid var(--ah-line);">
          <div class="flex h-16 items-center justify-between px-4 sm:px-6">
            <!-- Mobile menu button -->
            <button
              type="button"
              class="lg:hidden inline-flex items-center justify-center rounded-md text-gray-500 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-emerald-500"
              data-action="mobile-menu#open">
              <span class="sr-only">Open sidebar</span>
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>

            <div class="flex items-center">
              <% if current_page?(dashboard_path) %>
                <h1 class="text-2xl font-semibold text-gray-900">My Dashboard</h1>
              <% elsif current_page?(reports_path) && current_user&.admin? %>
                <h1 class="text-2xl font-semibold text-gray-900">Reports</h1>
              <% elsif current_page?(my_reports_path) %>
                <h1 class="text-2xl font-semibold text-gray-900">My Reports</h1>
              <% elsif current_page?(my_tasks_dashboard_path) %>
                <h1 class="text-2xl font-semibold text-gray-900">My Tasks Dashboard</h1>
              <% elsif current_page?(calling_path) %>
                <h1 class="text-2xl font-semibold text-gray-900">Calling</h1>
              <% elsif controller_name == 'all_invoices' %>
                <h1 class="text-2xl font-semibold text-gray-900">Invoices</h1>
              <% elsif controller_name == 'customers' %>
                <h1 class="text-2xl font-semibold text-gray-900">Customers</h1>
              <% elsif controller_name == 'deals' %>
                <h1 class="text-2xl font-semibold text-gray-900">
                  <%= (current_user&.admin? || current_user&.manager?) ? (action_name == 'my_deals' ? 'My Deals' : 'Deals') : 'My Deals' %>
                </h1>
              <% elsif controller_name == 'tasks' %>
                <h1 class="text-2xl font-semibold text-gray-900">
                  <%= current_user&.admin? ? (action_name == 'my_tasks' ? 'My Tasks' : 'Tasks') : 'My Tasks' %>
                </h1>
              <% elsif controller_name == 'recordings' %>
                <h1 class="text-2xl font-semibold text-gray-900">
                  <%= current_user&.admin? ? (action_name == 'my_recordings' ? 'My Recordings' : 'Recordings') : 'My Recordings' %>
                </h1>
              <% else %>
                <h1 class="text-2xl font-semibold text-gray-900">Tecaudex CRM</h1>
              <% end %>
            </div>
            <div class="flex items-center">

              <div class="relative ml-3">
                <div class="flex items-center">
                  <!-- Task notifications -->
                  <div class="relative mr-4">
                    <a href="<%= my_tasks_tasks_path(status: 'pending', due_date: 'overdue') %>" class="flex items-center">
                      <span class="p-2 rounded-full bg-gray-100 hover:bg-gray-200 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-gray-600">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                        </svg>
                      </span>
                      <% if @urgent_tasks_count && @urgent_tasks_count > 0 %>
                        <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">
                          <%= @urgent_tasks_count %>
                        </span>
                      <% end %>
                    </a>
                  </div>
                  
                  <!-- Pending Tasks notification -->
                  <div class="relative mr-4">
                    <a href="<%= my_tasks_tasks_path(status: 'pending') %>" class="flex items-center">
                      <span class="p-2 rounded-full bg-gray-100 hover:bg-gray-200 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-gray-600">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
                        </svg>
                      </span>
                      <% if @pending_tasks_count && @pending_tasks_count > 0 %>
                        <span class="absolute -top-1 -right-1 bg-yellow-500 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">
                          <%= @pending_tasks_count %>
                        </span>
                      <% end %>
                    </a>
                  </div>
                  
                  <!-- Messages/Notifications dropdown -->
                  <div class="relative mr-4" data-controller="dropdown">
                    <button type="button" data-action="dropdown#toggle" class="flex items-center">
                      <span class="p-2 rounded-full bg-gray-100 hover:bg-gray-200 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-gray-600">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                        </svg>
                      </span>
                      <% if @unread_notifications_count && @unread_notifications_count > 0 %>
                        <span id="notification-count" class="absolute -top-1 -right-1 bg-emerald-500 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">
                          <%= @unread_notifications_count %>
                        </span>
                      <% else %>
                        <span id="notification-count" class="absolute -top-1 -right-1 bg-emerald-500 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center hidden">
                          0
                        </span>
                      <% end %>
                    </button>
                    
                    <!-- Notifications dropdown -->
                    <div data-dropdown-target="menu" class="hidden absolute right-0 z-10 mt-2 w-80 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" role="menu" aria-orientation="vertical" aria-labelledby="user-menu-button" tabindex="-1">
                      <div class="px-4 py-2 border-b border-gray-100 flex justify-between items-center">
                        <h3 class="text-sm font-medium text-gray-700">Notifications</h3>
                        <% if @unread_notifications_count && @unread_notifications_count > 0 %>
                          <%= button_to mark_all_as_read_notifications_path, method: :post, class: "text-xs text-emerald-600 hover:text-emerald-800", id: "mark-all-read-btn", data: { turbo: false } do %>
                            Mark all as read
                          <% end %>
                        <% end %>
                      </div>
                      
                      <div id="notifications-list" class="max-h-96 overflow-y-auto">
                        <% unread_notifications = current_user.notifications.unread.recent.limit(5) %>
                        <% if unread_notifications.any? %>
                          <% unread_notifications.each do |notification| %>
                            <div class="block px-4 py-2 hover:bg-gray-50 border-b border-gray-100 bg-emerald-50" data-notification-id="<%= notification.id %>">
                              <div class="flex items-start">
                                <div class="flex-1">
                                  <p class="text-sm text-gray-700"><%= notification.content %></p>
                                  <p class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(notification.created_at) %> ago</p>
                                  <div class="mt-1 flex items-center justify-end">
                                    <% if notification.resource.present? %>
                                      <a href="<%= notification_path(notification) %>" class="text-xs text-emerald-600 hover:text-emerald-800">
                                        View
                                      </a>
                                    <% end %>
                                    <%= button_to mark_as_read_notification_path(notification), method: :post, class: "ml-3 text-xs text-gray-500 hover:text-gray-700", form: { class: 'inline-block' }, data: { turbo: false } do %>
                                      Mark as read
                                    <% end %>
                                  </div>
                                </div>
                                <div class="h-2 w-2 bg-emerald-500 rounded-full mt-1"></div>
                              </div>
                            </div>
                          <% end %>
                        <% else %>
                          <div class="px-4 py-6 text-center text-sm text-gray-500">
                            No unread notifications
                          </div>
                        <% end %>
                      </div>
                      
                      <div class="border-t border-gray-100 px-4 py-2">
                        <a href="<%= notifications_path %>" class="block w-full text-center py-2 text-sm font-medium text-emerald-600 hover:bg-emerald-50 rounded-md transition-colors">
                          View all notifications
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main content area -->
        <main class="py-6 px-4 sm:px-6">
          <% if flash[:error] %>
            <div class="mb-4 px-4 py-2 bg-red-100 border border-red-400 text-red-700 rounded">
              <%= flash[:error] %>
            </div>
          <% end %>
          
          <% if flash[:notice] %>
            <div class="mb-4 px-4 py-2 bg-green-100 border border-green-400 text-green-700 rounded">
              <%= flash[:notice] %>
            </div>
          <% end %>

          <% if current_user && !current_user.phone_number_set? %>
            <div data-controller="phone-modal" data-show-modal="true">
              <!-- Phone Number Modal -->
              <div data-phone-modal-target="modal" class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
                <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
                  <!-- Background overlay -->
                  <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
                  
                  <!-- Modal panel -->
                  <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                    <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                      <div class="sm:flex sm:items-start">
                        <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-emerald-100 sm:mx-0 sm:h-10 sm:w-10">
                          <svg class="h-6 w-6 text-emerald-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                          </svg>
                        </div>
                        <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                          <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">
                            Set Up Your Phone Number
                          </h3>
                          <div class="mt-2">
                            <p class="text-sm text-gray-500">
                              Please set up your phone number to use the calling features of the CRM. This number will be used for inbound calls.
                            </p>
                          </div>
                          
                          <%= form_with(url: update_settings_path, method: :patch, class: "mt-4") do |form| %>
                            <div>
                              <%= form.label :phone_number, "Phone Number", class: "block text-sm font-medium text-gray-700" %>
                              <div class="mt-1">
                                <%= form.telephone_field "user[phone_number]", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500", placeholder: "Include country code (e.g. +923001234567)", data: { phone_modal_target: "phoneInput" } %>
                                <p class="mt-1 text-xs text-gray-500">Include country code with + sign (e.g. +923001234567)</p>
                              </div>
                              <div data-phone-modal-target="errorMessage" class="mt-2 text-sm text-red-600 hidden"></div>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    </div>
                    <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                      <button type="button" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-emerald-600 text-base font-medium text-white hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 sm:ml-3 sm:w-auto sm:text-sm" data-action="click->phone-modal#save">
                        Save
                      </button>
                      <button type="button" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm" data-action="click->phone-modal#closeModal">
                        Skip for now
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
          
          <%= yield %>
        </main>

        <%= render "shared/call_widget" %>
      </div>

      <!-- Cost Calculator Modal -->
      <div class="hidden fixed inset-0 z-50 overflow-y-auto" data-cost-calculator-target="modal" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
          <!-- Background overlay -->
          <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" data-action="click->cost-calculator#closeModal"></div>
          
          <!-- Modal panel -->
          <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
              <div class="sm:flex sm:items-start">
                <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-emerald-100 sm:mx-0 sm:h-10 sm:w-10">
                  <svg class="h-6 w-6 text-emerald-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                  <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">
                    Project Cost Calculator
                  </h3>
                  <div class="mt-4">
                    <%= form_with url: cost_estimates_path, method: :post, data: { cost_calculator_target: "form", turbo: false }, class: "space-y-4" do |form| %>
                      <!-- Customer Information -->
                      <div class="border-b border-gray-200 pb-4 mb-4">
                        <h4 class="text-sm font-medium text-gray-900 mb-3">Customer Information</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div>
                            <%= form.label :customer_id, "Existing Customer (Optional)", class: "block text-sm font-medium text-gray-700" %>
                            <%= form.select :customer_id, 
                                options_from_collection_for_select(
                                  current_user.admin? ? Customer.all.order(:name) : current_user.customers.order(:name), 
                                  :id, :name
                                ), 
                                { prompt: 'Select existing customer (optional)' },
                                { 
                                  class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500",
                                  data: { action: "change->cost-calculator#toggleCustomerName" }
                                } %>
                          </div>
                          
                          <div data-cost-calculator-target="customerNameField">
                            <%= form.label :customer_name, "Customer Name", class: "block text-sm font-medium text-gray-700" %>
                            <%= form.text_field :customer_name, 
                                placeholder: "Enter customer name for this estimate",
                                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
                            <p class="mt-1 text-xs text-gray-500">Used for PDF generation and record keeping</p>
                          </div>
                        </div>
                      </div>

                      <!-- Project Configuration -->
                      <div class="border-b border-gray-200 pb-4 mb-4">
                        <h4 class="text-sm font-medium text-gray-900 mb-3">Project Configuration</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div>
                            <%= form.label :app_type, "Application Type", class: "block text-sm font-medium text-gray-700" %>
                            <%= form.select :app_type, 
                                options_for_select([
                                  ['Web Application', 'web'],
                                  ['Mobile Application (iOS)', 'mobile_ios'],
                                  ['Mobile Application (Android)', 'mobile_android'],
                                  ['Mobile Application (Cross-platform)', 'mobile_cross'],
                                  ['Desktop Application', 'desktop'],
                                  ['E-commerce Platform', 'ecommerce'],
                                  ['CRM System', 'crm'],
                                  ['API/Backend Service', 'api'],
                                  ['Custom Software', 'custom']
                                ]), 
                                { prompt: 'Select application type' },
                                { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" } %>
                          </div>
                          
                          <div>
                            <%= form.label :scale, "Project Scale", class: "block text-sm font-medium text-gray-700" %>
                            <%= form.select :scale, 
                                options_for_select([
                                  ['MVP (300-600 hours)', 'mvp'],
                                  ['Moderate Scale (600-1500 hours)', 'moderate'],
                                  ['Enterprise (1500+ hours)', 'enterprise']
                                ]), 
                                { prompt: 'Select project scale' },
                                { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" } %>
                          </div>
                        </div>
                        
                        <!-- UI/UX Design Option -->
                        <div class="mt-4">
                          <div class="flex items-center">
                            <%= form.check_box :include_design, 
                                { class: "h-4 w-4 text-emerald-600 focus:ring-emerald-500 border-gray-300 rounded" },
                                { data: { action: "change->cost-calculator#toggleDesignInfo" } } %>
                            <%= form.label :include_design, "Include UI/UX Design Estimates", class: "ml-2 block text-sm text-gray-900" %>
                          </div>
                          <p class="mt-1 text-xs text-gray-500">Include professional UI/UX design using Figma in your estimate</p>
                          
                          <div data-cost-calculator-target="designInfo" class="hidden mt-2 p-3 bg-emerald-50 rounded-md">
                            <p class="text-sm text-emerald-700">
                              <strong>UI/UX Design includes:</strong> User research, wireframes, high-fidelity mockups, 
                              design system creation, responsive design, and Figma prototype development.
                            </p>
                          </div>
                        </div>
                      </div>
                      
                      <div>
                        <%= form.label :description, "Project Description", class: "block text-sm font-medium text-gray-700" %>
                        <%= form.text_area :description, 
                            placeholder: "Describe your project requirements, features, and functionality in detail...",
                            rows: 4,
                            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
                        <p class="mt-1 text-xs text-gray-500">Provide detailed information about your project to get accurate estimates</p>
                      </div>
                      
                      <div>
                        <%= form.label :hourly_rate, "Hourly Rate ($)", class: "block text-sm font-medium text-gray-700" %>
                        <%= form.number_field :hourly_rate,
                            value: 25,
                            min: 1,
                            step: 0.01,
                            placeholder: "25.00",
                            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
                        <p class="mt-1 text-xs text-gray-500">Set your preferred hourly rate for this estimate</p>
                      </div>

                      <div data-cost-calculator-target="loadingState" class="hidden">
                        <div class="flex items-center justify-center py-4">
                          <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-600"></div>
                          <span class="ml-2 text-sm text-gray-600">Analyzing project requirements...</span>
                        </div>
                      </div>

                      <div data-cost-calculator-target="results" class="hidden space-y-4">
                        <div class="bg-gray-50 rounded-lg p-4">
                          <h4 class="text-sm font-medium text-gray-900 mb-2">Estimated Features & Hours</h4>
                          <div data-cost-calculator-target="featuresDisplay" class="space-y-2"></div>
                        </div>
                        
                        <div class="bg-emerald-50 rounded-lg p-4">
                          <h4 class="text-sm font-medium text-gray-900 mb-2">Cost Breakdown</h4>
                          <div data-cost-calculator-target="costSummary" class="space-y-1"></div>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
            <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
              <button 
                type="button" 
                data-action="click->cost-calculator#calculateCost"
                data-cost-calculator-target="calculateButton"
                class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-emerald-600 text-base font-medium text-white hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 sm:ml-3 sm:w-auto sm:text-sm">
                Calculate Cost
              </button>
              <button 
                type="button" 
                data-action="click->cost-calculator#saveEstimate"
                data-cost-calculator-target="saveButton"
                class="hidden w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-green-600 text-base font-medium text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 sm:ml-3 sm:w-auto sm:text-sm">
                Save Estimate
              </button>
              <button 
                type="button" 
                data-action="click->cost-calculator#generateProposal"
                data-cost-calculator-target="proposalButton"
                class="hidden w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-purple-600 text-base font-medium text-white hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 sm:ml-3 sm:w-auto sm:text-sm">
                Generate Proposal PDF
              </button>
              <button 
                type="button" 
                data-action="click->cost-calculator#closeModal" 
                class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                Close
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <script>
      function calculateLeadScore(customerId) {
        // Show loading state
        const button = event.target;
        const originalText = button.textContent;
        button.textContent = 'Calculating...';
        button.disabled = true;
        
        fetch(`/customers/${customerId}/calculate_lead_score`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            // Reload the page to show updated score
            window.location.reload();
          }
        })
        .catch(error => {
            window.location.reload();
        });
      }
    </script>
  </body>
</html> 