<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title>Sales Gorilla</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/svg+xml" href="/sales-gorilla-mark.svg">
    <link rel="apple-touch-icon" href="/sales-gorilla-mark.svg">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- Add Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>

  <body class="h-full bg-gray-50 font-sans antialiased" style="font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif">
    <% if flash[:error] %>
      <div class="fixed top-4 right-4 px-4 py-2 bg-red-100 border border-red-400 text-red-700 rounded">
        <%= flash[:error] %>
      </div>
    <% end %>
    
    <% if flash[:success] %>
      <div class="fixed top-4 right-4 px-4 py-2 bg-green-100 border border-green-400 text-green-700 rounded">
        <%= flash[:success] %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
