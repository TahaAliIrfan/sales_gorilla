<!DOCTYPE html>
<html class="h-full">
  <head>
    <script>
      (function () {
        try { document.documentElement.dataset.theme = localStorage.getItem("theme") || "light"; }
        catch (e) { document.documentElement.dataset.theme = "light"; }
      })();
    </script>
    <title><%= content_for(:title).presence || "#{current_organization&.name || "Relay"} · Relay" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="view-transition" content="same-origin">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-paper font-sans text-ink antialiased"
        style="<%= brand_style(current_organization) %>">
    <%= render "shared/flash" %>

    <div class="flex h-full" data-controller="mobile-menu">
      <%# ---- Mobile backdrop ---- %>
      <div data-mobile-menu-target="backdrop"
           class="fixed inset-0 z-20 hidden bg-black/40 lg:hidden"
           data-action="click->mobile-menu#close"></div>

      <%# ---- Sidebar ---- %>
      <aside data-mobile-menu-target="sidebar"
             class="fixed inset-y-0 left-0 z-30 flex w-64 -translate-x-full transform flex-col border-r border-[var(--color-line)] bg-deep transition-transform duration-200 lg:static lg:translate-x-0">
        <div class="flex items-center gap-3 px-5 py-5">
          <%= render "shared/org_logo", organization: current_organization, size: "h-10 w-10" %>
          <div class="min-w-0 flex-1">
            <p class="truncate font-display text-[15px] font-bold leading-tight text-ink"><%= current_organization&.name %></p>
            <p class="mono truncate text-[11px] text-ink-soft"><%= current_organization&.subdomain %>.<%= root_host_for_request %></p>
          </div>
          <button type="button" class="text-ink-soft lg:hidden" data-action="mobile-menu#close" aria-label="Close menu">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18 18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <nav class="flex-1 space-y-0.5 overflow-y-auto px-3 py-3">
          <p class="micro px-3 pt-3 pb-2">Workspace</p>
          <%= nav_link "Dashboard",  dashboard_path,            icon: "grid" %>
          <%= nav_link "Customers",  customers_path,            icon: "users" %>
          <%= nav_link "My Deals",   my_deals_deals_path,       icon: "deal" %>
          <% if current_user&.admin? || current_user&.manager? %>
            <%= nav_link "All Deals", deals_path, icon: "deal" %>
          <% end %>
          <%= nav_link "My Tasks",   my_tasks_tasks_path(status: 'pending'), icon: "task" %>
          <% if current_user&.admin? %>
            <%= nav_link "All Tasks", tasks_path, icon: "task" %>
          <% end %>
          <%= nav_link "My Recordings", my_recordings_recordings_path, icon: "rec" %>
          <% if current_user&.admin? %>
            <%= nav_link "All Recordings", recordings_path, icon: "rec" %>
          <% end %>
          <%= nav_link "Calling",    calling_path,              icon: "phone" %>
          <%= nav_link "Invoices",   invoices_path,             icon: "doc" %>

          <p class="micro px-3 pt-5 pb-2">Outreach</p>
          <%= nav_link "Customer Groups", customer_groups_path, icon: "users-2" %>
          <%= nav_link "Campaigns",       campaigns_path,       icon: "megaphone" %>
          <% if current_user&.admin? %>
            <%= nav_link "WhatsApp Templates", whatsapp_templates_path, icon: "megaphone" %>
          <% end %>

          <p class="micro px-3 pt-5 pb-2">Sales tools</p>
          <%= nav_link "Cost Calculator", cost_estimates_path, icon: "calc" %>
          <%= nav_link "Odoo Calculator", odoo_proposals_path, icon: "calc" %>

          <% if current_user&.admin? || current_user&.manager? %>
            <p class="micro px-3 pt-5 pb-2">Team</p>
            <%= nav_link "Manager Dashboard", manager_dashboard_path, icon: "graph" %>
            <% if current_user&.admin? %>
              <%= nav_link "Reports",         reports_path,    icon: "graph" %>
              <%= nav_link "User Management", users_path,      icon: "users-2" %>
              <%= nav_link "Pipelines",       pipelines_path,  icon: "deal" %>
            <% else %>
              <%= nav_link "My Reports", my_reports_path, icon: "graph" %>
            <% end %>
          <% else %>
            <%= nav_link "My Reports", my_reports_path, icon: "graph" %>
          <% end %>

          <p class="micro px-3 pt-5 pb-2">Workspace</p>
          <% if policy(current_organization).edit_branding? %>
            <%= nav_link "Branding", edit_branding_path, icon: "swatch" %>
          <% end %>
          <%= nav_link "Settings", settings_path, icon: "cog" %>
        </nav>

        <div class="flex items-center justify-between border-t border-[var(--color-line)] px-5 py-4">
          <span class="micro">Relay</span>
          <span class="mono text-[11px] text-ink-soft">v0.1</span>
        </div>
      </aside>

      <%# ---- Main column ---- %>
      <div class="flex min-w-0 flex-1 flex-col">
        <header class="sticky top-0 z-10 flex items-center justify-between border-b border-[var(--color-line-2)] bg-paper/85 px-4 py-3.5 backdrop-blur sm:px-6">
          <div class="flex items-center gap-3">
            <button type="button" class="text-ink-soft lg:hidden" data-action="mobile-menu#open" aria-label="Open menu">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
            <span class="font-display font-bold lg:hidden"><%= current_organization&.name %></span>
          </div>

          <div class="flex items-center gap-3 sm:gap-5">
            <% if current_user_in_org? %>
              <%# Pending tasks badge %>
              <%= link_to my_tasks_tasks_path(status: 'pending'),
                    class: "relative grid h-9 w-9 place-items-center rounded-md text-ink-soft ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)] hover:text-ink",
                    title: "Pending tasks" do %>
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
                <% if (@pending_tasks_count || 0) > 0 %>
                  <span class="absolute -top-1 -right-1 grid h-5 min-w-5 place-items-center rounded-full px-1 text-[10px] font-bold text-white" style="background: var(--brand-accent)"><%= @pending_tasks_count %></span>
                <% end %>
              <% end %>

              <%# Notifications dropdown %>
              <div class="relative" data-controller="dropdown">
                <button type="button" data-action="dropdown#toggle"
                        class="relative grid h-9 w-9 place-items-center rounded-md text-ink-soft ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)] hover:text-ink"
                        title="Notifications">
                  <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/></svg>
                  <% if (@unread_notifications_count || 0) > 0 %>
                    <span class="absolute -top-1 -right-1 grid h-5 min-w-5 place-items-center rounded-full px-1 text-[10px] font-bold text-white" style="background: var(--brand-primary)"><%= @unread_notifications_count %></span>
                  <% end %>
                </button>
                <div data-dropdown-target="menu"
                     class="hidden absolute right-0 z-20 mt-2 w-80 overflow-hidden rounded-lg bg-panel shadow-lift ring-1 ring-[var(--color-line-2)] motion-safe:animate-fade">
                  <div class="flex items-center justify-between border-b border-[var(--color-line)] px-4 py-3">
                    <span class="micro">Notifications</span>
                    <% if (@unread_notifications_count || 0) > 0 %>
                      <%= button_to "Mark all read", mark_all_as_read_notifications_path, method: :post,
                            class: "text-xs font-medium text-ink-soft transition hover:text-ink",
                            data: { turbo: false } %>
                    <% end %>
                  </div>
                  <div class="max-h-96 overflow-y-auto">
                    <% unread = current_user.notifications.unread.order(created_at: :desc).limit(5) %>
                    <% if unread.any? %>
                      <% unread.each do |n| %>
                        <div class="border-b border-[var(--color-line)] px-4 py-3 last:border-b-0">
                          <p class="text-sm text-ink"><%= n.content %></p>
                          <p class="micro mt-1"><%= time_ago_in_words(n.created_at) %> ago</p>
                        </div>
                      <% end %>
                    <% else %>
                      <p class="px-4 py-8 text-center text-sm text-ink-soft">No unread notifications</p>
                    <% end %>
                  </div>
                  <div class="border-t border-[var(--color-line)] px-4 py-2">
                    <%= link_to "View all", notifications_path, class: "block py-1 text-center text-sm font-medium text-ink-soft transition hover:text-ink" %>
                  </div>
                </div>
              </div>

              <% if current_member_orgs.size > 1 %>
                <%= render "shared/org_switcher" %>
              <% end %>
            <% end %>

            <div class="flex items-center gap-3">
              <div class="hidden text-right sm:block">
                <p class="text-sm font-semibold leading-tight text-ink"><%= current_user&.name.presence || current_user&.email %></p>
                <p class="micro mt-0.5"><%= current_membership&.role || "member" %></p>
              </div>
              <%= button_to "Sign out", signout_path, method: :get,
                    class: "rounded-md px-3 py-1.5 text-sm font-medium text-ink-soft transition hover:bg-[var(--color-line)] hover:text-ink",
                    form: { class: "inline-block" } %>
            </div>
          </div>
        </header>

        <main class="flex-1 overflow-y-auto px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
          <div class="mx-auto max-w-[1600px] motion-safe:animate-rise">
            <%= yield %>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
