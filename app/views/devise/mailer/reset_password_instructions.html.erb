<h1 style="margin:0 0 16px 0; font-size:22px; font-weight:700; letter-spacing:-0.01em; color:#1b2640;">Reset your password</h1>

<p style="margin:0 0 14px 0;">Hi <%= @resource.name.presence || @resource.email %>,</p>

<p style="margin:0 0 22px 0;">You requested a password reset for your Sales Gorilla account. Click the button below to choose a new password.</p>

<!-- CTA button -->
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 0 24px 0;">
  <tr>
    <td style="border-radius:8px; background-color:#ff5c35;">
      <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>" style="display:inline-block; padding:12px 26px; font-family:'Segoe UI',Roboto,Helvetica,Arial,sans-serif; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px;">Reset my password</a>
    </td>
  </tr>
</table>

<p style="margin:0 0 8px 0; color:#4f6680; font-size:13px;">Or paste this link into your browser:</p>
<p style="margin:0 0 22px 0; font-size:13px; word-break:break-all;"><a href="<%= edit_password_url(@resource, reset_password_token: @token) %>" style="color:#ff5c35; text-decoration:none;"><%= edit_password_url(@resource, reset_password_token: @token) %></a></p>

<p style="margin:0; color:#4f6680; font-size:14px;">If you didn't make this request, you can safely ignore this email — the link expires in <%= (Devise.reset_password_within / 1.hour).to_i %> hours.</p>
