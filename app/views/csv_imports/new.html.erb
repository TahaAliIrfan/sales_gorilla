<div class="container mx-auto px-4 py-8">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-bold text-gray-900">Import Customers from CSV</h1>
        <%= link_to customers_path, class: "text-gray-600 hover:text-gray-900" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        <% end %>
      </div>
      
      <!-- Progress Steps -->
      <div class="flex items-center mb-6">
        <div class="flex items-center">
          <div class="flex items-center justify-center w-8 h-8 bg-emerald-600 text-white rounded-full text-sm font-medium">
            1
          </div>
          <span class="ml-2 text-sm font-medium text-emerald-600">Upload CSV</span>
        </div>
        <div class="flex-1 h-px bg-gray-300 mx-4"></div>
        <div class="flex items-center">
          <div class="flex items-center justify-center w-8 h-8 bg-gray-300 text-gray-600 rounded-full text-sm font-medium">
            2
          </div>
          <span class="ml-2 text-sm font-medium text-gray-600">Map Fields</span>
        </div>
        <div class="flex-1 h-px bg-gray-300 mx-4"></div>
        <div class="flex items-center">
          <div class="flex items-center justify-center w-8 h-8 bg-gray-300 text-gray-600 rounded-full text-sm font-medium">
            3
          </div>
          <span class="ml-2 text-sm font-medium text-gray-600">Import</span>
        </div>
      </div>
    </div>

    <!-- Upload Form -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Step 1: Upload CSV File</h2>
      
      <!-- Instructions -->
      <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-4 mb-6">
        <h3 class="text-sm font-medium text-emerald-900 mb-2">CSV File Requirements:</h3>
        <ul class="text-sm text-emerald-800 space-y-1">
          <li>• File must be in CSV format (.csv)</li>
          <li>• First row should contain column headers</li>
          <li>• At minimum, include a 'Name' column</li>
          <li>• Recommended columns: Email, Phone, Company, Lead Source</li>
          <li>• Maximum file size: 10MB</li>
        </ul>
      </div>

      <!-- Sample CSV Template -->
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6">
        <h3 class="text-sm font-medium text-gray-900 mb-2">Sample CSV Format:</h3>
        <div class="text-xs font-mono text-gray-700 bg-white p-3 rounded border overflow-x-auto">
          Name,Email,Phone,Company,Lead Source,Project Type<br>
          John Doe,john@example.com,+1234567890,Acme Corp,LinkedIn,Web App<br>
          Jane Smith,jane@company.com,+9876543210,Tech Inc,Website,Mobile App
        </div>
      </div>

      <!-- Upload Form -->
      <form action="<%= upload_csv_imports_path %>" method="post" enctype="multipart/form-data" class="space-y-4" id="csv-upload-form">
        <%= csrf_meta_tags %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        
        <div>
          <label for="csv_file" class="block text-sm font-medium text-gray-700 mb-2">
            Select CSV File
          </label>
          <div class="relative">
            <input type="file" 
                   name="csv_file" 
                   id="csv_file"
                   accept=".csv,text/csv"
                   required
                   class="block w-full text-sm text-gray-900 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 p-3">
          </div>
          <p class="text-xs text-gray-500 mt-1">Upload a CSV file (maximum 10MB)</p>
        </div>

        <div class="flex items-center justify-between pt-4">
          <%= link_to "Cancel", customers_path, 
                     class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500" %>
          
          <button type="submit" 
                  id="csv-upload-button"
                  class="px-6 py-2 text-sm font-medium text-white bg-emerald-600 border border-transparent rounded-md hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500">
            Upload and Continue
          </button>
        </div>
      </form>
    </div>

    <!-- Help Section -->
    <div class="bg-white shadow rounded-lg p-6 mt-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-3">Need Help?</h3>
      <div class="text-sm text-gray-600 space-y-2">
        <p><strong>Duplicate Handling:</strong> If a customer with the same email or phone already exists, their information will be updated with new data.</p>
        <p><strong>Field Mapping:</strong> In the next step, you'll be able to map your CSV columns to customer fields in our system.</p>
        <p><strong>Validation:</strong> All imported data will be validated. Invalid entries will be skipped and reported.</p>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('CSV import form loaded');
  
  const form = document.getElementById('csv-upload-form');
  const button = document.getElementById('csv-upload-button');
  const fileInput = document.getElementById('csv_file');
  
  if (form && button && fileInput) {
    // Remove any existing event listeners that might interfere
    form.onsubmit = null;
    button.onclick = null;
    
    // Add our own form submission handler
    form.addEventListener('submit', function(e) {
      console.log('CSV form submission started');
      
      // Validate file selection
      if (!fileInput.files || !fileInput.files[0]) {
        e.preventDefault();
        e.stopPropagation();
        alert('Please select a CSV file to upload');
        return false;
      }
      
      // Validate file type
      const file = fileInput.files[0];
      const fileName = file.name.toLowerCase();
      
      if (!fileName.endsWith('.csv')) {
        e.preventDefault();
        e.stopPropagation();
        alert('Please select a valid CSV file');
        return false;
      }
      
      // Show loading state
      button.disabled = true;
      button.textContent = 'Uploading...';
      
      console.log('Submitting CSV file:', file.name);
      console.log('Form action:', form.action);
      
      // Allow form to submit normally
      return true;
    }, true); // Use capture phase to run before other handlers
    
    // Handle button click specifically
    button.addEventListener('click', function(e) {
      console.log('CSV upload button clicked');
      
      // Don't prevent default - let the form submit handle validation
      if (!fileInput.files || !fileInput.files[0]) {
        e.preventDefault();
        e.stopPropagation();
        alert('Please select a CSV file first');
        return false;
      }
    }, true);
    
    console.log('CSV form handlers attached successfully');
  } else {
    console.error('CSV form elements not found');
  }
});
</script>