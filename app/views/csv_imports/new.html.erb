<%# Relay CSV import — step 1 of 3: upload. Restyled from the prototype's
    ImportModal upload step (docs/design/relay-app/project/app/view-leads.jsx). %>
<% content_for :title, "Import leads — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="rl-eyebrow" style="margin-bottom:6px">Import leads from CSV</div>
      <div class="pagehead__title">Upload a CSV</div>
      <div class="pagehead__sub">Step 1 of 3 · Upload → Map columns → Import.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to customers_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("x", size: 16) %>Cancel
      <% end %>
    </div>
  </div>

  <%# Step indicator %>
  <div class="row" style="gap:8px;margin-bottom:var(--space-5)">
    <span class="rl-badge rl-badge--primary">1 · Upload</span>
    <span class="rl-badge rl-badge--neutral">2 · Map columns</span>
    <span class="rl-badge rl-badge--neutral">3 · Import</span>
  </div>

  <% if flash[:error] %>
    <div class="rl-pill rl-pill--danger" style="margin-bottom:var(--space-4)"><i class="rl-dot"></i><%= flash[:error] %></div>
  <% end %>

  <div class="sect" style="max-width:680px">
    <div class="sect__body">
      <%= form_with url: upload_csv_imports_path, method: :post, multipart: true, local: true,
            data: { controller: "relay--csv-upload" } do %>
        <%# Dropzone — clicking it opens the file picker via the hidden input. %>
        <label class="clickable" style="display:block;position:relative;border:2px dashed var(--color-border-strong);border-radius:var(--radius-lg);padding:36px;text-align:center;background:var(--color-surface-2)"
               data-relay--csv-upload-target="zone">
          <span class="empty__ic" style="margin:0 auto 12px"><%= relay_icon("file-up", size: 26) %></span>
          <div class="rl-h4">Drop a CSV here, or click to browse</div>
          <div class="muted rl-sm" style="margin-top:4px" data-relay--csv-upload-target="hint">First row should contain column headers · .csv up to 10 MB</div>
          <%= file_field_tag :csv_file, accept: ".csv,text/csv", required: true,
                style: "position:absolute;width:1px;height:1px;opacity:0;overflow:hidden",
                data: { relay__csv_upload_target: "input", action: "change->relay--csv-upload#picked" } %>
        </label>

        <div class="row" style="gap:8px;margin-top:14px;color:var(--color-fg-3);font-size:13px">
          <%= relay_icon("info", size: 15) %>At minimum include a <b>Name</b> column. Email, Phone, Company are recommended.
        </div>

        <div class="rl-modal__foot" style="margin-top:18px;padding:0;border:none">
          <%= link_to "Cancel", customers_path, class: "rl-btn rl-btn--ghost" %>
          <button type="submit" class="rl-btn rl-btn--primary" data-relay--csv-upload-target="submit">
            <%= relay_icon("upload", size: 15) %>Upload and continue
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <%# Sample format helper %>
  <div class="sect" style="max-width:680px;margin-top:var(--space-5)">
    <div class="sect__head"><div class="sect__title"><%= relay_icon("columns-2", size: 18) %>Sample CSV format</div></div>
    <div class="sect__body">
      <div class="mono rl-sm" style="background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:var(--radius-md);padding:12px;overflow-x:auto">
        Name,Email,Phone,Company,Lead Source,Project Type<br>
        John Doe,john@example.com,+1234567890,Acme Corp,LinkedIn,Web App<br>
        Jane Smith,jane@company.com,+9876543210,Tech Inc,Website,Mobile App
      </div>
      <div class="muted rl-sm" style="margin-top:10px">Existing leads matched by email or phone are updated. Invalid rows are skipped and reported.</div>
    </div>
  </div>
</div>
