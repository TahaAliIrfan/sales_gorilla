<div class="container mx-auto px-4 py-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-bold text-gray-900">Map CSV Fields to Customer Data</h1>
        <%= link_to cancel_csv_imports_path(token: @csv_import[:upload_token]), class: "text-gray-600 hover:text-gray-900" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        <% end %>
      </div>
      
      <!-- Progress Steps -->
      <div class="flex items-center mb-6">
        <div class="flex items-center">
          <div class="flex items-center justify-center w-8 h-8 bg-green-600 text-white rounded-full text-sm font-medium">
            ✓
          </div>
          <span class="ml-2 text-sm font-medium text-green-600">Upload CSV</span>
        </div>
        <div class="flex-1 h-px bg-gray-300 mx-4"></div>
        <div class="flex items-center">
          <div class="flex items-center justify-center w-8 h-8 bg-blue-600 text-white rounded-full text-sm font-medium">
            2
          </div>
          <span class="ml-2 text-sm font-medium text-blue-600">Map Fields</span>
        </div>
        <div class="flex-1 h-px bg-gray-300 mx-4"></div>
        <div class="flex items-center">
          <div class="flex items-center justify-center w-8 h-8 bg-gray-300 text-gray-600 rounded-full text-sm font-medium">
            3
          </div>
          <span class="ml-2 text-sm font-medium text-gray-600">Import</span>
        </div>
      </div>

      <!-- File Info -->
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <div class="flex items-center">
          <svg class="w-5 h-5 text-green-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span class="text-sm font-medium text-green-800">
            CSV file uploaded successfully: <%= @csv_import[:total_rows] %> rows found
          </span>
        </div>
      </div>
    </div>

    <div id="csv-mapping-form">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <!-- Field Mapping Section -->
        <div class="bg-white shadow rounded-lg p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Step 2: Map CSV Columns to Customer Fields</h2>
          
          <!-- Lead Source Selection -->
          <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
            <h3 class="text-sm font-semibold text-blue-900 mb-3">Default Lead Source for All Customers</h3>
            <div class="flex items-center space-x-4">
              <label for="default_lead_source" class="text-sm font-medium text-blue-800">
                Lead Source:
              </label>
              <select id="default_lead_source" name="default_lead_source" 
                      class="block rounded-md border-blue-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
                <option value="">-- Select Lead Source --</option>
                <% Customer::LEAD_SOURCES.each do |key, value| %>
                  <option value="<%= value %>" <%= 'selected' if value == 'Qatar_Web_summit' %>>
                    <%= value %>
                  </option>
                <% end %>
              </select>
            </div>
            <p class="text-xs text-blue-600 mt-2">
              This lead source will be applied to all imported customers unless a lead_source column is mapped below.
            </p>
          </div>
          
          <div class="space-y-4">
            <% @csv_import[:headers].each do |header| %>
              <div class="border border-gray-200 rounded-lg p-4">
                <div class="flex items-center justify-between mb-2">
                  <label class="text-sm font-medium text-gray-900">
                    CSV Column: "<%= header %>"
                  </label>
                  <% if @csv_import[:suggested_mappings][header] %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      Auto-suggested
                    </span>
                  <% end %>
                </div>
                
                <select name="field_mappings[<%= header %>]" 
                        class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
                  <option value="">-- Don't Import --</option>
                  <% CsvImportService.available_customer_fields.each do |key, label| %>
                    <option value="<%= key %>" <%= 'selected' if @csv_import[:suggested_mappings][header] == key %>>
                      <%= label %>
                    </option>
                  <% end %>
                </select>
                
                <!-- Sample Data Preview -->
                <div class="mt-2 text-xs text-gray-600">
                  <span class="font-medium">Sample data:</span>
                  <% sample_values = @csv_import[:sample_rows].map { |row| row[header] }.compact.first(3) %>
                  <% if sample_values.any? %>
                    <%= sample_values.join(', ') %>
                  <% else %>
                    <em>No sample data available</em>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
          
          <!-- Action Buttons -->
          <div class="flex items-center justify-between pt-6 mt-6 border-t border-gray-200">
            <%= link_to "Back to Upload", new_csv_import_path, 
                       class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            
            <button type="button" 
                    id="csv-import-button"
                    onclick="submitCsvImport()"
                    class="px-6 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
              Import Customers
            </button>
          </div>
        </div>

        <!-- Preview Section -->
        <div class="bg-white shadow rounded-lg p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Data Preview</h2>
          
          <!-- Sample Data Table -->
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <% @csv_import[:headers].each do |header| %>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      <%= truncate(header, length: 15) %>
                    </th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @csv_import[:sample_rows].each do |row| %>
                  <tr>
                    <% @csv_import[:headers].each do |header| %>
                      <td class="px-3 py-2 whitespace-nowrap text-xs text-gray-900">
                        <%= truncate(row[header].to_s, length: 20) %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <p class="text-xs text-gray-500 mt-4">
            Showing first <%= @csv_import[:sample_rows].length %> rows of <%= @csv_import[:total_rows] %> total rows
          </p>

          <!-- Import Summary -->
          <div class="mt-6 pt-4 border-t border-gray-200">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">Import Summary</h3>
            <div class="space-y-2 text-sm text-gray-600">
              <div class="flex justify-between">
                <span>Total Rows:</span>
                <span class="font-medium"><%= @csv_import[:total_rows] %></span>
              </div>
              <div class="flex justify-between">
                <span>CSV Columns:</span>
                <span class="font-medium"><%= @csv_import[:headers].length %></span>
              </div>
              <div class="flex justify-between">
                <span>Auto-mapped Fields:</span>
                <span class="font-medium"><%= @csv_import[:suggested_mappings].length %></span>
              </div>
            </div>
          </div>

          <!-- Field Mapping Guide -->
          <div class="mt-6 pt-4 border-t border-gray-200">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">Field Mapping Guide</h3>
            <div class="space-y-2 text-xs text-gray-600">
              <div><strong>Required:</strong> Name (at minimum)</div>
              <div><strong>Lead Source:</strong> Either map a lead_source column OR select default above</div>
              <div><strong>Assignment:</strong> All imported customers will be unassigned by default</div>
              <div><strong>Recommended:</strong> Email, Phone, Company</div>
              <div><strong>Optional:</strong> All other fields can be imported or skipped</div>
              <div><strong>Duplicates:</strong> Existing customers (by email/phone) will be updated</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Add some interactivity to show field mapping preview
  document.addEventListener('DOMContentLoaded', function() {
    const selects = document.querySelectorAll('select[name^="field_mappings"]');
    
    selects.forEach(select => {
      select.addEventListener('change', function() {
        // Add visual feedback when fields are mapped
        const container = this.closest('.border');
        if (this.value) {
          container.classList.add('border-blue-300', 'bg-blue-50');
          container.classList.remove('border-gray-200');
        } else {
          container.classList.remove('border-blue-300', 'bg-blue-50');
          container.classList.add('border-gray-200');
        }
      });
      
      // Initialize mapped fields styling
      if (select.value) {
        const container = select.closest('.border');
        container.classList.add('border-blue-300', 'bg-blue-50');
        container.classList.remove('border-gray-200');
      }
    });
  });

// Add debugging for import form
document.addEventListener('DOMContentLoaded', function() {
  console.log('CSV mapping form loaded');
  
  const form = document.getElementById('csv-mapping-form');
  const button = document.getElementById('csv-import-button');
  
  if (form && button) {
    form.addEventListener('submit', function(e) {
      console.log('CSV mapping form submission started');
      console.log('Form action:', this.action);
      console.log('Form method:', this.method);
      
      // Show loading state
      button.disabled = true;
      button.textContent = 'Importing...';
      
      console.log('Form data being submitted:', new FormData(form));
      return true; // Allow form to submit
    });
    
    button.addEventListener('click', function(e) {
      console.log('CSV import button clicked');
    });
    
    console.log('CSV mapping form handlers attached');
  } else {
    console.error('CSV mapping form elements not found');
  }
});

// Function to submit CSV import via AJAX
function submitCsvImport() {
  console.log('Starting CSV import submission...');
  
  const button = document.getElementById('csv-import-button');
  const originalText = button.textContent;
  
  // Collect field mappings
  const fieldMappings = {};
  const selects = document.querySelectorAll('select[name^="field_mappings"]');
  
  selects.forEach(select => {
    const headerMatch = select.name.match(/field_mappings\[(.*)\]/);
    if (headerMatch && select.value) {
      fieldMappings[headerMatch[1]] = select.value;
    }
  });
  
  // Get default lead source
  const defaultLeadSource = document.getElementById('default_lead_source').value;
  
  console.log('Field mappings:', fieldMappings);
  console.log('Default lead source:', defaultLeadSource);
  
  // Check if lead_source is mapped in field mappings
  const leadSourceMapped = Object.values(fieldMappings).includes('lead_source');
  
  // Validate that either lead_source is mapped OR default lead source is selected
  if (!leadSourceMapped && !defaultLeadSource) {
    alert('Please either map a lead_source column or select a default lead source for all customers.');
    button.disabled = false;
    button.textContent = originalText;
    return;
  }
  
  // Show loading state
  button.disabled = true;
  button.textContent = 'Importing...';
  
  // Get CSRF token
  const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
  
  // Make AJAX request
  fetch('<%= import_csv_imports_path %>', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
      'X-CSRF-Token': csrfToken
    },
    body: JSON.stringify({
      field_mappings: fieldMappings,
      upload_token: '<%= @csv_import[:upload_token] %>',
      default_lead_source: defaultLeadSource
    })
  })
  .then(response => {
    if (response.ok) {
      return response.json();
    }
    throw new Error('Network response was not ok');
  })
  .then(data => {
    console.log('Import response:', data);
    if (data.success) {
      // Show success message and redirect
      alert('CSV import started in background! You will receive a notification when it completes.');
      window.location.href = '<%= customers_path %>';
    } else {
      alert('Import failed: ' + data.error);
      button.disabled = false;
      button.textContent = originalText;
    }
  })
  .catch(error => {
    console.error('Import error:', error);
    alert('Import failed: ' + error.message);
    button.disabled = false;
    button.textContent = originalText;
  });
}
</script>