<%# Relay CSV import — step 2 of 3: map columns. Restyled from the prototype's
    ImportModal mapping step. Import is submitted as JSON to
    CsvImportsController#import (kept intact; it enqueues CsvImportWorker). %>
<% content_for :title, "Map columns — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="rl-eyebrow" style="margin-bottom:6px">Import leads from CSV</div>
      <div class="pagehead__title">Map columns</div>
      <div class="pagehead__sub">Step 2 of 3 · Match each CSV column to a lead field.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to cancel_csv_imports_path(token: @csv_import[:upload_token]), data: { turbo_method: :delete },
            class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("x", size: 16) %>Cancel
      <% end %>
    </div>
  </div>

  <div class="row" style="gap:8px;margin-bottom:var(--space-5)">
    <span class="rl-badge rl-badge--success"><%= relay_icon("check", size: 12) %>Upload</span>
    <span class="rl-badge rl-badge--primary">2 · Map columns</span>
    <span class="rl-badge rl-badge--neutral">3 · Import</span>
  </div>

  <div class="rl-pill rl-pill--success" style="margin-bottom:var(--space-5)">
    <i class="rl-dot"></i><%= relay_icon("file-check-2", size: 15) %>&nbsp;Uploaded · <%= number_with_delimiter(@csv_import[:total_rows]) %> rows found
  </div>

  <div class="grid grid-2" style="gap:var(--space-5);align-items:start">
    <%# Mapping panel %>
    <div class="sect">
      <div class="sect__head"><div class="sect__title"><%= relay_icon("columns-2", size: 18) %>Map CSV columns</div></div>
      <div class="sect__body">
        <%# Default lead source %>
        <div class="rl-field" style="margin-bottom:var(--space-5)">
          <label class="rl-label" for="default_lead_source">Default lead source</label>
          <%= select_tag "default_lead_source",
                options_for_select([["— Select lead source —", ""]] + current_organization.taxonomy_options("lead_source"), "Qatar_Web_summit"),
                id: "default_lead_source", class: "rl-select", style: "width:100%" %>
          <div class="muted rl-sm" style="margin-top:6px">Applied to every imported lead unless a lead_source column is mapped below.</div>
        </div>

        <div style="border:1px solid var(--color-border);border-radius:var(--radius-md);overflow:hidden">
          <div class="spread" style="padding:8px 14px;background:var(--color-surface-2);border-bottom:1px solid var(--color-border);font-size:12px;font-weight:700;color:var(--color-fg-3);text-transform:uppercase;letter-spacing:.04em">
            <span>CSV column</span><span>Maps to lead field</span>
          </div>
          <% @csv_import[:headers].each do |header| %>
            <div class="spread" style="padding:9px 14px;border-bottom:1px solid var(--color-divider);gap:12px">
              <span class="row" style="gap:8px;min-width:0">
                <%= relay_icon("columns-2", size: 15, css: "muted") %>
                <span style="min-width:0">
                  <b class="rl-sm" style="display:block"><%= header %></b>
                  <% sample_values = @csv_import[:sample_rows].map { |row| row[header] }.compact.first(2) %>
                  <span class="muted" style="font-size:11px"><%= sample_values.any? ? truncate(sample_values.join(", "), length: 32) : "no sample data" %></span>
                </span>
              </span>
              <%= select_tag "field_mappings[#{header}]",
                    options_for_select(
                      [["— skip —", ""]] + CsvImportService.available_customer_fields.map { |k, label| [label, k] },
                      @csv_import[:suggested_mappings][header]
                    ),
                    class: "rl-select rl-input--sm", style: "width:200px;flex:none" %>
            </div>
          <% end %>
        </div>

        <div class="rl-modal__foot" style="margin-top:18px;padding:0;border:none">
          <%= link_to "Back", new_csv_import_path, class: "rl-btn rl-btn--ghost" %>
          <button type="button" id="csv-import-button" class="rl-btn rl-btn--primary" onclick="submitCsvImport()">
            <%= relay_icon("upload", size: 15) %>Import <%= number_with_delimiter(@csv_import[:total_rows]) %> leads
          </button>
        </div>
      </div>
    </div>

    <%# Preview + summary panel %>
    <div class="col" style="gap:var(--space-5)">
      <div class="sect">
        <div class="sect__head"><div class="sect__title"><%= relay_icon("list-checks", size: 18) %>Data preview</div></div>
        <div class="sect__body--flush">
          <div class="rl-table-scroll">
            <table class="rl-table is-dense">
              <thead><tr>
                <% @csv_import[:headers].each do |header| %><th><%= truncate(header, length: 14) %></th><% end %>
              </tr></thead>
              <tbody>
                <% @csv_import[:sample_rows].each do |row| %>
                  <tr>
                    <% @csv_import[:headers].each do |header| %>
                      <td class="mono" style="font-size:12px"><%= truncate(row[header].to_s, length: 20) %></td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="rl-pagination"><span>Showing <%= @csv_import[:sample_rows].length %> of <%= number_with_delimiter(@csv_import[:total_rows]) %> rows</span></div>
      </div>

      <div class="sect">
        <div class="sect__head"><div class="sect__title"><%= relay_icon("info", size: 18) %>Import summary</div></div>
        <div class="sect__body col" style="gap:8px">
          <div class="spread rl-sm"><span class="muted">Total rows</span><b class="mono"><%= number_with_delimiter(@csv_import[:total_rows]) %></b></div>
          <div class="spread rl-sm"><span class="muted">CSV columns</span><b class="mono"><%= @csv_import[:headers].length %></b></div>
          <div class="spread rl-sm"><span class="muted">Auto-mapped</span><b class="mono"><%= @csv_import[:suggested_mappings].length %></b></div>
          <div class="muted rl-sm" style="margin-top:6px">Required: Name. Duplicates (by email/phone) are updated. All imports start unassigned.</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Submit field mappings as JSON to CsvImportsController#import (unchanged
  // contract — it enqueues CsvImportWorker and redirects to the leads list).
  function submitCsvImport() {
    const button = document.getElementById('csv-import-button');
    const original = button.innerHTML;

    const fieldMappings = {};
    document.querySelectorAll('select[name^="field_mappings"]').forEach(select => {
      const m = select.name.match(/field_mappings\[(.*)\]/);
      if (m && select.value) fieldMappings[m[1]] = select.value;
    });
    const defaultLeadSource = document.getElementById('default_lead_source').value;

    const leadSourceMapped = Object.values(fieldMappings).includes('lead_source');
    if (!leadSourceMapped && !defaultLeadSource) {
      alert('Map a lead_source column or pick a default lead source.');
      return;
    }

    button.disabled = true;
    button.textContent = 'Importing…';

    fetch('<%= import_csv_imports_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({
        field_mappings: fieldMappings,
        upload_token: '<%= @csv_import[:upload_token] %>',
        default_lead_source: defaultLeadSource
      })
    })
    .then(r => r.ok ? r.json() : Promise.reject(new Error('Network error')))
    .then(data => {
      if (data.success) {
        window.location.href = '<%= customers_path %>';
      } else {
        alert('Import failed: ' + data.error);
        button.disabled = false; button.innerHTML = original;
      }
    })
    .catch(err => {
      alert('Import failed: ' + err.message);
      button.disabled = false; button.innerHTML = original;
    });
  }
</script>
