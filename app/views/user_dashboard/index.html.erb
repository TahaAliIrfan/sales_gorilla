<%# Relay "Today" — role-aware rep cockpit. Mirrors docs/design/relay-app/project/app/view-today.jsx %>
<% content_for :title, "Today — #{current_organization&.name}" %>
<%
  hour = Time.current.hour
  greeting = hour < 12 ? "Good morning" : hour < 18 ? "Good afternoon" : "Good evening"
  first_name = (current_user.name.presence || current_user.email.split("@").first).split(/\s+/).first
%>

<div class="page">
  <%# === Header === %>
  <div class="pagehead">
    <div>
      <div class="rl-eyebrow" style="margin-bottom:6px"><%= Date.current.strftime("%A, %B %-d") %></div>
      <div class="pagehead__title"><%= greeting %>, <%= first_name %>.</div>
      <div class="pagehead__sub">
        <% if @is_manager %>
          Your team has <b><%= @team_open_followups %> open follow-ups</b> and <b><%= relay_money_compact(@open_pipeline_value) %></b> in active pipeline.
        <% elsif @overdue_tasks.any? %>
          You have <b style="color:var(--color-danger-text)"><%= @overdue_tasks.size %> overdue</b> and <%= @today_tasks.size %> due today. Let's clear them.
        <% else %>
          You're on track — <%= @today_tasks.size %> follow-ups due today and <%= @queue_count %> leads in your queue.
        <% end %>
      </div>
    </div>
    <div class="pagehead__actions">
      <%= link_to (@is_manager ? reports_path : my_reports_path), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("bar-chart-3", size: 15) %><%= @is_manager ? "Team numbers" : "My numbers" %>
      <% end %>
      <%= link_to customers_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("zap", size: 15) %>Work my list
      <% end %>
    </div>
  </div>

  <%# === KPI row — reps see their own numbers, managers/admins their team's === %>
  <% scope_word = @is_manager ? "team" : "you" %>
  <div class="grid <%= feature_enabled?(:calling) ? "grid-4" : "grid-3" %>" style="margin-bottom:var(--space-6)">
    <% if feature_enabled?(:calling) %>
      <%= render "user_dashboard/stat", label: "Calls today", value: @calls_today,
            sub: "#{@connected_today} connected · #{scope_word}", icon: "phone" %>
    <% end %>
    <%= render "user_dashboard/stat", label: "Leads worked", value: @leads_worked,
          sub: "this month · #{scope_word}", icon: "users" %>
    <%= render "user_dashboard/stat", label: "Deals won (mo)", value: relay_money_compact(@deals_won_value),
          sub: "#{@deals_won_count} closed · #{scope_word}", icon: "trophy" %>
    <%= render "user_dashboard/stat", label: "Conversion", value: "#{@conversion}%",
          sub: "win rate, all time · #{scope_word}", icon: "target" %>
  </div>

  <div class="grid" style="grid-template-columns:1.55fr 1fr;align-items:start">
    <%# === Left column === %>
    <div class="col" style="gap:var(--space-5)">
      <%# Today's follow-ups === %>
      <div class="sect">
        <div class="sect__head">
          <div class="sect__title"><%= relay_icon("list-checks", size: 19) %>Today's follow-ups</div>
          <div class="row" style="gap:8px">
            <span class="muted rl-sm"><%= @done_today %> done</span>
            <%= link_to "View all", my_tasks_tasks_path(status: "pending"), class: "rl-btn rl-btn--ghost rl-btn--sm" %>
          </div>
        </div>
        <div class="sect__body--flush">
          <% if @open_followups.zero? %>
            <div class="empty">
              <span class="empty__ic"><%= relay_icon("check-circle-2", size: 26) %></span>
              <div class="rl-h4" style="margin-bottom:4px">Inbox zero on tasks</div>
              <div class="muted rl-sm" style="max-width:360px">You've cleared every follow-up. Nice work — go work some fresh leads.</div>
              <div style="margin-top:16px"><%= link_to "Work my list", customers_path, class: "rl-btn rl-btn--primary rl-btn--sm" %></div>
            </div>
          <% else %>
            <% if @overdue_tasks.any? %>
              <div style="padding:10px 16px 4px"><span class="rl-eyebrow" style="color:var(--color-danger-text)">Overdue · <%= @overdue_tasks.size %></span></div>
              <%= render partial: "user_dashboard/task_row", collection: @overdue_tasks, as: :task, locals: { overdue: true } %>
            <% end %>
            <div style="padding:12px 16px 4px"><span class="rl-eyebrow">Today · <%= @today_tasks.size %></span></div>
            <% if @today_tasks.any? %>
              <%= render partial: "user_dashboard/task_row", collection: @today_tasks, as: :task, locals: { overdue: false } %>
            <% else %>
              <div style="padding:8px 16px 12px" class="muted rl-sm">Nothing due today.</div>
            <% end %>
            <div style="padding:12px 16px 4px"><span class="rl-eyebrow">Upcoming · <%= @upcoming_tasks.size %></span></div>
            <% if @upcoming_tasks.any? %>
              <%= render partial: "user_dashboard/task_row", collection: @upcoming_tasks, as: :task, locals: { overdue: false } %>
            <% else %>
              <div style="padding:8px 16px 12px" class="muted rl-sm">No upcoming follow-ups.</div>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Your queue === %>
      <div class="sect">
        <div class="sect__head">
          <div class="sect__title"><%= relay_icon("users", size: 19) %>Your queue</div>
          <div class="row" style="gap:8px">
            <span class="muted rl-sm"><%= @queue_count %> active</span>
            <%= link_to "View all", customers_path, class: "rl-btn rl-btn--ghost rl-btn--sm" %>
          </div>
        </div>
        <div class="sect__body--flush">
          <% if @queue.empty? %>
            <div style="padding:20px 16px;text-align:center" class="muted rl-sm">No active leads in your queue.</div>
          <% else %>
            <% @queue.each do |lead| %>
              <%= link_to customer_path(lead), class: "rl-convo" do %>
                <span class="rl-avatar rl-avatar--sm <%= relay_avatar_class(lead.name) %>"><%= relay_initials(lead.name) %></span>
                <div class="rl-convo__main">
                  <div class="rl-convo__row">
                    <span class="rl-convo__name"><%= lead.name %></span>
                    <span class="rl-convo__time"><%= time_ago_in_words(lead.updated_at) %> ago</span>
                  </div>
                  <div class="rl-convo__preview">
                    <%= lead.company.presence || "No company" %>
                  </div>
                </div>
                <span class="rl-pill rl-pill--brand"><i class="rl-dot"></i><%= lead.status %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Manager/admin: team attainment === %>
      <% if @is_manager %>
        <div class="sect">
          <div class="sect__head">
            <div class="sect__title"><%= relay_icon("users-2", size: 19) %>Team this month</div>
            <%= link_to "Full report", manager_dashboard_path, class: "rl-btn rl-btn--ghost rl-btn--sm" %>
          </div>
          <div class="sect__body--flush">
            <% if @team.empty? %>
              <div style="padding:20px 16px;text-align:center" class="muted rl-sm">No reps assigned to you yet.</div>
            <% else %>
              <% @team.each do |row| %>
                <% rep = row[:user]; rep_name = rep.name.presence || rep.email %>
                <div class="rl-listitem">
                  <span class="rl-avatar rl-avatar--sm <%= relay_avatar_class(rep_name) %>"><%= relay_initials(rep_name) %></span>
                  <div class="rl-listitem__main">
                    <div class="rl-listitem__title"><%= rep_name %></div>
                    <div class="rl-listitem__sub"><%= row[:calls] %> calls · <%= row[:leads] %> leads · <%= relay_money_compact(row[:won_value]) %> won</div>
                  </div>
                  <div style="width:130px">
                    <div class="spread" style="margin-bottom:4px">
                      <span class="muted" style="font-size:11px">Target</span>
                      <span class="mono" style="font-size:11px;font-weight:700;color:<%= relay_attainment_text_color(row[:attainment]) %>"><%= row[:attainment] %>%</span>
                    </div>
                    <div class="targetbar"><i style="width:<%= row[:attainment] %>%;background:<%= relay_attainment_color(row[:attainment]) %>"></i></div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# === Right column === %>
    <div class="col" style="gap:var(--space-5)">
      <%# Unassigned leads === %>
      <div class="sect">
        <div class="sect__head">
          <div class="sect__title"><%= relay_icon("inbox", size: 18) %>Unassigned leads</div>
          <span class="rl-badge rl-badge--warning"><%= @unassigned_count %> new</span>
        </div>
        <div class="sect__body--flush">
          <% if @unassigned.empty? %>
            <div style="padding:20px 16px;text-align:center" class="muted rl-sm">All caught up — nothing waiting.</div>
          <% else %>
            <% @unassigned.each do |lead| %>
              <div class="rl-listitem" id="<%= dom_id(lead, :unassigned) %>">
                <span class="rl-avatar rl-avatar--sm <%= relay_avatar_class(lead.name) %>"><%= relay_initials(lead.name) %></span>
                <div class="rl-listitem__main">
                  <div class="rl-listitem__title"><%= lead.name %></div>
                  <div class="rl-listitem__sub row" style="gap:6px">
                    <span><%= lead.company.presence || "No company" %></span>
                    <% if lead.lead_source.present? %>
                      <i style="width:3px;height:3px;border-radius:9px;background:var(--color-fg-4)"></i>
                      <span><%= lead.lead_source %></span>
                    <% end %>
                  </div>
                </div>
                <%= button_to assign_to_self_customer_path(lead), method: :post,
                      form: {},
                      class: "rl-btn rl-btn--brand-soft rl-btn--sm" do %>
                  Assign to me
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Pipeline snapshot === %>
      <div class="sect">
        <div class="sect__head">
          <div class="sect__title"><%= relay_icon("trending-up", size: 18) %>Pipeline</div>
          <%= link_to "Open board", deals_path, class: "rl-btn rl-btn--ghost rl-btn--sm" %>
        </div>
        <div class="sect__body">
          <div class="spread" style="align-items:center">
            <div>
              <div class="rl-eyebrow">Open pipeline</div>
              <div style="font-family:var(--font-display);font-weight:800;font-size:30px;letter-spacing:-.02em;line-height:1.1" class="mono"><%= relay_money_compact(@open_pipeline_value) %></div>
              <div class="muted rl-sm" style="margin-top:2px"><%= @open_pipeline_count %> active deals</div>
            </div>
            <div class="score" style="flex-direction:column;align-items:flex-end;gap:6px">
              <span class="mono" style="font-family:var(--font-display);font-weight:800;font-size:22px"><%= @win_rate %>%</span>
              <span class="muted" style="font-size:11px">win rate</span>
              <span class="score__bar" style="width:84px"><i style="width:<%= @win_rate %>%;background:var(--color-primary)"></i></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
