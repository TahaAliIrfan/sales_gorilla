<% content_for :title, "Dashboard — #{current_organization&.name}" %>

<%= render "shared/page_header",
      eyebrow: "Overview",
      title: "Good to see you, #{current_user.name.presence || current_user.email.split('@').first}.",
      subtitle: "#{current_organization&.name} at a glance." %>

<%# === Headline stats: figures in mono, hairline dividers, no busy chrome === %>
<div class="grid grid-cols-2 overflow-hidden rounded-xl bg-panel shadow-card ring-1 ring-[var(--color-line-2)] lg:grid-cols-4">
  <% [
    [ "Customers",      @total_customers,                                      "#{@customers_this_month} new this month", :accent, customers_path,           "users",     0   ],
    [ "Active deals",   number_to_currency(@active_deal_value, precision: 0),  "#{@active_deals} open",                    :muted,  my_deals_deals_path,      "deal",      80  ],
    [ "Pending tasks",  @pending_tasks_count,                                  (@overdue_tasks_count.to_i > 0 ? "#{@overdue_tasks_count} overdue" : "On track"), (@overdue_tasks_count.to_i > 0 ? :alert : :accent), my_tasks_tasks_path(status: 'pending'), "task", 160 ],
    [ "Call success",   "#{@call_success_rate}%",                              "#{@calls_this_month} calls this month",    :muted,  my_recordings_recordings_path, "phone", 240 ]
  ].each_with_index do |(label, value, sub, sub_tone, href, icon, delay), i| %>
    <div class="border-[var(--color-line)] <%= 'border-l' if i.positive? %>">
      <%= render "shared/stat_card",
            label: label, value: value, sub: sub, sub_tone: sub_tone,
            href: href, icon: icon, delay: delay %>
    </div>
  <% end %>
</div>

<%# === Three-column row: deal performance · customer status · weekly activity === %>
<div class="mt-6 grid gap-6 lg:grid-cols-3">
  <%= render "shared/panel", eyebrow: "Deal performance" do %>
    <dl class="space-y-3 text-sm">
      <div class="flex items-center justify-between">
        <dt class="text-ink-soft">Won</dt>
        <dd class="flex items-baseline gap-2">
          <span class="mono text-lg font-semibold text-ink"><%= @won_deals %></span>
          <span class="mono text-xs text-ink-soft"><%= number_to_currency(@won_deal_value, precision: 0) %></span>
        </dd>
      </div>
      <div class="flex items-center justify-between">
        <dt class="text-ink-soft">Lost</dt>
        <dd class="flex items-baseline gap-2">
          <span class="mono text-lg font-semibold text-ink"><%= @lost_deals %></span>
          <span class="mono text-xs text-ink-soft"><%= number_to_currency(@lost_deal_value, precision: 0) %></span>
        </dd>
      </div>
    </dl>

    <div class="mt-5 border-t border-dashed border-[var(--color-line-2)] pt-4">
      <div class="flex items-center justify-between">
        <span class="micro">Win rate</span>
        <span class="mono text-2xl font-semibold text-ink"><%= @win_rate %>%</span>
      </div>
      <div class="mt-2 h-1.5 overflow-hidden rounded-full bg-[var(--color-line)]">
        <div class="h-full rounded-full" style="width: <%= @win_rate %>%; background: var(--brand-accent)"></div>
      </div>
    </div>

    <div class="mt-5 border-t border-dashed border-[var(--color-line-2)] pt-4">
      <p class="micro">Revenue this month</p>
      <p class="mono mt-1 text-xl font-semibold text-ink"><%= number_to_currency(@revenue_this_month) %></p>
    </div>
  <% end %>

  <%= render "shared/panel", eyebrow: "Customer status" do %>
    <ul class="space-y-2.5 text-sm">
      <% [
        [ "Pending",             :pending,             "warn" ],
        [ "Contact established", :contact_established, "info" ],
        [ "Converted",           :converted,           "ok"   ],
        [ "Not interested",      :not_interested,      "bad"  ],
        [ "Exhausted",           :exhausted,           "muted" ]
      ].each do |label, key, tone| %>
        <li class="flex items-center justify-between">
          <span class="flex items-center gap-2 text-ink-soft">
            <span class="h-1.5 w-1.5 rounded-full" style="background: <%= { ok: '#10B981', warn: '#d97706', bad: '#dc2626', info: '#2563eb', muted: '#9ca3af' }[tone.to_sym] %>"></span>
            <%= label %>
          </span>
          <span class="mono text-base font-semibold text-ink"><%= @customer_status_counts[key] || 0 %></span>
        </li>
      <% end %>
    </ul>
    <div class="mt-4 border-t border-dashed border-[var(--color-line-2)] pt-4">
      <div class="flex items-center justify-between">
        <span class="micro">Total customers</span>
        <span class="mono text-2xl font-semibold text-ink"><%= @total_customers %></span>
      </div>
    </div>
  <% end %>

  <%= render "shared/panel", eyebrow: "This month" do %>
    <ul class="divide-y divide-[var(--color-line)] text-sm">
      <% [
        [ "New customers",      @customers_this_month        ],
        [ "Deals created",      @deals_created_this_month    ],
        [ "Tasks completed",    @completed_tasks_this_month  ],
        [ "Calls made",         @calls_this_month            ]
      ].each do |label, value| %>
        <li class="flex items-center justify-between py-2.5 first:pt-0 last:pb-0">
          <span class="text-ink-soft"><%= label %></span>
          <span class="mono text-lg font-semibold text-ink"><%= value %></span>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>

<%# === Pipeline overview === %>
<% if @deal_stages.any? %>
  <div class="mt-6">
    <%= render "shared/panel", eyebrow: "Pipeline", title: "My pipeline overview",
          actions: link_to("View deals →", my_deals_deals_path, class: "text-ink-soft transition hover:text-ink", style: "color: var(--brand-primary)") do %>
      <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
        <% @deal_stages.each do |stage| %>
          <div class="rounded-lg p-3 ring-1 ring-[var(--color-line-2)]">
            <p class="micro truncate" title="<%= stage.name %>"><%= stage.name %></p>
            <p class="mono mt-2 text-2xl font-semibold text-ink"><%= @deals_by_stage[stage.id] || 0 %></p>
            <p class="mono text-[10px] text-ink-soft/70">deals</p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# === Task triage: today · overdue · upcoming === %>
<div class="mt-6 grid gap-6 lg:grid-cols-3">
  <% [
    [ "Today's tasks", @today_tasks,    @today_tasks_count,    "ok",   "Nothing due today." ],
    [ "Overdue",        @overdue_tasks, @overdue_tasks_count, "bad",  "All clear — nothing overdue." ],
    [ "Upcoming",       @pending_tasks,  @pending_tasks_count,  "warn", "No upcoming tasks." ]
  ].each do |title, tasks, count, tone, empty_label| %>
    <%= render "shared/panel",
          eyebrow: title,
          title: nil,
          actions: tag.span(count.to_s, class: "mono inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold",
                            style: "background: var(--color-line); color: var(--color-ink)") do %>
      <% if tasks.any? %>
        <ul class="divide-y divide-[var(--color-line)]">
          <% tasks.each do |task| %>
            <li class="flex items-start gap-3 py-3 first:pt-0 last:pb-0">
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-ink">
                  <%= link_to task.title, task_path(task), class: "transition hover:text-accent" %>
                </p>
                <p class="mono mt-1 text-xs text-ink-soft">
                  <%= task.due_date&.strftime("%b %-d, %-I:%M %p") %>
                  <% if task.customer %>· <%= task.customer.name %><% end %>
                  <% if task.priority.present? %>
                    · <span style="color: <%= task.priority == 'High' ? '#dc2626' : task.priority == 'Medium' ? '#d97706' : 'var(--color-ink-soft)' %>"><%= task.priority %></span>
                  <% end %>
                </p>
              </div>
              <%= button_to complete_task_path(task), method: :patch,
                    form: { class: "shrink-0" },
                    class: "grid h-7 w-7 place-items-center rounded-md ring-1 ring-[var(--color-line-2)] text-ink-soft transition hover:text-ink hover:bg-[var(--color-line)]",
                    title: "Mark complete" do %>
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="py-6 text-center text-sm text-ink-soft"><%= empty_label %></p>
      <% end %>
    <% end %>
  <% end %>
</div>

<%# === Recent deals & customers === %>
<div class="mt-6 grid gap-6 lg:grid-cols-2">
  <%= render "shared/panel",
        eyebrow: "Recent",
        title: "My active deals",
        actions: link_to("View all →", my_deals_deals_path, class: "transition hover:text-ink", style: "color: var(--brand-primary)") do %>
    <% if @recent_deals.any? %>
      <ul class="divide-y divide-[var(--color-line)]">
        <% @recent_deals.each do |deal| %>
          <li class="flex items-center justify-between py-3 first:pt-0 last:pb-0">
            <div class="min-w-0 flex-1 pr-3">
              <p class="truncate text-sm font-medium text-ink">
                <%= link_to deal.title.presence || "Untitled deal", deal_path(deal), class: "transition hover:text-accent" %>
              </p>
              <p class="mono mt-1 truncate text-xs text-ink-soft">
                <%= deal.customer&.name.presence || "No customer" %> · <%= deal.deal_stage.name %>
              </p>
            </div>
            <span class="mono shrink-0 text-sm font-semibold text-ink">
              <%= number_to_currency(deal.amount, precision: 0) %>
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="py-6 text-center text-sm text-ink-soft">No recent deals.</p>
    <% end %>
  <% end %>

  <%= render "shared/panel",
        eyebrow: "Recent",
        title: "Recent customers",
        actions: link_to("View all →", customers_path, class: "transition hover:text-ink", style: "color: var(--brand-primary)") do %>
    <% if @recent_customers.any? %>
      <ul class="divide-y divide-[var(--color-line)]">
        <% @recent_customers.each do |customer| %>
          <li class="flex items-center justify-between gap-3 py-3 first:pt-0 last:pb-0">
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium text-ink">
                <%= link_to customer.name, customer_path(customer), class: "transition hover:text-accent" %>
              </p>
              <p class="mono mt-1 truncate text-xs text-ink-soft">
                <%= customer.email.presence || customer.phone.presence || "—" %>
              </p>
            </div>
            <%= render "shared/status_pill", label: customer.status %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="py-6 text-center text-sm text-ink-soft">No recent customers.</p>
    <% end %>
  <% end %>
</div>
