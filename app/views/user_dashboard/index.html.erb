<div class="px-4 sm:px-6 lg:px-8 py-8 bg-gray-50 min-h-screen">
  <!-- Welcome Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">
      Welcome back, <%= current_user.name || current_user.email %>! 👋
    </h1>
    <p class="mt-2 text-sm text-gray-600">Here's what's happening with your work today.</p>
  </div>

  <!-- Key Metrics - 4 Main Stats -->
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-8">
    <!-- Total Customers Card -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-blue-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Total Customers</dt>
              <dd class="flex items-baseline">
                <div class="text-3xl font-bold text-gray-900"><%= @total_customers %></div>
                <span class="ml-2 text-xs font-medium text-green-600">
                  +<%= @customers_this_month %> this month
                </span>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-blue-50 px-6 py-3">
        <%= link_to customers_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-800 flex items-center" do %>
          View all customers
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- Active Deals Card -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-green-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Active Deals</dt>
              <dd class="flex items-baseline">
                <div class="text-3xl font-bold text-gray-900"><%= @active_deals %></div>
                <span class="ml-2 text-xs font-medium text-gray-600">
                  <%= number_to_currency(@active_deal_value, precision: 0) %>
                </span>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-green-50 px-6 py-3">
        <%= link_to my_deals_deals_path, class: "text-sm font-semibold text-green-600 hover:text-green-800 flex items-center" do %>
          View all deals
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- Pending Tasks Card -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-orange-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12l2 2 4-4" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Pending Tasks</dt>
              <dd class="flex items-baseline">
                <div class="text-3xl font-bold text-gray-900"><%= @pending_tasks_count %></div>
                <% if @overdue_tasks_count > 0 %>
                  <span class="ml-2 text-xs font-medium text-red-600">
                    <%= @overdue_tasks_count %> overdue
                  </span>
                <% end %>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-orange-50 px-6 py-3">
        <%= link_to my_tasks_tasks_path, class: "text-sm font-semibold text-orange-600 hover:text-orange-800 flex items-center" do %>
          View all tasks
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- Call Success Rate Card -->
    <div class="bg-white overflow-hidden shadow-lg rounded-xl hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-purple-500 rounded-xl p-3">
            <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Call Success Rate</dt>
              <dd class="flex items-baseline">
                <div class="text-3xl font-bold text-gray-900"><%= @call_success_rate %>%</div>
                <span class="ml-2 text-xs font-medium text-gray-600">
                  <%= @calls_this_month %> calls this month
                </span>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-purple-50 px-6 py-3">
        <%= link_to my_recordings_recordings_path, class: "text-sm font-semibold text-purple-600 hover:text-purple-800 flex items-center" do %>
          View recordings
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Performance Overview Section -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <!-- Deal Performance -->
    <div class="bg-white shadow-lg rounded-xl p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
        <span class="bg-green-100 text-green-600 rounded-lg p-2 mr-3">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </span>
        Deal Performance
      </h3>
      <div class="space-y-4">
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-600">Won Deals</span>
          <div class="flex items-center">
            <span class="text-lg font-bold text-green-600"><%= @won_deals %></span>
            <span class="ml-2 text-xs text-gray-500"><%= number_to_currency(@won_deal_value, precision: 0) %></span>
          </div>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-600">Lost Deals</span>
          <div class="flex items-center">
            <span class="text-lg font-bold text-red-600"><%= @lost_deals %></span>
            <span class="ml-2 text-xs text-gray-500"><%= number_to_currency(@lost_deal_value, precision: 0) %></span>
          </div>
        </div>
        <div class="pt-3 border-t">
          <div class="flex justify-between items-center">
            <span class="text-sm font-medium text-gray-700">Win Rate</span>
            <span class="text-2xl font-bold text-blue-600"><%= @win_rate %>%</span>
          </div>
          <div class="mt-2 bg-gray-200 rounded-full h-2">
            <div class="bg-blue-600 rounded-full h-2" style="width: <%= @win_rate %>%"></div>
          </div>
        </div>
        <div class="pt-3 border-t">
          <div class="text-sm text-gray-600">Revenue This Month</div>
          <div class="text-xl font-bold text-gray-900 mt-1"><%= number_to_currency(@revenue_this_month) %></div>
        </div>
      </div>
    </div>

    <!-- Customer Status Breakdown -->
    <div class="bg-white shadow-lg rounded-xl p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
        <span class="bg-blue-100 text-blue-600 rounded-lg p-2 mr-3">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </span>
        Customer Status
      </h3>
      <div class="space-y-3">
        <div class="flex justify-between items-center">
          <div class="flex items-center">
            <div class="w-3 h-3 rounded-full bg-yellow-400 mr-2"></div>
            <span class="text-sm text-gray-600">Pending</span>
          </div>
          <span class="text-lg font-bold text-gray-900"><%= @customer_status_counts[:pending] %></span>
        </div>
        <div class="flex justify-between items-center">
          <div class="flex items-center">
            <div class="w-3 h-3 rounded-full bg-blue-500 mr-2"></div>
            <span class="text-sm text-gray-600">Contact Established</span>
          </div>
          <span class="text-lg font-bold text-gray-900"><%= @customer_status_counts[:contact_established] %></span>
        </div>
        <div class="flex justify-between items-center">
          <div class="flex items-center">
            <div class="w-3 h-3 rounded-full bg-green-500 mr-2"></div>
            <span class="text-sm text-gray-600">Converted</span>
          </div>
          <span class="text-lg font-bold text-gray-900"><%= @customer_status_counts[:converted] %></span>
        </div>
        <div class="flex justify-between items-center">
          <div class="flex items-center">
            <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
            <span class="text-sm text-gray-600">Not Interested</span>
          </div>
          <span class="text-lg font-bold text-gray-900"><%= @customer_status_counts[:not_interested] %></span>
        </div>
        <div class="flex justify-between items-center">
          <div class="flex items-center">
            <div class="w-3 h-3 rounded-full bg-gray-500 mr-2"></div>
            <span class="text-sm text-gray-600">Exhausted</span>
          </div>
          <span class="text-lg font-bold text-gray-900"><%= @customer_status_counts[:exhausted] %></span>
        </div>
        <div class="pt-3 border-t">
          <div class="text-sm text-gray-600">Total Customers</div>
          <div class="text-2xl font-bold text-gray-900 mt-1"><%= @total_customers %></div>
        </div>
      </div>
    </div>

    <!-- Activity This Week -->
    <div class="bg-white shadow-lg rounded-xl p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
        <span class="bg-indigo-100 text-indigo-600 rounded-lg p-2 mr-3">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </span>
        Recent Activity (7 Days)
      </h3>
      <div class="space-y-4">
        <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
          <div class="flex items-center">
            <svg class="h-5 w-5 text-blue-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            <span class="text-sm font-medium text-gray-700">Customers This Month</span>
          </div>
          <span class="text-xl font-bold text-blue-600"><%= @customers_this_month %></span>
        </div>
        <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
          <div class="flex items-center">
            <svg class="h-5 w-5 text-green-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm font-medium text-gray-700">Deals This Month</span>
          </div>
          <span class="text-xl font-bold text-green-600"><%= @deals_created_this_month %></span>
        </div>
        <div class="flex items-center justify-between p-3 bg-purple-50 rounded-lg">
          <div class="flex items-center">
            <svg class="h-5 w-5 text-purple-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm font-medium text-gray-700">Tasks Completed</span>
          </div>
          <span class="text-xl font-bold text-purple-600"><%= @completed_tasks_this_month %></span>
        </div>
        <div class="flex items-center justify-between p-3 bg-orange-50 rounded-lg">
          <div class="flex items-center">
            <svg class="h-5 w-5 text-orange-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span class="text-sm font-medium text-gray-700">Calls This Month</span>
          </div>
          <span class="text-xl font-bold text-orange-600"><%= @calls_this_month %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Pipeline Overview -->
  <% if @deal_stages.any? %>
    <div class="bg-white shadow-lg rounded-xl p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-6 flex items-center">
        <span class="bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-lg p-2 mr-3">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        </span>
        My Pipeline Overview
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <% @deal_stages.each_with_index do |stage, index| %>
          <div class="relative group">
            <div class="bg-gradient-to-br from-gray-50 to-gray-100 hover:from-blue-50 hover:to-blue-100 rounded-xl p-4 text-center transition-all duration-300 border-2 border-gray-200 hover:border-blue-400">
              <div class="text-xs font-semibold text-gray-500 mb-2 truncate" title="<%= stage.name %>">
                <%= stage.name %>
              </div>
              <div class="text-3xl font-bold text-gray-900"><%= @deals_by_stage[stage.id] || 0 %></div>
              <div class="text-xs text-gray-500 mt-1">deals</div>
            </div>
            <% unless index == @deal_stages.length - 1 %>
              <div class="hidden lg:block absolute top-1/2 -right-2 transform -translate-y-1/2 z-10">
                <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Tasks Section -->
  <div class="mb-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-6 flex items-center">
      <span class="bg-gradient-to-r from-orange-500 to-red-600 text-white rounded-lg p-2 mr-3">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12l2 2 4-4" />
        </svg>
      </span>
      My Tasks Overview
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Today's Tasks -->
      <div class="bg-white shadow-lg rounded-xl overflow-hidden">
        <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-white">Today's Tasks</h3>
            <span class="px-3 py-1 text-sm font-bold rounded-full bg-white text-blue-600">
              <%= @today_tasks_count %>
            </span>
          </div>
        </div>
        <div class="p-6">
          <% if @today_tasks.any? %>
            <ul class="space-y-3">
              <% @today_tasks.each do |task| %>
                <li class="flex items-start p-3 bg-gray-50 rounded-lg hover:bg-blue-50 transition-colors">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= link_to task.title, task_path(task), class: "hover:text-blue-600" %>
                    </p>
                    <p class="text-xs text-gray-500 mt-1">
                      <%= task.due_date.strftime("%I:%M %p") %>
                      <% if task.customer %>
                        • <%= task.customer.name %>
                      <% end %>
                    </p>
                  </div>
                  <%= button_to complete_task_path(task), method: :patch, class: "ml-2 p-1 rounded-full bg-green-100 hover:bg-green-200 text-green-700" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="text-center py-8 text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-sm">No tasks due today</p>
            </div>
          <% end %>
        </div>
        <div class="bg-gray-50 px-6 py-3">
          <%= link_to my_tasks_tasks_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-800 flex items-center justify-center" do %>
            View all tasks
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- Overdue Tasks -->
      <div class="bg-white shadow-lg rounded-xl overflow-hidden">
        <div class="bg-gradient-to-r from-red-500 to-red-600 px-6 py-4">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-white">Overdue Tasks</h3>
            <span class="px-3 py-1 text-sm font-bold rounded-full bg-white text-red-600">
              <%= @overdue_tasks_count %>
            </span>
          </div>
        </div>
        <div class="p-6">
          <% if @overdue_tasks.any? %>
            <ul class="space-y-3">
              <% @overdue_tasks.each do |task| %>
                <li class="flex items-start p-3 bg-gray-50 rounded-lg hover:bg-red-50 transition-colors">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= link_to task.title, task_path(task), class: "hover:text-red-600" %>
                    </p>
                    <p class="text-xs text-red-600 mt-1 font-medium">
                      Due <%= task.due_date.strftime("%b %d, %I:%M %p") %>
                      <% if task.customer %>
                        • <%= task.customer.name %>
                      <% end %>
                    </p>
                  </div>
                  <%= button_to complete_task_path(task), method: :patch, class: "ml-2 p-1 rounded-full bg-green-100 hover:bg-green-200 text-green-700" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="text-center py-8 text-gray-500">
              <svg class="mx-auto h-12 w-12 text-green-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-sm">No overdue tasks! 🎉</p>
            </div>
          <% end %>
        </div>
        <div class="bg-gray-50 px-6 py-3">
          <%= link_to my_tasks_tasks_path(status: "Pending"), class: "text-sm font-semibold text-red-600 hover:text-red-800 flex items-center justify-center" do %>
            View overdue tasks
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- Upcoming Tasks -->
      <div class="bg-white shadow-lg rounded-xl overflow-hidden">
        <div class="bg-gradient-to-r from-yellow-500 to-yellow-600 px-6 py-4">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-white">Upcoming Tasks</h3>
            <span class="px-3 py-1 text-sm font-bold rounded-full bg-white text-yellow-600">
              <%= @pending_tasks_count %>
            </span>
          </div>
        </div>
        <div class="p-6">
          <% if @pending_tasks.any? %>
            <ul class="space-y-3">
              <% @pending_tasks.each do |task| %>
                <li class="flex items-start p-3 bg-gray-50 rounded-lg hover:bg-yellow-50 transition-colors">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= link_to task.title, task_path(task), class: "hover:text-yellow-600" %>
                    </p>
                    <div class="flex items-center mt-1 text-xs text-gray-500">
                      <span><%= task.due_date.strftime("%b %d, %I:%M %p") %></span>
                      <% if task.customer %>
                        <span class="ml-2">• <%= task.customer.name %></span>
                      <% end %>
                      <span class="ml-2 px-2 py-0.5 rounded-full <%= task.priority == 'High' ? 'bg-red-100 text-red-700' : task.priority == 'Medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700' %>">
                        <%= task.priority %>
                      </span>
                    </div>
                  </div>
                  <%= button_to complete_task_path(task), method: :patch, class: "ml-2 p-1 rounded-full bg-green-100 hover:bg-green-200 text-green-700" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="text-center py-8 text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              <p class="text-sm">No upcoming tasks</p>
            </div>
          <% end %>
        </div>
        <div class="bg-gray-50 px-6 py-3">
          <%= link_to my_tasks_tasks_path, class: "text-sm font-semibold text-yellow-600 hover:text-yellow-800 flex items-center justify-center" do %>
            View all tasks
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Deals and Customers -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Recent Deals -->
    <div class="bg-white shadow-lg rounded-xl overflow-hidden">
      <div class="bg-gradient-to-r from-green-500 to-green-600 px-6 py-4">
        <h3 class="text-lg font-semibold text-white flex items-center">
          <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          My Active Deals
        </h3>
      </div>
      <div class="p-6">
        <% if @recent_deals.any? %>
          <ul class="space-y-3">
            <% @recent_deals.each do |deal| %>
              <li class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-green-50 transition-colors">
                <div class="flex-1 min-w-0 mr-4">
                  <p class="text-sm font-semibold text-gray-900 truncate">
                    <%= link_to deal.title, deal_path(deal), class: "hover:text-green-600" %>
                  </p>
                  <p class="text-xs text-gray-600 mt-1">
                    <% if deal.customer.present? %>
                      <%= deal.customer.name %>
                    <% else %>
                      <span class="text-gray-400">No customer</span>
                    <% end %>
                    • <%= deal.deal_stage.name %>
                  </p>
                </div>
                <span class="px-3 py-1 text-sm font-bold rounded-full bg-green-100 text-green-700 whitespace-nowrap">
                  <%= number_to_currency(deal.amount, precision: 0) %>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="text-center py-8 text-gray-500">
            <svg class="mx-auto h-12 w-12 text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm">No recent deals</p>
          </div>
        <% end %>
      </div>
      <div class="bg-gray-50 px-6 py-3">
        <%= link_to my_deals_deals_path, class: "text-sm font-semibold text-green-600 hover:text-green-800 flex items-center justify-center" do %>
          View all my deals
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- Recent Customers -->
    <div class="bg-white shadow-lg rounded-xl overflow-hidden">
      <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
        <h3 class="text-lg font-semibold text-white flex items-center">
          <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          Recent Customers
        </h3>
      </div>
      <div class="p-6">
        <% if @recent_customers.any? %>
          <ul class="space-y-3">
            <% @recent_customers.each do |customer| %>
              <li class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-blue-50 transition-colors">
                <div class="flex-1 min-w-0 mr-4">
                  <p class="text-sm font-semibold text-gray-900 truncate">
                    <%= link_to customer.name, customer_path(customer), class: "hover:text-blue-600" %>
                  </p>
                  <p class="text-xs text-gray-600 mt-1 truncate">
                    <%= customer.email.presence || "No email" %>
                  </p>
                </div>
                <span class="px-3 py-1 text-xs font-semibold rounded-full whitespace-nowrap
                  <%= case customer.status
                      when 'Pending' then 'bg-yellow-100 text-yellow-700'
                      when 'Contact Established' then 'bg-blue-100 text-blue-700'
                      when 'Converted' then 'bg-green-100 text-green-700'
                      when 'Not Interested' then 'bg-red-100 text-red-700'
                      else 'bg-gray-100 text-gray-700'
                      end %>">
                  <%= customer.status %>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="text-center py-8 text-gray-500">
            <svg class="mx-auto h-12 w-12 text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <p class="text-sm">No recent customers</p>
          </div>
        <% end %>
      </div>
      <div class="bg-gray-50 px-6 py-3">
        <%= link_to customers_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-800 flex items-center justify-center" do %>
          View all customers
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
