<div>
  <h1 class="text-2xl font-bold mb-6">My Dashboard</h1>

  <% if @needs_attention %>
    <!-- Items Needing Attention -->
    <div class="mb-8 bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded-md">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800">Items Needing Attention</h3>
          <div class="mt-2 text-sm text-yellow-700">
            <% if @deals_needing_attention.any? %>
              <p class="mb-2">You have <%= @deals_needing_attention.count %> deals that need your attention:</p>
              <ul class="list-disc pl-5 space-y-1 mb-3">
                <% @deals_needing_attention.each do |deal| %>
                  <li>
                    <%= link_to deal.title, deal_path(deal), class: "underline hover:text-yellow-900" %>
                    <% if deal.expected_close_date && deal.expected_close_date < Date.today %>
                      <span class="text-red-600 font-medium"> (Overdue)</span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% end %>
            
            <% if @customers_needing_attention.any? %>
              <p class="mb-2">You have <%= @customers_needing_attention.count %> customers that need your attention:</p>
              <ul class="list-disc pl-5 space-y-1">
                <% @customers_needing_attention.each do |customer| %>
                  <li>
                    <%= link_to customer.name, customer_path(customer), class: "underline hover:text-yellow-900" %>
                    <span class="text-gray-600"> (<%= customer.status %>)</span>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <!-- My Deals Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">My Active Deals</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @active_deals %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_deals_deals_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all my deals
          <% end %>
        </div>
      </div>
    </div>

    <!-- Won Deals Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">My Won Deals</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @won_deals %></div>
                <div class="ml-2 text-sm font-medium text-green-600">
                  <%= number_to_currency(@won_deal_value) %>
                </div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_deals_deals_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all my deals
          <% end %>
        </div>
      </div>
    </div>

    <!-- Lost Deals Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">My Lost Deals</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @lost_deals %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to my_deals_deals_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all my deals
          <% end %>
        </div>
      </div>
    </div>

    <!-- My Customers Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">My Customers</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @my_customers.count %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to customers_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all customers
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- My Pipeline Overview -->
  <div class="mt-8">
    <h2 class="text-lg font-medium text-gray-900 mb-4">My Pipeline Overview</h2>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center space-x-4">
          <% @deal_stages.each do |stage| %>
            <div class="flex-1 text-center">
              <div class="text-sm font-medium text-gray-500"><%= stage.name %></div>
              <div class="mt-1 text-2xl font-semibold text-gray-900"><%= @deals_by_stage[stage.id] || 0 %></div>
            </div>
            <% unless stage == @deal_stages.last %>
              <div class="text-gray-300">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Tasks Overview Cards -->
  <div class="mt-8">
    <h2 class="text-lg font-medium text-gray-900 mb-4">My Tasks</h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
      <!-- Today's Tasks Card -->
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="p-5 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Today's Tasks</h3>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800">
              <%= @today_tasks_count %>
            </span>
          </div>
        </div>
        <div class="p-5">
          <% if @today_tasks.any? %>
            <ul class="divide-y divide-gray-200">
              <% @today_tasks.each do |task| %>
                <li class="py-3">
                  <div class="flex items-center">
                    <div class="flex-1">
                      <h4 class="text-sm font-medium">
                        <%= link_to task.title, task_path(task, from: "my_tasks"), class: "text-blue-600 hover:text-blue-900" %>
                      </h4>
                      <p class="text-xs text-gray-500">
                        Due <%= task.due_date.strftime("%I:%M %p") %>
                        <% if task.customer %>
                         • <%= task.customer.name %>
                        <% end %>
                      </p>
                    </div>
                    <div>
                      <%= button_to complete_task_path(task), method: :patch, class: "inline-flex items-center px-2 py-1 text-xs font-medium rounded text-green-700 bg-green-100 hover:bg-green-200" do %>
                        Complete
                      <% end %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-center text-gray-500 text-sm py-4">No tasks due today</p>
          <% end %>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <%= link_to my_tasks_tasks_path, class: "text-sm font-medium text-blue-600 hover:text-blue-900" do %>
            View all my tasks
          <% end %>
        </div>
      </div>

      <!-- Overdue Tasks Card -->
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="p-5 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Overdue Tasks</h3>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">
              <%= @overdue_tasks_count %>
            </span>
          </div>
        </div>
        <div class="p-5">
          <% if @overdue_tasks.any? %>
            <ul class="divide-y divide-gray-200">
              <% @overdue_tasks.first(5).each do |task| %>
                <li class="py-3">
                  <div class="flex items-center">
                    <div class="flex-1">
                      <h4 class="text-sm font-medium">
                        <%= link_to task.title, task_path(task, from: "my_tasks"), class: "text-blue-600 hover:text-blue-900" %>
                      </h4>
                      <p class="text-xs text-gray-500">
                        Due <%= task.due_date.strftime("%b %d, %I:%M %p") %>
                        <% if task.customer %>
                         • <%= task.customer.name %>
                        <% end %>
                      </p>
                    </div>
                    <div>
                      <%= button_to complete_task_path(task), method: :patch, class: "inline-flex items-center px-2 py-1 text-xs font-medium rounded text-green-700 bg-green-100 hover:bg-green-200" do %>
                        Complete
                      <% end %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-center text-gray-500 text-sm py-4">No overdue tasks</p>
          <% end %>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <%= link_to my_tasks_tasks_path(status: "Pending"), class: "text-sm font-medium text-blue-600 hover:text-blue-900" do %>
            View all overdue tasks
          <% end %>
        </div>
      </div>

      <!-- Upcoming Tasks Card -->
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="p-5 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Pending Tasks</h3>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800">
              <%= @pending_tasks_count %>
            </span>
          </div>
        </div>
        <div class="p-5">
          <% if @pending_tasks.any? %>
            <ul class="divide-y divide-gray-200">
              <% @pending_tasks.each do |task| %>
                <li class="py-3">
                  <div class="flex items-center">
                    <div class="flex-1">
                      <h4 class="text-sm font-medium">
                        <%= link_to task.title, task_path(task, from: "my_tasks"), class: "text-blue-600 hover:text-blue-900" %>
                      </h4>
                      <p class="text-xs text-gray-500">
                        Due <%= task.due_date.strftime("%b %d, %I:%M %p") %>
                        <% if task.customer %>
                         • <%= task.customer.name %>
                        <% end %>
                      </p>
                    </div>
                    <div>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                        <%= case task.priority
                            when 'High' then 'bg-red-100 text-red-800'
                            when 'Medium' then 'bg-yellow-100 text-yellow-800'
                            when 'Low' then 'bg-green-100 text-green-800'
                            end %>">
                        <%= task.priority %>
                      </span>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-center text-gray-500 text-sm py-4">No pending tasks</p>
          <% end %>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <%= link_to my_tasks_tasks_path, class: "text-sm font-medium text-blue-600 hover:text-blue-900" do %>
            View all tasks
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- My Deals and Customers -->
  <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- My Deals -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">My Deals</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @my_deals.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @my_deals.each do |deal| %>
                <li class="py-4">
                  <div class="flex items-center space-x-4">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate">
                        <%= link_to deal.title, deal_path(deal), class: "hover:text-blue-600" %>
                      </p>
                      <p class="text-sm text-gray-500 truncate">
                        <% if deal.customer.present? %>
                          <%= deal.customer.name %>
                        <% else %>
                          <span class="text-gray-500">No customer</span>
                        <% end %> • <%= deal.deal_stage.name %>
                      </p>
                    </div>
                    <div>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <%= number_to_currency(deal.amount) %>
                      </span>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
          <div class="mt-6">
            <%= link_to "View all my deals", my_deals_deals_path, class: "w-full flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          </div>
        <% else %>
          <div class="text-center text-gray-500">
            No deals assigned to you
          </div>
        <% end %>
      </div>
    </div>

    <!-- My Customers -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">My Customers</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @my_customers.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @my_customers.each do |customer| %>
                <li class="py-4">
                  <div class="flex items-center space-x-4">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate">
                        <%= link_to customer.name, customer_path(customer), class: "hover:text-blue-600" %>
                      </p>
                      <p class="text-sm text-gray-500 truncate">
                        <%= customer.email || "No email" %> • <%= customer.status %>
                      </p>
                    </div>
                    <div>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                        <%= case customer.status
                            when 'Pending' then 'bg-yellow-100 text-yellow-800'
                            when 'Connection Established' then 'bg-blue-100 text-blue-800'
                            when 'Connection Not Established' then 'bg-red-100 text-red-800'
                            when 'Not Interested' then 'bg-gray-100 text-gray-800'
                            when 'Exhausted' then 'bg-purple-100 text-purple-800'
                            end %>">
                        <%= customer.status %>
                      </span>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
          <div class="mt-6">
            <%= link_to "View all customers", customers_path, class: "w-full flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          </div>
        <% else %>
          <div class="text-center text-gray-500">
            No customers assigned to you
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div> 