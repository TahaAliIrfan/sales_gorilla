<%# Floating softphone. Driven by call_widget_controller mounted on the layout. %>
<div data-call-widget-target="panel" class="cw-panel hidden">
  <div class="cw-card">
    <div class="cw-head">
      <span class="cw-avatar" data-call-widget-target="avatar">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      </span>
      <div class="cw-id">
        <div class="cw-name" data-call-widget-target="name">Calling…</div>
        <div class="cw-num cb-mono" data-call-widget-target="number"></div>
      </div>
      <button type="button" class="cw-x" data-action="call-widget#close" title="Close" aria-label="Close">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <%# Step 1 — pick the caller ID before dialing (preferred one preselected). %>
    <div class="cw-choose" data-call-widget-target="chooser">
      <div class="cw-choose-label">Call from</div>
      <div class="cw-numbers" data-call-widget-target="numbers">
        <div class="cw-loading">Finding the best number…</div>
      </div>
      <div class="cw-note" data-call-widget-target="preferredNote"></div>
      <button type="button" class="cw-btn cw-call" data-action="call-widget#confirmCall" data-call-widget-target="callBtn" disabled>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call
      </button>
    </div>

    <%# Step 2 — in-call view. %>
    <div class="cw-live hidden" data-call-widget-target="live">
      <div class="cw-meta">
        <span class="cw-status" data-call-widget-target="status" data-state="info">Ready</span>
        <span class="cw-timer cb-mono" data-call-widget-target="timer">0:00</span>
      </div>

      <div class="cw-actions">
        <button type="button" class="cw-btn cw-mute" data-action="call-widget#toggleMute" data-call-widget-target="muteBtn">Mute</button>
        <button type="button" class="cw-btn cw-hang" data-action="call-widget#hangup">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          End call
        </button>
      </div>
    </div>
  </div>
</div>
