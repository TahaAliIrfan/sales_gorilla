<div class="bg-white border border-gray-300 rounded-lg shadow-lg" data-controller="chat" data-chat-customer-id-value="<%= customer.id %>" data-chat-customer-name-value="<%= customer.name %>" id="whatsapp-chat-window" data-debug="chat-controller-test">
  <!-- Chat Header -->
  <div class="bg-gradient-to-r from-green-50 to-green-100 border-b border-green-200 px-4 py-4 rounded-t-lg">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-medium text-gray-900">
        WhatsApp Chat with <%= customer.name %>
      </h3>
      <div class="flex items-center space-x-2">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          <svg class="-ml-0.5 mr-1.5 h-2 w-2 text-green-400" fill="currentColor" viewBox="0 0 8 8">
            <circle cx="4" cy="4" r="3"/>
          </svg>
          WhatsApp
        </span>
        <button 
          data-action="click->chat#refreshMessages"
          class="text-gray-400 hover:text-gray-600 p-1 rounded-md hover:bg-gray-100 mr-2"
          title="Refresh messages"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </button>
        <button 
          data-action="click->chat#syncMessages"
          class="inline-flex items-center px-2 py-1 text-xs font-medium rounded-md bg-green-100 text-green-700 hover:bg-green-200"
          title="Sync messages from WhatsApp"
        >
          <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Sync
        </button>
      </div>
    </div>
  </div>

  <!-- Chat Messages Container -->
  <div class="h-96 overflow-y-auto p-4 space-y-4 bg-gray-50" data-chat-target="messagesContainer">
    <div data-chat-target="messagesArea">
      <!-- Messages will be loaded here -->
      <div class="flex justify-center items-center py-8">
        <div class="text-gray-500 text-sm">Loading messages...</div>
      </div>
    </div>
  </div>

  <!-- Chat Input -->
  <div class="border-t border-gray-200 p-4 bg-white rounded-b-lg">
    <!-- File Upload Form (hidden) -->
    <form data-action="submit->chat#sendFile" data-chat-target="fileForm" class="hidden">
      <input 
        type="file" 
        data-chat-target="fileInput" 
        accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.json,.xml,.zip,.flac,.ogg,.mp4,.mov,.webm"
        data-action="change->chat#handleFileSelect"
      />
      <input type="text" data-chat-target="captionInput" placeholder="Add a caption (optional)" class="hidden" />
    </form>

    <!-- File Preview (hidden by default) -->
    <div data-chat-target="filePreview" class="hidden mb-3 p-3 bg-gray-50 rounded-lg border">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div data-chat-target="fileIcon" class="flex-shrink-0"></div>
          <div>
            <div data-chat-target="fileName" class="text-sm font-medium text-gray-900"></div>
            <div data-chat-target="fileSize" class="text-xs text-gray-500"></div>
          </div>
        </div>
        <button 
          type="button" 
          data-action="click->chat#cancelFile"
          class="text-gray-400 hover:text-gray-600"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="mt-2">
        <input 
          type="text" 
          data-chat-target="fileCaption" 
          placeholder="Add a caption (optional)"
          class="block w-full text-sm border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500"
        />
      </div>
      <div class="mt-3 flex space-x-2">
        <button
          type="button"
          data-action="click->chat#cancelFile"
          class="flex-1 inline-flex justify-center items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
        >
          Cancel
        </button>
        <button
          type="button"
          data-action="click->chat#sendFile"
          data-chat-target="fileSendButton"
          class="flex-1 inline-flex justify-center items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
          Send File
        </button>
      </div>
    </div>

    <!-- Message Input Form -->
    <form data-action="submit->chat#sendMessage" data-chat-target="messageForm">
      <div class="flex space-x-2">
        <div class="flex-shrink-0">
          <button
            type="button"
            data-action="click->chat#openFileDialog"
            class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
            title="Attach file"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
            </svg>
          </button>
        </div>
        <div class="flex-1">
          <textarea
            data-chat-target="messageInput"
            placeholder="Type your message..."
            rows="2"
            class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm resize-none"
            data-action="keydown->chat#handleKeydown"
          ></textarea>
        </div>
        <div class="flex-shrink-0">
          <button
            type="submit"
            data-chat-target="sendButton"
            class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            <span class="ml-1">Send</span>
          </button>
        </div>
      </div>
    </form>
    
    <!-- Status message area -->
    <div data-chat-target="statusMessage" class="mt-2 text-sm hidden"></div>
    
    <!-- Supported file formats info -->
    <div class="mt-3 pt-3 border-t border-gray-200">
      <div class="text-xs text-gray-500">
        <span class="font-medium">Supported file formats & size limits:</span>
        <div class="mt-1 flex flex-wrap gap-1">
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-blue-50 text-blue-700">Images: JPG, PNG, GIF, WebP (max 5MB)</span>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-green-50 text-green-700">Documents: PDF, DOC, DOCX, XLS, XLSX, CSV (max 5MB)</span>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-purple-50 text-purple-700">Audio: MP3, FLAC, OGG, WAV (max 16MB)</span>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-orange-50 text-orange-700">Video: MP4, MOV, WebM, AVI (max 16MB)</span>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-50 text-gray-700">Text: TXT, JSON, XML (max 5MB)</span>
        </div>
        <div class="mt-2 text-xs text-amber-600">
          <svg class="inline h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
          Large files (>2MB) may upload slowly or fail due to WhatsApp API limitations
        </div>
      </div>
    </div>
  </div>

  <!-- Message Template -->
  <template data-chat-target="messageTemplate">
  <div class="message-item">
    <!-- Inbound Message -->
    <div class="message-inbound flex items-start space-x-3 hidden">
      <div class="flex-shrink-0">
        <div class="h-8 w-8 bg-gray-300 rounded-full flex items-center justify-center">
          <span class="text-xs font-medium text-gray-700 customer-initial"></span>
        </div>
      </div>
      <div class="flex-1 min-w-0">
        <div class="bg-gray-100 rounded-lg px-3 py-2 max-w-xs">
          <div class="message-content text-sm text-gray-900"></div>
          <div class="message-attachment hidden mt-2"></div>
        </div>
        <div class="message-time text-xs text-gray-500 mt-1"></div>
      </div>
    </div>
    
    <!-- Outbound Message -->
    <div class="message-outbound flex items-start justify-end space-x-3 hidden">
      <div class="flex-1 min-w-0 flex justify-end">
        <div class="bg-blue-500 text-white rounded-lg px-3 py-2 max-w-xs">
          <div class="message-content text-sm"></div>
          <div class="message-attachment hidden mt-2"></div>
        </div>
      </div>
      <div class="flex-shrink-0">
        <div class="h-8 w-8 bg-blue-500 rounded-full flex items-center justify-center">
          <span class="text-xs font-medium text-white">You</span>
        </div>
      </div>
    </div>
    <div class="message-time-outbound text-xs text-gray-500 mt-1 text-right hidden"></div>
  </div>
  </template>
</div>