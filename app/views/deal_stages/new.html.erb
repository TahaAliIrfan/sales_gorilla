<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to #{@pipeline ? @pipeline.name : 'Deal Stages'}", @pipeline ? pipeline_path(@pipeline) : deal_stages_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="p-6 border-b border-gray-200">
      <h1 class="text-2xl font-bold text-gray-900">New Deal Stage</h1>
      <p class="text-gray-600 mt-1">Create a new stage in <% if @pipeline %>the <%= @pipeline.name %> pipeline<% else %>your sales pipeline<% end %></p>
    </div>

    <div class="p-6">
      <%= render 'form', deal_stage: @deal_stage %>
    </div>
  </div>
</div>
