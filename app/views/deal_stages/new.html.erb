<% content_for :title, "New deal stage — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">New deal stage</div>
      <div class="pagehead__sub">Create a new stage in <%= @pipeline ? "the #{@pipeline.name} pipeline" : "your sales pipeline" %>.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to (@pipeline ? pipeline_path(@pipeline) : deal_stages_path), class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
    </div>
  </div>

  <div style="max-width:680px"><%= render "form", deal_stage: @deal_stage %></div>
</div>
