<% content_for :title, "Edit #{@deal_stage.name} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Edit deal stage</div>
      <div class="pagehead__sub"><%= @deal_stage.name %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to deal_stages_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
    </div>
  </div>

  <div style="max-width:680px"><%= render "form", deal_stage: @deal_stage %></div>
</div>
