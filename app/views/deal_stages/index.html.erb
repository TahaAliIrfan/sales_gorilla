<% content_for :title, "Deal stages — #{current_organization&.name}" %>
<%
  selected = (@selected_pipeline_id.present? && @selected_pipeline_id != "") ? @pipelines.find(@selected_pipeline_id) : nil
%>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Deal stages</div>
      <div class="pagehead__sub">Configure and manage your sales pipeline stages.</div>
    </div>
    <div class="pagehead__actions">
      <% if selected %>
        <%= link_to deals_path(pipeline_id: selected.id), class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("columns-2", size: 15) %>Open board
        <% end %>
      <% end %>
      <%= link_to pipelines_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("layers", size: 15) %>Pipelines
      <% end %>
    </div>
  </div>

  <% if @pipelines.count > 1 %>
    <%= form_with url: deal_stages_path, method: :get, data: { turbo_frame: "_top" },
          class: "row", html: { style: "margin-bottom:var(--space-4);gap:8px;align-items:center" } do |form| %>
      <span class="rl-label" style="margin:0">Pipeline</span>
      <%
        options = []
        options << [ "All Pipelines", "" ] if current_user.admin?
        options += @pipelines.map { |p| [ p.name, p.id ] }
      %>
      <%= form.select :pipeline_id,
            options_for_select(options, @selected_pipeline_id),
            { include_blank: false },
            { class: "rl-select rl-input--sm", style: "width:auto",
              onchange: "this.form.requestSubmit()" } %>
    <% end %>
  <% end %>

  <div class="sect">
    <div class="sect__head">
      <div class="sect__title">
        <%= selected ? "#{selected.name} — stages" : "Current pipeline stages" %>
      </div>
    </div>
    <div class="sect__body--flush">
      <% if @deal_stages.any? %>
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Position</th>
                <th>Name</th>
                <th>Description</th>
                <th>Active deals</th>
                <th style="text-align:right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @deal_stages.each do |stage| %>
                <tr>
                  <td class="mono"><%= stage.position %></td>
                  <td class="rl-cell-strong"><%= stage.name %></td>
                  <td class="muted rl-sm"><%= stage.description %></td>
                  <td class="mono"><%= Deal.active.by_stage(stage).count %></td>
                  <td style="text-align:right">
                    <div class="row" style="gap:6px;justify-content:flex-end">
                      <%= link_to "Edit", edit_pipeline_deal_stage_path(stage.pipeline, stage), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                      <% if Deal.by_stage(stage).none? %>
                        <%= button_to pipeline_deal_stage_path(stage.pipeline, stage), method: :delete,
                              form: { data: { turbo_confirm: "Are you sure you want to delete this stage?" } },
                              class: "rl-btn rl-btn--destructive-ghost rl-btn--sm" do %>Delete<% end %>
                      <% else %>
                        <span class="rl-btn rl-btn--ghost rl-btn--sm" style="opacity:.4;cursor:not-allowed" title="Cannot delete a stage with deals">Delete</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="muted rl-sm" style="text-align:center;padding:var(--space-6)">
          No deal stages defined yet. <%= link_to "Create stages through Pipelines", pipelines_path, style: "color:var(--color-primary-text)" %>.
        </div>
      <% end %>
    </div>
  </div>
</div>
