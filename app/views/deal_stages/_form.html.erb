<%= form_with(model: [ @pipeline, deal_stage ].compact, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if deal_stage.errors.any? %>
    <%= render "settings/errors", record: deal_stage %>
  <% end %>

  <div class="sect">
    <div class="sect__body">
      <div class="grid grid-2">
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :name, required: true,
                placeholder: "e.g. Qualified" %>
        </div>
        <%= render "shared/relay_field", f: form, field: :position, type: "number", min: 1,
              hint: "Position in the sales pipeline (1 is the first stage)." %>
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :description, type: "textarea", rows: 3,
                placeholder: "Describe this stage…" %>
        </div>
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :active, type: "checkbox",
                hint: "Inactive stages are hidden from the board." %>
        </div>
      </div>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", (@pipeline ? pipeline_path(@pipeline) : deal_stages_path), class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (deal_stage.new_record? ? "Create stage" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
