<% content_for :title, "New audience — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">New customer group</div>
      <div class="pagehead__sub">Group customers for campaign targeting.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to customer_groups_path, class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to groups
      <% end %>
    </div>
  </div>

  <%= render "form", customer_group: @customer_group %>
</div>
