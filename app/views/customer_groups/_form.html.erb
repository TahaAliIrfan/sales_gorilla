<%= form_with(model: customer_group, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if customer_group.errors.any? %>
    <%= render "settings/errors", record: customer_group %>
  <% end %>

  <div class="sect">
    <div class="sect__body col" style="gap:var(--space-5)">
      <%= render "shared/relay_field", f: form, field: :name, required: true,
            placeholder: "e.g., VIP Customers" %>
      <%= render "shared/relay_field", f: form, field: :description, type: "textarea", rows: 4,
            placeholder: "Optional description of this group" %>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", customer_group.persisted? ? customer_group_path(customer_group) : customer_groups_path,
          class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (customer_group.new_record? ? "Create group" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
