<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <div class="cb-eyebrow mb-1.5">segments // groups</div>
      <h1 class="text-[26px] font-semibold tracking-tight text-[#0F172A]">Customer Groups</h1>
      <p class="text-[#64748B] mt-1.5 text-sm">Manage groups for campaign targeting</p>
    </div>
    <%= link_to "New Group", new_customer_group_path,
        class: "bg-emerald-500 hover:bg-emerald-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @customer_groups.each do |group| %>
      <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-xl font-semibold text-gray-800"><%= group.name %></h3>
          <span class="bg-emerald-100 text-emerald-800 text-xs font-semibold px-2.5 py-0.5 rounded">
            <%= group.customer_count %> customers
          </span>
        </div>

        <% if group.description.present? %>
          <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= group.description %></p>
        <% end %>

        <div class="flex gap-2 mt-4">
          <%= link_to "View", customer_group_path(group),
              class: "flex-1 text-center bg-emerald-500 hover:bg-emerald-600 text-white text-sm py-2 px-3 rounded" %>
          <%= link_to "Edit", edit_customer_group_path(group),
              class: "flex-1 text-center bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm py-2 px-3 rounded" %>
          <%= link_to "Delete", customer_group_path(group),
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "flex-1 text-center bg-red-500 hover:bg-red-600 text-white text-sm py-2 px-3 rounded" %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @customer_groups.empty? %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No groups</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by creating a new customer group.</p>
      <div class="mt-6">
        <%= link_to "New Group", new_customer_group_path,
            class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-emerald-600 hover:bg-emerald-700" %>
      </div>
    </div>
  <% end %>
</div>
