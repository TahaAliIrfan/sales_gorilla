<%# Customer groups index — relay DS card grid. View / Edit / Delete keep the
    existing endpoints. %>
<% content_for :title, "Customer groups — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Customer groups</div>
      <div class="pagehead__sub">Manage audiences for campaign targeting.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_customer_group_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("users-round", size: 15) %>New group
      <% end %>
    </div>
  </div>

  <% if @customer_groups.empty? %>
    <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
      <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-fg-3)"><%= relay_icon("users-round", size: 22) %></span>
      <div class="rl-h4">No groups</div>
      <div class="muted rl-sm" style="margin-top:6px">Get started by creating a new customer group.</div>
      <div style="margin-top:16px"><%= link_to "New group", new_customer_group_path, class: "rl-btn rl-btn--primary rl-btn--sm" %></div>
    </div></div>
  <% else %>
    <div class="grid grid-3" style="gap:var(--space-4)">
      <% @customer_groups.each do |group| %>
        <div class="sect">
          <div class="sect__body col" style="gap:var(--space-3)">
            <div class="spread" style="align-items:flex-start">
              <b style="font-size:var(--text-h4);font-weight:700"><%= group.name %></b>
              <span class="rl-badge rl-badge--info"><%= group.customer_count %> customers</span>
            </div>
            <% if group.description.present? %>
              <p class="muted rl-sm" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= group.description %></p>
            <% end %>
            <div class="row" style="gap:6px">
              <%= link_to customer_group_path(group), class: "rl-btn rl-btn--secondary rl-btn--sm", style: "flex:1;justify-content:center" do %>
                <%= relay_icon("eye", size: 14) %>View
              <% end %>
              <%= link_to edit_customer_group_path(group), class: "rl-iconbtn rl-iconbtn--sm", title: "Edit" do %>
                <%= relay_icon("pencil", size: 15) %>
              <% end %>
              <%= button_to customer_group_path(group), method: :delete,
                    form: { data: { turbo_confirm: "Are you sure?" } },
                    class: "rl-iconbtn rl-iconbtn--sm", title: "Delete" do %>
                <%= relay_icon("trash-2", size: 15) %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
