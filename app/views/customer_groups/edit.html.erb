<% content_for :title, "Edit group — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Edit customer group</div>
      <div class="pagehead__sub"><%= @customer_group.name %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to customer_group_path(@customer_group), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to group
      <% end %>
    </div>
  </div>

  <%= render "form", customer_group: @customer_group %>
</div>
