<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @customer_group.name %></h1>
      <% if @customer_group.description.present? %>
        <p class="text-gray-600 mt-1"><%= @customer_group.description %></p>
      <% end %>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_customer_group_path(@customer_group),
          class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded" %>
      <%= link_to "Back", customer_groups_path,
          class: "bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Current Customers -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Customers in Group</h2>
        <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded">
          <%= @customers.count %>
        </span>
      </div>

      <% if @customers.any? %>
        <div class="space-y-2 max-h-96 overflow-y-auto">
          <% @customers.each do |customer| %>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded hover:bg-gray-100">
              <div>
                <p class="font-medium text-gray-900"><%= customer.name %></p>
                <p class="text-sm text-gray-500"><%= customer.email %></p>
              </div>
              <%= link_to "Remove", remove_customer_customer_group_path(@customer_group, customer_id: customer.id),
                  method: :delete,
                  data: { confirm: "Remove this customer from the group?" },
                  class: "text-red-600 hover:text-red-800 text-sm" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-8">No customers in this group yet.</p>
      <% end %>
    </div>

    <!-- Available Customers -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold mb-4">Add Customers</h2>

      <% if @available_customers.any? %>
        <div class="space-y-2 max-h-96 overflow-y-auto">
          <% @available_customers.each do |customer| %>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded hover:bg-gray-100">
              <div>
                <p class="font-medium text-gray-900"><%= customer.name %></p>
                <p class="text-sm text-gray-500"><%= customer.email %></p>
              </div>
              <%= link_to "Add", add_customer_customer_group_path(@customer_group, customer_id: customer.id),
                  method: :post,
                  class: "bg-blue-500 hover:bg-blue-600 text-white text-sm py-1 px-3 rounded" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-8">All customers are already in this group.</p>
      <% end %>
    </div>
  </div>
</div>
