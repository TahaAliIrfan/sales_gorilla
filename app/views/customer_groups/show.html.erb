<%# Customer group show — relay DS. Two panels: current members (remove) and
    available customers (add). Both keep the existing add_customer (POST) /
    remove_customer (DELETE) endpoints with customer_id. %>
<% content_for :title, "#{@customer_group.name} — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title"><%= @customer_group.name %></div>
      <% if @customer_group.description.present? %>
        <div class="pagehead__sub"><%= @customer_group.description %></div>
      <% end %>
    </div>
    <div class="pagehead__actions">
      <%= link_to edit_customer_group_path(@customer_group), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit
      <% end %>
      <%= link_to customer_groups_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
    </div>
  </div>

  <div class="grid grid-2" style="gap:var(--space-4);align-items:start">
    <div class="sect">
      <div class="sect__head">
        <div class="sect__title grow">Customers in group</div>
        <span class="rl-badge rl-badge--info"><%= @customers.count %></span>
      </div>
      <div class="sect__body">
        <% if @customers.any? %>
          <div class="col" style="gap:8px;max-height:24rem;overflow-y:auto">
            <% @customers.each do |customer| %>
              <div class="spread" style="padding:10px 12px;background:var(--color-surface-2);border-radius:var(--radius-md)">
                <div style="min-width:0">
                  <div class="rl-cell-strong" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= customer.name %></div>
                  <div class="muted rl-sm" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= customer.email %></div>
                </div>
                <%= button_to remove_customer_customer_group_path(@customer_group, customer_id: customer.id), method: :delete,
                      form: { data: { turbo_confirm: "Remove this customer from the group?" } },
                      class: "rl-iconbtn rl-iconbtn--sm", title: "Remove" do %>
                  <%= relay_icon("x", size: 15) %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="muted rl-sm" style="text-align:center;padding:24px 0">No customers in this group yet.</p>
        <% end %>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Add customers</div></div>
      <div class="sect__body">
        <% if @available_customers.any? %>
          <div class="col" style="gap:8px;max-height:24rem;overflow-y:auto">
            <% @available_customers.each do |customer| %>
              <div class="spread" style="padding:10px 12px;background:var(--color-surface-2);border-radius:var(--radius-md)">
                <div style="min-width:0">
                  <div class="rl-cell-strong" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= customer.name %></div>
                  <div class="muted rl-sm" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= customer.email %></div>
                </div>
                <%= button_to add_customer_customer_group_path(@customer_group, customer_id: customer.id), method: :post,
                      class: "rl-btn rl-btn--secondary rl-btn--sm" do %>
                  <%= relay_icon("plus", size: 14) %>Add
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="muted rl-sm" style="text-align:center;padding:24px 0">All customers are already in this group.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
