<!-- Navigation Bar -->
<div class="bg-white border-b border-gray-200 px-4 py-3">
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to dashboard_path, class: "inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Dashboard
      <% end %>
      <h1 class="text-xl font-semibold text-gray-900">TecaudexChat</h1>
    </div>
    <div class="text-sm text-gray-500">
      WhatsApp Business Integration
    </div>
  </div>
</div>

<div class="h-[calc(100vh-4rem)] bg-gray-100 flex" data-controller="tecaudex-chat">
  <!-- Chat List Sidebar -->
  <div class="w-1/3 bg-white border-r border-gray-300 flex flex-col">
    <!-- Header -->
    <div class="bg-gradient-to-r from-red-500 to-red-600 px-4 py-6 text-white">
      <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold">TecaudexChat</h1>
        <div class="flex items-center space-x-2">
          <button 
            data-action="click->tecaudex-chat#refreshChatList"
            class="p-2 text-red-100 hover:text-white hover:bg-red-400 rounded-md transition-colors"
            title="Refresh chat list"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="mt-2 text-red-100 text-sm">
        <span><%= pluralize(@chats.count, 'chat') %> available</span>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="p-4 border-b border-gray-200">
      <div class="relative">
        <input 
          type="text" 
          placeholder="Search chats..." 
          class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
          data-action="input->tecaudex-chat#filterChats"
        >
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Chat List -->
    <div class="flex-1 overflow-y-auto" data-tecaudex-chat-target="chatList">
      <%= render 'chat_list', chats: @chats %>
    </div>
  </div>

  <!-- Chat Area -->
  <div class="flex-1 flex flex-col bg-white" data-tecaudex-chat-target="chatArea">
    <!-- Chat Header -->
    <div class="bg-gradient-to-r from-red-50 to-red-100 border-b border-red-200 px-6 py-4 hidden" data-tecaudex-chat-target="chatHeader">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <!-- Contact Avatar -->
          <div class="h-10 w-10 bg-red-100 rounded-full flex items-center justify-center">
            <span class="text-red-600 font-medium" data-tecaudex-chat-target="contactAvatar">?</span>
          </div>
          
          <!-- Contact Info -->
          <div>
            <h3 class="text-lg font-medium text-gray-900" data-tecaudex-chat-target="contactName">Select a chat</h3>
            <p class="text-sm text-gray-600" data-tecaudex-chat-target="contactInfo"></p>
          </div>
        </div>
        
        <!-- Chat Actions -->
        <div class="flex items-center space-x-2">
          <button 
            data-action="click->tecaudex-chat#refreshMessages"
            class="inline-flex items-center px-3 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-all duration-200"
            title="Refresh messages"
          >
            <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Refresh
          </button>
          
          <button 
            data-tecaudex-chat-target="viewCustomerBtn"
            class="hidden inline-flex items-center px-3 py-2 border border-blue-300 text-sm font-medium rounded-md text-blue-700 bg-white hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200"
            title="View customer details"
          >
            <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            View Customer
          </button>
        </div>
      </div>
    </div>

    <!-- Messages Area -->
    <div class="flex-1 flex flex-col bg-gray-50 overflow-hidden">
      <div class="flex-1 overflow-y-auto messages-scroll" data-tecaudex-chat-target="messagesContainer">
        <div class="p-6 min-h-full" data-tecaudex-chat-target="messagesArea">
          <!-- Default placeholder -->
          <div class="flex items-center justify-center h-full min-h-[400px]" data-tecaudex-chat-target="placeholder">
            <div class="text-center">
              <div class="h-24 w-24 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="h-12 w-12 text-red-500" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Welcome to TecaudexChat</h2>
              <p class="text-gray-600 mb-4">Select a chat from the sidebar to start messaging</p>
              <p class="text-sm text-gray-500">
                Manage all your WhatsApp conversations in one place
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Message Input Area -->
    <div class="border-t border-gray-200 p-4 bg-white hidden" data-tecaudex-chat-target="messageInputArea">
      <!-- File Upload Form (hidden) -->
      <form data-action="submit->tecaudex-chat#sendFile" data-tecaudex-chat-target="fileForm" class="hidden">
        <input 
          type="file" 
          data-tecaudex-chat-target="fileInput" 
          accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.json,.xml,.zip,.flac,.ogg,.mp4,.mov,.webm"
          data-action="change->tecaudex-chat#handleFileSelect"
        />
      </form>

      <!-- File Preview (hidden by default) -->
      <div data-tecaudex-chat-target="filePreview" class="hidden mb-3 p-3 bg-gray-50 rounded-lg border">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div data-tecaudex-chat-target="fileIcon" class="flex-shrink-0"></div>
            <div>
              <div data-tecaudex-chat-target="fileName" class="text-sm font-medium text-gray-900"></div>
              <div data-tecaudex-chat-target="fileSize" class="text-xs text-gray-500"></div>
            </div>
          </div>
          <button 
            type="button" 
            data-action="click->tecaudex-chat#cancelFile"
            class="text-gray-400 hover:text-gray-600"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="mt-2">
          <input 
            type="text" 
            data-tecaudex-chat-target="fileCaption" 
            placeholder="Add a caption (optional)"
            class="block w-full text-sm border-gray-300 rounded-md shadow-sm focus:ring-red-500 focus:border-red-500"
          />
        </div>
        <div class="mt-3 flex space-x-2">
          <button
            type="button"
            data-action="click->tecaudex-chat#cancelFile"
            class="flex-1 inline-flex justify-center items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
          >
            Cancel
          </button>
          <button
            type="button"
            data-action="click->tecaudex-chat#sendFile"
            data-tecaudex-chat-target="fileSendButton"
            class="flex-1 inline-flex justify-center items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            Send File
          </button>
        </div>
      </div>

      <!-- Message Input Form -->
      <form data-action="submit->tecaudex-chat#sendMessage" data-tecaudex-chat-target="messageForm">
        <div class="flex space-x-2">
          <div class="flex-shrink-0">
            <button
              type="button"
              data-action="click->tecaudex-chat#openFileDialog"
              class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
              title="Attach file"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
              </svg>
            </button>
          </div>
          <div class="flex-1">
            <textarea
              data-tecaudex-chat-target="messageInput"
              placeholder="Type your message..."
              rows="2"
              class="message-input block w-full border-gray-300 rounded-md shadow-sm focus:ring-red-500 focus:border-red-500 sm:text-sm resize-none transition-all duration-200"
              data-action="keydown->tecaudex-chat#handleKeydown"
            ></textarea>
          </div>
          <div class="flex-shrink-0">
            <button
              type="submit"
              data-tecaudex-chat-target="sendButton"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
              <span class="ml-1">Send</span>
            </button>
          </div>
        </div>
      </form>
      
      <!-- Status message area -->
      <div data-tecaudex-chat-target="statusMessage" class="mt-2 text-sm hidden"></div>
      
      <!-- Supported file formats info -->
      <div class="mt-3 pt-3 border-t border-gray-200">
        <div class="text-xs text-gray-500">
          <span class="font-medium">Supported file formats:</span>
          <div class="mt-1 flex flex-wrap gap-1">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-blue-50 text-blue-700">Images</span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-green-50 text-green-700">Documents</span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-purple-50 text-purple-700">Audio</span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-orange-50 text-orange-700">Video</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .chat-item:hover {
    transform: translateX(2px);
    background-color: #fef2f2;
  }
  
  .chat-item {
    transition: all 0.2s ease-in-out;
    cursor: pointer;
  }
  
  .chat-item.active {
    background-color: #fef2f2;
    border-left: 4px solid #dc2626;
  }
  
  /* Custom scrollbar for messages area */
  .messages-scroll::-webkit-scrollbar {
    width: 6px;
  }
  
  .messages-scroll::-webkit-scrollbar-track {
    background: #f1f1f1;
  }
  
  .messages-scroll::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 3px;
  }
  
  .messages-scroll::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
  }
  
  /* Message animation */
  .message-item {
    animation: fadeInUp 0.3s ease-out;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Input focus improvements */
  .message-input:focus {
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    border-color: #dc2626;
  }
  
  /* Status indicator pulse */
  .status-sending {
    animation: pulse 1.5s infinite;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }
</style>