<h1 class="text-2xl font-bold mb-6">Your Sales Reports</h1>

<div class="bg-white rounded-lg shadow p-6 mb-8">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-semibold">Reports for <%= current_user.name %></h2>
    
    <div class="flex space-x-2">
      <form action="<%= my_reports_path %>" method="get" class="flex space-x-2">
        <select name="filter_range" id="filter_range" class="rounded border border-gray-300 px-3 py-2 text-sm" onchange="toggleCustomDateFields(this.value)">
          <option value="30" <%= @filter_range == '30' ? 'selected' : '' %>>Last 30 Days</option>
          <option value="90" <%= @filter_range == '90' ? 'selected' : '' %>>Last 90 Days</option>
          <option value="custom" <%= @filter_range == 'custom' ? 'selected' : '' %>>Custom Range</option>
        </select>
        
        <div id="custom_date_fields" class="flex space-x-2 <%= @filter_range == 'custom' ? '' : 'hidden' %>">
          <input type="date" name="start_date" id="start_date" class="rounded border border-gray-300 px-3 py-2 text-sm" value="<%= @custom_start_date&.strftime('%Y-%m-%d') %>">
          <span class="self-center">to</span>
          <input type="date" name="end_date" id="end_date" class="rounded border border-gray-300 px-3 py-2 text-sm" value="<%= @custom_end_date&.strftime('%Y-%m-%d') %>">
        </div>
        
        <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded text-sm">Apply</button>
      </form>
    </div>
  </div>
  
  <div class="text-sm text-gray-600 mb-4">
    Showing data from <%= @start_date.strftime('%B %d, %Y') %> to <%= @end_date.strftime('%B %d, %Y') %>
  </div>
  
  <!-- New section for Deal Performance by Closing Date -->
  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 mb-8">
    <h3 class="text-lg font-medium mb-4">Deal Performance by Closing Date</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="flex justify-between items-center mb-4">
          <h4 class="text-md font-medium">Won Deals</h4>
          <p class="text-sm text-gray-500">Based on closing date</p>
        </div>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-3xl font-bold text-green-600"><%= @total_won_deals %></p>
            <p class="text-xl text-green-700 mt-2">$<%= number_with_delimiter(@total_won_deal_value) %></p>
          </div>
          <div class="text-sm text-gray-600">
            <p>Filtered by: <%= @filter_range == '30' ? 'Last 30 Days' : (@filter_range == '90' ? 'Last 90 Days' : 'Custom Range') %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="flex justify-between items-center mb-4">
          <h4 class="text-md font-medium">Lost Deals</h4>
          <p class="text-sm text-gray-500">Based on closing date</p>
        </div>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-3xl font-bold text-red-600"><%= @total_lost_deals %></p>
            <p class="text-xl text-red-700 mt-2">$<%= number_with_delimiter(@total_lost_deal_value) %></p>
          </div>
          <div class="text-sm text-gray-600">
            <p>Filtered by: <%= @filter_range == '30' ? 'Last 30 Days' : (@filter_range == '90' ? 'Last 90 Days' : 'Custom Range') %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sales Rep Metrics -->
<div class="bg-white rounded-lg shadow p-6 mb-8">
  <h2 class="text-xl font-semibold mb-4">Sales Rep Performance</h2>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Assigned Leads</h3>
      <p class="text-3xl font-bold text-blue-600"><%= @total_assigned_leads %></p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Total Deals</h3>
      <p class="text-3xl font-bold text-green-600"><%= @total_deals %></p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Total Deal Value</h3>
      <p class="text-3xl font-bold text-purple-600">$<%= number_with_delimiter(@total_deal_value) %></p>
    </div>
  </div>
  
  <!-- Deal Status Metrics -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Win Rate</h3>
      <p class="text-3xl font-bold text-indigo-600"><%= @total_deals > 0 ? ((@total_won_deals.to_f / @total_deals) * 100).round(1) : 0 %>%</p>
      <p class="text-sm text-gray-600 mt-2">(<%= @total_won_deals %> of <%= @total_deals %> deals)</p>
    </div>
  </div>
  
  <!-- Deal Value by Status Chart -->
  <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-8">
    <h3 class="text-lg font-medium mb-4">Deal Value by Status</h3>
    <div class="h-64">
      <%= bar_chart({
          "Active" => (@total_deal_value - @total_won_deal_value - @total_lost_deal_value),
          "Won" => @total_won_deal_value,
          "Lost" => @total_lost_deal_value
        }, 
        colors: ["#6366F1", "#10B981", "#EF4444"],
        prefix: "$",
        empty: "No deal data available",
        xtitle: "Value ($)"
      ) %>
    </div>
  </div>
  
  <!-- System Call Metrics -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">System Calls</h3>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-600">Total calls made from system:</p>
          <p class="text-3xl font-bold text-blue-600"><%= @total_system_calls %></p>
        </div>
        <i class="fas fa-phone-alt text-blue-600 text-5xl"></i>
      </div>
    </div>
  </div>
  
  <!-- Monthly System Calls Chart -->
  <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-8">
    <h3 class="text-lg font-medium mb-4">Monthly System Call Trend</h3>
    <div class="h-64">
      <%= line_chart @monthly_system_calls, 
          colors: ["#4F46E5"],
          curve: true,
          title: "System Calls per Month",
          legend: false,
          empty: "No system call data available" %>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Lead Sources</h3>
      <div class="h-64">
        <!-- Chart placeholder - would be implemented with a JavaScript charting library -->
        <div class="bg-gray-100 h-full rounded">
          <%= pie_chart @lead_source_distribution, 
              colors: ["#4F46E5", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#EC4899", "#3B82F6", "#6366F1"],
              donut: true, 
              title: "Source Distribution",
              legend: true,
              empty: "No data available" %>
        </div>
      </div>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Deal Stages</h3>
      <div class="h-64">
        <!-- Chart placeholder - would be implemented with a JavaScript charting library -->
        <div class="bg-gray-100 h-full rounded">
          <%= pie_chart @deal_stage_distribution, 
              colors: ["#4F46E5", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#EC4899", "#3B82F6", "#6366F1"],
              donut: true, 
              title: "Deal Stages",
              legend: true,
              empty: "No data available" %>
        </div>
      </div>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-4">Lead Status Metrics</h3>
      <table class="min-w-full">
        <tbody>
          <tr>
            <td class="py-2">Connection Established</td>
            <td class="py-2 text-right"><%= @connection_established_percentage %>%</td>
          </tr>
          <tr>
            <td class="py-2">Not Interested</td>
            <td class="py-2 text-right"><%= @not_interested_percentage %>%</td>
          </tr>
          <tr>
            <td class="py-2">Discovery Call Booked</td>
            <td class="py-2 text-right"><%= @discovery_call_booked_percentage %>%</td>
          </tr>
          <tr>
            <td class="py-2">Unresponsive Leads</td>
            <td class="py-2 text-right"><%= @unresponsive_percentage %>%</td>
          </tr>
          <tr class="font-semibold">
            <td class="py-2">Conversion</td>
            <td class="py-2 text-right"><%= @conversion_count %> (<%= @conversion_percentage %>%)</td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Monthly Deals Trend</h3>
      <div class="h-64">
        <!-- Chart placeholder - would be implemented with a JavaScript charting library -->
        <div class="bg-gray-100 h-full rounded">
          <%= line_chart @monthly_deals, 
              colors: ["#3B82F6"],
              curve: true,
              title: "Deals per Month",
              empty: "No data available" %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Communication Metrics -->
<div class="bg-white rounded-lg shadow p-6 mb-8">
  <h2 class="text-xl font-semibold mb-4">Communication Metrics</h2>
  
  <!-- User Call Recording Reports -->
  <div class="bg-blue-50 rounded-lg p-6 border border-blue-200 mb-6">
    <h3 class="text-lg font-bold text-blue-800 mb-3">Your Call Activity</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="bg-white p-6 rounded-lg border border-gray-200 shadow-sm flex flex-col items-center justify-center">
        <span class="text-sm uppercase text-gray-500 tracking-wide">Calls in Last 24 Hours</span>
        <span class="text-4xl font-bold mt-3 <%= @user_call_reports[current_user.id][:last_day_calls] > 0 ? 'text-green-600' : 'text-gray-400' %>">
          <%= @user_call_reports[current_user.id][:last_day_calls] %>
        </span>
        <span class="text-xs mt-2 text-gray-500">
          <% if @user_call_reports[current_user.id][:last_day_calls] == 0 %>
            No calls today
          <% elsif @user_call_reports[current_user.id][:last_day_calls] == 1 %>
            1 call today
          <% else %>
            <%= @user_call_reports[current_user.id][:last_day_calls] %> calls today
          <% end %>
        </span>
        
        <% if @user_call_reports[current_user.id][:last_day_calls] > 0 %>
          <div class="flex justify-between w-full mt-3 text-xs">
            <div class="text-center">
              <span class="block text-green-600 font-semibold"><%= @user_call_reports[current_user.id][:last_day_successful_calls] %></span>
              <span class="text-gray-500">Successful</span>
              <span class="block text-blue-600 text-xxs">(≥ 10s)</span>
            </div>
            <div class="text-center">
              <span class="block text-red-600 font-semibold"><%= @user_call_reports[current_user.id][:last_day_failed_calls] %></span>
              <span class="text-gray-500">Failed</span>
              <span class="block text-blue-600 text-xxs">(< 10s)</span>
            </div>
            <div class="text-center">
              <span class="block font-semibold <%= @user_call_reports[current_user.id][:last_day_successful_calls] > (@user_call_reports[current_user.id][:last_day_calls]/2) ? 'text-green-600' : 'text-amber-600' %>">
                <%= (@user_call_reports[current_user.id][:last_day_successful_calls].to_f / @user_call_reports[current_user.id][:last_day_calls].to_f * 100).round %>%
              </span>
              <span class="text-gray-500">Success Rate</span>
            </div>
          </div>
        <% end %>
      </div>
      
      <div class="bg-white p-6 rounded-lg border border-gray-200 shadow-sm flex flex-col items-center justify-center">
        <span class="text-sm uppercase text-gray-500 tracking-wide">Calls in Last Month</span>
        <span class="text-4xl font-bold mt-3 <%= @user_call_reports[current_user.id][:last_month_calls] > 0 ? 'text-blue-600' : 'text-gray-400' %>">
          <%= @user_call_reports[current_user.id][:last_month_calls] %>
        </span>
        <span class="text-xs mt-2 text-gray-500">
          <% if @user_call_reports[current_user.id][:last_month_calls] == 0 %>
            No calls this month
          <% elsif @user_call_reports[current_user.id][:last_month_calls] == 1 %>
            1 call this month
          <% else %>
            <%= @user_call_reports[current_user.id][:last_month_calls] %> calls this month
          <% end %>
        </span>
        
        <% if @user_call_reports[current_user.id][:last_month_calls] > 0 %>
          <div class="flex justify-between w-full mt-3 text-xs">
            <div class="text-center">
              <span class="block text-green-600 font-semibold"><%= @user_call_reports[current_user.id][:last_month_successful_calls] %></span>
              <span class="text-gray-500">Successful</span>
              <span class="block text-blue-600 text-xxs">(≥ 10s)</span>
            </div>
            <div class="text-center">
              <span class="block text-red-600 font-semibold"><%= @user_call_reports[current_user.id][:last_month_failed_calls] %></span>
              <span class="text-gray-500">Failed</span>
              <span class="block text-blue-600 text-xxs">(< 10s)</span>
            </div>
            <div class="text-center">
              <span class="block font-semibold <%= @user_call_reports[current_user.id][:last_month_successful_calls] > (@user_call_reports[current_user.id][:last_month_calls]/2) ? 'text-green-600' : 'text-amber-600' %>">
                <%= (@user_call_reports[current_user.id][:last_month_successful_calls].to_f / @user_call_reports[current_user.id][:last_month_calls].to_f * 100).round %>%
              </span>
              <span class="text-gray-500">Success Rate</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Call Success Analysis Section -->
    <div class="bg-white rounded-lg border border-blue-100 p-4 mb-4">
      <h4 class="text-sm font-semibold text-blue-800 mb-2">Call Success Analysis - This Period</h4>
      <p class="text-xs text-gray-600 mb-3">Calls lasting 10 seconds or more are considered successful communications</p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-green-50 rounded p-3 text-center border border-green-100">
          <span class="text-sm text-green-700">Successful Calls</span>
          <span class="block text-2xl font-bold text-green-600 mt-1"><%= @successful_calls_count %></span>
          <span class="text-xs text-green-500 mt-1">≥ 10 seconds</span>
        </div>
        
        <div class="bg-red-50 rounded p-3 text-center border border-red-100">
          <span class="text-sm text-red-700">Failed Calls</span>
          <span class="block text-2xl font-bold text-red-600 mt-1"><%= @failed_calls_count %></span>
          <span class="text-xs text-red-500 mt-1">< 10 seconds</span>
        </div>
        
        <div class="bg-blue-50 rounded p-3 text-center border border-blue-100">
          <span class="text-sm text-blue-700">Success Rate</span>
          <span class="block text-2xl font-bold <%= @successful_calls_percentage > 50 ? 'text-green-600' : 'text-amber-600' %> mt-1"><%= @successful_calls_percentage %>%</span>
          <span class="text-xs text-blue-500 mt-1">Your effectiveness</span>
        </div>
      </div>
    </div>
    
    <!-- Call Success Rate Trend -->
    <div class="bg-white rounded-lg border border-blue-100 p-4">
      <h4 class="text-sm font-semibold text-blue-800 mb-2">Call Success Trend</h4>
      <div class="h-48">
        <%= area_chart [
          {name: "Successful Calls (≥ 10s)", data: @monthly_successful_calls},
          {name: "Failed Calls (< 10s)", data: @monthly_failed_calls}
        ], 
        stacked: true,
        colors: ["#10B981", "#EF4444"],
        curve: true,
        library: {
          plotOptions: {
            area: {
              stacking: 'normal'
            }
          }
        } %>
      </div>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Calls</h3>
      <div class="mb-4">
        <h4 class="font-medium">Total Calls Connected</h4>
        <p><%= @calls_connected_count_monthly %> of <%= @total_calls_monthly %> (<%= @calls_connected_percentage_monthly %>%)</p>
      </div>
      
      <h4 class="font-medium mb-2">Daily Call Trend</h4>
      <div class="max-h-40 overflow-y-auto">
        <ul class="text-sm">
          <% @total_calls_daily.each do |date, count| %>
            <li class="py-1"><%= date.strftime('%b %d, %Y') %>: <%= count %> calls</li>
          <% end %>
        </ul>
      </div>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Weekly Call Trend</h3>
      <div class="max-h-64 overflow-y-auto">
        <ul class="text-sm">
          <% @total_calls_weekly.each do |week_start, count| %>
            <li class="py-1">Week of <%= week_start.strftime('%b %d, %Y') %>: <%= count %> calls</li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">WhatsApp</h3>
      <p class="text-2xl font-bold text-green-600"><%= @whatsapp_conversations_monthly %></p>
      <p class="text-sm text-gray-600">Total conversations started</p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Email</h3>
      <p class="text-2xl font-bold text-blue-600"><%= @email_conversations_monthly %></p>
      <p class="text-sm text-gray-600">Total conversations started</p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">LinkedIn</h3>
      <p class="text-2xl font-bold text-purple-600"><%= @linkedin_conversations_monthly %></p>
      <p class="text-sm text-gray-600">Total conversations started</p>
    </div>
  </div>
</div>

<style>
.text-xxs {
  font-size: 0.65rem;
}
</style>

<script>
  function toggleCustomDateFields(value) {
    const customFields = document.getElementById('custom_date_fields');
    if (value === 'custom') {
      customFields.classList.remove('hidden');
    } else {
      customFields.classList.add('hidden');
    }
  }
</script> 