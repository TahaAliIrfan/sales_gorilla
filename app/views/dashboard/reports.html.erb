<h1 class="text-2xl font-bold mb-6">Sales Reports</h1>

<div class="bg-white rounded-lg shadow p-6 mb-8">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-semibold">Team Performance Dashboard</h2>
    
    <div class="flex space-x-2">
      <form action="<%= reports_path %>" method="get" class="flex space-x-2">
        <select name="user_id" id="user_filter" class="rounded border border-gray-300 px-3 py-2 text-sm">
          <option value="">All Team Members</option>
          <% @users.each do |user| %>
            <option value="<%= user.id %>" <%= @selected_user_id == user.id.to_s ? 'selected' : '' %>><%= user.name %></option>
          <% end %>
        </select>
        
        <select name="filter_range" id="filter_range" class="rounded border border-gray-300 px-3 py-2 text-sm" onchange="toggleCustomDateFields(this.value)">
          <option value="30" <%= @filter_range == '30' ? 'selected' : '' %>>Last 30 Days</option>
          <option value="90" <%= @filter_range == '90' ? 'selected' : '' %>>Last 90 Days</option>
          <option value="custom" <%= @filter_range == 'custom' ? 'selected' : '' %>>Custom Range</option>
        </select>
        
        <div id="custom_date_fields" class="flex space-x-2 <%= @filter_range == 'custom' ? '' : 'hidden' %>">
          <input type="date" name="start_date" id="start_date" class="rounded border border-gray-300 px-3 py-2 text-sm" value="<%= @custom_start_date&.strftime('%Y-%m-%d') %>">
          <span class="self-center">to</span>
          <input type="date" name="end_date" id="end_date" class="rounded border border-gray-300 px-3 py-2 text-sm" value="<%= @custom_end_date&.strftime('%Y-%m-%d') %>">
        </div>
        
        <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded text-sm">Apply</button>
      </form>
    </div>
  </div>
  
  <div class="text-sm text-gray-600 mb-4">
    <% if @selected_user_id.present? %>
      Showing data for <%= @selected_user.name %> from <%= @start_date.strftime('%B %d, %Y') %> to <%= @end_date.strftime('%B %d, %Y') %>
    <% else %>
      Showing team data from <%= @start_date.strftime('%B %d, %Y') %> to <%= @end_date.strftime('%B %d, %Y') %>
    <% end %>
  </div>

  <!-- New section for Won & Lost Deals -->
  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 mb-8">
    <h3 class="text-lg font-medium mb-4">Deals Performance</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="flex justify-between items-center mb-4">
          <h4 class="text-md font-medium">Won Deals</h4>
          <p class="text-sm text-gray-500">Based on closing date</p>
        </div>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-3xl font-bold text-green-600"><%= @total_won_deals %></p>
            <p class="text-xl text-green-700 mt-2">$<%= number_with_delimiter(@total_won_deal_value) %></p>
          </div>
          <div class="text-sm text-gray-600">
            <p>Filtered by: <%= @filter_range == '30' ? 'Last 30 Days' : (@filter_range == '90' ? 'Last 90 Days' : 'Custom Range') %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="flex justify-between items-center mb-4">
          <h4 class="text-md font-medium">Lost Deals</h4>
          <p class="text-sm text-gray-500">Based on closing date</p>
        </div>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-3xl font-bold text-red-600"><%= @total_lost_deals %></p>
            <p class="text-xl text-red-700 mt-2">$<%= number_with_delimiter(@total_lost_deal_value) %></p>
          </div>
          <div class="text-sm text-gray-600">
            <p>Filtered by: <%= @filter_range == '30' ? 'Last 30 Days' : (@filter_range == '90' ? 'Last 90 Days' : 'Custom Range') %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <% if @selected_user_id.blank? %>
    <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 mb-8">
      <h3 class="text-lg font-medium mb-4">Customer & Deal Progression by User</h3>
      <div class="h-96">
        <% 
          # Prepare data for horizontal stacked bar chart with specific order
          series_data = [
            { name: "Deals Won", color: "#10B981", data: {} },
            { name: "Deals Created", color: "#8B5CF6", data: {} },
            { name: "Contact Established", color: "#3B82F6", data: {} },
            { name: "Contact Not Established / Unresponsive", color: "#FFA500", data: {} },
            { name: "Exhausted", color: "#FF0000", data: {} },
            { name: "Invalid", color: "#6B7280", data: {} },
            { name: "Pending", color: "#FFFA00", data: {} }
          ]
          
          # Populate the data for each user and series
          @users.each do |user|
            series_data[0][:data][user.name] = @user_progression_metrics[user.id]['Deals Won']
            series_data[1][:data][user.name] = @user_progression_metrics[user.id]['Deals Created']
            series_data[2][:data][user.name] = @user_progression_metrics[user.id]['Contact Established']
            series_data[3][:data][user.name] = @user_progression_metrics[user.id]['Contact Not Established / Unresponsive']
            series_data[4][:data][user.name] = @user_progression_metrics[user.id]['Exhausted']
            series_data[5][:data][user.name] = @user_progression_metrics[user.id]['Invalid']
            series_data[6][:data][user.name] = @user_progression_metrics[user.id]['Pending']
          end
        %>
        <%= bar_chart series_data,
          stacked: true,
          legend: true,
          library: {
            plotOptions: {
              series: {
                dataLabels: {
                  enabled: true,
                  format: '{point.y}'
                }
              },
              bar: {
                horizontal: true
              }
            },
            chart: {
              type: 'bar',
              height: 400
            },
            xAxis: {
              title: {
                text: 'Count'
              }
            },
            yAxis: {
              title: {
                text: 'Users'
              }
            }
          }
        %>
      </div>
      <div class="mt-4 text-sm text-gray-600">
        <p>This chart shows the progression of customers from initial status to deal won for each user.</p>
        <p class="flex items-center mt-2"><span class="w-4 h-4 inline-block mr-2" style="background-color: #F59E0B"></span> Pending: Initial contact stage</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #3B82F6"></span> Contact Established: Initial communication established</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #EF4444"></span> Contact Not Established / Unresponsive: Unable to establish contact</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #9333EA"></span> Exhausted: All contact attempts exhausted</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #6B7280"></span> Invalid: Invalid contact information</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #8B5CF6"></span> Deals Created: Number of deals created</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #10B981"></span> Deals Won: Successfully closed deals</p>
      </div>
    </div>
  <% else %>
    <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 mb-8">
      <h3 class="text-lg font-medium mb-4">Customer & Deal Progression</h3>
      <div class="h-64">
        <% 
          # Prepare data for horizontal stacked bar chart with specific order
          series_data = [
            { name: "Deals Won", color: "#10B981", data: {} },
            { name: "Deals Created", color: "#8B5CF6", data: {} },
            { name: "Contact Established", color: "#3B82F6", data: {} },
            { name: "Contact Not Established / Unresponsive", color: "#EF4444", data: {} },
            { name: "Exhausted", color: "#9333EA", data: {} },
            { name: "Invalid", color: "#6B7280", data: {} },
            { name: "Pending", color: "#F59E0B", data: {} }
          ]
          
          # Populate the data for single user
          series_data[0][:data][@selected_user.name] = @user_progression_metrics[@selected_user.id]['Deals Won']
          series_data[1][:data][@selected_user.name] = @user_progression_metrics[@selected_user.id]['Deals Created']
          series_data[2][:data][@selected_user.name] = @user_progression_metrics[@selected_user.id]['Contact Established']
          series_data[3][:data][@selected_user.name] = @user_progression_metrics[@selected_user.id]['Contact Not Established / Unresponsive']
          series_data[4][:data][@selected_user.name] = @user_progression_metrics[@selected_user.id]['Exhausted']
          series_data[5][:data][@selected_user.name] = @user_progression_metrics[@selected_user.id]['Invalid']
          series_data[6][:data][@selected_user.name] = @user_progression_metrics[@selected_user.id]['Pending']
        %>
        <%= bar_chart series_data,
          stacked: true,
          legend: true,
          library: {
            plotOptions: {
              series: {
                dataLabels: {
                  enabled: true,
                  format: '{point.y}'
                }
              },
              bar: {
                horizontal: true
              }
            },
            chart: {
              type: 'bar',
              height: 200
            },
            xAxis: {
              title: {
                text: 'Count'
              }
            },
            yAxis: {
              title: {
                text: 'Status'
              }
            }
          }
        %>
      </div>
      <div class="mt-10 text-sm text-gray-600">
        <p class="mb-2">This chart shows your progression of customers from initial status to deal won.</p>
        <p class="flex items-center mt-2"><span class="w-4 h-4 inline-block mr-2" style="background-color: #F59E0B"></span> Pending: Initial contact stage</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #3B82F6"></span> Contact Established: Initial communication established</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #EF4444"></span> Contact Not Established / Unresponsive: Unable to establish contact</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #9333EA"></span> Exhausted: All contact attempts exhausted</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #6B7280"></span> Invalid: Invalid contact information</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #8B5CF6"></span> Deals Created: Number of deals created</p>
        <p class="flex items-center mt-1"><span class="w-4 h-4 inline-block mr-2" style="background-color: #10B981"></span> Deals Won: Successfully closed deals</p>
      </div>
    </div>
  <% end %>
</div>

<!-- Sales Rep Metrics -->
<div class="bg-white rounded-lg shadow p-6 mb-8">
  <h2 class="text-xl font-semibold mb-4">
    <% if @selected_user_id.present? %>
      Sales Rep Performance: <%= @selected_user.name %>
    <% else %>
      Team Sales Performance
    <% end %>
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Assigned Leads</h3>
      <p class="text-3xl font-bold text-blue-600"><%= @total_assigned_leads %></p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Total Deals</h3>
      <p class="text-3xl font-bold text-green-600"><%= @total_deals %></p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Total Deal Value</h3>
      <p class="text-3xl font-bold text-purple-600">$<%= number_with_delimiter(@total_deal_value) %></p>
    </div>
  </div>
  
  <!-- Deal Status Metrics -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Win Rate</h3>
      <p class="text-3xl font-bold text-indigo-600"><%= @total_deals > 0 ? ((@total_won_deals.to_f / @total_deals) * 100).round(1) : 0 %>%</p>
      <p class="text-sm text-gray-600 mt-2">(<%= @total_won_deals %> of <%= @total_deals %> deals)</p>
    </div>
  </div>
  
  <!-- Deal Value by Status Chart -->
  <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-8">
    <h3 class="text-lg font-medium mb-4">Deal Value by Status</h3>
    <div class="h-64">
      <%= bar_chart({
          "Active" => (@total_deal_value - @total_won_deal_value - @total_lost_deal_value),
          "Won" => @total_won_deal_value,
          "Lost" => @total_lost_deal_value
        }, 
        colors: ["#6366F1", "#10B981", "#EF4444"],
        prefix: "$",
        empty: "No deal data available",
        xtitle: "Value ($)"
      ) %>
    </div>
  </div>
  
  <!-- System Call Metrics -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">System Calls</h3>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-600">Total calls made from system:</p>
          <p class="text-3xl font-bold text-blue-600"><%= @total_system_calls %></p>
        </div>
        <i class="fas fa-phone-alt text-blue-600 text-5xl"></i>
      </div>
    </div>
  </div>
  
  <!-- Monthly System Calls Chart -->
  <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-8">
    <h3 class="text-lg font-medium mb-4">Monthly System Call Trend</h3>
    <div class="h-64">
      <%= line_chart @monthly_system_calls, 
          colors: ["#4F46E5"],
          curve: true,
          title: "System Calls per Month",
          legend: false,
          empty: "No system call data available" %>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Lead Sources</h3>
      <div class="h-full">
        <!-- Chart placeholder - would be implemented with a JavaScript charting library -->
        <div class="bg-gray-100 rounded">
          <%= pie_chart @lead_source_distribution, 
              colors: ["#4F46E5", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#EC4899", "#3B82F6", "#6366F1"],
              donut: true, 
              title: "Source Distribution",
              legend: true,
              empty: "No data available" %>
        </div>
      </div>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Deal Stages</h3>
      <div class="h-full">
        <!-- Chart placeholder - would be implemented with a JavaScript charting library -->
        <div class="bg-gray-100 rounded">
          <%= pie_chart @deal_stage_distribution, 
              colors: ["#4F46E5", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#EC4899", "#3B82F6", "#6366F1"],
              donut: true, 
              title: "Deal Stages",
              legend: true,
              empty: "No data available" %>
        </div>
      </div>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-4">Lead Status Metrics</h3>
      <table class="min-w-full">
        <tbody>
          <tr>
            <td class="py-2">Connection Established</td>
            <td class="py-2 text-right"><%= @connection_established_percentage %>%</td>
          </tr>
          <tr>
            <td class="py-2">Not Interested</td>
            <td class="py-2 text-right"><%= @not_interested_percentage %>%</td>
          </tr>
          <tr>
            <td class="py-2">Discovery Call Booked</td>
            <td class="py-2 text-right"><%= @discovery_call_booked_percentage %>%</td>
          </tr>
          <tr>
            <td class="py-2">Unresponsive Leads</td>
            <td class="py-2 text-right"><%= @unresponsive_percentage %>%</td>
          </tr>
          <tr class="font-semibold">
            <td class="py-2">Conversion</td>
            <td class="py-2 text-right"><%= @conversion_count %> (<%= @conversion_percentage %>%)</td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Monthly Deals Trend</h3>
      <div class="h-64">
        <!-- Chart placeholder - would be implemented with a JavaScript charting library -->
        <div class="bg-gray-100 h-full rounded">
          <%= line_chart @monthly_deals, 
              colors: ["#3B82F6"],
              curve: true,
              title: "Deals per Month",
              empty: "No data available" %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Communication Metrics -->
<div class="bg-white rounded-lg shadow p-6 mb-8">
  <h2 class="text-xl font-semibold mb-4">Communication Metrics</h2>
  
  <% if current_user&.admin? %>
  <!-- Admin Team Call Report -->
  <div class="bg-blue-50 rounded-lg p-6 border border-blue-200 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-bold text-blue-800">Team Call Recording Report <span class="text-xs bg-blue-600 text-white px-2 py-1 rounded ml-2">Admin Only</span></h3>
      <div class="text-sm text-blue-600 font-medium">
        <span><%= @successful_calls_count + @failed_calls_count %> total calls this period</span>
      </div>
    </div>
    
    <div class="bg-white rounded-lg border border-blue-100 shadow-sm overflow-hidden mb-6">
      <div class="flex justify-between items-center bg-gradient-to-r from-blue-500 to-blue-600 text-white px-4 py-3">
        <div class="text-sm font-semibold">Call Success Analysis</div>
        <div class="text-xs">
          <span class="mr-2">Success: Calls ≥ 40 seconds</span>
          <span>Failed: Calls < 40 seconds</span>
        </div>
      </div>
      
      <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center border border-blue-100">
            <div class="text-sm text-blue-700 font-medium">Successful Calls</div>
            <div class="text-3xl font-bold text-blue-600 mt-2"><%= @successful_calls_count %></div>
            <div class="text-xs text-blue-500 mt-1">Calls ≥ 40 seconds</div>
          </div>
          
          <div class="bg-red-50 rounded-lg p-4 text-center border border-red-100">
            <div class="text-sm text-red-700 font-medium">Failed Calls</div>
            <div class="text-3xl font-bold text-red-600 mt-2"><%= @failed_calls_count %></div>
            <div class="text-xs text-red-500 mt-1">Calls < 40 seconds</div>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-4 text-center border border-gray-200">
            <div class="text-sm text-gray-700 font-medium">Success Rate</div>
            <div class="text-3xl font-bold <%= @successful_calls_percentage > 50 ? 'text-green-600' : 'text-amber-600' %> mt-2"><%= @successful_calls_percentage %>%</div>
            <div class="text-xs text-gray-500 mt-1">Of all calls</div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="overflow-x-auto">
      <table class="min-w-full bg-white">
        <thead>
          <tr class="bg-blue-100 border-b border-blue-200">
            <th class="px-4 py-3 text-left text-xs font-medium text-blue-800 uppercase tracking-wider">Team Member</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-blue-800 uppercase tracking-wider">Today</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-blue-800 uppercase tracking-wider">Success Rate (Today)</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-blue-800 uppercase tracking-wider">This Month</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-blue-800 uppercase tracking-wider">Success Rate (Month)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @user_call_reports.each do |user_id, report| %>
            <tr class="hover:bg-blue-50 transition-colors">
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= report[:name] %></td>
              <td class="px-4 py-3 text-sm text-center">
                <span class="font-semibold <%= report[:last_day_calls] > 0 ? 'text-green-600' : 'text-gray-400' %>"><%= report[:last_day_calls] %></span>
                <% if report[:last_day_calls] > 0 %>
                  <div class="text-xs text-gray-500">
                    <span class="text-green-600"><%= report[:last_day_successful_calls] %> successful</span>, 
                    <span class="text-red-600"><%= report[:last_day_failed_calls] %> failed</span>
                  </div>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-center">
                <% if report[:last_day_calls] > 0 %>
                  <span class="font-semibold <%= (report[:last_day_successful_calls].to_f / report[:last_day_calls].to_f * 100) > 50 ? 'text-green-600' : 'text-amber-600' %>">
                    <%= (report[:last_day_successful_calls].to_f / report[:last_day_calls].to_f * 100).round %>%
                  </span>
                <% else %>
                  <span class="text-gray-400">—</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-center">
                <span class="font-semibold <%= report[:last_month_calls] > 0 ? 'text-blue-600' : 'text-gray-400' %>"><%= report[:last_month_calls] %></span>
                <% if report[:last_month_calls] > 0 %>
                  <div class="text-xs text-gray-500">
                    <span class="text-green-600"><%= report[:last_month_successful_calls] %> successful</span>, 
                    <span class="text-red-600"><%= report[:last_month_failed_calls] %> failed</span>
                  </div>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-center">
                <% if report[:last_month_calls] > 0 %>
                  <span class="font-semibold <%= (report[:last_month_successful_calls].to_f / report[:last_month_calls].to_f * 100) > 50 ? 'text-green-600' : 'text-amber-600' %>">
                    <%= (report[:last_month_successful_calls].to_f / report[:last_month_calls].to_f * 100).round %>%
                  </span>
                <% else %>
                  <span class="text-gray-400">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <!-- Team Totals Row -->
          <tr class="bg-blue-50 font-semibold border-t-2 border-blue-200">
            <td class="px-4 py-3 text-sm text-blue-800">TEAM TOTAL</td>
            <td class="px-4 py-3 text-sm text-center text-blue-800">
              <% 
                total_day_calls = @user_call_reports.values.sum { |r| r[:last_day_calls] } 
                total_day_successful = @user_call_reports.values.sum { |r| r[:last_day_successful_calls] } 
                total_day_failed = @user_call_reports.values.sum { |r| r[:last_day_failed_calls] }
              %>
              <%= total_day_calls %>
              <% if total_day_calls > 0 %>
                <div class="text-xs">
                  <span class="text-green-700"><%= total_day_successful %> successful</span>, 
                  <span class="text-red-700"><%= total_day_failed %> failed</span>
                </div>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-center text-blue-800">
              <% if total_day_calls > 0 %>
                <%= (total_day_successful.to_f / total_day_calls.to_f * 100).round %>%
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-center text-blue-800">
              <% 
                total_month_calls = @user_call_reports.values.sum { |r| r[:last_month_calls] } 
                total_month_successful = @user_call_reports.values.sum { |r| r[:last_month_successful_calls] } 
                total_month_failed = @user_call_reports.values.sum { |r| r[:last_month_failed_calls] }
              %>
              <%= total_month_calls %>
              <% if total_month_calls > 0 %>
                <div class="text-xs">
                  <span class="text-green-700"><%= total_month_successful %> successful</span>, 
                  <span class="text-red-700"><%= total_month_failed %> failed</span>
                </div>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-center text-blue-800">
              <% if total_month_calls > 0 %>
                <%= (total_month_successful.to_f / total_month_calls.to_f * 100).round %>%
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
  <% end %>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Calls</h3>
      <div class="mb-4">
        <h4 class="font-medium">Total Calls Connected</h4>
        <p><%= @calls_connected_count_monthly %> of <%= @total_calls_monthly %> (<%= @calls_connected_percentage_monthly %>%)</p>
      </div>
      
      <h4 class="font-medium mb-2">Daily Call Trend</h4>
      <div class="max-h-40 overflow-y-auto">
        <ul class="text-sm">
          <% @total_calls_daily.each do |date, count| %>
            <li class="py-1"><%= date.strftime('%b %d, %Y') %>: <%= count %> calls</li>
          <% end %>
        </ul>
      </div>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Weekly Call Trend</h3>
      <div class="max-h-64 overflow-y-auto">
        <ul class="text-sm">
          <% @total_calls_weekly.each do |week_start, count| %>
            <li class="py-1">Week of <%= week_start.strftime('%b %d, %Y') %>: <%= count %> calls</li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
  
  <!-- Call Success Rate Monthly Trend -->
  <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-8">
    <h3 class="text-lg font-medium mb-2">Monthly Call Success Rate Trend</h3>
    <div class="h-64">
      <%= area_chart [
        {name: "Successful Calls (≥ 40s)", data: @monthly_successful_calls},
        {name: "Failed Calls (< 40s)", data: @monthly_failed_calls}
      ], 
      stacked: true,
      colors: ["#10B981", "#EF4444"],
      curve: true,
      library: {
        plotOptions: {
          area: {
            stacking: 'normal'
          }
        }
      } %>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">WhatsApp</h3>
      <p class="text-2xl font-bold text-green-600"><%= @whatsapp_conversations_monthly %></p>
      <p class="text-sm text-gray-600">Total conversations started</p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">Email</h3>
      <p class="text-2xl font-bold text-blue-600"><%= @email_conversations_monthly %></p>
      <p class="text-sm text-gray-600">Total conversations started</p>
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
      <h3 class="text-lg font-medium mb-2">LinkedIn</h3>
      <p class="text-2xl font-bold text-purple-600"><%= @linkedin_conversations_monthly %></p>
      <p class="text-sm text-gray-600">Total conversations started</p>
    </div>
  </div>
</div>

<script>
  function toggleCustomDateFields(value) {
    const customFields = document.getElementById('custom_date_fields');
    if (value === 'custom') {
      customFields.classList.remove('hidden');
    } else {
      customFields.classList.add('hidden');
    }
  }
</script> 