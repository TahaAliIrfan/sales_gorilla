<div id="dashboard-container" data-controller="dashboard" 
     data-dashboard-filter-range-value="<%= @filter_range %>"
     data-dashboard-start-date-value="<%= @custom_start_date %>"
     data-dashboard-end-date-value="<%= @custom_end_date %>"
     data-dashboard-user-id-value="<%= @selected_user_id %>">

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Admin Performance Dashboard</h1>
    <div class="text-sm text-gray-600 bg-white px-3 py-1 rounded-lg border">
      <%= @period_name %>
    </div>
  </div>

  <!-- Filters Section -->
  <div class="mb-6 bg-white p-4 rounded-lg shadow">
    <%= form_with url: admin_dashboard_path, method: :get, local: false, id: "dashboard-filters", 
                  class: "flex flex-wrap gap-4 items-end", 
                  data: { action: "submit->dashboard#updateFilters" } do |form| %>
      <div class="flex-1 min-w-48">
        <%= form.label :filter_range, "Time Period", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.select :filter_range, 
            options_for_select([
              ['Last 7 Days', '7'],
              ['Last 30 Days', '30'],
              ['Last 90 Days', '90'],
              ['Custom Range', 'custom']
            ], @filter_range), 
            {}, 
            { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", 
              data: { action: "change->dashboard#toggleCustomDates" } } %>
      </div>
      
      <div class="flex-1 min-w-48" id="custom-dates" style="<%= @filter_range != 'custom' ? 'display: none;' : '' %>">
        <div class="flex gap-2">
          <div>
            <%= form.label :start_date, "From", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.date_field :start_date, value: @custom_start_date, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          </div>
          <div>
            <%= form.label :end_date, "To", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.date_field :end_date, value: @custom_end_date, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          </div>
        </div>
      </div>
      
      <div class="flex-1 min-w-48">
        <%= form.label :user_id, "Filter by User", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.select :user_id, 
            options_from_collection_for_select(@users, :id, :name, @selected_user_id), 
            { prompt: "All Users" }, 
            { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" } %>
      </div>
      
      <div>
        <%= form.submit "Apply Filters", class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2", id: "filter-submit" %>
        <%= link_to "Clear", "#", class: "ml-2 bg-gray-200 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-300", 
                    data: { action: "click->dashboard#clearFilters" } %>
      </div>
    <% end %>
  </div>

  <!-- Team Overview Stats -->
  <div data-dashboard-target="teamOverview" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-7 mb-8">
    <!-- Loading placeholders -->
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-20 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-16"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-24 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-16"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-28 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-24"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-24 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-16"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-28 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-16"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-32 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-20"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-28 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-16"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Top Performers -->
  <div data-dashboard-target="topPerformers" class="bg-white shadow rounded-lg mb-8">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium leading-6 text-gray-900">Top Performers</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        Highest performing team members for the selected period
      </p>
    </div>
    <div class="px-4 py-5 sm:p-6 animate-pulse">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="bg-gray-300 rounded-lg h-24"></div>
        <div class="bg-gray-300 rounded-lg h-24"></div>
        <div class="bg-gray-300 rounded-lg h-24"></div>
      </div>
    </div>
  </div>

  <!-- User Performance Table -->
  <div data-dashboard-target="userPerformance" class="bg-white shadow rounded-lg mb-8">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium leading-6 text-gray-900">
        <%= @selected_user ? "#{@selected_user.name}'s Performance" : "Team Performance Overview" %>
      </h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        Daily, weekly, and monthly activity metrics for sales representatives
      </p>
    </div>
    <div class="overflow-x-auto">
      <div class="min-w-full divide-y divide-gray-200 animate-pulse">
        <div class="bg-gray-50 px-6 py-3">
          <div class="flex space-x-4">
            <div class="h-4 bg-gray-300 rounded w-20"></div>
            <div class="h-4 bg-gray-300 rounded w-16"></div>
            <div class="h-4 bg-gray-300 rounded w-32"></div>
            <div class="h-4 bg-gray-300 rounded w-20"></div>
            <div class="h-4 bg-gray-300 rounded w-24"></div>
            <div class="h-4 bg-gray-300 rounded w-24"></div>
          </div>
        </div>
        <% 3.times do %>
          <div class="bg-white px-6 py-4">
            <div class="flex space-x-4">
              <div class="h-4 bg-gray-300 rounded w-32"></div>
              <div class="h-4 bg-gray-300 rounded w-20"></div>
              <div class="h-4 bg-gray-300 rounded w-16"></div>
              <div class="h-4 bg-gray-300 rounded w-24"></div>
              <div class="h-4 bg-gray-300 rounded w-32"></div>
              <div class="h-4 bg-gray-300 rounded w-40"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Communication Analytics -->
  <div data-dashboard-target="communicationAnalytics" class="bg-white shadow rounded-lg mb-8">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium leading-6 text-gray-900">Communication Analytics</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        Call activity and customer engagement metrics
      </p>
    </div>
    <div class="overflow-x-auto">
      <div class="min-w-full divide-y divide-gray-200 animate-pulse">
        <div class="bg-gray-50 px-6 py-3">
          <div class="flex space-x-4">
            <div class="h-4 bg-gray-300 rounded w-20"></div>
            <div class="h-4 bg-gray-300 rounded w-24"></div>
            <div class="h-4 bg-gray-300 rounded w-28"></div>
            <div class="h-4 bg-gray-300 rounded w-24"></div>
          </div>
        </div>
        <% 3.times do %>
          <div class="bg-white px-6 py-4">
            <div class="flex space-x-4">
              <div class="h-4 bg-gray-300 rounded w-32"></div>
              <div class="h-4 bg-gray-300 rounded w-16"></div>
              <div class="h-4 bg-gray-300 rounded w-16"></div>
              <div class="h-4 bg-gray-300 rounded w-20"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Deal Pipeline Analytics -->
  <div data-dashboard-target="dealAnalytics" class="grid grid-cols-1 gap-6 lg:grid-cols-2 mb-8">
    <div class="bg-white shadow rounded-lg animate-pulse">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Deals by Stage</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <div class="space-y-4">
          <% 4.times do %>
            <div class="flex items-center justify-between">
              <div class="h-4 bg-gray-300 rounded w-24"></div>
              <div class="flex items-center">
                <div class="h-4 bg-gray-300 rounded w-8 mr-3"></div>
                <div class="w-16 bg-gray-200 rounded-full h-2">
                  <div class="bg-gray-300 h-2 rounded-full w-1/2"></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="bg-white shadow rounded-lg animate-pulse">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Deals by User</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <div class="space-y-4">
          <% 4.times do %>
            <div class="flex items-center justify-between">
              <div class="h-4 bg-gray-300 rounded w-32"></div>
              <div class="flex items-center">
                <div class="h-4 bg-gray-300 rounded w-8 mr-3"></div>
                <div class="w-16 bg-gray-200 rounded-full h-2">
                  <div class="bg-gray-300 h-2 rounded-full w-3/4"></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Additional Analytics -->
  <div data-dashboard-target="additionalAnalytics" class="grid grid-cols-1 gap-6 sm:grid-cols-3 mb-8">
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-28 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-24"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg animate-pulse">
      <div class="p-5">
        <div class="flex items-center">
          <div class="h-6 w-6 bg-gray-300 rounded"></div>
          <div class="ml-5 w-0 flex-1">
            <div class="h-4 bg-gray-300 rounded w-24 mb-2"></div>
            <div class="h-8 bg-gray-300 rounded w-20"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Total Pipeline Value</dt>
              <dd class="text-2xl font-semibold text-gray-900">$<%= number_with_delimiter(@total_deal_value) %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Global loading indicator -->
  <div id="global-loading" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 flex items-center space-x-3">
      <svg class="animate-spin h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="m4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span class="text-gray-700">Updating dashboard...</span>
    </div>
  </div>

</div>