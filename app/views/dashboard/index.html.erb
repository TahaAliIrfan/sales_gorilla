<div>
  <h1 class="text-2xl font-bold mb-6">Dashboard</h1>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Customers Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Total Customers</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @total_customers %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to customers_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all customers
          <% end %>
        </div>
      </div>
    </div>

    <!-- Active Deals Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Active Deals</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @active_deals %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to deals_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all deals
          <% end %>
        </div>
      </div>
    </div>

    <!-- Won Deals Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Won Deals</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @won_deals %></div>
                <div class="ml-2 text-sm font-medium text-green-600">
                  <%= number_to_currency(@won_deal_value) %>
                </div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to deals_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all deals
          <% end %>
        </div>
      </div>
    </div>

    <!-- Lost Deals Stats card -->
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Lost Deals</dt>
              <dd class="flex items-baseline">
                <div class="text-2xl font-semibold text-gray-900"><%= @lost_deals %></div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <%= link_to deals_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
            View all deals
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Pipeline Overview -->
  <div class="mt-8">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Pipeline Overview</h2>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center space-x-4">
          <% @deal_stages.each do |stage| %>
            <div class="flex-1 text-center">
              <div class="text-sm font-medium text-gray-500"><%= stage.name %></div>
              <div class="mt-1 text-2xl font-semibold text-gray-900"><%= @deals_by_stage[stage.id] || 0 %></div>
            </div>
            <% unless stage == @deal_stages.last %>
              <div class="text-gray-300">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- My Deals -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">My Deals</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @my_deals.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @my_deals.each do |deal| %>
                <li class="py-4">
                  <div class="flex items-center space-x-4">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate">
                        <%= link_to deal.title, deal_path(deal), class: "hover:text-blue-600" %>
                      </p>
                      <p class="text-sm text-gray-500 truncate">
                        <% if deal.customer.present? %>
                          <%= deal.customer.name %>
                        <% else %>
                          <span class="text-gray-500">No customer</span>
                        <% end %> • <%= deal.deal_stage.name %>
                      </p>
                    </div>
                    <div>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <%= number_to_currency(deal.amount) %>
                      </span>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
          <div class="mt-6">
            <%= link_to "View all my deals", my_deals_deals_path, class: "w-full flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          </div>
        <% else %>
          <div class="text-center text-gray-500">
            No deals assigned to you
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Deals -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Recent Deals</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @recent_deals.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @recent_deals.each do |deal| %>
                <li class="py-4">
                  <div class="flex items-center space-x-4">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate">
                        <%= link_to deal.title, deal_path(deal), class: "hover:text-blue-600" %>
                      </p>
                      <p class="text-sm text-gray-500 truncate">
                        <% if deal.customer.present? %>
                          <%= deal.customer.name %>
                        <% else %>
                          <span class="text-gray-500">No customer</span>
                        <% end %> • <%= deal.deal_stage.name %>
                      </p>
                    </div>
                    <div>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                        <%= case deal.status
                            when 'active' then 'bg-blue-100 text-blue-800'
                            when 'won' then 'bg-green-100 text-green-800'
                            when 'lost' then 'bg-red-100 text-red-800'
                            end %>">
                        <%= deal.status.capitalize %>
                      </span>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
          <div class="mt-6">
            <%= link_to "View all deals", deals_path, class: "w-full flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          </div>
        <% else %>
          <div class="text-center text-gray-500">
            No deals created yet
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tasks Overview -->
  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-medium text-gray-900">Tasks Overview</h2>
      <div>
        <%= link_to tasks_path, class: "text-sm font-medium text-blue-600 hover:text-blue-900" do %>
          View all tasks
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 mb-6">
      <!-- Pending Tasks Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Pending Tasks</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900"><%= @pending_tasks_count %></div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <%= link_to tasks_path(status: 'Pending'), class: "font-medium text-blue-600 hover:text-blue-900" do %>
              View pending tasks
            <% end %>
          </div>
        </div>
      </div>

      <!-- Today's Tasks Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Today's Tasks</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900"><%= @today_tasks_count %></div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <%= link_to tasks_path(due_date: Date.today), class: "font-medium text-blue-600 hover:text-blue-900" do %>
              View today's tasks
            <% end %>
          </div>
        </div>
      </div>

      <!-- Overdue Tasks Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Overdue Tasks</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900"><%= @overdue_tasks_count %></div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <%= link_to tasks_path, class: "font-medium text-blue-600 hover:text-blue-900" do %>
              View overdue tasks
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Today's Tasks -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Today's Tasks</h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">
          Tasks due today across all team members (including completed)
        </p>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% if @today_tasks.any? %>
          <div class="flow-root">
            <ul class="-my-5 divide-y divide-gray-200">
              <% @today_tasks.each do |task| %>
                <li class="py-4">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <div class="min-w-0 flex-1 flex items-center">
                        <div class="flex-shrink-0">
                          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                            <%= case task.priority
                                when 'High' then 'bg-red-100 text-red-800'
                                when 'Medium' then 'bg-yellow-100 text-yellow-800'
                                when 'Low' then 'bg-green-100 text-green-800'
                                end %>">
                            <%= task.priority %>
                          </span>
                        </div>
                        <div class="min-w-0 flex-1 px-4">
                          <div>
                            <div class="flex">
                              <p class="text-sm font-medium <%= task.completed? ? 'text-gray-500 line-through' : 'text-blue-600' %> truncate">
                                <%= link_to task.title, task_path(task) %>
                              </p>
                              <% if task.completed? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800 rounded-full">
                                  Completed
                                </span>
                              <% elsif task.overdue? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800 rounded-full">
                                  Overdue
                                </span>
                              <% elsif task.due_today? && task.pending? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">
                                  Due Today
                                </span>
                              <% elsif task.pending? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">
                                  Pending
                                </span>
                              <% elsif task.in_progress? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-purple-100 text-purple-800 rounded-full">
                                  In Progress
                                </span>
                              <% elsif task.cancelled? %>
                                <span class="ml-2 flex-shrink-0 inline-block px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800 rounded-full">
                                  Cancelled
                                </span>
                              <% end %>
                            </div>
                            <p class="mt-1 text-sm text-gray-500">
                              Due: <%= task.due_date.strftime("%I:%M %p") %> • 
                              Assigned to: <%= task.user.name %>
                              <% if task.customer.present? %>
                                • Customer: <%= link_to task.customer.name, customer_path(task.customer), class: "text-blue-600 hover:text-blue-900" %>
                              <% end %>
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="flex-shrink-0 flex items-center">
                      <% unless task.completed? %>
                        <%= button_to complete_task_path(task, return_to: 'dashboard'), method: :patch, class: "mr-2 rounded-full p-1 bg-green-100 hover:bg-green-200 text-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                          </svg>
                        <% end %>
                      <% else %>
                        <span class="mr-2 rounded-full p-1 bg-gray-100 text-gray-500">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-500">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                          </svg>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center text-gray-500 py-4">
            No tasks due today
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
