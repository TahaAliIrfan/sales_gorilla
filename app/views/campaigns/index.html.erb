<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <div class="cb-eyebrow mb-1.5">outreach // campaigns</div>
      <h1 class="text-[26px] font-semibold tracking-tight text-[#0F172A]">WhatsApp Campaigns</h1>
      <p class="text-[#64748B] mt-1.5 text-sm">Create and manage WhatsApp message campaigns</p>
    </div>
    <%= link_to "New Campaign", new_campaign_path,
        class: "bg-emerald-500 hover:bg-emerald-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Recipients</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Scheduled</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Progress</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @campaigns.each do |campaign| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900"><%= campaign.name %></div>
              <div class="text-sm text-gray-500"><%= truncate(campaign.message, length: 50) %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% status_colors = {
                'draft' => 'bg-gray-100 text-gray-800',
                'scheduled' => 'bg-yellow-100 text-yellow-800',
                'in_progress' => 'bg-emerald-100 text-emerald-800',
                'completed' => 'bg-green-100 text-green-800',
                'failed' => 'bg-red-100 text-red-800'
              } %>
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_colors[campaign.status] %>">
                <%= campaign.status.titleize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= campaign.total_recipients %> customers
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= campaign.scheduled_at ? campaign.scheduled_at.strftime("%b %d, %Y %I:%M %p") : "Send immediately" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% total = campaign.campaign_executions.count %>
              <% completed = campaign.campaign_executions.where(status: 'completed').count %>
              <% failed = campaign.campaign_executions.where(status: 'failed').count %>
              <% if total > 0 %>
                <div class="text-sm">
                  <%= completed %>/<%= total %> sent
                  <% if failed > 0 %>
                    (<span class="text-red-600"><%= failed %> failed</span>)
                  <% end %>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2 mt-1">
                  <div class="bg-emerald-600 h-2 rounded-full" style="width: <%= (completed.to_f / total * 100).round %>%"></div>
                </div>
              <% else %>
                -
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
              <div class="flex gap-2">
                <%= link_to "View", campaign_path(campaign), class: "text-emerald-600 hover:text-emerald-900" %>
                <% if campaign.draft? %>
                  <%= link_to "Edit", edit_campaign_path(campaign), class: "text-gray-600 hover:text-gray-900" %>
                  <%= button_to "Send Now", send_now_campaign_path(campaign), method: :post,
                      form: { data: { turbo_confirm: "Send #{campaign.total_recipients} messages?" }, class: "inline" },
                      class: "text-green-600 hover:text-green-900 bg-transparent border-0 p-0 cursor-pointer" %>
                <% end %>
                <%= button_to "Delete", campaign_path(campaign), method: :delete,
                    form: { data: { turbo_confirm: "Are you sure?" }, class: "inline" },
                    class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @campaigns.empty? %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No campaigns</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by creating a new campaign.</p>
        <div class="mt-6">
          <%= link_to "New Campaign", new_campaign_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-emerald-600 hover:bg-emerald-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
