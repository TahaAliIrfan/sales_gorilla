<%# Campaigns index — relay DS table. Status badges via OutreachHelper. Row
    actions keep the existing endpoints (View / Edit / Send now / Delete) and
    their turbo_confirm prompts. %>
<% content_for :title, "Campaigns — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">WhatsApp campaigns</div>
      <div class="pagehead__sub">Create and manage bulk WhatsApp message campaigns.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_campaign_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("megaphone", size: 15) %>New campaign
      <% end %>
    </div>
  </div>

  <% if @campaigns.empty? %>
    <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
      <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-fg-3)"><%= relay_icon("megaphone", size: 22) %></span>
      <div class="rl-h4">No campaigns</div>
      <div class="muted rl-sm" style="margin-top:6px">Get started by creating a new campaign.</div>
      <div style="margin-top:16px"><%= link_to "New campaign", new_campaign_path, class: "rl-btn rl-btn--primary rl-btn--sm" %></div>
    </div></div>
  <% else %>
    <div class="sect">
      <div class="sect__body--flush">
        <div class="rl-table-scroll">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Recipients</th>
                <th>Scheduled</th>
                <th>Progress</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @campaigns.each do |campaign| %>
                <% meta = outreach_campaign_status_meta(campaign.status) %>
                <tr>
                  <td>
                    <div class="rl-cell-strong"><%= campaign.name %></div>
                    <div class="muted rl-sm" style="max-width:360px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= truncate(campaign.message, length: 60) %></div>
                  </td>
                  <td><span class="rl-badge <%= meta[:badge] %>"><%= relay_icon(meta[:icon], size: 11) %><%= meta[:label] %></span></td>
                  <td class="rl-sm tnum"><%= campaign.total_recipients %></td>
                  <td class="rl-sm"><%= campaign.scheduled_at ? campaign.scheduled_at.strftime("%b %-d, %Y %-I:%M %p") : "Send immediately" %></td>
                  <td>
                    <% total = campaign.campaign_executions.count %>
                    <% completed = campaign.campaign_executions.where(status: "completed").count %>
                    <% failed = campaign.campaign_executions.where(status: "failed").count %>
                    <% if total > 0 %>
                      <div class="rl-sm tnum"><%= completed %>/<%= total %> sent<% if failed > 0 %> <span style="color:var(--color-danger)">(<%= failed %> failed)</span><% end %></div>
                      <div class="segbar" style="margin-top:4px;max-width:140px">
                        <i style="width:<%= (completed.to_f / total * 100).round(2) %>%;background:var(--channel-whatsapp)"></i>
                      </div>
                    <% else %>
                      <span class="muted rl-sm">—</span>
                    <% end %>
                  </td>
                  <td>
                    <div class="row" style="gap:6px;justify-content:flex-end">
                      <%= link_to campaign_path(campaign), class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
                        <%= relay_icon("eye", size: 14) %>View
                      <% end %>
                      <% if campaign.draft? %>
                        <%= link_to edit_campaign_path(campaign), class: "rl-iconbtn rl-iconbtn--sm", title: "Edit" do %>
                          <%= relay_icon("pencil", size: 15) %>
                        <% end %>
                        <%= button_to send_now_campaign_path(campaign), method: :post,
                              form: { data: { turbo_confirm: "Send #{campaign.total_recipients} messages?" } },
                              class: "rl-iconbtn rl-iconbtn--sm", title: "Send now" do %>
                          <%= relay_icon("send", size: 15) %>
                        <% end %>
                      <% end %>
                      <%= button_to campaign_path(campaign), method: :delete,
                            form: { data: { turbo_confirm: "Are you sure?" } },
                            class: "rl-iconbtn rl-iconbtn--sm", title: "Delete" do %>
                        <%= relay_icon("trash-2", size: 15) %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>
