<%# Campaign form — relay DS. Preserves the message_template Stimulus contract
    (textarea target + insertVariable buttons with data-variable) and the
    campaign_customer_selector contract on new records (via _customer_picker).
    Params unchanged: campaign[name], campaign[message], campaign[scheduled_at],
    campaign[customer_ids][]. %>
<%= form_with(model: campaign, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if campaign.errors.any? %>
    <%= render "settings/errors", record: campaign %>
  <% end %>

  <div class="sect">
    <div class="sect__body col" style="gap:var(--space-5)">
      <%= render "shared/relay_field", f: form, field: :name, required: true,
            placeholder: "e.g., New Product Launch" %>

      <div data-controller="message-template" class="rl-field">
        <%= form.label :message, "WhatsApp message", class: "rl-label" %>
        <%= form.text_area :message, rows: 12,
              class: "rl-textarea",
              style: "resize:vertical;min-height:200px",
              placeholder: "Type your message here…\n\nPress Enter or Shift+Enter for a new line.\nClick the buttons below to insert customer data.",
              data: { message_template_target: "textarea" } %>

        <div style="margin-top:var(--space-3);padding:14px;background:var(--color-surface-2);border-radius:var(--radius-md)">
          <div class="micro" style="margin-bottom:8px">Click to insert customer data</div>
          <div class="row row--wrap" style="gap:6px">
            <% [["{{name}}", "Name"], ["{{first_name}}", "First name"], ["{{email}}", "Email"],
                ["{{phone}}", "Phone"], ["{{company}}", "Company"], ["{{lead_source}}", "Lead source"]].each do |variable, label| %>
              <button type="button"
                      data-variable="<%= variable %>"
                      data-action="click->message-template#insertVariable"
                      class="rl-btn rl-btn--secondary rl-btn--sm">
                <%= relay_icon("plus", size: 13) %><%= label %>
              </button>
            <% end %>
          </div>
          <p class="rl-help" style="margin-top:8px">Placeholders are replaced with each customer's data when the campaign is sent.</p>
        </div>
      </div>

      <% local_time = campaign.scheduled_at&.in_time_zone("Islamabad") %>
      <div class="rl-field">
        <%= form.label :scheduled_at, "Schedule for (optional)", class: "rl-label" %>
        <%= form.datetime_field :scheduled_at,
              value: (local_time ? local_time.strftime("%Y-%m-%dT%H:%M") : nil),
              class: "rl-input" %>
        <p class="rl-help">Pakistan Time (PKT), 24-hour format (e.g. 15:50 for 3:50 PM). Leave blank to send immediately.</p>
      </div>
    </div>
  </div>

  <% if campaign.new_record? && @customers.present? %>
    <div class="sect">
      <div class="sect__head"><div class="sect__title">Select customers (optional)</div></div>
      <div class="sect__body">
        <p class="muted rl-sm" style="margin-bottom:var(--space-3)">You can add customers now or after creating the campaign.</p>
        <%= render "campaigns/customer_picker", customers: @customers,
              checkbox_name: "campaign[customer_ids][]", checkbox_id_prefix: "campaign_customer_ids_" %>
      </div>
    </div>
  <% end %>

  <div class="sect" style="background:var(--color-warning-subtle);border-color:var(--color-warning-border)">
    <div class="sect__body row" style="gap:12px;align-items:flex-start">
      <span style="color:var(--color-warning-text);flex-shrink:0"><%= relay_icon("alert-triangle", size: 18) %></span>
      <div class="rl-sm" style="color:var(--color-warning-text)">
        <b>Important notice</b>
        <p style="margin-top:4px">Messages are sent with random delays (15–55 seconds) between customers to appear natural and avoid spamming. For example:</p>
        <ul style="margin:6px 0 0;padding-left:18px">
          <li>Customer 1: sent at the scheduled time</li>
          <li>Customer 2: sent at the scheduled time + ~25 seconds</li>
          <li>Customer 3: sent at the scheduled time + ~68 seconds</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", campaign.persisted? ? campaign_path(campaign) : campaigns_path,
          class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (campaign.new_record? ? "Create campaign" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
