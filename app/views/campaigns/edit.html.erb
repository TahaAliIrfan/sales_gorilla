<% content_for :title, "Edit campaign — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Edit campaign</div>
      <div class="pagehead__sub"><%= @campaign.name %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to campaign_path(@campaign), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to campaign
      <% end %>
    </div>
  </div>

  <%= render "form", campaign: @campaign %>
</div>
