<%# Campaign show — relay DS. Preserves every state-gated action POST
    (send_now / schedule / stop / restart), the add_customers flows (by group +
    individual via campaign_customer_selector), remove_customer DELETE, and the
    per-recipient execution status queue. %>
<% content_for :title, "#{@campaign.name} — #{current_organization&.name}" %>
<% meta = outreach_campaign_status_meta(@campaign.status) %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="row" style="gap:10px;align-items:center">
        <div class="pagehead__title"><%= @campaign.name %></div>
        <span class="rl-badge <%= meta[:badge] %>"><%= relay_icon(meta[:icon], size: 11) %><%= meta[:label] %></span>
      </div>
      <% if @campaign.scheduled? && @campaign.scheduled_at %>
        <div class="pagehead__sub">Scheduled for <%= @campaign.scheduled_at.in_time_zone("Islamabad").strftime("%b %-d, %Y at %-I:%M %p PKT") %></div>
      <% elsif @campaign.in_progress? %>
        <div class="pagehead__sub">Campaign in progress…</div>
      <% end %>
    </div>
    <div class="pagehead__actions">
      <% if @campaign.draft? %>
        <%= link_to edit_campaign_path(@campaign), class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("pencil", size: 15) %>Edit
        <% end %>
        <%= button_to send_now_campaign_path(@campaign), method: :post,
              form: { data: { turbo_confirm: "Send this campaign now? This will queue #{@campaign.total_recipients} message(s) with random intervals (15–55 seconds between each)." } },
              class: "rl-btn rl-btn--primary" do %>
          <%= relay_icon("send", size: 15) %>Send now
        <% end %>
      <% elsif @campaign.scheduled? %>
        <%= link_to edit_campaign_path(@campaign), class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("pencil", size: 15) %>Edit
        <% end %>
        <%= button_to send_now_campaign_path(@campaign), method: :post,
              form: { data: { turbo_confirm: "This will cancel the scheduled time and send immediately. Continue?" } },
              class: "rl-btn rl-btn--primary" do %>
          <%= relay_icon("send", size: 15) %>Send now instead
        <% end %>
        <%= button_to stop_campaign_path(@campaign), method: :post,
              form: { data: { turbo_confirm: "This will stop the campaign and cancel all pending messages. You can restart it later. Continue?" } },
              class: "rl-btn rl-btn--destructive-ghost" do %>
          <%= relay_icon("square", size: 15) %>Stop
        <% end %>
      <% elsif @campaign.in_progress? %>
        <%= button_to stop_campaign_path(@campaign), method: :post,
              form: { data: { turbo_confirm: "This will stop the campaign and cancel all pending messages. Already sent messages will not be affected. Continue?" } },
              class: "rl-btn rl-btn--destructive-ghost" do %>
          <%= relay_icon("square", size: 15) %>Stop
        <% end %>
      <% elsif @campaign.completed? || @campaign.failed? || @campaign.stopped? %>
        <%= link_to edit_campaign_path(@campaign), class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("pencil", size: 15) %>Edit
        <% end %>
        <%= button_to restart_campaign_path(@campaign), method: :post,
              form: { data: { turbo_confirm: "This will reset all failed messages to pending and change the campaign status to draft. You can then edit and re-send. Continue?" } },
              class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("play", size: 15) %>Restart
        <% end %>
      <% end %>
      <%= link_to campaigns_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
    </div>
  </div>

  <div class="grid grid-2" style="gap:var(--space-4);align-items:start">
    <div class="sect">
      <div class="sect__head"><div class="sect__title">Campaign details</div></div>
      <div class="sect__body col" style="gap:var(--space-4)">
        <div class="rl-field">
          <label class="rl-label">Message</label>
          <div style="padding:14px;background:var(--color-surface-2);border-radius:var(--radius-md);white-space:pre-wrap"><%= @campaign.message %></div>
        </div>
        <div class="grid grid-2">
          <div>
            <div class="micro" style="margin-bottom:4px">Scheduled time (PKT)</div>
            <div class="rl-sm"><%= @campaign.scheduled_at ? @campaign.scheduled_at.in_time_zone("Islamabad").strftime("%b %-d, %Y %-I:%M %p") : "Send immediately" %></div>
          </div>
          <div>
            <div class="micro" style="margin-bottom:4px">Created by</div>
            <div class="rl-sm"><%= @campaign.user.name %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title">Statistics</div></div>
      <div class="sect__body">
        <div class="grid grid-2" style="gap:var(--space-3)">
          <div><div class="micro">Total recipients</div><p class="mono" style="font-size:1.75rem;font-weight:600;margin-top:4px"><%= @executions.count %></p></div>
          <div><div class="micro">Completed</div><p class="mono" style="font-size:1.75rem;font-weight:600;margin-top:4px;color:var(--color-success)"><%= @executions.completed.count %></p></div>
          <div><div class="micro">Failed</div><p class="mono" style="font-size:1.75rem;font-weight:600;margin-top:4px;color:var(--color-danger)"><%= @executions.failed.count %></p></div>
          <div><div class="micro">Pending</div><p class="mono" style="font-size:1.75rem;font-weight:600;margin-top:4px;color:var(--color-warning-text)"><%= @executions.pending.count %></p></div>
        </div>
      </div>
    </div>
  </div>

  <% if @campaign.draft? || @campaign.scheduled? %>
    <div class="sect" style="margin-top:var(--space-4)">
      <div class="sect__head"><div class="sect__title">Add customers to campaign</div></div>
      <div class="sect__body col" style="gap:var(--space-5)">
        <% if @customer_groups.any? %>
          <div>
            <div class="micro" style="margin-bottom:8px">Add all customers from a group</div>
            <%= form_with url: add_customers_campaign_path(@campaign), method: :post, class: "row", html: { style: "gap:8px;align-items:flex-end" } do |f| %>
              <div class="rl-field" style="flex:1;margin:0">
                <%= f.select :group_id,
                      options_from_collection_for_select(@customer_groups, :id, ->(g) { "#{g.name} (#{g.customer_count} customers)" }),
                      { prompt: "Select a group" }, class: "rl-select" %>
              </div>
              <%= f.submit "Add group", class: "rl-btn rl-btn--secondary" %>
            <% end %>
          </div>
        <% end %>

        <% if @available_customers.any? %>
          <div>
            <div class="micro" style="margin-bottom:8px">Add individual customers</div>
            <%= form_with url: add_customers_campaign_path(@campaign), method: :post, class: "col", html: { style: "gap:var(--space-3)" } do |f| %>
              <%= render "campaigns/customer_picker", customers: @available_customers,
                    checkbox_name: "customer_ids[]", checkbox_id_prefix: "customer_" %>
              <div class="row" style="justify-content:flex-end">
                <%= f.submit "Add selected customers", class: "rl-btn rl-btn--primary" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="muted rl-sm">All customers have been added to this campaign.</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="sect" style="margin-top:var(--space-4)">
    <div class="sect__head"><div class="sect__title">Recipients (<%= @customers.count %>)</div></div>
    <div class="sect__body">
      <% if @customers.any? %>
        <div class="grid grid-3" style="gap:var(--space-3)">
          <% @customers.each do |customer| %>
            <div class="spread" style="padding:12px;background:var(--color-surface-2);border-radius:var(--radius-md)">
              <div style="min-width:0">
                <div class="rl-cell-strong" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= customer.name %></div>
                <div class="muted rl-sm" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= customer.email %></div>
              </div>
              <% if @campaign.draft? || @campaign.scheduled? %>
                <%= button_to remove_customer_campaign_path(@campaign, customer_id: customer.id), method: :delete,
                      form: { data: { turbo_confirm: "Remove this customer from the campaign?" } },
                      class: "rl-iconbtn rl-iconbtn--sm", title: "Remove" do %>
                  <%= relay_icon("x", size: 15) %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="muted rl-sm">No customers added yet. Add customers using the options above.</p>
      <% end %>
    </div>
  </div>

  <div class="sect" style="margin-top:var(--space-4)">
    <div class="sect__head"><div class="sect__title">Message queue</div></div>
    <div class="sect__body--flush">
      <% if @executions.any? %>
        <div class="rl-table-scroll">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Customer</th>
                <th>Scheduled (PKT)</th>
                <th>Status</th>
                <th>Executed at (PKT)</th>
                <th>Error</th>
              </tr>
            </thead>
            <tbody>
              <% exec_meta = {
                   "pending"    => { badge: "rl-badge--warning", label: "Pending" },
                   "processing" => { badge: "rl-badge--info",    label: "Processing" },
                   "completed"  => { badge: "rl-badge--success", label: "Completed" },
                   "failed"     => { badge: "rl-badge--danger",  label: "Failed" }
                 } %>
              <% @executions.each do |execution| %>
                <% em = exec_meta.fetch(execution.status, { badge: "rl-badge--neutral", label: execution.status.titleize }) %>
                <tr>
                  <td>
                    <div class="rl-cell-strong"><%= execution.customer.name %></div>
                    <div class="muted rl-sm"><%= execution.customer.email %></div>
                  </td>
                  <td class="rl-sm mono"><%= execution.scheduled_at.in_time_zone("Islamabad").strftime("%-I:%M:%S %p") %></td>
                  <td><span class="rl-badge <%= em[:badge] %>"><%= em[:label] %></span></td>
                  <td class="rl-sm mono"><%= execution.executed_at ? execution.executed_at.in_time_zone("Islamabad").strftime("%-I:%M:%S %p") : "—" %></td>
                  <td class="rl-sm" style="color:var(--color-danger)"><%= execution.error_message ? truncate(execution.error_message, length: 50) : "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="sect__body"><p class="muted rl-sm">No executions scheduled yet. Add customers and send the campaign to see the message queue.</p></div>
      <% end %>
    </div>
  </div>
</div>
