<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @campaign.name %></h1>
      <% status_colors = {
        'draft' => 'bg-gray-100 text-gray-800',
        'scheduled' => 'bg-yellow-100 text-yellow-800',
        'in_progress' => 'bg-blue-100 text-blue-800',
        'completed' => 'bg-green-100 text-green-800',
        'failed' => 'bg-red-100 text-red-800',
        'stopped' => 'bg-orange-100 text-orange-800'
      } %>
      <span class="mt-2 inline-flex px-2 text-xs leading-5 font-semibold rounded-full <%= status_colors[@campaign.status] %>">
        <%= @campaign.status.titleize %>
      </span>
    </div>
    <div class="flex gap-2">
      <% if @campaign.draft? %>
        <%= link_to "Edit", edit_campaign_path(@campaign),
            class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded" %>
        <%= button_to "Send Now", send_now_campaign_path(@campaign), method: :post,
            form: { data: { turbo_confirm: "Are you sure you want to send this campaign now? This will queue #{@campaign.total_recipients} message(s) with 30-second intervals." } },
            class: "bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded" %>
      <% elsif @campaign.scheduled? %>
        <div class="bg-yellow-100 border border-yellow-400 text-yellow-800 px-4 py-2 rounded font-semibold">
          Scheduled for <%= @campaign.scheduled_at.in_time_zone("Islamabad").strftime("%b %d, %Y at %I:%M %p PKT") %>
        </div>
        <%= link_to "Edit", edit_campaign_path(@campaign),
            class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded" %>
        <%= button_to "Send Now Instead", send_now_campaign_path(@campaign), method: :post,
            form: { data: { turbo_confirm: "This will cancel the scheduled time and send immediately. Continue?" } },
            class: "bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded" %>
        <%= button_to "Stop Campaign", stop_campaign_path(@campaign), method: :post,
            form: { data: { turbo_confirm: "This will stop the campaign and cancel all pending messages. You can restart it later. Continue?" } },
            class: "bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded" %>
      <% elsif @campaign.in_progress? %>
        <div class="bg-blue-100 border border-blue-400 text-blue-800 px-4 py-2 rounded font-semibold">
          Campaign in progress...
        </div>
        <%= button_to "Stop Campaign", stop_campaign_path(@campaign), method: :post,
            form: { data: { turbo_confirm: "This will stop the campaign and cancel all pending messages. Already sent messages will not be affected. Continue?" } },
            class: "bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded" %>
      <% elsif @campaign.completed? || @campaign.failed? || @campaign.stopped? %>
        <%= link_to "Edit", edit_campaign_path(@campaign),
            class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded" %>
        <%= button_to "Restart Campaign", restart_campaign_path(@campaign), method: :post,
            form: { data: { turbo_confirm: "This will reset all failed messages to pending and change the campaign status to draft. You can then edit and re-send. Continue?" } },
            class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded" %>
      <% end %>
      <%= link_to "Back", campaigns_path,
          class: "bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- Campaign Details -->
    <div class="lg:col-span-2 bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold mb-4">Campaign Details</h2>

      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">Message</label>
          <div class="mt-1 p-4 bg-gray-50 rounded border border-gray-200">
            <%= simple_format(@campaign.message) %>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Scheduled Time (PKT)</label>
            <p class="mt-1 text-sm text-gray-900">
              <%= @campaign.scheduled_at ? @campaign.scheduled_at.in_time_zone("Islamabad").strftime("%b %d, %Y %I:%M %p") : "Send immediately" %>
            </p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Created By</label>
            <p class="mt-1 text-sm text-gray-900"><%= @campaign.user.name %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Statistics -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold mb-4">Statistics</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">Total Recipients</label>
          <p class="mt-1 text-2xl font-bold text-gray-900"><%= @executions.count %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Completed</label>
          <p class="mt-1 text-2xl font-bold text-green-600"><%= @executions.completed.count %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Failed</label>
          <p class="mt-1 text-2xl font-bold text-red-600"><%= @executions.failed.count %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Pending</label>
          <p class="mt-1 text-2xl font-bold text-yellow-600"><%= @executions.pending.count %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Customers Section -->
  <% if @campaign.draft? || @campaign.scheduled? %>
    <div class="bg-white rounded-lg shadow-md p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">Add Customers to Campaign</h2>

      <!-- Add by Group -->
      <% if @customer_groups.any? %>
        <div class="mb-6">
          <h3 class="text-sm font-medium text-gray-700 mb-2">Add All Customers from a Group</h3>
          <%= form_with url: add_customers_campaign_path(@campaign), method: :post, class: "flex gap-2" do |f| %>
            <%= f.select :group_id, options_from_collection_for_select(@customer_groups, :id, ->(g) { "#{g.name} (#{g.customer_count} customers)" }),
                { prompt: "Select a group" },
                class: "flex-1 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <%= f.submit "Add Group", class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded cursor-pointer" %>
          <% end %>
        </div>
      <% end %>

      <!-- Add Individual Customers -->
      <% if @available_customers.any? %>
        <div data-controller="campaign-customer-selector">
          <h3 class="text-sm font-medium text-gray-700 mb-3">Add Individual Customers</h3>

          <%= form_with url: add_customers_campaign_path(@campaign), method: :post do |f| %>
            <!-- Search and Filter Bar -->
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Search Input -->
                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Search</label>
                  <input
                    type="text"
                    placeholder="Search by name, email, or phone..."
                    class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm"
                    data-campaign-customer-selector-target="searchInput"
                    data-action="input->campaign-customer-selector#filter">
                </div>

                <!-- Lead Source Filter -->
                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Lead Source</label>
                  <select
                    class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm"
                    data-campaign-customer-selector-target="leadSourceFilter"
                    data-action="change->campaign-customer-selector#filter">
                    <option value="">All Lead Sources</option>
                    <% Customer::LEAD_SOURCES.keys.each do |source| %>
                      <option value="<%= source %>"><%= source %></option>
                    <% end %>
                  </select>
                </div>
              </div>

              <!-- Selected Count and Select All -->
              <div class="flex justify-between items-center mt-4 pt-4 border-t border-gray-300">
                <div class="flex items-center">
                  <%= check_box_tag "select_all", "1", false,
                      class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded",
                      data: {
                        campaign_customer_selector_target: "selectAllCheckbox",
                        action: "change->campaign-customer-selector#toggleSelectAll"
                      } %>
                  <%= label_tag "select_all", "Select All Visible", class: "ml-2 text-sm font-medium text-gray-700" %>
                </div>
                <div class="text-sm text-gray-600">
                  Selected: <span class="font-semibold text-blue-600" data-campaign-customer-selector-target="selectedCount">0</span>
                </div>
              </div>
            </div>

            <!-- Customer List Table -->
            <div class="max-h-96 overflow-y-auto border border-gray-200 rounded-lg mb-4">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50 sticky top-0">
                  <tr>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase w-12"></th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Phone</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Lead Source</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  <% @available_customers.each do |customer| %>
                    <tr
                      class="hover:bg-gray-50"
                      data-campaign-customer-selector-target="customerItem"
                      data-customer-name="<%= customer.name || '' %>"
                      data-customer-email="<%= customer.email || '' %>"
                      data-customer-phone="<%= customer.phone || '' %>"
                      data-customer-lead-source="<%= customer.lead_source || '' %>">
                      <td class="px-3 py-3">
                        <%= check_box_tag "customer_ids[]", customer.id, false,
                            id: "customer_#{customer.id}",
                            class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded",
                            data: { action: "change->campaign-customer-selector#updateSelectedCount change->campaign-customer-selector#updateSelectAllState" } %>
                      </td>
                      <td class="px-3 py-3">
                        <div class="text-sm font-medium text-gray-900"><%= customer.name || 'N/A' %></div>
                      </td>
                      <td class="px-3 py-3">
                        <div class="text-sm text-gray-600"><%= customer.email || 'N/A' %></div>
                      </td>
                      <td class="px-3 py-3">
                        <div class="text-sm text-gray-600"><%= customer.phone || 'N/A' %></div>
                      </td>
                      <td class="px-3 py-3">
                        <% if customer.lead_source.present? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                            <%= customer.lead_source %>
                          </span>
                        <% else %>
                          <span class="text-sm text-gray-400">N/A</span>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <%= f.submit "Add Selected Customers", class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded cursor-pointer" %>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">All customers have been added to this campaign.</p>
      <% end %>
    </div>
  <% end %>

  <!-- Current Recipients -->
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Recipients (<%= @customers.count %>)</h2>

    <% if @customers.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @customers.each do |customer| %>
          <div class="flex justify-between items-center p-4 bg-gray-50 rounded">
            <div class="flex-1">
              <p class="font-medium text-gray-900"><%= customer.name %></p>
              <p class="text-sm text-gray-500"><%= customer.email %></p>
            </div>
            <% if @campaign.draft? || @campaign.scheduled? %>
              <%= link_to "Remove", remove_customer_campaign_path(@campaign, customer_id: customer.id),
                  method: :delete,
                  data: { confirm: "Remove this customer from the campaign?" },
                  class: "text-red-600 hover:text-red-800 text-sm ml-2" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-center py-4">No customers added yet. Add customers using the options above.</p>
    <% end %>
  </div>

  <!-- Execution Details -->
  <div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-xl font-semibold mb-4">Message Queue</h2>

    <% if @executions.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Scheduled Time (PKT)</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Executed At (PKT)</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Error</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @executions.each do |execution| %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= execution.customer.name %></div>
                  <div class="text-sm text-gray-500"><%= execution.customer.email %></div>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500">
                  <%= execution.scheduled_at.in_time_zone("Islamabad").strftime("%I:%M:%S %p") %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <% exec_status_colors = {
                    'pending' => 'bg-yellow-100 text-yellow-800',
                    'processing' => 'bg-blue-100 text-blue-800',
                    'completed' => 'bg-green-100 text-green-800',
                    'failed' => 'bg-red-100 text-red-800'
                  } %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= exec_status_colors[execution.status] %>">
                    <%= execution.status.titleize %>
                  </span>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500">
                  <%= execution.executed_at ? execution.executed_at.in_time_zone("Islamabad").strftime("%I:%M:%S %p") : "-" %>
                </td>
                <td class="px-4 py-3 text-sm text-red-600">
                  <%= execution.error_message ? truncate(execution.error_message, length: 50) : "-" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-gray-500 text-center py-4">
        No executions scheduled yet. Add groups and send the campaign to see the message queue.
      </p>
    <% end %>
  </div>
</div>
