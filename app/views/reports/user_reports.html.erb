<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">My Reports</h1>
      <p class="mt-2 text-sm text-gray-600">
        <%= @filter_range == 'today' ? "Today's" : @filter_range == 'yesterday' ? "Yesterday's" : @filter_range.titleize %>
        performance overview
        <span class="text-gray-400">&mdash; <%= @start_date.strftime('%b %d, %Y') %> to <%= @end_date.strftime('%b %d, %Y') %></span>
      </p>
    </div>

    <!-- ═══════════════════════════════════════ -->
    <!-- FILTER BAR                              -->
    <!-- ═══════════════════════════════════════ -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-5 mb-8">
      <%= form_tag my_reports_path, method: :get, class: "flex flex-wrap items-end gap-4", id: "report-filter-form" do %>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Time Period</label>
          <div class="flex rounded-lg border border-gray-300 overflow-hidden">
            <% [['Today', 'today'], ['Yesterday', 'yesterday'], ['Last Week', 'last_week'], ['This Month', 'month'], ['Custom', 'custom']].each do |label, value| %>
              <label class="relative cursor-pointer">
                <input type="radio" name="filter_range" value="<%= value %>"
                       class="sr-only peer"
                       <%= 'checked' if @filter_range == value %>
                       onchange="document.getElementById('custom-date-fields').style.display = this.value === 'custom' ? 'flex' : 'none'; if(this.value !== 'custom') this.form.submit();">
                <div class="px-4 py-2 text-sm font-medium border-r border-gray-300 last:border-r-0
                            peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-600
                            text-gray-700 hover:bg-gray-50 transition-colors">
                  <%= label %>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div id="custom-date-fields" class="<%= @filter_range == 'custom' ? 'flex' : 'hidden' %> items-end gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Start Date</label>
            <%= date_field_tag :start_date, @custom_start_date, class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-emerald-500 focus:border-emerald-500 text-sm" %>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">End Date</label>
            <%= date_field_tag :end_date, @custom_end_date, class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-emerald-500 focus:border-emerald-500 text-sm" %>
          </div>
          <%= submit_tag "Apply", class: "px-5 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors font-medium shadow-sm text-sm cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <!-- ═══════════════════════════════════════ -->
    <!-- 1) MY PERFORMANCE SUMMARY               -->
    <!-- ═══════════════════════════════════════ -->
    <% perf = @user_performance.first %>
    <% if perf %>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="text-sm font-medium text-gray-500 mb-1">Leads Assigned</div>
          <div class="text-3xl font-bold text-emerald-600"><%= perf[:leads_assigned] %></div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="text-sm font-medium text-gray-500 mb-1">Calls Attempted</div>
          <div class="text-3xl font-bold text-gray-900"><%= perf[:calls_attempted] %></div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="text-sm font-medium text-gray-500 mb-1">Connected Calls</div>
          <div class="text-3xl font-bold text-green-600"><%= perf[:connected_calls] %></div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="text-sm font-medium text-gray-500 mb-1">Emails Sent</div>
          <div class="text-3xl font-bold text-purple-600"><%= perf[:emails_sent] %></div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="text-sm font-medium text-gray-500 mb-1">WhatsApp Sent</div>
          <div class="text-3xl font-bold text-emerald-600"><%= perf[:whatsapp_sent] %></div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="text-sm font-medium text-gray-500 mb-1">WhatsApp Replies</div>
          <div class="text-3xl font-bold text-green-600"><%= perf[:whatsapp_replies] %></div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="text-sm font-medium text-gray-500 mb-1">Deals</div>
          <div class="text-3xl font-bold text-amber-600"><%= perf[:deals] %></div>
        </div>
      </div>
    <% end %>

    <!-- ═══════════════════════════════════════ -->
    <!-- 1b) MY KPI TRACKER                       -->
    <!-- ═══════════════════════════════════════ -->
    <% if @kpi_targets.present? && perf.present? %>
      <%
        calls_met = perf[:calls_attempted] >= @kpi_targets[:calls_attempted]
        connected_met = perf[:connected_calls] >= @kpi_targets[:connected_calls]
        whatsapp_met = perf[:whatsapp_sent] >= @kpi_targets[:whatsapp_messages_sent]
        emails_met = perf[:emails_sent] >= @kpi_targets[:emails_sent]
        all_met = calls_met && connected_met && whatsapp_met && emails_met
        met_count = [calls_met, connected_met, whatsapp_met, emails_met].count(true)
      %>
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 mb-8 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
          <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
            <svg class="h-5 w-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            KPI Tracker
          </h2>
          <% if all_met %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-bold bg-green-100 text-green-700">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              All KPIs Met
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-bold <%= met_count >= 2 ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
              <%= met_count %>/4 KPIs Met
            </span>
          <% end %>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-6">
          <div class="rounded-xl border-2 p-4 text-center <%= calls_met ? 'border-green-300 bg-green-50' : 'border-red-300 bg-red-50' %>">
            <div class="text-xs font-semibold uppercase tracking-wider mb-2 <%= calls_met ? 'text-green-600' : 'text-red-600' %>">Calls Attempted</div>
            <div class="text-3xl font-bold <%= calls_met ? 'text-green-700' : 'text-red-700' %>"><%= perf[:calls_attempted] %></div>
            <div class="mt-2 w-full bg-gray-200 rounded-full h-2">
              <div class="h-2 rounded-full transition-all <%= calls_met ? 'bg-green-500' : 'bg-red-400' %>" style="width: <%= [((perf[:calls_attempted].to_f / [@kpi_targets[:calls_attempted], 1].max) * 100), 100].min %>%"></div>
            </div>
            <div class="text-xs mt-1 text-gray-500">Target: <%= @kpi_targets[:calls_attempted] %></div>
          </div>
          <div class="rounded-xl border-2 p-4 text-center <%= connected_met ? 'border-green-300 bg-green-50' : 'border-red-300 bg-red-50' %>">
            <div class="text-xs font-semibold uppercase tracking-wider mb-2 <%= connected_met ? 'text-green-600' : 'text-red-600' %>">Connected Calls</div>
            <div class="text-3xl font-bold <%= connected_met ? 'text-green-700' : 'text-red-700' %>"><%= perf[:connected_calls] %></div>
            <div class="mt-2 w-full bg-gray-200 rounded-full h-2">
              <div class="h-2 rounded-full transition-all <%= connected_met ? 'bg-green-500' : 'bg-red-400' %>" style="width: <%= [((perf[:connected_calls].to_f / [@kpi_targets[:connected_calls], 1].max) * 100), 100].min %>%"></div>
            </div>
            <div class="text-xs mt-1 text-gray-500">Target: <%= @kpi_targets[:connected_calls] %></div>
          </div>
          <div class="rounded-xl border-2 p-4 text-center <%= whatsapp_met ? 'border-green-300 bg-green-50' : 'border-red-300 bg-red-50' %>">
            <div class="text-xs font-semibold uppercase tracking-wider mb-2 <%= whatsapp_met ? 'text-green-600' : 'text-red-600' %>">WhatsApp Sent</div>
            <div class="text-3xl font-bold <%= whatsapp_met ? 'text-green-700' : 'text-red-700' %>"><%= perf[:whatsapp_sent] %></div>
            <div class="mt-2 w-full bg-gray-200 rounded-full h-2">
              <div class="h-2 rounded-full transition-all <%= whatsapp_met ? 'bg-green-500' : 'bg-red-400' %>" style="width: <%= [((perf[:whatsapp_sent].to_f / [@kpi_targets[:whatsapp_messages_sent], 1].max) * 100), 100].min %>%"></div>
            </div>
            <div class="text-xs mt-1 text-gray-500">Target: <%= @kpi_targets[:whatsapp_messages_sent] %></div>
          </div>
          <div class="rounded-xl border-2 p-4 text-center <%= emails_met ? 'border-green-300 bg-green-50' : 'border-red-300 bg-red-50' %>">
            <div class="text-xs font-semibold uppercase tracking-wider mb-2 <%= emails_met ? 'text-green-600' : 'text-red-600' %>">Emails Sent</div>
            <div class="text-3xl font-bold <%= emails_met ? 'text-green-700' : 'text-red-700' %>"><%= perf[:emails_sent] %></div>
            <div class="mt-2 w-full bg-gray-200 rounded-full h-2">
              <div class="h-2 rounded-full transition-all <%= emails_met ? 'bg-green-500' : 'bg-red-400' %>" style="width: <%= [((perf[:emails_sent].to_f / [@kpi_targets[:emails_sent], 1].max) * 100), 100].min %>%"></div>
            </div>
            <div class="text-xs mt-1 text-gray-500">Target: <%= @kpi_targets[:emails_sent] %></div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- ═══════════════════════════════════════ -->
    <!-- 2) DAILY CUSTOMER ACTIVITY DETAIL       -->
    <!--    (only for Today / Yesterday)         -->
    <!-- ═══════════════════════════════════════ -->
    <% if @filter_range.in?(%w[today yesterday]) && @daily_customer_details.present? %>
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 mb-8 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
          <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
            <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Customer Activity Detail
            <span class="text-sm font-normal text-gray-500">&mdash; <%= @filter_range == 'today' ? 'Today' : 'Yesterday' %></span>
          </h2>
          <div class="flex items-center gap-4 text-xs">
            <span class="flex items-center gap-1.5">
              <span class="h-3 w-3 rounded-full bg-green-500 inline-block"></span> Successful response
            </span>
            <span class="flex items-center gap-1.5">
              <span class="h-3 w-3 rounded-full bg-red-500 inline-block"></span> No response yet
            </span>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr class="bg-gray-50">
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Signal</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Customer</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Calls Attempted</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Messages Sent</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Emails Sent</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100">
              <% @daily_customer_details.each do |detail| %>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="px-6 py-3">
                    <% if detail[:signal] == 'green' %>
                      <span class="relative flex h-4 w-4">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-4 w-4 bg-green-500 shadow-sm shadow-green-200"></span>
                      </span>
                    <% else %>
                      <span class="inline-flex rounded-full h-4 w-4 bg-red-500 shadow-sm shadow-red-200"></span>
                    <% end %>
                  </td>
                  <td class="px-6 py-3 whitespace-nowrap">
                    <a href="<%= customer_path(detail[:customer]) %>" class="text-sm font-medium text-gray-900 hover:text-emerald-600 transition-colors">
                      <%= detail[:customer].name %>
                    </a>
                    <% if detail[:customer].company.present? %>
                      <div class="text-xs text-gray-500"><%= detail[:customer].company %></div>
                    <% end %>
                  </td>
                  <td class="px-6 py-3 whitespace-nowrap">
                    <%
                      status_colors = {
                        'Pending' => 'bg-gray-100 text-gray-700',
                        'Contact Established' => 'bg-green-100 text-green-800',
                        'Contact Not Established' => 'bg-yellow-100 text-yellow-800',
                        'Unresponsive' => 'bg-yellow-100 text-yellow-800',
                        'Converted' => 'bg-emerald-100 text-emerald-800',
                        'Proposal Sent' => 'bg-purple-100 text-purple-800',
                        'Not Interested' => 'bg-red-100 text-red-800',
                        'Exhausted' => 'bg-red-100 text-red-700',
                        'Invalid' => 'bg-gray-200 text-gray-600',
                        'Retarget' => 'bg-orange-100 text-orange-800'
                      }
                    %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= status_colors[detail[:status]] || 'bg-gray-100 text-gray-700' %>">
                      <%= detail[:status] %>
                    </span>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <span class="text-sm font-semibold <%= detail[:calls_attempted] > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= detail[:calls_attempted] %></span>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <span class="text-sm font-semibold <%= detail[:messages_sent] > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= detail[:messages_sent] %></span>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <span class="text-sm font-semibold <%= detail[:emails_sent] > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= detail[:emails_sent] %></span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <!-- ═══════════════════════════════════════ -->
    <!-- 3) CUSTOMER STATUS OVERVIEW (BOTTOM)    -->
    <!-- ═══════════════════════════════════════ -->
    <% overview = @user_status_overview&.first %>
    <% if overview %>
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
          <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
            <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            My Customer Status Overview
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 p-6">
          <div class="bg-gray-50 rounded-lg p-4 text-center border border-gray-200">
            <div class="text-2xl font-bold text-gray-600"><%= overview[:pending] %></div>
            <div class="text-xs font-medium text-gray-500 mt-1">Pending</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center border border-green-200">
            <div class="text-2xl font-bold text-green-600"><%= overview[:contact_established] %></div>
            <div class="text-xs font-medium text-green-700 mt-1">Contact Est.</div>
          </div>
          <div class="bg-yellow-50 rounded-lg p-4 text-center border border-yellow-200">
            <div class="text-2xl font-bold text-yellow-600"><%= overview[:contact_not_established] %></div>
            <div class="text-xs font-medium text-yellow-700 mt-1">No Contact</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center border border-purple-200">
            <div class="text-2xl font-bold text-purple-600"><%= overview[:proposal_sent] %></div>
            <div class="text-xs font-medium text-purple-700 mt-1">Proposal Sent</div>
          </div>
          <div class="bg-emerald-50 rounded-lg p-4 text-center border border-emerald-200">
            <div class="text-2xl font-bold text-emerald-600"><%= overview[:converted] %></div>
            <div class="text-xs font-medium text-emerald-700 mt-1">Converted</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center border border-red-200">
            <div class="text-2xl font-bold text-red-600"><%= overview[:not_interested] %></div>
            <div class="text-xs font-medium text-red-700 mt-1">Not Interested</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center border border-red-300">
            <div class="text-2xl font-bold text-red-500"><%= overview[:exhausted] %></div>
            <div class="text-xs font-medium text-red-600 mt-1">Exhausted</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center border border-gray-300">
            <div class="text-2xl font-bold text-gray-500"><%= overview[:invalid] %></div>
            <div class="text-xs font-medium text-gray-500 mt-1">Invalid</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4 text-center border border-orange-200">
            <div class="text-2xl font-bold text-orange-600"><%= overview[:retarget] %></div>
            <div class="text-xs font-medium text-orange-700 mt-1">Retarget</div>
          </div>
          <div class="bg-emerald-50 rounded-lg p-4 text-center border border-emerald-200">
            <div class="text-2xl font-bold text-emerald-600"><%= overview[:deals_created] %></div>
            <div class="text-xs font-medium text-emerald-700 mt-1">Deals Created</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center border border-green-300">
            <div class="text-2xl font-bold text-green-700"><%= overview[:deals_won] %></div>
            <div class="text-xs font-medium text-green-800 mt-1">Deals Won</div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
