<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Reports & Analytics</h1>
      <p class="mt-2 text-sm text-gray-600">
        <%= @filter_range == 'today' ? "Today's" : @filter_range == 'yesterday' ? "Yesterday's" : @filter_range.titleize %>
        performance overview
        <span class="text-gray-400">&mdash; <%= @start_date.strftime('%b %d, %Y') %> to <%= @end_date.strftime('%b %d, %Y') %></span>
      </p>
    </div>

    <!-- ═══════════════════════════════════════ -->
    <!-- FILTER BAR                              -->
    <!-- ═══════════════════════════════════════ -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-5 mb-8">
      <%= form_tag reports_path, method: :get, class: "flex flex-wrap items-end gap-4", id: "report-filter-form" do %>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Time Period</label>
          <div class="flex rounded-lg border border-gray-300 overflow-hidden">
            <% [['Today', 'today'], ['Yesterday', 'yesterday'], ['Last Week', 'last_week'], ['This Month', 'month'], ['Custom', 'custom']].each do |label, value| %>
              <label class="relative cursor-pointer">
                <input type="radio" name="filter_range" value="<%= value %>"
                       class="sr-only peer"
                       <%= 'checked' if @filter_range == value %>
                       onchange="document.getElementById('custom-date-fields').style.display = this.value === 'custom' ? 'flex' : 'none'; if(this.value !== 'custom') this.form.submit();">
                <div class="px-4 py-2 text-sm font-medium border-r border-gray-300 last:border-r-0
                            peer-checked:bg-blue-600 peer-checked:text-white peer-checked:border-blue-600
                            text-gray-700 hover:bg-gray-50 transition-colors">
                  <%= label %>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div id="custom-date-fields" class="<%= @filter_range == 'custom' ? 'flex' : 'hidden' %> items-end gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Start Date</label>
            <%= date_field_tag :start_date, @custom_start_date, class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm" %>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">End Date</label>
            <%= date_field_tag :end_date, @custom_end_date, class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm" %>
          </div>
          <%= submit_tag "Apply", class: "px-5 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-sm text-sm cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <!-- ═══════════════════════════════════════ -->
    <!-- 1) USER PERFORMANCE TABLE               -->
    <!-- ═══════════════════════════════════════ -->
    <div class="bg-white shadow-sm rounded-xl border border-gray-200 mb-8 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
          <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          User Performance
        </h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr class="bg-gray-50">
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
              <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Leads Assigned</th>
              <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Calls Attempted</th>
              <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Connected Calls</th>
              <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Emails Sent</th>
              <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">WhatsApp Sent</th>
              <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Deals</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-100">
            <% @user_performance.each do |perf| %>
              <tr class="hover:bg-blue-50/30 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-3">
                    <div class="h-9 w-9 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-sm font-bold shadow-sm">
                      <%= perf[:user].name&.first&.upcase || '?' %>
                    </div>
                    <div class="text-sm font-semibold text-gray-900"><%= perf[:user].name || 'Unknown' %></div>
                  </div>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-bold bg-blue-50 text-blue-700">
                    <%= perf[:leads_assigned] %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-bold bg-gray-100 text-gray-700">
                    <%= perf[:calls_attempted] %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-bold <%= perf[:connected_calls] > 0 ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-400' %>">
                    <%= perf[:connected_calls] %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-bold <%= perf[:emails_sent] > 0 ? 'bg-purple-50 text-purple-700' : 'bg-gray-100 text-gray-400' %>">
                    <%= perf[:emails_sent] %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-bold <%= perf[:whatsapp_sent] > 0 ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-400' %>">
                    <%= perf[:whatsapp_sent] %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-bold <%= perf[:deals] > 0 ? 'bg-amber-50 text-amber-700' : 'bg-gray-100 text-gray-400' %>">
                    <%= perf[:deals] %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
          <!-- Totals row -->
          <tfoot>
            <tr class="bg-gray-50 font-bold border-t-2 border-gray-200">
              <td class="px-6 py-3 text-sm text-gray-900">Total</td>
              <td class="px-6 py-3 text-center text-sm text-gray-900"><%= @user_performance.sum { |p| p[:leads_assigned] } %></td>
              <td class="px-6 py-3 text-center text-sm text-gray-900"><%= @user_performance.sum { |p| p[:calls_attempted] } %></td>
              <td class="px-6 py-3 text-center text-sm text-gray-900"><%= @user_performance.sum { |p| p[:connected_calls] } %></td>
              <td class="px-6 py-3 text-center text-sm text-gray-900"><%= @user_performance.sum { |p| p[:emails_sent] } %></td>
              <td class="px-6 py-3 text-center text-sm text-gray-900"><%= @user_performance.sum { |p| p[:whatsapp_sent] } %></td>
              <td class="px-6 py-3 text-center text-sm text-gray-900"><%= @user_performance.sum { |p| p[:deals] } %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- ═══════════════════════════════════════ -->
    <!-- 2) DAILY CUSTOMER ACTIVITY DETAIL       -->
    <!--    (only for Today / Yesterday)         -->
    <!-- ═══════════════════════════════════════ -->
    <% if @filter_range.in?(%w[today yesterday]) && @daily_customer_details.present? %>
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 mb-8 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
          <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
            <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Customer Activity Detail
            <span class="text-sm font-normal text-gray-500">&mdash; <%= @filter_range == 'today' ? 'Today' : 'Yesterday' %></span>
          </h2>
          <div class="flex items-center gap-4 text-xs">
            <span class="flex items-center gap-1.5">
              <span class="h-3 w-3 rounded-full bg-green-500 inline-block"></span> Successful response
            </span>
            <span class="flex items-center gap-1.5">
              <span class="h-3 w-3 rounded-full bg-red-500 inline-block"></span> No response yet
            </span>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr class="bg-gray-50">
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Signal</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Customer</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Assigned To</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Calls Attempted</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Messages Sent</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Emails Sent</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100">
              <% current_user_name = nil %>
              <% @daily_customer_details.each do |detail| %>
                <% if detail[:user_name] != current_user_name %>
                  <% current_user_name = detail[:user_name] %>
                  <tr class="bg-blue-50/50">
                    <td colspan="7" class="px-6 py-2">
                      <span class="text-xs font-bold text-blue-700 uppercase tracking-wider"><%= current_user_name %></span>
                    </td>
                  </tr>
                <% end %>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="px-6 py-3">
                    <% if detail[:signal] == 'green' %>
                      <span class="relative flex h-4 w-4">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-4 w-4 bg-green-500 shadow-sm shadow-green-200"></span>
                      </span>
                    <% else %>
                      <span class="inline-flex rounded-full h-4 w-4 bg-red-500 shadow-sm shadow-red-200"></span>
                    <% end %>
                  </td>
                  <td class="px-6 py-3 whitespace-nowrap">
                    <a href="<%= customer_path(detail[:customer]) %>" class="text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors">
                      <%= detail[:customer].name %>
                    </a>
                    <% if detail[:customer].company.present? %>
                      <div class="text-xs text-gray-500"><%= detail[:customer].company %></div>
                    <% end %>
                  </td>
                  <td class="px-6 py-3 whitespace-nowrap">
                    <%
                      status_colors = {
                        'Pending' => 'bg-gray-100 text-gray-700',
                        'Contact Established' => 'bg-green-100 text-green-800',
                        'Contact Not Established' => 'bg-yellow-100 text-yellow-800',
                        'Unresponsive' => 'bg-yellow-100 text-yellow-800',
                        'Converted' => 'bg-blue-100 text-blue-800',
                        'Proposal Sent' => 'bg-purple-100 text-purple-800',
                        'Not Interested' => 'bg-red-100 text-red-800',
                        'Exhausted' => 'bg-red-100 text-red-700',
                        'Invalid' => 'bg-gray-200 text-gray-600',
                        'Retarget' => 'bg-orange-100 text-orange-800'
                      }
                    %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= status_colors[detail[:status]] || 'bg-gray-100 text-gray-700' %>">
                      <%= detail[:status] %>
                    </span>
                  </td>
                  <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-600"><%= detail[:user_name] %></td>
                  <td class="px-6 py-3 text-center">
                    <span class="text-sm font-semibold <%= detail[:calls_attempted] > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= detail[:calls_attempted] %></span>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <span class="text-sm font-semibold <%= detail[:messages_sent] > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= detail[:messages_sent] %></span>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <span class="text-sm font-semibold <%= detail[:emails_sent] > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= detail[:emails_sent] %></span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <% if @daily_customer_details.empty? %>
          <div class="p-12 text-center text-gray-400">
            <svg class="mx-auto h-12 w-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            <p class="text-sm">No customer activity recorded for <%= @filter_range == 'today' ? 'today' : 'yesterday' %>.</p>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- ═══════════════════════════════════════ -->
    <!-- 3) CUSTOMER STATUS OVERVIEW (BOTTOM)    -->
    <!-- ═══════════════════════════════════════ -->
    <div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
          <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          Customer Status Overview
        </h2>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr class="bg-gray-50">
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Pending</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-green-600 uppercase tracking-wider">Contact Est.</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-yellow-600 uppercase tracking-wider">No Contact</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-purple-600 uppercase tracking-wider">Proposal Sent</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-blue-600 uppercase tracking-wider">Converted</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-red-600 uppercase tracking-wider">Not Interested</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-red-500 uppercase tracking-wider">Exhausted</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-400 uppercase tracking-wider">Invalid</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-orange-600 uppercase tracking-wider">Retarget</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-indigo-600 uppercase tracking-wider">Deals</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-green-700 uppercase tracking-wider">Won</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-100">
            <% @user_status_overview.each do |overview| %>
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="px-6 py-3 whitespace-nowrap">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white text-xs font-bold">
                      <%= overview[:user].name&.first&.upcase || '?' %>
                    </div>
                    <span class="text-sm font-medium text-gray-900"><%= overview[:user].name || 'Unknown' %></span>
                  </div>
                </td>
                <td class="px-4 py-3 text-center text-sm font-medium text-gray-600"><%= overview[:pending] %></td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:contact_established] > 0 ? 'text-green-600' : 'text-gray-300' %>"><%= overview[:contact_established] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:contact_not_established] > 0 ? 'text-yellow-600' : 'text-gray-300' %>"><%= overview[:contact_not_established] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:proposal_sent] > 0 ? 'text-purple-600' : 'text-gray-300' %>"><%= overview[:proposal_sent] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:converted] > 0 ? 'text-blue-600' : 'text-gray-300' %>"><%= overview[:converted] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:not_interested] > 0 ? 'text-red-600' : 'text-gray-300' %>"><%= overview[:not_interested] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:exhausted] > 0 ? 'text-red-500' : 'text-gray-300' %>"><%= overview[:exhausted] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:invalid] > 0 ? 'text-gray-500' : 'text-gray-300' %>"><%= overview[:invalid] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:retarget] > 0 ? 'text-orange-600' : 'text-gray-300' %>"><%= overview[:retarget] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:deals_created] > 0 ? 'text-indigo-600' : 'text-gray-300' %>"><%= overview[:deals_created] %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="text-sm font-bold <%= overview[:deals_won] > 0 ? 'text-green-700' : 'text-gray-300' %>"><%= overview[:deals_won] %></span>
                </td>
              </tr>
            <% end %>
          </tbody>
          <!-- Totals -->
          <tfoot>
            <tr class="bg-gray-50 font-bold border-t-2 border-gray-200">
              <td class="px-6 py-3 text-sm text-gray-900">Total</td>
              <td class="px-4 py-3 text-center text-sm text-gray-900"><%= @user_status_overview.sum { |o| o[:pending] } %></td>
              <td class="px-4 py-3 text-center text-sm text-green-700"><%= @user_status_overview.sum { |o| o[:contact_established] } %></td>
              <td class="px-4 py-3 text-center text-sm text-yellow-700"><%= @user_status_overview.sum { |o| o[:contact_not_established] } %></td>
              <td class="px-4 py-3 text-center text-sm text-purple-700"><%= @user_status_overview.sum { |o| o[:proposal_sent] } %></td>
              <td class="px-4 py-3 text-center text-sm text-blue-700"><%= @user_status_overview.sum { |o| o[:converted] } %></td>
              <td class="px-4 py-3 text-center text-sm text-red-700"><%= @user_status_overview.sum { |o| o[:not_interested] } %></td>
              <td class="px-4 py-3 text-center text-sm text-red-600"><%= @user_status_overview.sum { |o| o[:exhausted] } %></td>
              <td class="px-4 py-3 text-center text-sm text-gray-600"><%= @user_status_overview.sum { |o| o[:invalid] } %></td>
              <td class="px-4 py-3 text-center text-sm text-orange-700"><%= @user_status_overview.sum { |o| o[:retarget] } %></td>
              <td class="px-4 py-3 text-center text-sm text-indigo-700"><%= @user_status_overview.sum { |o| o[:deals_created] } %></td>
              <td class="px-4 py-3 text-center text-sm text-green-800"><%= @user_status_overview.sum { |o| o[:deals_won] } %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

  </div>
</div>
