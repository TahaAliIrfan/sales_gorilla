<%# Relay Insights (Phase 8) — KPI dashboard, trend, funnel, per-rep, sources.
    Mirrors docs/design/relay-app/project/app/view-insights.jsx. Shared by
    #index (admins/managers, with per-rep table) and #my_reports (self, no
    per-rep table) via @show_per_rep. %>
<% content_for :title, "Insights — #{current_organization&.name}" %>
<%
  cur  = @kpis[:current]
  prev = @kpis[:previous]
  range_labels = { "7d" => "7 days", "30d" => "30 days", "90d" => "90 days" }
  range_caption = range_labels[@filter_range] || "#{@start_date.strftime('%b %-d')}–#{@end_date.strftime('%b %-d')}"
%>

<div class="page page--wide">
  <%# === Header + range filter === %>
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Insights</div>
      <div class="pagehead__sub"><%= @scope_label %> · <%= range_caption %></div>
    </div>
    <div class="pagehead__actions">
      <div class="rl-segmented">
        <% { "7d" => "7 days", "30d" => "30 days", "90d" => "90 days" }.each do |value, label| %>
          <%= link_to label, (@show_per_rep ? reports_path(filter_range: value) : my_reports_path(filter_range: value)),
                class: ("is-active" if @filter_range == value) %>
        <% end %>
      </div>
    </div>
  </div>

  <%# === KPI row (current window + real delta vs previous equal window) === %>
  <div class="grid grid-4" style="margin-bottom:var(--space-6)">
    <%= render "reports/kpi", label: "Calls", value: number_with_delimiter(cur[:calls]),
          icon: "phone", delta: relay_pct_delta(cur[:calls], prev[:calls]), delta_suffix: "%" %>
    <%= render "reports/kpi", label: "Leads worked", value: number_with_delimiter(cur[:leads_worked]),
          icon: "users", delta: relay_pct_delta(cur[:leads_worked], prev[:leads_worked]), delta_suffix: "%" %>
    <%= render "reports/kpi", label: "Won value", value: relay_money_compact(cur[:won_value]),
          icon: "trophy", delta: relay_pct_delta(cur[:won_value], prev[:won_value]), delta_suffix: "%" %>
    <%= render "reports/kpi", label: "Conversion", value: "#{cur[:conversion]}%",
          icon: "target", delta: relay_point_delta(cur[:conversion], prev[:conversion]), delta_suffix: "pt" %>
  </div>

  <%# === Trend + funnel === %>
  <div class="grid" style="grid-template-columns:1.4fr 1fr;margin-bottom:var(--space-6);align-items:start">
    <div class="sect">
      <div class="sect__head">
        <div class="sect__title"><%= relay_icon("bar-chart-3", size: 19) %>Calls over time</div>
        <span class="muted rl-sm"><%= @show_per_rep ? "Team" : "You" %> · <%= number_with_delimiter(@trend_total) %> total</span>
      </div>
      <div class="sect__body">
        <% if @trend_total.zero? %>
          <div style="padding:24px 8px;text-align:center" class="muted rl-sm">No calls logged in this range.</div>
        <% else %>
          <%= render "reports/bars", labels: @trend_labels, values: @trend_values,
                height: 180, label_every: (@trend_labels.size > 16 ? (@trend_labels.size / 8.0).ceil : 1) %>
        <% end %>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head">
        <div class="sect__title"><%= relay_icon("filter", size: 19) %>Conversion funnel</div>
        <span class="muted rl-sm">leads created in range</span>
      </div>
      <div class="sect__body">
        <% if @funnel.first[:value].zero? %>
          <div style="padding:24px 8px;text-align:center" class="muted rl-sm">No leads created in this range.</div>
        <% else %>
          <div class="col" style="gap:10px">
            <% @funnel.each_with_index do |f, i| %>
              <div>
                <div class="spread" style="margin-bottom:4px">
                  <span class="rl-sm" style="font-weight:600"><%= f[:stage] %></span>
                  <span class="row" style="gap:8px">
                    <b class="tnum mono"><%= number_with_delimiter(f[:value]) %></b>
                    <span class="muted tnum mono" style="font-size:12px;width:38px;text-align:right"><%= f[:pct] %>%</span>
                  </span>
                </div>
                <div style="height:26px;border-radius:6px;background:var(--color-surface-3);overflow:hidden">
                  <div style="width:<%= f[:pct] %>%;height:100%;border-radius:6px;background:color-mix(in oklch, var(--color-primary) <%= 100 - i * 14 %>%, var(--color-surface-3))"></div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# === Per-rep performance (admins/managers only) === %>
  <% if @show_per_rep %>
    <div class="sect" style="margin-bottom:var(--space-6)">
      <div class="sect__head">
        <div class="sect__title"><%= relay_icon("users-2", size: 19) %>Per-rep performance</div>
        <span class="muted rl-sm">vs derived monthly target</span>
      </div>
      <div class="sect__body--flush">
        <% if @per_rep.empty? %>
          <div style="padding:24px 16px;text-align:center" class="muted rl-sm">No reps in scope yet.</div>
        <% else %>
          <div class="rl-table-scroll">
            <table class="rl-table">
              <thead>
                <tr>
                  <th>Rep</th>
                  <th style="text-align:right">Calls</th>
                  <th style="text-align:right">Leads</th>
                  <th style="text-align:right">Won</th>
                  <th style="text-align:right">Won value</th>
                  <th style="text-align:right">Conv.</th>
                  <th style="width:200px">Target attainment</th>
                </tr>
              </thead>
              <tbody>
                <% @per_rep.each do |r| %>
                  <% rep = r[:user]; rep_name = rep.name.presence || rep.email %>
                  <tr>
                    <td>
                      <div class="row" style="gap:10px">
                        <span class="rl-avatar rl-avatar--sm <%= relay_avatar_class(rep_name) %>"><%= relay_initials(rep_name) %></span>
                        <span class="rl-cell-strong"><%= rep_name %></span>
                      </div>
                    </td>
                    <td class="rl-cell-num"><%= number_with_delimiter(r[:calls]) %></td>
                    <td class="rl-cell-num"><%= number_with_delimiter(r[:leads]) %></td>
                    <td class="rl-cell-num"><%= r[:won_count] %></td>
                    <td class="rl-cell-num"><%= relay_money_compact(r[:won_value]) %></td>
                    <td class="rl-cell-num"><%= r[:conversion] %>%</td>
                    <td>
                      <div class="row" style="gap:10px">
                        <div class="targetbar" style="flex:1">
                          <i style="width:<%= r[:attainment] %>%;background:<%= relay_attainment_color(r[:attainment]) %>"></i>
                        </div>
                        <b class="tnum mono" style="font-size:13px;width:38px;text-align:right;color:<%= relay_attainment_text_color(r[:attainment]) %>"><%= r[:attainment] %>%</b>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# === Lead source performance (real attribution, won deals) === %>
  <div class="sect">
    <div class="sect__head">
      <div class="sect__title"><%= relay_icon("git-fork", size: 19) %>Lead source performance</div>
      <span class="muted rl-sm">won deals by attribution</span>
    </div>
    <div class="sect__body">
      <% if @lead_sources.empty? %>
        <div style="padding:24px 8px;text-align:center" class="muted rl-sm">No won deals with attribution in this range.</div>
      <% else %>
        <div class="grid grid-4">
          <% @lead_sources.each_with_index do |s, i| %>
            <div>
              <div class="row" style="gap:6px;margin-bottom:6px">
                <i style="width:9px;height:9px;border-radius:2px;background:color-mix(in oklch, var(--color-primary) <%= 100 - i * 16 %>%, var(--color-surface-3))"></i>
                <span class="rl-sm" style="font-weight:600"><%= s[:source] %></span>
              </div>
              <div class="mono" style="font-family:var(--font-display);font-weight:800;font-size:24px"><%= s[:pct] %>%</div>
              <div class="muted" style="font-size:12px"><%= s[:won_count] %> won · <%= relay_money_compact(s[:won_value]) %></div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
