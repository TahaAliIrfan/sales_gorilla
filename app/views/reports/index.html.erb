<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Reports & Analytics</h1>
      <p class="mt-2 text-sm text-gray-600">Comprehensive performance metrics and insights</p>
    </div>

    <!-- Filter Section -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-6 mb-6">
      <%= form_tag reports_path, method: :get, class: "flex flex-wrap items-end gap-4" do %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Time Period</label>
          <%= select_tag :filter_range, 
              options_for_select([['Last 30 Days', '30'], ['Last 90 Days', '90'], ['Custom Range', 'custom']], @filter_range), 
              class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500",
              onchange: "this.form.submit()" %>
        </div>
        
        <% if @filter_range == 'custom' %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
            <%= date_field_tag :start_date, @custom_start_date, class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">End Date</label>
            <%= date_field_tag :end_date, @custom_end_date, class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        <% end %>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">User Filter</label>
          <%= select_tag :user_id,
              options_for_select([['All Users', '']] + @users.map { |u| [u.name, u.id] }, @selected_user_id),
              class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
        </div>
        
        <%= submit_tag "Apply Filters", class: "px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-sm" %>
      <% end %>
    </div>

    <% if @selected_user %>
      <div class="bg-blue-50 border border-blue-200 rounded-lg px-6 py-4 mb-6">
        <p class="text-blue-900 font-medium">
          📊 Showing reports for: <span class="font-bold"><%= @selected_user.name %></span>
        </p>
      </div>
    <% end %>

    <!-- Customer Status Overview - PROMINENT SECTION -->
    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-lg border border-blue-200 p-6 mb-6">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
        <svg class="h-5 w-5 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Customer Status Overview
      </h2>
      
      <% if @selected_user %>
        <% metrics = @user_progression_metrics[@selected_user.id] || {} %>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
          <div class="bg-white rounded-lg p-5 shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <div class="text-3xl font-bold text-gray-600"><%= metrics['Pending'] || 0 %></div>
              <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="text-sm font-medium text-gray-600">Pending</div>
            <div class="text-xs text-gray-500 mt-1">Awaiting action</div>
          </div>
          
          <div class="bg-white rounded-lg p-5 shadow-sm border border-green-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <div class="text-3xl font-bold text-green-600"><%= metrics['Contact Established'] || 0 %></div>
              <svg class="h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="text-sm font-medium text-green-700">Contact Established</div>
            <div class="text-xs text-green-600 mt-1">Active communication</div>
          </div>
          
          <div class="bg-white rounded-lg p-5 shadow-sm border border-yellow-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <div class="text-3xl font-bold text-yellow-600"><%= metrics['Contact Not Established / Unresponsive'] || 0 %></div>
              <svg class="h-8 w-8 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <div class="text-sm font-medium text-yellow-700">No Contact</div>
            <div class="text-xs text-yellow-600 mt-1">Need follow-up</div>
          </div>
          
          <div class="bg-white rounded-lg p-5 shadow-sm border border-red-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <div class="text-3xl font-bold text-red-600"><%= metrics['Exhausted'] || 0 %></div>
              <svg class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
            <div class="text-sm font-medium text-red-700">Exhausted</div>
            <div class="text-xs text-red-600 mt-1">Max attempts reached</div>
          </div>
          
          <div class="bg-white rounded-lg p-5 shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <div class="text-3xl font-bold text-gray-600"><%= metrics['Invalid'] || 0 %></div>
              <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
            </div>
            <div class="text-sm font-medium text-gray-600">Invalid</div>
            <div class="text-xs text-gray-500 mt-1">Bad data/number</div>
          </div>
          
          <div class="bg-white rounded-lg p-5 shadow-sm border border-blue-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <div class="text-3xl font-bold text-blue-600"><%= metrics['Deals Created'] || 0 %></div>
              <svg class="h-8 w-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
            </div>
            <div class="text-sm font-medium text-blue-700">Deals Created</div>
            <div class="text-xs text-blue-600 mt-1">Pipeline entries</div>
          </div>
          
          <div class="bg-white rounded-lg p-5 shadow-sm border border-green-300 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <div class="text-3xl font-bold text-green-600"><%= metrics['Deals Won'] || 0 %></div>
              <svg class="h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="text-sm font-medium text-green-700">Deals Won</div>
            <div class="text-xs text-green-600 mt-1 font-medium">Closed! 🎉</div>
          </div>
        </div>
      <% else %>
        <!-- Team Overview -->
        <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider sticky left-0 bg-gray-50">Team Member</th>
                  <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Pending</th>
                  <th class="px-6 py-3 text-center text-xs font-semibold text-green-700 uppercase tracking-wider">Contact Est.</th>
                  <th class="px-6 py-3 text-center text-xs font-semibold text-yellow-700 uppercase tracking-wider">No Contact</th>
                  <th class="px-6 py-3 text-center text-xs font-semibold text-red-700 uppercase tracking-wider">Exhausted</th>
                  <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Invalid</th>
                  <th class="px-6 py-3 text-center text-xs font-semibold text-blue-700 uppercase tracking-wider">Deals Created</th>
                  <th class="px-6 py-3 text-center text-xs font-semibold text-green-700 uppercase tracking-wider">Deals Won</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @users.each do |user| %>
                  <% metrics = @user_progression_metrics[user.id] || {} %>
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 sticky left-0 bg-white">
                      <%= user.name %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-600 font-semibold"><%= metrics['Pending'] || 0 %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-green-600 font-semibold"><%= metrics['Contact Established'] || 0 %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-yellow-600 font-semibold"><%= metrics['Contact Not Established / Unresponsive'] || 0 %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-red-600 font-semibold"><%= metrics['Exhausted'] || 0 %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-600 font-semibold"><%= metrics['Invalid'] || 0 %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-blue-600 font-semibold"><%= metrics['Deals Created'] || 0 %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-green-600 font-bold text-lg"><%= metrics['Deals Won'] || 0 %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Key Performance Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total Leads</p>
            <p class="text-3xl font-bold text-gray-900 mt-2"><%= @total_assigned_leads %></p>
            <p class="text-xs text-gray-500 mt-1">Assigned in period</p>
          </div>
          <div class="bg-blue-100 rounded-full p-3">
            <svg class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total Deals</p>
            <p class="text-3xl font-bold text-gray-900 mt-2"><%= @total_deals %></p>
            <p class="text-xs text-gray-500 mt-1">In pipeline</p>
          </div>
          <div class="bg-purple-100 rounded-full p-3">
            <svg class="h-8 w-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-green-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Deals Won</p>
            <p class="text-3xl font-bold text-green-600 mt-2"><%= @total_won_deals %></p>
            <p class="text-xs text-green-600 mt-1 font-medium">$<%= number_with_delimiter(@total_won_deal_value.to_i) %> value</p>
          </div>
          <div class="bg-green-100 rounded-full p-3">
            <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-blue-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total Revenue</p>
            <p class="text-3xl font-bold text-blue-600 mt-2">$<%= number_with_delimiter(@total_deal_value.to_i) %></p>
            <p class="text-xs text-gray-500 mt-1">Pipeline value</p>
          </div>
          <div class="bg-blue-100 rounded-full p-3">
            <svg class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Communication Metrics -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
        <svg class="h-6 w-6 mr-3 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Communication Metrics
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
        <div class="text-center p-4 bg-gray-50 rounded-lg">
          <p class="text-3xl font-bold text-gray-900"><%= @total_system_calls %></p>
          <p class="text-sm text-gray-600 mt-1">Total Calls</p>
        </div>
        <div class="text-center p-4 bg-green-50 rounded-lg">
          <p class="text-3xl font-bold text-green-600"><%= @successful_calls_count %></p>
          <p class="text-sm text-gray-600 mt-1">Connected (120s+)</p>
        </div>
        <div class="text-center p-4 bg-yellow-50 rounded-lg">
          <p class="text-3xl font-bold text-yellow-600"><%= @attempted_calls_count %></p>
          <p class="text-sm text-gray-600 mt-1">Attempted (40-120s)</p>
        </div>
        <div class="text-center p-4 bg-red-50 rounded-lg">
          <p class="text-3xl font-bold text-red-600"><%= @failed_calls_count %></p>
          <p class="text-sm text-gray-600 mt-1">Failed (<40s)</p>
        </div>
        <div class="text-center p-4 bg-blue-50 rounded-lg">
          <p class="text-3xl font-bold text-blue-600"><%= @successful_calls_percentage %>%</p>
          <p class="text-sm text-gray-600 mt-1">Success Rate</p>
        </div>
      </div>
    </div>

    <!-- Conversion Metrics -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <h3 class="text-xl font-bold text-gray-900 mb-6">Conversion Funnel</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="text-center p-4 border-2 border-blue-200 rounded-lg bg-blue-50">
          <p class="text-3xl font-bold text-blue-600"><%= @connection_established_percentage %>%</p>
          <p class="text-sm text-gray-700 mt-1 font-medium">Contact Established</p>
        </div>
        <div class="text-center p-4 border-2 border-yellow-200 rounded-lg bg-yellow-50">
          <p class="text-3xl font-bold text-yellow-600"><%= @unresponsive_percentage %>%</p>
          <p class="text-sm text-gray-700 mt-1 font-medium">Unresponsive</p>
        </div>
        <div class="text-center p-4 border-2 border-red-200 rounded-lg bg-red-50">
          <p class="text-3xl font-bold text-red-600"><%= @not_interested_percentage %>%</p>
          <p class="text-sm text-gray-700 mt-1 font-medium">Not Interested</p>
        </div>
        <div class="text-center p-4 border-2 border-purple-200 rounded-lg bg-purple-50">
          <p class="text-3xl font-bold text-purple-600"><%= @discovery_call_booked_percentage %>%</p>
          <p class="text-sm text-gray-700 mt-1 font-medium">Proposal Sent</p>
        </div>
        <div class="text-center p-4 border-2 border-green-200 rounded-lg bg-green-50">
          <p class="text-3xl font-bold text-green-600"><%= @conversion_percentage %>%</p>
          <p class="text-sm text-gray-700 mt-1 font-medium">Converted (<%= @conversion_count %>)</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <!-- Deal Stage Distribution -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Deal Stage Distribution</h3>
        <div class="space-y-3">
          <% @deal_stage_distribution.each do |stage_name, count| %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-gray-700"><%= stage_name %></span>
                <span class="text-sm font-bold text-gray-900"><%= count %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2.5">
                <div class="bg-blue-600 h-2.5 rounded-full transition-all" style="width: <%= @total_deals > 0 ? (count.to_f / @total_deals * 100).round : 0 %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Lead Source Distribution -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Lead Source Distribution</h3>
        <div class="space-y-3">
          <% @lead_source_distribution.each do |source, count| %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-gray-700"><%= source %></span>
                <span class="text-sm font-bold text-gray-900"><%= count %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2.5">
                <div class="bg-green-600 h-2.5 rounded-full transition-all" style="width: <%= @total_assigned_leads > 0 ? (count.to_f / @total_assigned_leads * 100).round : 0 %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% unless @selected_user %>
      <!-- Team Call Performance -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-xl font-bold text-gray-900 mb-6">Team Call Performance</h3>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Team Member</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Last Day Calls</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-green-700 uppercase tracking-wider">Day Success</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-red-700 uppercase tracking-wider">Day Failed</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Month Calls</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-green-700 uppercase tracking-wider">Month Success</th>
                <th class="px-6 py-3 text-center text-xs font-semibold text-red-700 uppercase tracking-wider">Month Failed</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @user_call_reports.each do |user_id, report| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= report[:name] %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-600 font-semibold"><%= report[:last_day_calls] %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-green-600 font-semibold"><%= report[:last_day_successful_calls] %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-red-600 font-semibold"><%= report[:last_day_failed_calls] %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-600 font-semibold"><%= report[:last_month_calls] %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-green-600 font-semibold"><%= report[:last_month_successful_calls] %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-red-600 font-semibold"><%= report[:last_month_failed_calls] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  </div>
</div>
