<div class="min-h-screen bg-gray-50" data-controller="email-modal email-inbox" data-email-modal-customer-id-value="<%= @customer.id %>" data-email-inbox-customer-id-value="<%= @customer.id %>">
  <!-- Modern Header Section -->
  <div class="bg-white border-b border-gray-200 sticky top-0 z-10 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <%= link_to customers_path, class: "text-gray-600 hover:text-gray-900 flex items-center text-sm font-medium" do %>
          <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Customers
        <% end %>
        
        <div class="flex items-center space-x-3">
          <%= link_to edit_customer_path(@customer), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium text-sm shadow-sm" do %>
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit
          <% end %>
          
          <% if @customer.phone.present? %>
            <%= link_to calling_path(customer_id: @customer.id, phone: @customer.phone), class: "inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium text-sm shadow-sm" do %>
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Customer Profile Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
      <div class="flex items-start space-x-6">
        <div class="flex-shrink-0">
          <div class="h-24 w-24 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-3xl font-bold shadow-lg">
            <%= @customer.name.first.upcase %>
          </div>
        </div>
        
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-3xl font-bold text-gray-900"><%= @customer.name %></h1>
              <% if @customer.company.present? %>
                <p class="text-lg text-gray-600 mt-1"><%= @customer.company %></p>
              <% end %>
              <div class="flex flex-wrap gap-2 mt-3">
                <% if @customer.status.present? %>
                  <div class="relative inline-flex items-center" data-controller="status-updater" data-status-updater-customer-id-value="<%= @customer.id %>">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= customer_status_color_class(@customer.status) %>" data-status-updater-target="statusBadge" data-status="<%= @customer.status %>">
                      <%= @customer.status %>
                    </span>
                    <button type="button" data-action="click->status-updater#openDropdown" class="ml-2 text-gray-500 hover:text-gray-700 transition-colors" title="Update status">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                    </button>
                    
                    <!-- Status Dropdown -->
                    <div data-status-updater-target="dropdown" class="hidden absolute top-full left-0 mt-2 bg-white rounded-lg shadow-xl border border-gray-200 py-2 w-64 max-h-96 overflow-y-auto z-50">
                      <div class="px-3 py-2 border-b border-gray-200 sticky top-0 bg-white">
                        <p class="text-xs font-semibold text-gray-700 uppercase">Update Status</p>
                      </div>
                      <% Customer::STATUSES.values.each do |status| %>
                        <button type="button" 
                                data-action="click->status-updater#updateStatus" 
                                data-status="<%= status %>"
                                class="w-full text-left px-3 py-2 text-sm hover:bg-gray-100 transition-colors flex items-center justify-between <%= 'bg-gray-50 font-medium' if @customer.status == status %>">
                          <span class="<%= 'font-medium' if @customer.status == status %>"><%= status %></span>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= customer_status_color_class(status) %>">
                            •
                          </span>
                        </button>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                <% if @customer.lead_source.present? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <%= @customer.lead_source %>
                  </span>
                <% end %>
                <% if @customer.customer_type == 'High Value' %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-800 border border-amber-300">
                    ⭐ High Value
                  </span>
                <% end %>
                <% if @customer.repeat_lead? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    🔄 Repeat Lead
                  </span>
                <% end %>
              </div>
            </div>
            
            <% if @customer.lead_score.present? %>
              <div class="text-center">
                <div class="text-4xl font-bold <%= @customer.lead_score_color %>"><%= @customer.lead_score %></div>
                <div class="text-xs text-gray-500 mt-1">Lead Score</div>
              </div>
            <% end %>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
            <div class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div class="text-sm">
                <div class="text-gray-500">Email</div>
                <div class="font-medium text-gray-900"><%= @customer.email.present? ? @customer.email : 'N/A' %></div>
              </div>
            </div>
            
            <div class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div class="text-sm">
                <div class="text-gray-500">Phone</div>
                <div class="font-medium text-gray-900"><%= @customer.phone.present? ? @customer.phone : 'N/A' %></div>
              </div>
            </div>
            
            <div class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <div class="text-sm">
                <div class="text-gray-500">Assigned To</div>
                <div class="font-medium text-gray-900"><%= @customer.user ? @customer.user.name : 'Unassigned' %></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabs Navigation -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" data-controller="tabs">
      <div class="border-b border-gray-200">
        <nav class="flex -mb-px overflow-x-auto" aria-label="Tabs">
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="overview" class="tab-button active group inline-flex items-center py-4 px-6 border-b-2 border-blue-500 font-medium text-sm text-blue-600 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
            Overview
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="emails" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Emails
            <span class="ml-2 bg-gray-100 text-gray-800 py-0.5 px-2 rounded-full text-xs font-medium"><%= @customer.emails.count %></span>
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="communications" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            WhatsApp
            <% if @customer.whatsapp_chat_id.present? %>
              <span class="ml-2 bg-green-100 text-green-800 py-0.5 px-2 rounded-full text-xs font-medium">Active</span>
            <% end %>
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="recordings" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Recordings
            <span class="ml-2 bg-gray-100 text-gray-800 py-0.5 px-2 rounded-full text-xs font-medium"><%= @recordings.count %></span>
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="deals" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Deals
            <span class="ml-2 bg-gray-100 text-gray-800 py-0.5 px-2 rounded-full text-xs font-medium"><%= @customer.deals.count %></span>
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="tasks" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
            Tasks
            <span class="ml-2 bg-gray-100 text-gray-800 py-0.5 px-2 rounded-full text-xs font-medium"><%= @customer.tasks.count %></span>
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="activities" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Activities
          </button>
          <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="documents" class="tab-button group inline-flex items-center py-4 px-6 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Documents
          </button>
        </nav>
      </div>

      <!-- Tab Contents -->
      <div class="p-6">
        <!-- Overview Tab -->
        <div data-tabs-target="content" data-tab-id="overview" class="tab-content">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Stats Cards -->
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-blue-50 rounded-lg p-4">
                <div class="text-3xl font-bold text-blue-600"><%= @customer.total_call_attempts %></div>
                <div class="text-sm text-gray-600 mt-1">Call Attempts</div>
              </div>
              <div class="bg-green-50 rounded-lg p-4">
                <div class="text-3xl font-bold text-green-600"><%= @customer.successful_call_attempts %></div>
                <div class="text-sm text-gray-600 mt-1">Connected</div>
              </div>
              <div class="bg-purple-50 rounded-lg p-4">
                <div class="text-3xl font-bold text-purple-600"><%= @customer.messages.count %></div>
                <div class="text-sm text-gray-600 mt-1">Messages</div>
              </div>
              <div class="bg-indigo-50 rounded-lg p-4">
                <div class="text-3xl font-bold text-indigo-600"><%= @customer.emails.count %></div>
                <div class="text-sm text-gray-600 mt-1">Emails</div>
              </div>
            </div>

            <!-- Location & Timezone -->
            <% if @customer.customer_location.present? || @customer.current_time_in_timezone %>
              <div class="bg-gray-50 rounded-lg p-6">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="text-lg font-semibold text-gray-900">Location & Time</h3>
                  <% if @customer.phone.present? %>
                    <%= button_to analyze_phone_customer_path(@customer), method: :post, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-blue-700 bg-blue-100 border border-blue-300 rounded-lg hover:bg-blue-200 transition-colors", form: { data: { turbo: false } } do %>
                      <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                      </svg>
                      Analyze
                    <% end %>
                  <% end %>
                </div>
                <div class="space-y-3">
                  <% if @customer.customer_location.present? %>
                    <% if @customer.customer_location.city.present? %>
                      <div class="flex justify-between">
                        <span class="text-gray-600">Location</span>
                        <span class="font-medium"><%= [@customer.customer_location.city, @customer.customer_location.state_province, @customer.customer_location.country_name].compact.join(', ') %></span>
                      </div>
                    <% end %>
                    <% if @customer.customer_location.timezone.present? %>
                      <div class="flex justify-between">
                        <span class="text-gray-600">Timezone</span>
                        <span class="font-medium"><%= @customer.customer_location.timezone %></span>
                      </div>
                      <div class="flex justify-between">
                        <span class="text-gray-600">Current Time</span>
                        <span class="font-bold text-blue-600 text-lg"><%= Time.current.in_time_zone(@customer.customer_location.timezone).strftime("%I:%M %p") %></span>
                      </div>
                    <% end %>
                  <% elsif @customer.current_time_in_timezone %>
                    <div class="flex justify-between">
                      <span class="text-gray-600">Current Time</span>
                      <span class="font-bold text-blue-600 text-lg"><%= @customer.current_time_in_timezone.strftime("%I:%M %p") %></span>
                    </div>
                  <% end %>
                  <% if @customer.preferred_calling_time.present? && @customer.preferred_calling_time != 'Not Applicable' %>
                    <div class="flex justify-between">
                      <span class="text-gray-600">Best Time to Call</span>
                      <span class="font-medium"><%= @customer.preferred_calling_time %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% elsif @customer.phone.present? %>
              <!-- Show Analyze button when no location data exists -->
              <div class="bg-gray-50 rounded-lg p-6 border-2 border-dashed border-gray-300">
                <div class="text-center">
                  <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                  </svg>
                  <h3 class="text-sm font-medium text-gray-900 mb-2">No Location Data</h3>
                  <p class="text-sm text-gray-500 mb-4">Analyze the phone number to get location and timezone information</p>
                  <%= button_to analyze_phone_customer_path(@customer), method: :post, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm", form: { data: { turbo: false } } do %>
                    <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                    </svg>
                    Analyze Phone Number
                  <% end %>
                </div>
              </div>
            <% end %>

            <!-- Project Info -->
            <% if @customer.project_type.present? || @customer.idea_description.present? %>
              <div class="bg-gray-50 rounded-lg p-6 lg:col-span-2">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Project Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <% if @customer.project_type.present? %>
                    <div>
                      <div class="text-sm text-gray-600">Project Type</div>
                      <div class="font-medium mt-1"><%= @customer.project_type %></div>
                    </div>
                  <% end %>
                  <% if @customer.project_scope.present? && @customer.project_scope != 'Not Applicable' %>
                    <div>
                      <div class="text-sm text-gray-600">Scope</div>
                      <div class="font-medium mt-1"><%= @customer.project_scope %></div>
                    </div>
                  <% end %>
                  <% if @customer.project_estimated_cost.present? %>
                    <div>
                      <div class="text-sm text-gray-600">Estimated Cost</div>
                      <div class="font-bold text-green-600 text-lg mt-1"><%= number_to_currency(@customer.project_estimated_cost) %></div>
                    </div>
                  <% end %>
                </div>
                <% if @customer.idea_description.present? %>
                  <div class="mt-4">
                    <div class="text-sm text-gray-600 mb-2">Description</div>
                    <p class="text-gray-700"><%= @customer.idea_description %></p>
                  </div>
                <% end %>
              </div>
            <% end %>

            <!-- Notes -->
            <div class="bg-yellow-50 rounded-lg p-6 lg:col-span-2" data-controller="notes-editor" data-notes-editor-customer-id-value="<%= @customer.id %>">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-lg font-semibold text-gray-900">Notes</h3>
                <% if policy(@customer).update? %>
                  <button type="button" 
                          data-action="click->notes-editor#toggleEdit"
                          data-notes-editor-target="editButton"
                          class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                    <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                    </svg>
                    <span data-notes-editor-target="editButtonText">Edit</span>
                  </button>
                <% end %>
              </div>
              
              <!-- View Mode -->
              <div data-notes-editor-target="viewMode">
                <% if @customer.notes.present? %>
                  <p class="text-gray-700 whitespace-pre-wrap"><%= @customer.notes %></p>
                <% else %>
                  <p class="text-gray-500 italic">No notes yet. Click "Edit" to add notes.</p>
                <% end %>
              </div>
              
              <!-- Edit Mode -->
              <div data-notes-editor-target="editMode" class="hidden">
                <textarea 
                  data-notes-editor-target="textarea"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-gray-700"
                  rows="6"
                  placeholder="Add notes about this customer..."><%= @customer.notes %></textarea>
                
                <div class="flex items-center justify-end space-x-3 mt-3">
                  <button type="button" 
                          data-action="click->notes-editor#cancel"
                          class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                    Cancel
                  </button>
                  <button type="button" 
                          data-action="click->notes-editor#save"
                          data-notes-editor-target="saveButton"
                          class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
                    <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Save Notes
                  </button>
                </div>
              </div>
              
              <!-- Loading State -->
              <div data-notes-editor-target="loadingState" class="hidden">
                <div class="flex items-center justify-center py-4">
                  <svg class="animate-spin h-5 w-5 text-blue-600 mr-3" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  <span class="text-sm text-gray-600">Saving notes...</span>
                </div>
              </div>
            </div>

            <!-- Cost Estimates (CCR Customers Only) -->
            <% if @customer.lead_source == 'CCR' && @customer.cost_estimates.any? %>
              <div class="bg-gradient-to-br from-purple-50 to-indigo-50 rounded-lg p-6 lg:col-span-2 border border-purple-200">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center space-x-2">
                    <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    <h3 class="text-lg font-semibold text-gray-900">Cost Estimates</h3>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      <%= @customer.cost_estimates.count %>
                    </span>
                  </div>
                </div>
                
                <div class="space-y-3">
                  <% @customer.cost_estimates.order(created_at: :desc).each do |estimate| %>
                    <div class="bg-white rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow border border-gray-200">
                      <div class="flex items-start justify-between">
                        <div class="flex-1">
                          <div class="flex items-center space-x-2 mb-2">
                            <h4 class="font-semibold text-gray-900">
                              <% if estimate.application_types.present? %>
                                <%= estimate.application_types_array.join(', ') %>
                              <% else %>
                                <%= estimate.app_type_display %>
                              <% end %>
                            </h4>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= estimate.final_status? ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
                              <%= estimate.status.titleize %>
                            </span>
                          </div>
                          
                          <p class="text-sm text-gray-600 mb-3 line-clamp-2"><%= estimate.description %></p>
                          
                          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                            <div>
                              <div class="text-xs text-gray-500">Scale</div>
                              <div class="text-sm font-medium text-gray-900"><%= estimate.scale_display %></div>
                            </div>
                            <div>
                              <div class="text-xs text-gray-500">Hours</div>
                              <div class="text-sm font-medium text-gray-900"><%= estimate.total_hours %>h</div>
                            </div>
                            <div>
                              <div class="text-xs text-gray-500">Rate</div>
                              <div class="text-sm font-medium text-gray-900">$<%= estimate.hourly_rate %>/h</div>
                            </div>
                            <div>
                              <div class="text-xs text-gray-500">Total Cost</div>
                              <div class="text-lg font-bold text-green-600"><%= number_to_currency(estimate.total_cost) %></div>
                            </div>
                          </div>
                          
                          <% if estimate.pdf_file.attached? %>
                            <div class="mt-3 flex items-center space-x-2">
                              <%= link_to rails_blob_path(estimate.pdf_file, disposition: "attachment"), class: "inline-flex items-center text-sm font-medium text-purple-600 hover:text-purple-800" do %>
                                <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Download PDF
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                        
                        <div class="text-right text-xs text-gray-500 ml-4">
                          <%= estimate.created_at.strftime('%b %d, %Y') %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Emails Tab -->
        <div data-tabs-target="content" data-tab-id="emails" class="tab-content hidden">
          <!-- Header with Actions -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <div class="flex items-center space-x-4">
            <h3 class="text-lg font-semibold text-gray-900">Emails</h3>
              <span class="text-sm text-gray-500">(<span data-email-inbox-target="totalCount"><%= @customer.emails.count %></span> total)</span>
            </div>
            <div class="flex items-center space-x-3">
              <button type="button" data-action="click->email-inbox#syncEmails" data-email-inbox-target="syncBtn" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                <svg class="h-4 w-4 mr-2" data-email-inbox-target="syncIcon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                <span data-email-inbox-target="syncText">Sync</span>
              </button>
              <button type="button" data-action="click->email-inbox#openCompose" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium text-sm transition-colors shadow-sm">
                <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Compose
              </button>
            </div>
          </div>

          <!-- Filter Tabs & Search -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4">
            <div class="flex space-x-1 bg-gray-100 rounded-lg p-1">
              <button type="button" data-action="click->email-inbox#filterAll" data-email-inbox-target="filterBtn" data-filter="all" class="px-4 py-2 text-sm font-medium rounded-md bg-white text-gray-900 shadow-sm">
                All <span class="ml-1 text-gray-500" data-email-inbox-target="allCount">(<%= @customer.emails.count %>)</span>
              </button>
              <button type="button" data-action="click->email-inbox#filterInbox" data-email-inbox-target="filterBtn" data-filter="received" class="px-4 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900">
                Inbox <span class="ml-1 text-gray-500" data-email-inbox-target="inboxCount">(<%= @customer.emails.received.count %>)</span>
              </button>
              <button type="button" data-action="click->email-inbox#filterSent" data-email-inbox-target="filterBtn" data-filter="sent" class="px-4 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900">
                Sent <span class="ml-1 text-gray-500" data-email-inbox-target="sentCount">(<%= @customer.emails.sent.count %>)</span>
              </button>
              <% unread_count = @customer.emails.unread.count %>
              <button type="button" data-action="click->email-inbox#filterUnread" data-email-inbox-target="filterBtn" data-filter="unread" class="px-4 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 relative">
                Unread
                <% if unread_count > 0 %>
                  <span class="ml-1 inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold bg-red-500 text-white rounded-full" data-email-inbox-target="unreadBadge"><%= unread_count %></span>
                <% else %>
                  <span class="ml-1 text-gray-500" data-email-inbox-target="unreadBadge">(0)</span>
              <% end %>
              </button>
            </div>
            
            <div class="relative w-full sm:w-64">
              <input type="text" data-action="input->email-inbox#search" data-email-inbox-target="searchInput" placeholder="Search emails..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <svg class="absolute left-3 top-2.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          </div>

          <!-- Email List -->
          <div data-email-inbox-target="emailList" class="space-y-2">
          <% if @customer.emails.any? %>
              <% @customer.emails.with_attached_attachments.recent.each do |email| %>
                <div class="email-item bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-all cursor-pointer <%= 'bg-blue-50 border-blue-200' if email.received? && email.read_at.nil? %>" 
                     data-action="click->email-modal#open" 
                     data-email-id="<%= email.id %>"
                     data-status="<%= email.status %>"
                     data-subject="<%= email.subject&.downcase %>"
                     data-from="<%= email.from_email&.downcase %>"
                     data-unread="<%= email.received? && email.read_at.nil? %>">
                    <div class="flex items-start space-x-4">
                      <div class="flex-shrink-0">
                      <div class="h-10 w-10 rounded-full <%= email.received? ? 'bg-gradient-to-br from-purple-500 to-pink-500' : 'bg-gradient-to-br from-blue-500 to-cyan-500' %> flex items-center justify-center text-white font-semibold text-sm shadow-sm">
                          <% name = email.received? ? email.sender_name : email.receiver_name %>
                          <%= name.present? ? name.first.upcase : '?' %>
                        </div>
                      </div>
                      
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between mb-1">
                        <div class="flex items-center space-x-2 flex-wrap">
                            <p class="text-sm font-semibold text-gray-900 <%= 'font-bold' if email.received? && email.read_at.nil? %>">
                            <%= email.received? ? (email.sender_name.presence || email.from_email) : "To: #{email.receiver_name.presence || email.to_email}" %>
                            </p>
                            <% if email.received? && email.read_at.nil? %>
                              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">New</span>
                            <% end %>
                            <% if email.has_downloadable_attachments? %>
                            <span class="inline-flex items-center text-gray-500" title="<%= email.attachments_count %> attachment(s)">
                              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                              </svg>
                              <span class="text-xs ml-0.5"><%= email.attachments_count %></span>
                            </span>
                            <% end %>
                          </div>
                        <time class="text-xs text-gray-500 whitespace-nowrap ml-2"><%= time_ago_in_words(email.sent_at || email.received_at || email.created_at) %> ago</time>
                        </div>
                        
                      <h4 class="text-sm text-gray-900 mb-1 truncate <%= 'font-semibold' if email.received? && email.read_at.nil? %>">
                          <%= email.display_subject %>
                        </h4>
                        
                        <% if email.snippet.present? %>
                        <p class="text-sm text-gray-500 truncate"><%= email.snippet %></p>
                        <% end %>
                        
                      <div class="mt-2 flex items-center space-x-2">
                          <% if email.sent? %>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                              <svg class="mr-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                              </svg>
                              Sent
                            </span>
                          <% elsif email.received? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                              <svg class="mr-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                              </svg>
                            Inbox
                            </span>
                          <% end %>
                      </div>
                    </div>
                  </div>
              </div>
            <% end %>
          <% else %>
              <div class="text-center py-16 bg-gray-50 rounded-xl">
                <div class="mx-auto h-20 w-20 rounded-full bg-gray-100 flex items-center justify-center mb-4">
                  <svg class="h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
                </div>
                <h3 class="text-lg font-medium text-gray-900">No emails yet</h3>
                <p class="mt-2 text-sm text-gray-500 max-w-sm mx-auto">Get started by composing an email to this customer or sync your Gmail inbox.</p>
              <div class="mt-6 flex justify-center space-x-4">
                  <button type="button" data-action="click->email-inbox#openCompose" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium text-sm shadow-sm">
                    <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  Compose Email
                  </button>
                  <button type="button" data-action="click->email-inbox#syncEmails" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                    <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                  Sync Emails
                  </button>
              </div>
            </div>
          <% end %>
          </div>
          
          <!-- Empty State for Filtered Results -->
          <div data-email-inbox-target="emptyState" class="hidden text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No emails found</h3>
            <p class="mt-1 text-sm text-gray-500">Try changing your filter or search terms</p>
          </div>
        </div>

        <!-- Communications Tab (WhatsApp) -->
        <div data-tabs-target="content" data-tab-id="communications" class="tab-content hidden">
          <!-- WhatsApp Chat (Featured) -->
          <% if @customer.whatsapp_chat_id.present? %>
            <div class="bg-gradient-to-r from-green-500 to-green-600 rounded-lg p-6 text-white mb-6">
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                  <svg class="h-10 w-10" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
                  </svg>
                  <div>
                    <h3 class="text-xl font-bold">WhatsApp Chat</h3>
                    <p class="text-green-100 text-sm">Messages sync automatically</p>
                  </div>
                </div>
                <%= button_to sync_customer_messages_path(@customer), method: :patch, class: "bg-white text-green-600 px-4 py-2 rounded-lg hover:bg-green-50 font-medium text-sm", form: { data: { turbo: true } } do %>
                  <svg class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                  Sync Now
                <% end %>
              </div>
            </div>
            
            <%= render 'shared/chat_window', customer: @customer %>
          <% else %>
            <div class="bg-gray-50 rounded-lg p-8 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No WhatsApp Chat ID</h3>
              <p class="mt-1 text-sm text-gray-500">This customer doesn't have a WhatsApp chat ID associated</p>
            </div>
          <% end %>
        </div>

        <!-- Call Recordings Tab -->
        <div data-tabs-target="content" data-tab-id="recordings" class="tab-content hidden">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-semibold text-gray-900">Call Recordings</h3>
            <% if @recordings.any? %>
              <span class="text-sm text-gray-500"><%= pluralize(@recordings.count, 'recording') %></span>
            <% end %>
          </div>
          
          <% if @recordings.any? %>
            <div class="space-y-4">
              <% @recordings.each do |recording| %>
                <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden" 
                     data-controller="recording-player" 
                     data-recording-player-recording-id-value="<%= recording.id %>">
                  <!-- Recording Header (Always Visible) -->
                  <div class="p-4 cursor-pointer hover:bg-gray-50 transition-colors" data-action="click->recording-player#toggle">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center space-x-4 flex-1">
                        <div class="flex-shrink-0">
                          <div class="h-12 w-12 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-sm">
                            <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                          </div>
                        </div>
                        
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center space-x-3">
                            <h4 class="font-semibold text-gray-900"><%= recording.date.strftime('%b %d, %Y') %></h4>
                            <span class="text-sm text-gray-500"><%= recording.date.strftime('%I:%M %p') %></span>
                          </div>
                          <div class="mt-1 flex items-center space-x-3">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                              <svg class="mr-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              <%= recording.duration %>s
                            </span>
                            <% if recording.user.present? %>
                              <span class="text-xs text-gray-500">by <%= recording.user.name %></span>
                            <% end %>
                            <% if recording.transcribed? %>
                              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                <svg class="mr-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Transcribed
                              </span>
                            <% end %>
                          </div>
                        </div>
                      </div>
                      
                      <div class="flex items-center space-x-2">
                        <!-- Expand/Collapse Icon -->
                        <div class="flex-shrink-0 text-gray-400">
                          <svg data-recording-player-target="expandIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                          </svg>
                          <svg data-recording-player-target="collapseIcon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                          </svg>
                        </div>
                      </div>
                    </div>
                  </div>
                  
                  <!-- Expandable Content -->
                  <div data-recording-player-target="content" class="hidden border-t border-gray-200">
                    <div class="p-6 bg-gray-50">
                      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Audio Player Section -->
                        <div class="bg-white rounded-lg p-4 shadow-sm">
                          <h4 class="text-sm font-semibold text-gray-900 mb-3 flex items-center">
                            <svg class="h-4 w-4 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Audio Player
                          </h4>
                          <% if recording.audio_file.attached? %>
                            <audio controls class="w-full" controlsList="nodownload">
                              <source src="<%= rails_blob_url(recording.audio_file) %>" type="audio/mpeg">
                              Your browser does not support the audio element.
                            </audio>
                            <div class="mt-3">
                              <%= link_to download_recording_path(recording), class: "inline-flex items-center text-sm text-blue-600 hover:text-blue-800 font-medium" do %>
                                <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                </svg>
                                Download Recording
                              <% end %>
                            </div>
                          <% else %>
                            <div class="text-center py-4 text-sm text-gray-500">
                              Audio file not available
                            </div>
                          <% end %>
                        </div>
                        
                        <!-- Recording Details -->
                        <div class="bg-white rounded-lg p-4 shadow-sm">
                          <h4 class="text-sm font-semibold text-gray-900 mb-3">Recording Details</h4>
                          <dl class="space-y-2">
                            <div class="flex justify-between text-sm">
                              <dt class="text-gray-500">Duration</dt>
                              <dd class="text-gray-900 font-medium">
                                <%= (recording.duration.to_i / 60).to_s.rjust(2, '0') %>:<%= (recording.duration.to_i % 60).to_s.rjust(2, '0') %>
                              </dd>
                            </div>
                            <% if recording.user.present? %>
                              <div class="flex justify-between text-sm">
                                <dt class="text-gray-500">Caller</dt>
                                <dd class="text-gray-900 font-medium"><%= recording.user.name %></dd>
                              </div>
                            <% end %>
                            <div class="flex justify-between text-sm">
                              <dt class="text-gray-500">Date & Time</dt>
                              <dd class="text-gray-900 font-medium"><%= recording.date.strftime('%b %d, %Y %I:%M %p') %></dd>
                            </div>
                            <div class="mt-3 pt-3 border-t border-gray-200">
                              <%= link_to recording_path(recording), class: "inline-flex items-center text-sm text-blue-600 hover:text-blue-800 font-medium", target: "_blank" do %>
                                <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                                View Full Details
                              <% end %>
                            </div>
                          </dl>
                        </div>
                      </div>
                      
                      <!-- Transcript Section -->
                      <% if recording.transcribed? %>
                        <div class="mt-6 bg-white rounded-lg p-4 shadow-sm">
                          <h4 class="text-sm font-semibold text-gray-900 mb-3 flex items-center">
                            <svg class="h-4 w-4 mr-2 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            Conversation Transcript
                          </h4>
                          <div class="max-h-96 overflow-y-auto" data-recording-player-target="transcriptContainer">
                            <!-- Transcript will be loaded here -->
                          </div>
                        </div>
                      <% else %>
                        <div class="mt-6 bg-white rounded-lg p-4 shadow-sm">
                          <div class="text-center py-6 text-sm text-gray-500">
                            Transcript is not available for this recording.
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-12 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <h3 class="mt-4 text-sm font-medium text-gray-900">No call recordings</h3>
              <p class="mt-2 text-sm text-gray-500">Call recordings will appear here after phone calls with this customer</p>
            </div>
          <% end %>
        </div>

        <!-- Deals Tab -->
        <div data-tabs-target="content" data-tab-id="deals" class="tab-content hidden">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-semibold text-gray-900">Deals</h3>
            <%= link_to new_deal_path(customer_id: @customer.id), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium text-sm" do %>
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              New Deal
            <% end %>
          </div>
          <% if @customer.deals.any? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <% @customer.deals.each do |deal| %>
                <div class="bg-white rounded-lg border border-gray-200 p-6 hover:shadow-lg transition-shadow">
                  <div class="flex justify-between items-start mb-4">
                    <div>
                      <h4 class="font-semibold text-gray-900 text-lg"><%= link_to deal.title, deal_path(deal), class: "hover:text-blue-600" %></h4>
                      <p class="text-sm text-gray-500 mt-1"><%= deal.deal_stage&.name || 'No stage' %></p>
                    </div>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= deal.status == 'won' ? 'bg-green-100 text-green-800' : deal.status == 'lost' ? 'bg-red-100 text-red-800' : 'bg-blue-100 text-blue-800' %>">
                      <%= deal.status&.titleize || 'Active' %>
                    </span>
                  </div>
                  <div class="text-2xl font-bold text-green-600"><%= number_to_currency(deal.amount) %></div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-12 bg-gray-50 rounded-lg">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No deals</h3>
              <p class="mt-1 text-sm text-gray-500">Get started by creating a new deal</p>
            </div>
          <% end %>
        </div>

        <!-- Tasks Tab -->
        <div data-tabs-target="content" data-tab-id="tasks" class="tab-content hidden">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-semibold text-gray-900">Tasks</h3>
            <%= link_to new_task_path(customer_id: @customer.id), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium text-sm" do %>
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              New Task
            <% end %>
          </div>
          <% if @customer.tasks.any? %>
            <div class="space-y-3">
              <% @customer.tasks.order(due_date: :asc).each do |task| %>
                <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow">
                  <div class="flex items-start justify-between">
                    <div class="flex items-start space-x-3">
                      <input type="checkbox" <%= 'checked' if task.completed? %> class="mt-1 h-5 w-5 text-blue-600 rounded" disabled>
                      <div>
                        <h4 class="font-medium text-gray-900 <%= 'line-through' if task.completed? %>"><%= task.title %></h4>
                        <% if task.due_date %>
                          <p class="text-sm text-gray-500 mt-1">Due: <%= task.due_date.strftime('%b %d, %Y at %I:%M %p') %></p>
                        <% end %>
                        <% if task.pending? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800 mt-2">Pending</span>
                        <% elsif task.completed? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 mt-2">Completed</span>
                        <% end %>
                      </div>
                    </div>
                    <%= link_to "View", task_path(task), class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-12 bg-gray-50 rounded-lg">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No tasks</h3>
              <p class="mt-1 text-sm text-gray-500">Create a task to get started</p>
            </div>
          <% end %>
        </div>

        <!-- Activities Tab -->
        <div data-tabs-target="content" data-tab-id="activities" class="tab-content hidden">
          <h3 class="text-lg font-semibold text-gray-900 mb-6">Recent Activities</h3>
          <% if @activities.any? %>
            <div class="flow-root">
              <ul class="-mb-8">
                <% @activities.each_with_index do |activity, index| %>
                  <li>
                    <div class="relative pb-8">
                      <% if index < @activities.size - 1 %>
                        <span class="absolute top-5 left-5 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                      <% end %>
                      <div class="relative flex items-start space-x-3">
                        <div>
                          <div class="relative px-1">
                            <div class="h-10 w-10 bg-blue-500 rounded-full ring-8 ring-white flex items-center justify-center">
                              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                            </div>
                          </div>
                        </div>
                        <div class="min-w-0 flex-1 py-1.5">
                          <div class="text-sm text-gray-900 font-medium"><%= activity.action %></div>
                          <% if activity.details.present? %>
                            <p class="text-sm text-gray-500 mt-1"><%= activity.details %></p>
                          <% end %>
                          <div class="mt-2 text-xs text-gray-400">
                            <%= time_ago_in_words(activity.created_at) %> ago
                            <% if activity.user.present? %>
                              • by <%= activity.user.name %>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>
          <% else %>
            <div class="text-center py-12 bg-gray-50 rounded-lg">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No activities</h3>
              <p class="mt-1 text-sm text-gray-500">Activity history will appear here</p>
            </div>
          <% end %>
        </div>

        <!-- Documents Tab -->
        <div data-tabs-target="content" data-tab-id="documents" class="tab-content hidden" data-controller="document-manager" data-document-manager-customer-id-value="<%= @customer.id %>">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-semibold text-gray-900">Documents</h3>
            <% if policy(@customer).update? %>
              <label class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium text-sm cursor-pointer transition-colors shadow-sm">
                <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                </svg>
                Upload Document
                <input type="file" 
                       data-action="change->document-manager#uploadDocument" 
                       data-document-manager-target="fileInput"
                       accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.jpg,.jpeg,.png,.gif"
                       multiple
                       class="hidden">
              </label>
            <% end %>
          </div>

          <div data-document-manager-target="documentsList">
            <% if @customer.documents.attached? %>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <% @customer.documents.each do |document| %>
                  <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow" data-document-id="<%= document.signed_id %>">
                    <div class="flex items-start justify-between">
                      <div class="flex items-start space-x-3 flex-1 min-w-0">
                        <svg class="h-10 w-10 text-blue-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm font-medium text-gray-900 truncate" title="<%= document.filename %>"><%= document.filename %></p>
                          <p class="text-xs text-gray-500 mt-1"><%= number_to_human_size(document.byte_size) %></p>
                          <div class="flex items-center space-x-2 mt-2">
                            <%= link_to rails_blob_path(document, disposition: "attachment"), class: "text-xs text-blue-600 hover:text-blue-800 font-medium inline-flex items-center" do %>
                              <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                              </svg>
                              Download
                            <% end %>
                            <% if policy(@customer).remove_document? %>
                              <button type="button" 
                                      data-action="click->document-manager#deleteDocument" 
                                      data-document-id="<%= document.signed_id %>"
                                      data-document-name="<%= document.filename %>"
                                      class="text-xs text-red-600 hover:text-red-800 font-medium inline-flex items-center">
                                <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Delete
                              </button>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12 bg-gray-50 rounded-lg">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900">No documents</h3>
                <p class="mt-1 text-sm text-gray-500">Upload documents to keep them organized</p>
              </div>
            <% end %>
          </div>

          <!-- Upload Progress Indicator -->
          <div data-document-manager-target="uploadProgress" class="hidden mt-4 bg-blue-50 border border-blue-200 rounded-lg p-4">
            <div class="flex items-center">
              <svg class="animate-spin h-5 w-5 text-blue-600 mr-3" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span class="text-sm font-medium text-blue-900">Uploading documents...</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Email View Modal (Partial) -->
  <%= render 'customers/email_view_modal', customer: @customer %>

  <!-- Compose Email Modal (Partial) -->
  <%= render 'customers/email_compose_modal', customer: @customer %>
</div>

<style>
.tab-content {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.tab-button {
  transition: all 0.2s ease-in-out;
}

.tab-button:hover {
  transform: translateY(-1px);
}
</style>
