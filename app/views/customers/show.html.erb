<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Customers", customers_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Customer Details Card -->
    <div class="lg:col-span-1">
      <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="p-6 border-b border-gray-200">
          <div class="flex justify-between items-center">
            <h2 class="text-xl font-bold text-gray-900">Customer Details</h2>
            <%= link_to edit_customer_path(@customer), class: "text-blue-600 hover:text-blue-800" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
              </svg>
            <% end %>
          </div>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <h3 class="text-sm font-medium text-gray-500">Name</h3>
            <p class="mt-1 text-lg text-gray-900"><%= @customer.name %></p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Company</h3>
            <p class="mt-1 text-lg text-gray-900"><%= @customer.company.present? ? @customer.company : "N/A" %></p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Email</h3>
            <p class="mt-1 text-lg text-gray-900"><%= @customer.email.present? ? @customer.email : "N/A" %></p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Phone</h3>
            <div class="mt-1 flex items-center">
              <p class="text-lg text-gray-900"><%= @customer.phone.present? ? @customer.phone : "N/A" %></p>
              <% if @customer.phone.present? %>
                <%= link_to calling_path(customer_id: @customer.id, phone: @customer.phone), class: "ml-2 text-green-600 hover:text-green-800 transition-colors duration-150", title: "Call this customer" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                <% end %>
                
                <%= button_to ai_call_customer_path(@customer), method: :post, class: "ml-2 inline-flex items-center px-3 py-2 border border-blue-300 rounded-md shadow-sm text-sm font-medium text-blue-700 bg-white hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200", title: "Make AI call", form_class: "inline" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  </svg>
                  AI Call
                <% end %>
                
                <%= button_to analyze_phone_customer_path(@customer), method: :post, class: "ml-2 inline-flex items-center px-3 py-2 border border-purple-300 rounded-md shadow-sm text-sm font-medium text-purple-700 bg-white hover:bg-purple-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-all duration-200", title: "Analyze phone number for location, timezone & calling time using our comprehensive database", form_class: "inline" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Get Timezone
                <% end %>
              <% end %>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Preferred Calling Time Given by Customer</h3>
            <div class="mt-1">
              <p class="text-lg text-gray-900">
                <%= @customer.preferred_calling_time %>
              </p>
            </div>
          </div>


          <% if @customer.customer_location.present? %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Phone Type</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.customer_location.phone_type.present? ? @customer.customer_location.phone_type : 'N/A'  %></p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Timezone</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.customer_location.timezone.present? ?  @customer.customer_location.timezone : 'N/A'  %></p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Country</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.customer_location.country_name.present? ?  @customer.customer_location.country_name : 'N/A'  %></p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Province</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.customer_location.state_province.present? ?  @customer.customer_location.state_province : 'N/A'  %></p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">City</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.customer_location.city.present? ? @customer.customer_location.city : 'N/A'  %></p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Line Type</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.customer_location.line_type.present? ? @customer.customer_location.line_type : 'N/A'  %></p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Current Time</h3>
              <p class="mt-1 text-lg text-gray-900"><%=  @customer.customer_location.timezone.present? ?  Time.current.in_time_zone(@customer.customer_location.timezone).strftime("%H:%M:%S") : 'N/A'  %></p>
            </div>

          <% else %>

            <div>
              <h3 class="text-sm font-medium text-gray-500">Current Customer Time</h3>
              <p class="mt-1 text-lg text-gray-900">
                <% if current_time = @customer.current_time_in_timezone %>
                  <span title="<%= @customer.timezone.present? ? @customer.timezone : 'Timezone based on country' %>">
                    <%= current_time.strftime("%I:%M %p") %>
                    <span class="text-sm text-blue-600">(<%= current_time.strftime("%Z") %>)</span>
                    <div class="text-sm text-gray-500 mt-1">
                      <%= current_time.strftime("%A, %b %d, %Y") %>
                    </div>
                  </span>
                <% else %>
                  Timezone not set
                <% end %>
              </p>
            </div>

            <div>
              <h3 class="text-sm font-medium text-gray-500">Country</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.country.present? ? @customer.country : "N/A" %></p>
            </div>
          <% end %>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Lead Score</h3>
            <% if @customer.lead_score.present? %>
              <div class="mt-2 bg-gray-50 border border-gray-200 p-4 rounded-lg">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-2xl font-bold <%= @customer.lead_score_color %>">
                    <%= @customer.lead_score %>/100
                  </span>
                  <span class="px-3 py-1 text-sm font-medium rounded-full <%= @customer.lead_score_color %> bg-opacity-10">
                    <%= @customer.lead_score_badge %>
                  </span>
                </div>
                
                <div class="grid grid-cols-2 gap-3 mb-3 text-sm">
                  <div>
                    <span class="text-gray-500">Geographic:</span>
                    <span class="font-medium ml-1"><%= @customer.geographic_score || 'N/A' %>/50</span>
                  </div>
                  <div>
                    <span class="text-gray-500">Description:</span>
                    <span class="font-medium ml-1"><%= @customer.description_score || 'N/A' %>/50</span>
                  </div>
                </div>
                
                <% if @customer.lead_score_updated_at.present? %>
                  <div class="text-xs text-gray-400 border-t border-gray-200 pt-2">
                    Last updated: <%= @customer.lead_score_updated_at.strftime('%b %d, %Y at %I:%M %p') %>
                  </div>
                <% end %>
                
                <div class="mt-3 pt-2 border-t border-gray-200">
                  <%= button_to "Recalculate Score", "#", 
                      class: "w-full text-sm text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 py-2 px-3 rounded border border-blue-200",
                      onclick: "calculateLeadScore(#{@customer.id}); return false;" %>
                </div>
              </div>
            <% else %>
              <div class="mt-2 bg-gray-50 border border-gray-200 p-4 rounded-lg text-center">
                <span class="text-gray-500 block mb-3">Lead score not calculated</span>
                <%= button_to "Calculate Score", "#", 
                    class: "text-sm text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 py-2 px-4 rounded border border-blue-200",
                    onclick: "calculateLeadScore(#{@customer.id}); return false;" %>
              </div>
            <% end %>
          </div>
          <% if current_user&.admin? || @customer.user == current_user %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Assigned To</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.user ? @customer.user.name : "Unassigned" %></p>
            </div>
          <% end %>
          <% if @customer.notes.present? %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Notes</h3>
              <p class="mt-1 text-gray-900"><%= @customer.notes %></p>
            </div>
          <% end %>
          
          <div>
            <h3 class="text-sm font-medium text-gray-500">Documents</h3>
            
            <!-- Enhanced Upload Area -->
            <div class="mt-2">
              <%= form_with(model: @customer, 
                            local: true, 
                            multipart: true, 
                            class: "mb-4", 
                            data: { 
                              controller: "customer-documents",
                              customer_documents_target: "form"
                            }) do |f| %>
                
                <!-- Drag and Drop Upload Zone -->
                <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-gray-400 transition-colors duration-200" 
                     data-customer-documents-target="dropZone"
                     data-action="dragover->customer-documents#preventDefault dragenter->customer-documents#handleDragEnter dragleave->customer-documents#handleDragLeave drop->customer-documents#handleDrop">
                  
                  <div class="space-y-3">
                    <div class="mx-auto h-16 w-16 text-gray-400">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-4.5B9.75 8.25 6.375 11.625 6.375 15v2.625m13.125 0h2.25a2.25 2.25 0 002.25-2.25V9a2.25 2.25 0 00-2.25-2.25H15M19.5 14.25v.375c0 .621-.504 1.125-1.125 1.125h-4.125a1.125 1.125 0 01-1.125-1.125v-.375m0 0H7.875c-.621 0-1.125-.504-1.125-1.125V9c0-.621.504-1.125 1.125-1.125h4.125c.621 0 1.125.504 1.125 1.125v.375" />
                      </svg>
                    </div>
                    
                    <div>
                      <p class="text-base font-medium text-gray-900">Drop files here</p>
                      <p class="text-sm text-gray-500">or</p>
                    </div>
                    
                    <%= f.file_field :documents, 
                        multiple: true, 
                        class: "hidden", 
                        id: "customer_documents",
                        accept: ".pdf,.doc,.docx,.xls,.xlsx,.csv,.jpg,.jpeg,.png,.gif",
                        direct_upload: true,
                        data: { 
                          action: "change->customer-documents#upload",
                          customer_documents_target: "fileInput"
                        } %>
                    
                    <%= f.label :documents, class: "cursor-pointer inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                      </svg>
                      Choose Files
                    <% end %>
                  </div>
                  
                  <div class="mt-4">
                    <p class="text-xs text-gray-500">
                      Supports: PDF, DOC, DOCX, XLS, XLSX, CSV, JPG, PNG, GIF
                      <br>
                      Maximum file size: 10MB
                    </p>
                  </div>
                </div>
                
                <!-- Enhanced Progress Bar -->
                <div data-customer-documents-target="progress" class="hidden mt-4">
                  <div class="mb-2 flex justify-between items-center">
                    <span class="text-sm font-medium text-gray-700">Uploading files...</span>
                    <span data-customer-documents-target="progressText" class="text-sm text-gray-500">0%</span>
                  </div>
                                     <div class="w-full bg-gray-200 rounded-full h-3 overflow-hidden">
                     <div data-customer-documents-target="progressBar" 
                          class="bg-gradient-to-r from-blue-500 to-blue-600 h-3 rounded-full transition-all duration-300 ease-out progress-bar"
                          style="width: 0%">
                     </div>
                   </div>
                  <div data-customer-documents-target="fileList" class="mt-2 space-y-1 text-xs text-gray-600">
                    <!-- File upload progress will be shown here -->
                  </div>
                </div>
                
                <!-- Upload Error Display -->
                <div data-customer-documents-target="errorDisplay" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-md error-message">
                  <div class="flex">
                    <div class="flex-shrink-0">
                      <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <div class="ml-3">
                      <h3 class="text-sm font-medium text-red-800">Upload Error</h3>
                      <div class="mt-1 text-sm text-red-700" data-customer-documents-target="errorMessage">
                        <!-- Error message will be inserted here -->
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
            
            <!-- Enhanced Documents Display -->
            <div class="mt-6">
              <% if @customer.documents.attached? %>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-4 document-grid">
                  <% @customer.documents.each do |document| %>
                    <div class="bg-gray-50 rounded-lg border border-gray-200 p-4 hover:bg-gray-100 transition-all duration-200 document-card">
                      <div class="flex items-start space-x-3">
                        <!-- File Type Icon -->
                                                 <div class="flex-shrink-0">
                           <% if document.content_type.start_with?('image/') %>
                             <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center file-icon">
                               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                              </svg>
                            </div>
                                                     <% elsif document.content_type == 'application/pdf' %>
                             <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center file-icon">
                               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                               </svg>
                             </div>
                           <% elsif document.content_type.include?('word') || document.content_type.include?('document') %>
                             <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center file-icon">
                               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                               </svg>
                             </div>
                           <% elsif document.content_type.include?('excel') || document.content_type.include?('spreadsheet') || document.content_type.include?('csv') %>
                             <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center file-icon">
                               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                               </svg>
                             </div>
                           <% else %>
                             <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center file-icon">
                               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                               </svg>
                             </div>
                          <% end %>
                        </div>
                        
                        <!-- File Information -->
                        <div class="flex-1 min-w-0">
                          <div class="flex items-start justify-between">
                            <div class="min-w-0 flex-1">
                              <p class="text-sm font-medium text-gray-900 truncate" title="<%= document.filename %>">
                                <%= document.filename %>
                              </p>
                              <div class="mt-1 flex items-center space-x-2 text-xs text-gray-500">
                                <span><%= number_to_human_size(document.byte_size) %></span>
                                <span>•</span>
                                <span class="capitalize">
                                  <%= document.content_type.split('/').last.upcase %>
                                </span>
                              </div>
                            </div>
                            
                            <!-- Action Buttons -->
                            <div class="flex items-center space-x-2 ml-2">
                              <%= link_to rails_blob_path(document, disposition: "attachment"), 
                                  target: "_blank", 
                                  class: "p-2 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-md transition-colors duration-200",
                                  title: "Download" do %>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                              <% end %>
                              
                              <%= button_to customer_path(@customer, remove_document: document.signed_id),
                                  method: :delete,
                                  class: "p-2 text-red-600 hover:text-red-800 hover:bg-red-50 rounded-md transition-colors duration-200",
                                  title: "Delete",
                                  form: { 
                                    data: { 
                                      turbo_confirm: "Are you sure you want to delete '#{document.filename}'? This action cannot be undone.",
                                      controller: "document-delete",
                                      action: "submit->document-delete#handleDelete"
                                    } 
                                  } do %>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                              <% end %>
                            </div>
                          </div>
                          
                          <!-- Image Preview -->
                          <% if document.content_type.start_with?('image/') %>
                            <div class="mt-3">
                              <%= link_to rails_blob_path(document, disposition: "attachment"), target: "_blank", class: "block" do %>
                                <%= image_tag rails_blob_path(document), 
                                    class: "h-32 w-full object-cover rounded-md border border-gray-200 hover:border-gray-300 transition-colors duration-200",
                                    loading: "lazy" %>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="text-center py-8 border-2 border-dashed border-gray-300 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  <h3 class="mt-2 text-sm font-medium text-gray-900">No documents uploaded</h3>
                  <p class="mt-1 text-sm text-gray-500">
                    Upload documents to keep track of important customer files
                  </p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Customer Status Card -->
      <div class="bg-white shadow-md rounded-lg overflow-hidden mt-6">
        <div class="p-6 border-b border-gray-200">
          <div class="flex justify-between items-center">
            <h2 class="text-xl font-bold text-gray-900">Status Information</h2>
            <button 
              type="button"
              data-action="click->followup-modal#open"
              class="inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
              </svg>
              Schedule Follow-up
            </button>
          </div>
        </div>
        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-sm font-medium text-gray-500">Customer Type</h3>
            <div class="mt-1 flex flex-wrap gap-2" data-controller="communication-status">
              <% Customer::CUSTOMER_TYPES.keys.each do |type| %>
                <button
                  data-communication-status-target="tag"
                  data-action="click->communication-status#update"
                  data-status-type="customer_type"
                  data-status-value="<%= type %>"
                  data-customer-id="<%= @customer.id %>"
                  class="comm-status-tag inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-200 hover:shadow-md
                    <%= type == @customer.customer_type ? 
                        case type
                        when 'High Value' then 'bg-purple-100 text-purple-800 ring-2 ring-purple-300'
                        else 'bg-gray-100 text-gray-800 ring-2 ring-gray-300'
                        end
                      : 
                        case type
                        when 'High Value' then 'bg-purple-50 text-purple-700'
                        else 'bg-gray-50 text-gray-700'
                        end
                    %>"
                >
                  <%= type %>
                </button>
              <% end %>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Lead Source</h3>
            <p class="mt-1 text-lg text-gray-900"><%= @customer.lead_source.present? ? @customer.lead_source : "N/A" %></p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Status</h3>
            <div class="mt-1 flex flex-wrap gap-2" data-controller="communication-status">
              <% Customer::STATUSES.keys.each do |status| %>
                <button
                  data-communication-status-target="tag"
                  data-action="click->communication-status#update"
                  data-status="<%= status %>"
                  data-customer-id="<%= @customer.id %>"
                  class="status-tag inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-200 hover:shadow-md
                    <%= status == @customer.status ? 
                        case status
                        when 'Contact Established' then 'bg-green-100 text-green-800 ring-2 ring-green-300'
                        when 'Exhausted' then 'bg-red-100 text-red-800 ring-2 ring-red-300'
                        when 'Pending' then 'bg-yellow-100 text-yellow-800 ring-2 ring-yellow-300'
                        when 'Contact Not Established' then 'bg-red-100 text-red-800 ring-2 ring-red-300'
                        when 'Unresponsive' then 'bg-orange-100 text-orange-800 ring-2 ring-orange-300'
                        when 'Converted' then 'bg-blue-100 text-blue-800 ring-2 ring-blue-300'
                        when 'Proposal Sent' then 'bg-indigo-100 text-indigo-800 ring-2 ring-indigo-300'
                        when 'Not Interested' then 'bg-gray-100 text-gray-800 ring-2 ring-gray-300'
                        when 'Invalid' then 'bg-purple-100 text-purple-800 ring-2 ring-purple-300'
                        else 'bg-blue-100 text-blue-800 ring-2 ring-blue-300'
                        end
                      : 
                        case status
                        when 'Contact Established' then 'bg-green-50 text-green-700'
                        when 'Exhausted' then 'bg-red-50 text-red-700'
                        when 'Pending' then 'bg-yellow-50 text-yellow-700'
                        when 'Contact Not Established' then 'bg-red-50 text-red-700'
                        when 'Unresponsive' then 'bg-orange-50 text-orange-700'
                        when 'Converted' then 'bg-blue-50 text-blue-700'
                        when 'Proposal Sent' then 'bg-indigo-50 text-indigo-700'
                        when 'Not Interested' then 'bg-gray-50 text-gray-700'
                        when 'Invalid' then 'bg-purple-50 text-purple-700'
                        else 'bg-blue-50 text-blue-700'
                        end
                    %>"
                >
                  <%= status %>
                </button>
              <% end %>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Call Status</h3>
            <div class="mt-1 flex flex-wrap gap-2" data-controller="communication-status">
              <% Customer::CALL_STATUSES.keys.each do |status| %>
                <button
                  data-communication-status-target="tag"
                  data-action="click->communication-status#update"
                  data-status-type="call_status"
                  data-status-value="<%= status %>"
                  data-customer-id="<%= @customer.id %>"
                  class="comm-status-tag inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-200 hover:shadow-md
                    <%= status == @customer.call_status ? 
                        case status
                        when 'Called' then 'bg-green-100 text-green-800 ring-2 ring-green-300'
                        when 'Incorrect Number' then 'bg-red-100 text-red-800 ring-2 ring-red-300'
                        when 'Pending' then 'bg-yellow-100 text-yellow-800 ring-2 ring-yellow-300'
                        when 'Followup' then 'bg-orange-100 text-orange-800 ring-2 ring-orange-300'
                        when 'Connected' then 'bg-blue-100 text-blue-800 ring-2 ring-blue-300'
                        else 'bg-gray-100 text-gray-800 ring-2 ring-gray-300'
                        end
                      : 
                        case status
                        when 'Called' then 'bg-green-50 text-green-700'
                        when 'Incorrect Number' then 'bg-red-50 text-red-700'
                        when 'Pending' then 'bg-yellow-50 text-yellow-700'
                        when 'Followup' then 'bg-orange-50 text-orange-700'
                        when 'Connected' then 'bg-blue-50 text-blue-700'
                        else 'bg-gray-50 text-gray-700'
                        end
                    %>"
                >
                  <%= status %>
                </button>
              <% end %>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Email Status</h3>
            <div class="mt-1 flex flex-wrap gap-2" data-controller="communication-status">
              <% Customer::EMAIL_STATUSES.keys.each do |status| %>
                <button
                  data-communication-status-target="tag"
                  data-action="click->communication-status#update"
                  data-status-type="email_status"
                  data-status-value="<%= status %>"
                  data-customer-id="<%= @customer.id %>"
                  class="comm-status-tag inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-200 hover:shadow-md
                    <%= status == @customer.email_status ? 
                        case status
                        when 'Email Sent' then 'bg-green-100 text-green-800 ring-2 ring-green-300'
                        when 'Incorrect Email' then 'bg-red-100 text-red-800 ring-2 ring-red-300'
                        when 'Pending' then 'bg-yellow-100 text-yellow-800 ring-2 ring-yellow-300'
                        when 'Followup' then 'bg-orange-100 text-orange-800 ring-2 ring-orange-300'
                        when 'Conversation Initiated' then 'bg-blue-100 text-blue-800 ring-2 ring-blue-300'
                        else 'bg-gray-100 text-gray-800 ring-2 ring-gray-300'
                        end
                      : 
                        case status
                        when 'Email Sent' then 'bg-green-50 text-green-700'
                        when 'Incorrect Email' then 'bg-red-50 text-red-700'
                        when 'Pending' then 'bg-yellow-50 text-yellow-700'
                        when 'Followup' then 'bg-orange-50 text-orange-700'
                        when 'Conversation Initiated' then 'bg-blue-50 text-blue-700'
                        else 'bg-gray-50 text-gray-700'
                        end
                    %>"
                >
                  <%= status %>
                </button>
              <% end %>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">WhatsApp Status</h3>
            <div class="mt-1 flex flex-wrap gap-2" data-controller="communication-status">
              <% Customer::WHATSAPP_STATUSES.keys.each do |status| %>
                <button
                  data-communication-status-target="tag"
                  data-action="click->communication-status#update"
                  data-status-type="whatsapp_status"
                  data-status-value="<%= status %>"
                  data-customer-id="<%= @customer.id %>"
                  class="comm-status-tag inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-200 hover:shadow-md
                    <%= status == @customer.whatsapp_status ? 
                        case status
                        when 'WhatsApp Message Sent' then 'bg-green-100 text-green-800 ring-2 ring-green-300'
                        when 'Incorrect Number' then 'bg-red-100 text-red-800 ring-2 ring-red-300'
                        when 'Pending' then 'bg-yellow-100 text-yellow-800 ring-2 ring-yellow-300'
                        when 'Followup' then 'bg-orange-100 text-orange-800 ring-2 ring-orange-300'
                        when 'Conversation Initiated' then 'bg-blue-100 text-blue-800 ring-2 ring-blue-300'
                        else 'bg-gray-100 text-gray-800 ring-2 ring-gray-300'
                        end
                      : 
                        case status
                        when 'WhatsApp Message Sent' then 'bg-green-50 text-green-700'
                        when 'Incorrect Number' then 'bg-red-50 text-red-700'
                        when 'Pending' then 'bg-yellow-50 text-yellow-700'
                        when 'Followup' then 'bg-orange-50 text-orange-700'
                        when 'Conversation Initiated' then 'bg-blue-50 text-blue-700'
                        else 'bg-gray-50 text-gray-700'
                        end
                    %>"
                >
                  <%= status %>
                </button>
              <% end %>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-medium text-gray-500">LinkedIn Status</h3>
            <div class="mt-1 flex flex-wrap gap-2" data-controller="communication-status">
              <% Customer::LINKEDIN_STATUSES.keys.each do |status| %>
                <button
                  data-communication-status-target="tag"
                  data-action="click->communication-status#update"
                  data-status-type="linkedin_status"
                  data-status-value="<%= status %>"
                  data-customer-id="<%= @customer.id %>"
                  class="comm-status-tag inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-200 hover:shadow-md
                    <%= status == @customer.linkedin_status ? 
                        case status
                        when 'Message Sent' then 'bg-green-100 text-green-800 ring-2 ring-green-300'
                        when 'Pending' then 'bg-yellow-100 text-yellow-800 ring-2 ring-yellow-300'
                        when 'Followup' then 'bg-orange-100 text-orange-800 ring-2 ring-orange-300'
                        when 'Conversation Initiated' then 'bg-blue-100 text-blue-800 ring-2 ring-blue-300'
                        else 'bg-gray-100 text-gray-800 ring-2 ring-gray-300'
                        end
                      : 
                        case status
                        when 'Message Sent' then 'bg-green-50 text-green-700'
                        when 'Pending' then 'bg-yellow-50 text-yellow-700'
                        when 'Followup' then 'bg-orange-50 text-orange-700'
                        when 'Conversation Initiated' then 'bg-blue-50 text-blue-700'
                        else 'bg-gray-50 text-gray-700'
                        end
                    %>"
                >
                  <%= status %>
                </button>
              <% end %>
            </div>
          </div>
          <% if @customer.exhaust_status == 'Exhausted' %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Exhausted On</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.exhaust_date&.strftime("%B %d, %Y") || "N/A" %></p>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- Project Information Card -->
      <div class="bg-white shadow-md rounded-lg overflow-hidden mt-6">
        <div class="p-6 border-b border-gray-200">
          <h2 class="text-xl font-bold text-gray-900">Project Information</h2>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <h3 class="text-sm font-medium text-gray-500">Project Type</h3>
            <p class="mt-1 text-lg text-gray-900"><%= @customer.project_type %></p>
          </div>
          <% if @customer.platform != 'Not Applicable' %>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Platform</h3>
            <p class="mt-1 text-lg text-gray-900"><%= @customer.platform %></p>
          </div>
          <% end %>
          <% if @customer.project_scope != 'Not Applicable' %>
          <div>
            <h3 class="text-sm font-medium text-gray-500">Project Scope</h3>
            <p class="mt-1 text-lg text-gray-900"><%= @customer.project_scope %></p>
          </div>
          <% end %>
          <% if @customer.project_estimated_cost.present? %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Estimated Cost</h3>
              <p class="mt-1 text-lg text-gray-900"><%= number_to_currency(@customer.project_estimated_cost) %></p>
            </div>
          <% end %>
          <% if @customer.idea_description.present? %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Idea Description</h3>
              <p class="mt-1 text-gray-900"><%= @customer.idea_description %></p>
            </div>
          <% end %>
          <% if @customer.upwork_profile != 'Not Applicable' %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Upwork Profile</h3>
              <p class="mt-1 text-lg text-gray-900"><%= @customer.upwork_profile %></p>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- External Links Card -->
      <div class="bg-white shadow-md rounded-lg overflow-hidden mt-6">
        <div class="p-6 border-b border-gray-200">
          <h2 class="text-xl font-bold text-gray-900">External Links</h2>
        </div>
        <div class="p-6 space-y-4">
          <% if @customer.linkedin_url.present? %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">LinkedIn Profile</h3>
              <a href="<%= @customer.linkedin_url %>" target="_blank" class="mt-1 text-blue-600 hover:text-blue-800 block">
                <%= @customer.linkedin_url %>
              </a>
            </div>
          <% end %>
          <% if @customer.ccr_link.present? %>
            <div>
              <h3 class="text-sm font-medium text-gray-500">CCR Link</h3>
              <a href="<%= @customer.ccr_link %>" target="_blank" class="mt-1 text-blue-600 hover:text-blue-800 block">
                <%= @customer.ccr_link %>
              </a>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-2">
      <!-- Customer Activities -->
      <div class="bg-white shadow-md rounded-lg overflow-hidden mb-6">
        <div class="p-6 border-b border-gray-200">
          <h2 class="text-xl font-bold text-gray-900">Recent Activities</h2>
        </div>
        <div class="p-6">
          <% if @activities.any? %>
            <div class="flow-root">
              <ul role="list" class="-mb-8">
                <% @activities.each_with_index do |activity, index| %>
                  <li>
                    <div class="relative pb-8">
                      <% if index < @activities.size - 1 %>
                        <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                      <% end %>
                      <div class="relative flex space-x-3">
                        <div>
                          <span class="h-8 w-8 rounded-full bg-blue-500 flex items-center justify-center ring-8 ring-white">
                            <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                            </svg>
                          </span>
                        </div>
                        <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                          <div>
                            <p class="text-sm text-gray-500"><%= activity.action %></p>
                            <p class="text-sm text-gray-700"><%= activity.details %></p>
                          </div>
                          <div class="text-right text-sm whitespace-nowrap text-gray-500">
                            <time datetime="<%= activity.created_at.iso8601 %>"><%= time_ago_in_words(activity.created_at) %> ago</time>
                            <% if activity.user.present? %>
                              <p>by <%= activity.user.name %></p>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>
          <% else %>
            <p class="text-gray-500 text-center">No activities recorded yet.</p>
          <% end %>
        </div>
      </div>

      <!-- Customer Deals -->
      <div class="mt-8">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-gray-900">Deals</h2>
          <%= link_to "New Deal", new_deal_path(customer_id: @customer.id), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
        </div>
        
        <% if @customer.deals.any? %>
          <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stage</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  <% @customer.deals.each do |deal| %>
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-medium text-gray-900"><%= deal.title %></div>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-gray-900"><%= number_to_currency(deal.amount) %></div>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-gray-900"><%= deal.deal_stage.name %></div>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                          <%= deal.status == 'active' ? 'bg-blue-100 text-blue-800' : 
                              deal.status == 'won' ? 'bg-green-100 text-green-800' : 
                              'bg-red-100 text-red-800' %>">
                          <%= deal.status&.capitalize %>
                        </span>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                        <%= link_to "View", deal_path(deal), class: "text-blue-600 hover:text-blue-900 mr-3" %>
                        <%= link_to "Edit", edit_deal_path(deal), class: "text-indigo-600 hover:text-indigo-900" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% else %>
          <div class="bg-white shadow-md rounded-lg p-6 text-center">
            <p class="text-gray-500">No deals found for this customer.</p>
            <p class="mt-2">
              <%= link_to "Create a new deal", new_deal_path(customer_id: @customer.id), class: "text-blue-600 hover:text-blue-800" %>
            </p>
          </div>
        <% end %>
      </div>
      
      <!-- Customer Call Recordings -->
      <div class="mt-8" data-controller="recording">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-gray-900">Call Recordings</h2>
          <%= link_to "Make a Call", calling_path(deal_id: @customer.deals.first&.id), class: "bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" if @customer.deals.any? %>
        </div>
        
        <div class="bg-white shadow-md rounded-lg overflow-hidden" data-controller="transcript">
          <% if @recordings.any? %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Agent</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                <% @recordings.each do |recording| %>
                  <% if recording.audio_file.attached? %>
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= recording.date.strftime("%B %d, %Y %I:%M %p") %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= "#{recording.duration / 60}:#{(recording.duration % 60).to_s.rjust(2, '0')}" %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= recording.user&.name || 'Unknown' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                        <button data-action="recording#play"
                                data-url="<%= recording.audio_file.url %>"
                                data-recording-id="<%= recording.id %>"
                                class="text-blue-600 hover:text-blue-900 mr-3">
                          <i class="fas fa-play"></i> Play
                        </button>
                        <% if recording.transcribed? %>
                          <button data-action="transcript#show" data-recording-id="<%= recording.id %>" class="text-green-600 hover:text-green-900 mr-3">
                            <i class="fas fa-file-alt"></i> Transcript
                          </button>
                        <% end %>
                        <a href="<%= recording.audio_file.url %>" download class="text-gray-600 hover:text-gray-900">
                          <i class="fas fa-download"></i> Download
                        </a>
                      </td>
                    </tr>
                  <% end %>
                <% end %>
                </tbody>
              </table>
            </div>
            
            <div id="recording-player" data-recording-target="player" class="hidden p-4 bg-gray-100">
              <h4 class="font-bold mb-2">Playing Recording</h4>
              <audio id="audio-player" 
                     data-recording-target="audio" 
                     data-transcript-target="audioPlayer" 
                     data-action="timeupdate->transcript#updateHighlight" 
                     controls 
                     class="w-full"></audio>
            </div>
          <% else %>
            <div class="text-center py-8">
              <p class="text-gray-500">No call recordings found for this customer.</p>
            </div>
          <% end %>
        
          <!-- Transcript Modal -->
          <div id="transcript-modal" data-transcript-target="modal" data-action="click->transcript#closeWithClick keydown@window->transcript#closeWithEscape" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 overflow-y-auto">
            <div class="min-h-screen px-4 text-center">
              <div class="fixed inset-0 transition-opacity" aria-hidden="true">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
              </div>

              <!-- Modal panel -->
              <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-4xl sm:w-full relative">
                <div class="absolute top-0 right-0 pt-4 pr-4">
                  <button type="button" data-action="transcript#close" class="text-gray-400 hover:text-gray-500">
                    <span class="sr-only">Close</span>
                    <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                  <div class="sm:flex sm:items-start">
                    <div class="mt-3 text-center sm:mt-0 sm:text-left w-full">
                      <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Call Transcript</h3>
                      <div id="transcript-content" data-transcript-target="content" class="mt-2 space-y-4 max-h-[60vh] overflow-y-auto">
                        <!-- Transcript content will be inserted here -->
                      </div>
                    </div>
                  </div>
                </div>
                <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                  <button type="button" data-action="transcript#close" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Close
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Customer Tasks -->
      <div class="mt-8">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-gray-900">Tasks</h2>
          <%= link_to "New Task", new_task_path(customer_id: @customer.id), class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded" %>
        </div>
        
        <div class="bg-white shadow-md rounded-lg overflow-hidden">
          <% if @customer.tasks.any? %>
            <div class="flow-root">
              <ul class="divide-y divide-gray-200">
                <% @customer.tasks.order(due_date: :asc).each do |task| %>
                  <li class="px-6 py-4">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center">
                        <div class="flex-shrink-0">
                          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                            <%= case task.priority
                                when 'High' then 'bg-red-100 text-red-800'
                                when 'Medium' then 'bg-yellow-100 text-yellow-800'
                                when 'Low' then 'bg-green-100 text-green-800'
                                end %>">
                            <%= task.priority %>
                          </span>
                        </div>
                        <div class="ml-3">
                          <div class="text-sm font-medium text-gray-900">
                            <%= link_to task.title, task_path(task), class: "text-blue-600 hover:text-blue-900" %>
                            <% if task.completed? %>
                              <span class="ml-2 px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800 rounded-full">Completed</span>
                            <% elsif task.overdue? %>
                              <span class="ml-2 px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800 rounded-full">Overdue</span>
                            <% elsif task.due_today? && task.pending? %>
                              <span class="ml-2 px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">Due Today</span>
                            <% elsif task.pending? %>
                              <span class="ml-2 px-2 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">Pending</span>
                            <% elsif task.in_progress? %>
                              <span class="ml-2 px-2 py-0.5 text-xs font-medium bg-purple-100 text-purple-800 rounded-full">In Progress</span>
                            <% elsif task.cancelled? %>
                              <span class="ml-2 px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800 rounded-full">Cancelled</span>
                            <% end %>
                          </div>
                          <div class="text-sm text-gray-500">
                            Due: <%= task.due_date.strftime("%b %d, %Y at %I:%M %p") %> • 
                            Assigned to: <%= task.user.name %>
                          </div>
                        </div>
                      </div>
                      <div class="flex">
                        <% unless task.completed? %>
                          <%= button_to complete_task_path(task), method: :patch, class: "mr-2 inline-flex items-center px-2.5 py-1.5 border border-transparent text-xs font-medium rounded text-green-700 bg-green-100 hover:bg-green-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
                            Complete
                          <% end %>
                        <% end %>
                        <%= link_to edit_task_path(task), class: "inline-flex items-center px-2.5 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                          Edit
                        <% end %>
                      </div>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>
          <% else %>
            <div class="text-center py-8">
              <p class="text-gray-500">No tasks found for this customer.</p>
              <p class="mt-2">
                <%= link_to "Create a new task", new_task_path(customer_id: @customer.id), class: "text-blue-600 hover:text-blue-800" %>
              </p>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- WhatsApp Chat -->
      <div class="mt-8">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-gray-900">WhatsApp Chat</h2>
        </div>
        
        <div class="bg-white shadow-md rounded-lg overflow-hidden" 
             data-controller="whatsapp-chat" 
             data-whatsapp-chat-url-value="<%= whatsapp_messages_customer_path(@customer) %>"
             data-whatsapp-chat-system-number-value="<%= Rails.application.credentials.dig(:WHATSAPP_SYSTEM_NUMBER) || '923004018239' %>">
          <div class="border-b border-gray-200 p-4 bg-green-50">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="h-10 w-10 rounded-full bg-green-500 flex items-center justify-center mr-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-md font-semibold text-gray-900"><%= @customer.name %></h3>
                  <p class="text-sm text-gray-500"><%= @customer.phone %></p>
                </div>
              </div>
              <div class="flex items-center space-x-4">
                <button 
                  data-whatsapp-chat-target="refreshButton"
                  data-action="click->whatsapp-chat#refresh"
                  class="inline-flex items-center px-2 py-1 border border-transparent text-xs font-medium rounded text-green-700 bg-green-100 hover:bg-green-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                  Refresh
                </button>
                <div class="flex items-center">
                  <div class="h-6 w-6 rounded-full bg-blue-500 flex items-center justify-center mr-1">
                    <i class="fas fa-user-tie text-white text-xs"></i>
                  </div>
                  <span class="text-xs text-gray-700">Support Agent</span>
                  <span class="text-xs text-gray-500 ml-1">(<%= Rails.application.credentials.dig(:WHATSAPP_SYSTEM_NUMBER) || '923004018239' %>)</span>
                </div>
                <div class="flex items-center">
                  <div class="h-6 w-6 rounded-full bg-green-500 flex items-center justify-center mr-1">
                    <i class="fas fa-user text-white text-xs"></i>
                  </div>
                  <span class="text-xs text-gray-700">Customer</span>
                  <span class="text-xs text-gray-500 ml-1">(<%= @customer.whatsapp_chat_id&.gsub('@c.us', '') %>)</span>
                </div>
              </div>
            </div>
          </div>
          
          <div class="p-4 h-96 overflow-y-auto" data-whatsapp-chat-target="messages">
            <div class="flex justify-center">
              <div class="spinner-border text-green-500" role="status" data-whatsapp-chat-target="loader">
                <span class="sr-only">Loading...</span>
                <svg class="animate-spin h-8 w-8 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </div>
            </div>
            <div class="space-y-4" data-whatsapp-chat-target="messageContainer">
              <!-- Messages will be loaded here -->
            </div>
          </div>
          
          <div data-whatsapp-chat-target="noMessages" class="p-6 text-center hidden">
            <p class="text-gray-500">No WhatsApp messages found.</p>
          </div>

          <div data-whatsapp-chat-target="error" class="p-6 text-center hidden">
            <p class="text-red-500">Error loading WhatsApp messages.</p>
            <p class="text-gray-500" data-whatsapp-chat-target="errorMessage"></p>
          </div>
          
          <!-- Message Input Form -->
          <div class="border-t border-gray-200 p-4 bg-gray-50" data-whatsapp-chat-target="messageForm">
            <div data-whatsapp-chat-target="sendingIndicator" class="mb-2 text-center hidden">
              <div class="inline-flex items-center px-2 py-1 text-xs font-medium text-blue-700 bg-blue-100 rounded-full">
                <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-blue-700" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Sending message...
              </div>
            </div>
            
            <div data-whatsapp-chat-target="sendError" class="mb-2 text-center hidden">
              <p class="text-red-500 text-sm" data-whatsapp-chat-target="sendErrorMessage"></p>
            </div>
            
            <div class="flex items-start">
              <div class="flex-grow mr-2">
                <textarea 
                  data-whatsapp-chat-target="messageInput"
                  data-action="keydown->whatsapp-chat#handleKeyPress"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                  placeholder="Type a message..."
                  rows="2"
                ></textarea>
                
                <div class="flex items-center mt-2">
                  <label class="flex items-center cursor-pointer mr-4">
                    <input type="radio" name="message_type" value="text" class="hidden" data-whatsapp-chat-target="textRadio" data-action="change->whatsapp-chat#toggleMessageType" checked>
                    <div class="w-4 h-4 rounded-full border border-gray-400 flex items-center justify-center mr-2 radio-button">
                      <div class="w-2 h-2 rounded-full bg-green-500 hidden radio-dot"></div>
                    </div>
                    <span class="text-sm text-gray-700">Text</span>
                  </label>
                  
                  <label class="flex items-center cursor-pointer">
                    <input type="radio" name="message_type" value="media" class="hidden" data-whatsapp-chat-target="mediaRadio" data-action="change->whatsapp-chat#toggleMessageType">
                    <div class="w-4 h-4 rounded-full border border-gray-400 flex items-center justify-center mr-2 radio-button">
                      <div class="w-2 h-2 rounded-full bg-green-500 hidden radio-dot"></div>
                    </div>
                    <span class="text-sm text-gray-700">Media</span>
                  </label>
                </div>
                
                <div class="hidden mt-2" data-whatsapp-chat-target="mediaInputs">
                  <div class="flex flex-col space-y-2">
                    <input 
                      type="text" 
                      data-whatsapp-chat-target="mediaUrl" 
                      class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                      placeholder="Media URL (must be a public accessible URL)"
                    >
                    <input 
                      type="text" 
                      data-whatsapp-chat-target="mediaCaption" 
                      class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" 
                      placeholder="Caption (optional)"
                    >
                    <select 
                      data-whatsapp-chat-target="mediaType" 
                      class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                    >
                      <option value="image">Image</option>
                      <option value="video">Video</option>
                      <option value="audio">Audio</option>
                      <option value="document">Document</option>
                    </select>
                  </div>
                </div>
              </div>
              
              <button 
                data-whatsapp-chat-target="sendButton"
                data-action="click->whatsapp-chat#sendMessage"
                class="inline-flex items-center px-4 py-2 border border-transparent rounded-full shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Email Communication -->
      <div class="mt-8">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-gray-900">Email Communication</h2>
          <div class="flex space-x-2">
            <%= button_to fetch_customer_emails_path(@customer), method: :get, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md bg-blue-100 text-blue-700 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500", form: { data: { turbo: true } } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" />
              </svg>
              Fetch Emails
            <% end %>
            <%= link_to new_customer_email_path(@customer), class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md bg-green-100 text-green-700 hover:bg-green-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
              </svg>
              New Email
            <% end %>
          </div>
        </div>
        
        <div class="bg-white shadow-md rounded-lg overflow-hidden">
          <% if @customer.emails.any? %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">From</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subject</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  <% @customer.emails.recent.limit(5).each do |email| %>
                    <tr class="<%= email.received? && email.read_at.nil? ? 'bg-blue-50' : '' %>">
                      <td class="px-6 py-4 whitespace-nowrap">
                        <% if email.received? %>
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                            Received
                          </span>
                        <% else %>
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            Sent
                          </span>
                        <% end %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                        <%= email.sender_name %>
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-900">
                        <div class="max-w-xs truncate">
                          <%= email.display_subject %>
                        </div>
                        <% if email.snippet.present? %>
                          <div class="max-w-xs truncate text-xs text-gray-500 mt-1">
                            <%= email.snippet %>
                          </div>
                        <% end %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                        <%= email.formatted_date %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <%= link_to "View", customer_email_path(@customer, email), class: "text-blue-600 hover:text-blue-900" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            <div class="p-4 border-t border-gray-200 text-center">
              <%= link_to "View All Emails", customer_emails_path(@customer), class: "text-blue-600 hover:text-blue-800" %>
            </div>
          <% else %>
            <div class="text-center py-8">
              <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No emails</h3>
              <p class="mt-1 text-sm text-gray-500">
                Click "Fetch Emails" to retrieve emails or "New Email" to send one.
              </p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<div id="followup-modal-wrapper" data-controller="followup-modal">
  <%= render partial: 'customer_followups/modal' %>
</div>

<style>
  .radio-button:has(+ input:checked) .radio-dot {
    display: block;
  }
  
  /* Enhanced document styles */
  .drop-zone-active {
    border-color: #3b82f6 !important;
    background-color: #dbeafe !important;
  }
  
  .document-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
  
  .file-icon {
    transition: all 0.2s ease-in-out;
  }
  
  .file-icon:hover {
    transform: scale(1.05);
  }
  
  .progress-bar {
    transition: width 0.3s ease-out;
  }
  
  .error-message {
    animation: fadeInDown 0.3s ease-out;
  }
  
  @keyframes fadeInDown {
    0% {
      opacity: 0;
      transform: translateY(-10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .document-grid {
    animation: fadeIn 0.5s ease-out;
  }
  
  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
</style>
