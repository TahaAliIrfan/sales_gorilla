<%# Relay lead workspace — the hero view. A 340px context rail beside one
    continuous, multi-channel conversation canvas + composer.
    Ports docs/design/relay-app/project/app/view-lead.jsx, honest to the DB. %>
<% content_for :title, "#{@customer.name} — #{current_organization&.name}" %>
<% content_for :body_class, "app__body--full" %>

<div class="lead" data-controller="relay--composer">
  <%= render "customers/relay/rail", customer: @customer %>

  <%= render "customers/relay/conversation", customer: @customer, conversation: @conversation %>
</div>
