<%= form_with(model: customer, class: "space-y-6") do |form| %>
  <% if customer.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(customer.errors.count, "error") %> prohibited this customer from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% customer.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Basic Information</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= form.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :phone, "Phone Number", class: "block text-sm font-medium text-gray-700" %>
        <div class="flex mt-1">
          <%= form.select :country_code, ["+1", "+44", "+91", "+92", "+971", "+966"], { include_blank: "Code" }, class: "rounded-l-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <%= form.telephone_field :phone, class: "flex-1 rounded-r-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", data: { action: "click->phone#dial" } %>
        </div>
      </div>

      <div>
        <%= form.label :company, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :company, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :country, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :country, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", list: "country-list" %>
        <datalist id="country-list">
          <option value="United States">
          <option value="United Kingdom">
          <option value="Canada">
          <option value="Australia">
          <option value="India">
          <option value="Pakistan">
          <option value="UAE">
          <option value="Saudi Arabia">
          <!-- Add more countries as needed -->
        </datalist>
      </div>

      <div>
        <%= form.label :address, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :address, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6" data-controller="lead-source">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Source & Project Details</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :lead_source, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :lead_source, Customer::LEAD_SOURCES.keys, { include_blank: "Select Source" },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
            data: { action: "change->lead-source#toggleCcrFields", "lead-source-target": "select" } %>
      </div>

      <div>
        <%= form.label :linkedin_url, "LinkedIn URL", class: "block text-sm font-medium text-gray-700" %>
        <%= form.url_field :linkedin_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div data-lead-source-target="ccrFields" class="<%= customer.lead_source == 'CCR' ? '' : 'hidden' %> space-y-4">
        <%= form.label :ccr_link, "CCR Link", class: "block text-sm font-medium text-gray-700" %>
        <%= form.url_field :ccr_link, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "Google Drive Link" %>
      </div>

      <div data-lead-source-target="ccrCost" class="<%= customer.lead_source == 'CCR' ? '' : 'hidden' %>">
        <%= form.label :project_estimated_cost, "Project Estimated Cost", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1 flex rounded-md shadow-sm">
          <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">$</span>
          <%= form.number_field :project_estimated_cost, class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md border-gray-300 focus:border-blue-500 focus:ring-blue-500", step: "0.01" %>
        </div>
      </div>

      <div>
        <%= form.label :project_type, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :project_type, Customer::PROJECT_TYPES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div class="md:col-span-2">
        <%= form.label :idea_description, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :idea_description, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Status & Communication</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :status, Customer::STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <% if current_user&.admin? || current_user&.sales_manager? %>
        <div>
          <%= form.label :user_id, "Assigned To", class: "block text-sm font-medium text-gray-700" %>
          <%= form.collection_select :user_id, User.all, :id, :name, { include_blank: "Unassigned" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
      <% end %>

      <div>
        <%= form.label :call_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :call_status, Customer::CALL_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :email_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :email_status, Customer::EMAIL_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :whatsapp_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :whatsapp_status, Customer::WHATSAPP_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :linkedin_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :linkedin_status, Customer::LINKEDIN_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :upwork_profile, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :upwork_profile, Customer::UPWORK_PROFILES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :exhaust_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :exhaust_status, Customer::EXHAUST_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div class="md:col-span-2">
        <%= form.label :notes, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :notes, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-3 pt-5">
    <%= link_to "Cancel", customers_path, class: "py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    <%= form.submit class: "py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
<% end %> 