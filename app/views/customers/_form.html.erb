<%= form_with(model: customer, class: "space-y-6") do |form| %>
  <div class="mb-2">
    <p class="micro mb-2"><%= customer.new_record? ? "Create" : "Edit" %></p>
    <h1 class="font-display text-3xl font-bold tracking-tight text-ink">
      <%= customer.new_record? ? "New customer" : customer.name %>
    </h1>
    <p class="mt-2 text-sm text-ink-soft">
      Fill in the details below to <%= customer.new_record? ? "create a new" : "update this" %> customer record.
    </p>
  </div>

  <%= render "shared/form_errors", record: customer %>

  <%# ============================== Basic info ============================ %>
  <%= render "shared/panel", eyebrow: "Basic information" do %>
    <div class="grid gap-5 md:grid-cols-2">
      <%= render "shared/form_field", f: form, field: :name, autofocus: customer.new_record?, required: true %>
      <%= render "shared/form_field", f: form, field: :email, type: "email" %>
      <%= render "shared/form_field", f: form, field: :phone, type: "tel", label: "Phone number",
            placeholder: "+923001234567",
            hint: "Include country code with + sign." %>
      <%= render "shared/form_field", f: form, field: :company %>

      <%# Country dropdown (Stimulus) — kept as-is functionally, restyled === %>
      <div data-controller="country">
        <%= form.label :country, class: "micro mb-1 block", style: "color: var(--color-ink-soft)" %>
        <%= form.hidden_field :country, data: { country_target: "select" } %>
        <div class="relative">
          <button type="button"
                  data-action="click->country#toggleDropdown"
                  class="flex w-full items-center rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink shadow-sm ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)] focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]">
            <span data-country-target="selectedFlag" class="flex-grow text-left">
              <%= customer.country.presence || "Select a country" %>
            </span>
            <svg class="h-4 w-4 text-ink-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div data-country-target="dropdown"
               class="hidden absolute z-30 mt-1 max-h-60 w-full overflow-auto rounded-md bg-panel py-1 text-sm shadow-lift ring-1 ring-[var(--color-line-2)]">
            <div class="sticky top-0 bg-panel p-2">
              <input type="text"
                     placeholder="Search countries…"
                     data-country-target="searchInput"
                     data-action="input->country#search"
                     class="block w-full rounded-md border-0 bg-paper px-3 py-2 text-sm text-ink ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]">
            </div>
            <ul class="py-1"></ul>
          </div>
        </div>
      </div>

      <div>
        <%= form.label :timezone, "Timezone", class: "micro mb-1 block", style: "color: var(--color-ink-soft)" %>
        <%= form.select :timezone,
              [
                [ "Auto-detect from country", "" ],
                [ "Common Timezones", [
                  [ "US Eastern (New York)",    "America/New_York" ],
                  [ "US Central (Chicago)",     "America/Chicago" ],
                  [ "US Mountain (Denver)",     "America/Denver" ],
                  [ "US Pacific (Los Angeles)", "America/Los_Angeles" ],
                  [ "UK (London)",              "Europe/London" ],
                  [ "Central European",         "Europe/Paris" ],
                  [ "India (New Delhi)",        "Asia/Kolkata" ],
                  [ "China (Beijing)",          "Asia/Shanghai" ],
                  [ "Japan (Tokyo)",            "Asia/Tokyo" ],
                  [ "Australia (Sydney)",       "Australia/Sydney" ]
                ] ],
                [ "All Timezones", ActiveSupport::TimeZone.all.map { |tz| [ "#{tz.formatted_offset} #{tz.name.tr('_', ' ')}", tz.name ] } ]
              ],
              {},
              class: "mono block w-full rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink shadow-sm ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]" %>
        <p class="mt-1 text-xs text-ink-soft">If not set, the timezone falls back to the country.</p>
      </div>

      <div class="md:col-span-2">
        <%= render "shared/form_field", f: form, field: :address, type: "textarea", rows: 2 %>
      </div>

      <%# Documents === %>
      <div class="md:col-span-2">
        <%= form.label :documents, "Attachment (PDF, DOC, or image)", class: "micro mb-1 block", style: "color: var(--color-ink-soft)" %>
        <div class="flex items-center gap-3">
          <% if form.object.documents.attached? %>
            <% doc = form.object.documents.first %>
            <div>
              <% if doc&.content_type&.start_with?("image/") %>
                <%= image_tag doc.variant(resize_to_limit: [ 96, 96 ]), class: "h-16 w-auto rounded-md object-cover ring-1 ring-[var(--color-line-2)]" %>
              <% else %>
                <div class="mono inline-flex items-center gap-1.5 rounded-md bg-[var(--color-line)] px-3 py-2 text-xs font-medium text-ink">
                  📎 <%= doc&.filename || "Document" %>
                </div>
              <% end %>
            </div>
            <label class="cursor-pointer rounded-md bg-paper px-3.5 py-2 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
              Change file
              <%= form.file_field :documents, class: "hidden", accept: "image/*,.pdf,.doc,.docx", multiple: true %>
            </label>
          <% else %>
            <label class="inline-flex cursor-pointer items-center gap-2 rounded-md bg-paper px-3.5 py-2 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
              Choose file
              <%= form.file_field :documents, class: "hidden", accept: "image/*,.pdf,.doc,.docx", multiple: true %>
            </label>
          <% end %>
        </div>
        <p class="mt-1 text-xs text-ink-soft">PDF, DOC, DOCX, JPG, PNG, GIF (max 10MB).</p>
      </div>
    </div>
  <% end %>

  <%# ========================= Source & Project ========================== %>
  <div data-controller="lead-source">
    <%= render "shared/panel", eyebrow: "Source & project details" do %>
      <div class="grid gap-5 md:grid-cols-2">
        <div>
          <%= form.label :lead_source, class: "micro mb-1 block", style: "color: var(--color-ink-soft)" %>
          <%= form.select :lead_source, Customer::LEAD_SOURCES.keys,
                { include_blank: "Select source" },
                class: "mono block w-full rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink shadow-sm ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]",
                data: { action: "change->lead-source#toggleCcrFields", "lead-source-target": "select" } %>
        </div>
        <%= render "shared/form_field", f: form, field: :linkedin_url, type: "url", label: "LinkedIn URL" %>
        <%= render "shared/form_field", f: form, field: :meta_lead_id, label: "Meta lead ID",
              placeholder: "e.g. 1234567890123456" %>

        <div data-lead-source-target="ccrFields" class="<%= 'hidden' unless customer.lead_source == 'CCR' %>">
          <%= render "shared/form_field", f: form, field: :ccr_link, type: "url",
                label: "CCR link", placeholder: "Google Drive link" %>
        </div>

        <div data-lead-source-target="ccrCost" class="<%= 'hidden' unless customer.lead_source == 'CCR' %>">
          <%= form.label :project_estimated_cost, "Project estimated cost",
                class: "micro mb-1 block", style: "color: var(--color-ink-soft)" %>
          <div class="relative">
            <span class="pointer-events-none absolute inset-y-0 left-3 grid place-items-center text-sm text-ink-soft">$</span>
            <%= form.number_field :project_estimated_cost, step: "0.01",
                  class: "mono block w-full rounded-md border-0 bg-paper py-2.5 pl-7 pr-3.5 text-sm text-ink shadow-sm ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]" %>
          </div>
        </div>

        <%= render "shared/form_field", f: form, field: :project_type, type: "select",
              options: Customer::PROJECT_TYPES.keys.zip(Customer::PROJECT_TYPES.values) %>
        <%= render "shared/form_field", f: form, field: :platform, type: "select",
              options: Customer::PLATFORMS.keys.zip(Customer::PLATFORMS.values) %>
        <%= render "shared/form_field", f: form, field: :project_scope, type: "select",
              options: Customer::PROJECT_SCOPES.keys.zip(Customer::PROJECT_SCOPES.values) %>

        <div class="md:col-span-2">
          <%= render "shared/form_field", f: form, field: :idea_description, type: "textarea", rows: 4 %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ====================== Status & Communication ======================= %>
  <%= render "shared/panel", eyebrow: "Status & communication" do %>
    <div class="grid gap-5 md:grid-cols-2">
      <%= render "shared/form_field", f: form, field: :status, type: "select",
            options: Customer::STATUSES.keys.zip(Customer::STATUSES.values) %>

      <% if current_user&.admin? %>
        <div>
          <%= form.label :user_id, "Assigned to",
                class: "micro mb-1 block", style: "color: var(--color-ink-soft)" %>
          <%= form.collection_select :user_id, User.all, :id, :name,
                { include_blank: "Unassigned" },
                class: "mono block w-full rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink shadow-sm ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]" %>
        </div>
      <% end %>

      <%= render "shared/form_field", f: form, field: :call_status, type: "select",
            options: Customer::CALL_STATUSES.keys.zip(Customer::CALL_STATUSES.values) %>
      <%= render "shared/form_field", f: form, field: :preferred_calling_time,
            label: "Preferred calling time" %>
      <%= render "shared/form_field", f: form, field: :email_status, type: "select",
            options: Customer::EMAIL_STATUSES.keys.zip(Customer::EMAIL_STATUSES.values) %>
      <%= render "shared/form_field", f: form, field: :whatsapp_status, type: "select",
            options: Customer::WHATSAPP_STATUSES.keys.zip(Customer::WHATSAPP_STATUSES.values) %>
      <%= render "shared/form_field", f: form, field: :linkedin_status, type: "select",
            options: Customer::LINKEDIN_STATUSES.keys.zip(Customer::LINKEDIN_STATUSES.values) %>
      <%= render "shared/form_field", f: form, field: :upwork_profile, type: "select",
            options: Customer::UPWORK_PROFILES.keys.zip(Customer::UPWORK_PROFILES.values) %>
      <%= render "shared/form_field", f: form, field: :exhaust_status, type: "select",
            options: Customer::EXHAUST_STATUSES.keys.zip(Customer::EXHAUST_STATUSES.values) %>

      <div class="md:col-span-2">
        <%= render "shared/form_field", f: form, field: :repeat_lead, type: "checkbox",
              label: "Mark as repeat lead",
              hint: "Tick if this customer has contacted us before with a different email/phone, or is returning after a long time." %>
      </div>

      <div class="md:col-span-2">
        <%= render "shared/form_field", f: form, field: :notes, type: "textarea", rows: 4 %>
      </div>
    </div>
  <% end %>

  <div class="flex items-center justify-end gap-2 border-t border-[var(--color-line)] pt-5">
    <%= link_to "Cancel", customers_path,
          class: "rounded-md px-4 py-2 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]" %>
    <%= form.submit class: "rounded-md px-4 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5 cursor-pointer",
                    style: "background: var(--brand-primary)" %>
  </div>
<% end %>
