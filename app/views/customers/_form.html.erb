<%= form_with(model: customer, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if customer.errors.any? %>
    <%= render "settings/errors", record: customer %>
  <% end %>

  <%# ============================== Basic info ============================ %>
  <div class="sect">
    <div class="sect__head"><div class="sect__title">Basic information</div></div>
    <div class="sect__body">
      <div class="grid grid-2">
        <%= render "shared/relay_field", f: form, field: :name, autofocus: customer.new_record?, required: true %>
        <%= render "shared/relay_field", f: form, field: :email, type: "email" %>
        <%= render "shared/relay_field", f: form, field: :phone, type: "tel", label: "Phone number",
              mono: true, placeholder: "+923001234567",
              hint: "Include country code with a + sign." %>
        <%= render "shared/relay_field", f: form, field: :company %>

        <%# Country dropdown (Stimulus) — kept functionally, restyled to DS === %>
        <div class="rl-field" data-controller="country">
          <%= form.label :country, class: "rl-label" %>
          <%= form.hidden_field :country, data: { country_target: "select" } %>
          <div style="position:relative">
            <button type="button" class="rl-select" style="text-align:left;display:flex;align-items:center"
                    data-action="click->country#toggleDropdown">
              <span data-country-target="selectedFlag" class="grow">
                <%= customer.country.presence || "Select a country" %>
              </span>
            </button>
            <div data-country-target="dropdown"
                 class="hidden rl-menu" style="position:absolute;z-index:30;margin-top:4px;max-height:240px;overflow:auto;width:100%;left:0">
              <div style="position:sticky;top:0;background:var(--color-surface);padding:8px">
                <input type="text" class="rl-input rl-input--sm" placeholder="Search countries…"
                       data-country-target="searchInput" data-action="input->country#search">
              </div>
              <ul style="list-style:none;margin:0;padding:4px 0"></ul>
            </div>
          </div>
        </div>

        <div class="rl-field">
          <%= form.label :timezone, "Timezone", class: "rl-label" %>
          <%= form.select :timezone,
                [
                  [ "Auto-detect from country", "" ],
                  [ "Common Timezones", [
                    [ "US Eastern (New York)",    "America/New_York" ],
                    [ "US Central (Chicago)",     "America/Chicago" ],
                    [ "US Mountain (Denver)",     "America/Denver" ],
                    [ "US Pacific (Los Angeles)", "America/Los_Angeles" ],
                    [ "UK (London)",              "Europe/London" ],
                    [ "Central European",         "Europe/Paris" ],
                    [ "India (New Delhi)",        "Asia/Kolkata" ],
                    [ "China (Beijing)",          "Asia/Shanghai" ],
                    [ "Japan (Tokyo)",            "Asia/Tokyo" ],
                    [ "Australia (Sydney)",       "Australia/Sydney" ]
                  ] ],
                  [ "All Timezones", ActiveSupport::TimeZone.all.map { |tz| [ "#{tz.formatted_offset} #{tz.name.tr('_', ' ')}", tz.name ] } ]
                ],
                {},
                class: "rl-select mono" %>
          <p class="rl-help">If not set, the timezone falls back to the country.</p>
        </div>

        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :address, type: "textarea", rows: 2 %>
        </div>

        <%# Documents === %>
        <div class="rl-field" style="grid-column:1 / -1">
          <%= form.label :documents, "Attachment (PDF, DOC, or image)", class: "rl-label" %>
          <div class="row" style="gap:12px">
            <% if form.object.documents.attached? %>
              <% doc = form.object.documents.first %>
              <% if doc&.content_type&.start_with?("image/") %>
                <%= image_tag doc.variant(resize_to_limit: [ 96, 96 ]), style: "height:64px;width:auto;border-radius:var(--radius-md);border:1px solid var(--color-border)" %>
              <% else %>
                <span class="rl-chip mono"><%= relay_icon("paperclip", size: 14) %><%= doc&.filename || "Document" %></span>
              <% end %>
              <label class="rl-btn rl-btn--secondary rl-btn--sm" style="cursor:pointer">
                Change file
                <%= form.file_field :documents, class: "hidden", accept: "image/*,.pdf,.doc,.docx", multiple: true %>
              </label>
            <% else %>
              <label class="rl-btn rl-btn--secondary rl-btn--sm" style="cursor:pointer">
                <%= relay_icon("upload", size: 14) %>Choose file
                <%= form.file_field :documents, class: "hidden", accept: "image/*,.pdf,.doc,.docx", multiple: true %>
              </label>
            <% end %>
          </div>
          <p class="rl-help">PDF, DOC, DOCX, JPG, PNG, GIF (max 10MB).</p>
        </div>
      </div>
    </div>
  </div>

  <%# ========================= Source & Project ========================== %>
  <div class="sect" data-controller="lead-source">
    <div class="sect__head"><div class="sect__title">Source &amp; project details</div></div>
    <div class="sect__body">
      <div class="grid grid-2">
        <div class="rl-field">
          <%= form.label :lead_source, class: "rl-label" %>
          <%= form.select :lead_source, current_organization.taxonomy_values("lead_source"),
                { include_blank: "Select source" },
                class: "rl-select mono",
                data: { action: "change->lead-source#toggleCcrFields", "lead-source-target": "select" } %>
        </div>
        <%= render "shared/relay_field", f: form, field: :linkedin_url, type: "url", label: "LinkedIn URL" %>
        <%= render "shared/relay_field", f: form, field: :meta_lead_id, label: "Meta lead ID",
              mono: true, placeholder: "e.g. 1234567890123456" %>

        <div data-lead-source-target="ccrFields" class="<%= 'hidden' unless customer.lead_source == 'CCR' %>">
          <%= render "shared/relay_field", f: form, field: :ccr_link, type: "url",
                label: "CCR link", placeholder: "Google Drive link" %>
        </div>

        <div class="rl-field <%= 'hidden' unless customer.lead_source == 'CCR' %>" data-lead-source-target="ccrCost">
          <%= form.label :project_estimated_cost, "Project estimated cost", class: "rl-label" %>
          <div class="rl-inputwrap">
            <span class="rl-affix">$</span>
            <%= form.number_field :project_estimated_cost, step: "0.01", class: "rl-input mono" %>
          </div>
        </div>

        <%= render "shared/relay_field", f: form, field: :project_type, type: "select",
              options: current_organization.taxonomy_options("project_type") %>
        <%= render "shared/relay_field", f: form, field: :platform, type: "select",
              options: Customer::PLATFORMS.keys.zip(Customer::PLATFORMS.values) %>
        <%= render "shared/relay_field", f: form, field: :project_scope, type: "select",
              options: Customer::PROJECT_SCOPES.keys.zip(Customer::PROJECT_SCOPES.values) %>

        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :idea_description, type: "textarea", rows: 4 %>
        </div>
      </div>
    </div>
  </div>

  <%# ====================== Status & Communication ======================= %>
  <div class="sect">
    <div class="sect__head"><div class="sect__title">Status &amp; communication</div></div>
    <div class="sect__body">
      <div class="grid grid-2">
        <%= render "shared/relay_field", f: form, field: :status, type: "select",
              options: current_organization.taxonomy_options("customer_status") %>

        <% if current_user&.admin? %>
          <div class="rl-field">
            <%= form.label :user_id, "Assigned to", class: "rl-label" %>
            <%= form.collection_select :user_id, User.all, :id, :name,
                  { include_blank: "Unassigned" }, class: "rl-select" %>
          </div>
        <% end %>

        <%= render "shared/relay_field", f: form, field: :call_status, type: "select",
              options: current_organization.taxonomy_options("call_status") %>
        <%= render "shared/relay_field", f: form, field: :preferred_calling_time,
              label: "Preferred calling time" %>
        <%= render "shared/relay_field", f: form, field: :email_status, type: "select",
              options: current_organization.taxonomy_options("email_status") %>
        <%= render "shared/relay_field", f: form, field: :whatsapp_status, type: "select",
              options: current_organization.taxonomy_options("whatsapp_status") %>
        <%= render "shared/relay_field", f: form, field: :linkedin_status, type: "select",
              options: current_organization.taxonomy_options("linkedin_status") %>
        <%= render "shared/relay_field", f: form, field: :exhaust_status, type: "select",
              options: current_organization.taxonomy_options("exhaust_status") %>

        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :repeat_lead, type: "checkbox",
                label: "Mark as repeat lead",
                hint: "Tick if this customer has contacted us before with a different email/phone, or is returning after a long time." %>
        </div>

        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :notes, type: "textarea", rows: 4 %>
        </div>
      </div>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", customers_path, class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (customer.new_record? ? "Create customer" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
