<%= form_with(model: customer, class: "space-y-6") do |form| %>
  <div class="mb-6 text-center">
    <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= customer.new_record? ? "New Customer" : "Edit Customer" %></h1>
    <p class="text-gray-600">Fill in the details below to <%= customer.new_record? ? "create a new" : "update the" %> customer record</p>
  </div>

  <% if customer.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 animate-fade-in">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(customer.errors.count, "error") %> prohibited this customer from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% customer.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6 hover:shadow-md transition-shadow duration-300">
    <h2 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
      </svg>
      Basic Information
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= form.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :phone, "Phone Number", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.telephone_field :phone, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "Include country code (e.g. +923001234567)" %>
          <p class="mt-1 text-xs text-gray-500">Include country code with + sign (e.g. +923001234567)</p>
        </div>
      </div>

      <div>
        <%= form.label :company, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :company, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div data-controller="country">
        <%= form.label :country, class: "block text-sm font-medium text-gray-700" %>
        <%= form.hidden_field :country, data: { country_target: "select" } %>
        
        <div class="mt-1 relative">
          <button type="button" 
                  class="flex items-center w-full rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                  data-action="click->country#toggleDropdown">
            <span data-country-target="selectedFlag" class="flex-grow text-left"><%= customer.country.present? ? "#{customer.country}" : "Select a country" %></span>
            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
          
          <div data-country-target="dropdown" class="hidden absolute z-10 mt-1 w-full bg-white shadow-lg max-h-60 rounded-md py-1 text-base ring-1 ring-black ring-opacity-5 overflow-auto focus:outline-none sm:text-sm">
            <div class="sticky top-0 z-10 bg-white p-2">
              <input type="text" 
                     class="block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" 
                     placeholder="Search countries..." 
                     data-country-target="searchInput"
                     data-action="input->country#search">
            </div>
            <ul class="py-1">
              <% # The list will be dynamically populated by the JavaScript controller %>
            </ul>
          </div>
        </div>
      </div>

      <div>
        <%= form.label :timezone, "Timezone", class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :timezone, ActiveSupport::TimeZone.all.map { |tz| [tz.to_s, tz.name] }, { include_blank: "Auto-detect from country" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        <p class="mt-1 text-xs text-gray-500">If not selected, timezone will be determined based on country</p>
      </div>

      <div>
        <%= form.label :address, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :address, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      
      <div class="md:col-span-2">
        <%= form.label :file, "Attachment (PDF, DOC, or Image)", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1 flex items-center">
          <% if form.object.file.attached? %>
            <div class="mr-3">
              <% if form.object.file.content_type.start_with?('image/') %>
                <%= image_tag form.object.file.variant(resize_to_limit: [100, 100]), class: "h-16 w-auto object-cover rounded border border-gray-200" %>
              <% else %>
                <div class="flex items-center px-3 py-2 rounded-md text-sm font-medium bg-gray-100 text-gray-700">
                  <svg class="mr-1.5 h-5 w-5 text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 11-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd" />
                  </svg>
                  <%= form.object.file.filename %>
                </div>
              <% end %>
            </div>
            <div>
              <label class="cursor-pointer inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                Change
                <%= form.file_field :file, class: "hidden", accept: "image/*,.pdf,.doc,.docx" %>
              </label>
            </div>
          <% else %>
            <div>
              <label class="cursor-pointer inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                <svg class="mr-2 h-4 w-4 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                </svg>
                Choose File
                <%= form.file_field :file, class: "hidden", accept: "image/*,.pdf,.doc,.docx" %>
              </label>
            </div>
          <% end %>
        </div>
        <p class="mt-1 text-xs text-gray-500">Accepted file types: PDF, DOC, DOCX, JPG, PNG, GIF (max 10MB)</p>
      </div>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6 hover:shadow-md transition-shadow duration-300" data-controller="lead-source">
    <h2 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M6.672 1.911a1 1 0 10-1.932.518l.259.966a1 1 0 001.932-.518l-.26-.966zM2.429 4.74a1 1 0 10-.517 1.932l.966.259a1 1 0 00.517-1.932l-.966-.26zm8.814-.569a1 1 0 00-1.415-1.414l-.707.707a1 1 0 101.415 1.415l.707-.708zm-7.071 7.072l.707-.707A1 1 0 003.465 9.12l-.708.707a1 1 0 001.415 1.415zm3.2-5.171a1 1 0 00-1.3 1.3l4 10a1 1 0 001.823.075l1.38-2.759 3.018 3.02a1 1 0 001.414-1.415l-3.019-3.02 2.76-1.379a1 1 0 00-.076-1.822l-10-4z" clip-rule="evenodd" />
      </svg>
      Source & Project Details
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :lead_source, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :lead_source, Customer::LEAD_SOURCES.keys, { include_blank: "Select Source" },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
            data: { action: "change->lead-source#toggleCcrFields", "lead-source-target": "select" } %>
      </div>

      <div>
        <%= form.label :linkedin_url, "LinkedIn URL", class: "block text-sm font-medium text-gray-700" %>
        <%= form.url_field :linkedin_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div data-lead-source-target="ccrFields" class="<%= customer.lead_source == 'CCR' ? '' : 'hidden' %> space-y-4">
        <%= form.label :ccr_link, "CCR Link", class: "block text-sm font-medium text-gray-700" %>
        <%= form.url_field :ccr_link, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "Google Drive Link" %>
      </div>

      <div data-lead-source-target="ccrCost" class="<%= customer.lead_source == 'CCR' ? '' : 'hidden' %>">
        <%= form.label :project_estimated_cost, "Project Estimated Cost", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1 flex rounded-md shadow-sm">
          <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">$</span>
          <%= form.number_field :project_estimated_cost, class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md border-gray-300 focus:border-blue-500 focus:ring-blue-500", step: "0.01" %>
        </div>
      </div>

      <div>
        <%= form.label :project_type, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :project_type, Customer::PROJECT_TYPES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div class="md:col-span-2">
        <%= form.label :idea_description, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :idea_description, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6 hover:shadow-md transition-shadow duration-300">
    <h2 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
      </svg>
      Status & Communication
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :status, Customer::STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <% if current_user&.admin? %>
        <div>
          <%= form.label :user_id, "Assigned To", class: "block text-sm font-medium text-gray-700" %>
          <%= form.collection_select :user_id, User.all, :id, :name, { include_blank: "Unassigned" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
      <% end %>

      <div>
        <%= form.label :call_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :call_status, Customer::CALL_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :preferred_calling_time, "Preferred Calling Time", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :preferred_calling_time, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :email_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :email_status, Customer::EMAIL_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :whatsapp_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :whatsapp_status, Customer::WHATSAPP_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :linkedin_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :linkedin_status, Customer::LINKEDIN_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :upwork_profile, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :upwork_profile, Customer::UPWORK_PROFILES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :exhaust_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :exhaust_status, Customer::EXHAUST_STATUSES.keys, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div class="md:col-span-2">
        <%= form.label :notes, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :notes, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-3 pt-5">
    <%= link_to "Cancel", customers_path, class: "py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-150" %>
    <%= form.submit class: "py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-150 transform hover:scale-105" %>
  </div>
<% end %>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }
  
  input:focus, select:focus, textarea:focus {
    transition: all 0.2s ease-in-out;
    transform: translateY(-1px);
  }
  
  /* Enhanced dropdown styling */
  [data-country-target="dropdown"] {
    animation: fadeIn 0.2s ease-out;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
  
  /* Flag animations */
  [data-country-item]:hover .mr-2 {
    transform: scale(1.2);
    transition: transform 0.2s ease;
  }
  
  /* Improved section transitions */
  .hover\:shadow-md {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .hover\:shadow-md:hover {
    transform: translateY(-2px);
  }
  
  /* Button enhancements */
  .bg-blue-600 {
    background-image: linear-gradient(to right, #3b82f6, #2563eb);
  }
  
  .bg-blue-600:hover {
    background-image: linear-gradient(to right, #2563eb, #1d4ed8);
  }
</style> 