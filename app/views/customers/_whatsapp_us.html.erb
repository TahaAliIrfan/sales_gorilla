<%# Twilio-backed WhatsApp US chat panel. Send is gated by the 24h reply window. %>
<div class="bg-white border border-gray-300 rounded-lg shadow-lg"
     data-controller="whatsapp-us"
     data-whatsapp-us-customer-id-value="<%= customer.id %>"
     data-whatsapp-us-window-open-value="<%= customer.whatsapp_us_window_open? %>"
     data-whatsapp-us-is-admin-value="<%= current_user&.admin? ? true : false %>"
     data-whatsapp-us-customer-fields-value='<%= { name: customer.name, phone: customer.phone, email: customer.email, company: customer.company }.compact.to_json %>'>

  <!-- Header -->
  <div class="bg-gradient-to-r from-emerald-500 to-emerald-600 border-b border-emerald-200 px-4 py-4 rounded-t-lg text-white">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/>
        </svg>
        <div>
          <h3 class="text-lg font-bold">WhatsApp US</h3>
          <p class="text-emerald-100 text-xs">via Twilio &middot; <%= customer.phone.presence || 'no phone number' %></p>
        </div>
      </div>
      <div class="flex items-center gap-1">
        <button type="button" data-action="click->whatsapp-us#syncChat" data-whatsapp-us-target="syncChatButton"
                class="inline-flex items-center gap-1 px-2 py-1 rounded-md text-xs text-white/90 hover:text-white hover:bg-white/10 disabled:opacity-50 disabled:cursor-wait"
                title="Pull every message from Twilio and reconcile with local history">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 17l-4 4m0 0l-4-4m4 4V3m0 0L8 7m4-4l4 4"/>
          </svg>
          <span data-whatsapp-us-target="syncChatLabel">Sync</span>
        </button>
        <button type="button" data-action="click->whatsapp-us#loadMessages"
                class="text-white/90 hover:text-white p-1 rounded-md hover:bg-white/10" title="Refresh">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Messages -->
  <div class="h-96 overflow-y-auto p-4 space-y-3 bg-gray-50" data-whatsapp-us-target="messagesContainer">
    <div data-whatsapp-us-target="messagesArea">
      <div class="flex justify-center items-center py-8 text-gray-500 text-sm">Loading messages...</div>
    </div>
  </div>

  <!-- Composer (enabled only while the 24h window is open) -->
  <div class="border-t border-gray-200 p-4 bg-white rounded-b-lg">
    <!-- Window-closed notice -->
    <div data-whatsapp-us-target="closedNotice" class="hidden mb-2 flex items-start gap-2 rounded-md bg-amber-50 border border-amber-200 px-3 py-2 text-sm text-amber-800">
      <svg class="h-5 w-5 flex-shrink-0 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>The 24-hour reply window is closed. The customer must message you first before you can send a freeform WhatsApp message (or use an approved template).</span>
    </div>

    <div data-whatsapp-us-target="error" class="hidden mb-2 rounded-md bg-red-50 border border-red-200 px-3 py-2 text-sm text-red-700"></div>

    <!-- Selected file preview -->
    <div data-whatsapp-us-target="filePreview" class="hidden mb-2 flex items-center justify-between rounded-md bg-gray-50 border border-gray-200 px-3 py-2">
      <div class="flex items-center gap-2 min-w-0">
        <svg class="h-5 w-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
        </svg>
        <span data-whatsapp-us-target="fileName" class="text-sm text-gray-700 truncate"></span>
      </div>
      <button type="button" data-action="click->whatsapp-us#clearFile" class="text-gray-400 hover:text-gray-600 flex-shrink-0">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <form data-action="submit->whatsapp-us#sendMessage" data-whatsapp-us-target="form">
      <input type="file" class="hidden" data-whatsapp-us-target="fileInput" data-action="change->whatsapp-us#fileSelected"
             accept="image/*,video/mp4,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.pptx,.txt,.csv,.json,.xml,.zip" />
      <div class="flex space-x-2">
        <button type="button" data-action="click->whatsapp-us#openFileDialog" data-whatsapp-us-target="attachButton"
                title="Attach a document"
                class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-600 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 disabled:opacity-50 disabled:cursor-not-allowed">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
          </svg>
        </button>
        <button type="button" data-action="click->whatsapp-us#openTemplatePicker"
                title="Send an approved template"
                class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-600 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
          </svg>
        </button>
        <input type="text" data-whatsapp-us-target="input" placeholder="Type a message..."
               class="flex-1 block w-full text-sm border-gray-300 rounded-md shadow-sm focus:ring-emerald-500 focus:border-emerald-500 disabled:bg-gray-100 disabled:cursor-not-allowed" />
        <button type="submit" data-whatsapp-us-target="sendButton"
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-emerald-600 hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 disabled:opacity-50 disabled:cursor-not-allowed">
          <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
          Send
        </button>
      </div>
    </form>
  </div>

  <!-- Template picker modal -->
  <div data-whatsapp-us-target="templateModal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 px-4">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl max-h-[85vh] flex flex-col">
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
        <div>
          <h4 class="text-base font-semibold text-gray-900">Send a WhatsApp template</h4>
          <p class="text-xs text-gray-500">Approved Twilio Content templates. Use these when the 24-hour reply window is closed.</p>
        </div>
        <div class="flex items-center gap-2">
          <% if current_user&.admin? %>
            <button type="button" data-action="click->whatsapp-us#syncTemplates" data-whatsapp-us-target="syncButton"
                    class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
              <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
              Sync from Twilio
            </button>
          <% end %>
          <button type="button" data-action="click->whatsapp-us#closeTemplatePicker"
                  class="text-gray-400 hover:text-gray-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <div data-whatsapp-us-target="templateError"
           class="hidden mx-4 mt-3 rounded-md bg-red-50 border border-red-200 px-3 py-2 text-sm text-red-700"></div>
      <div data-whatsapp-us-target="templateNotice"
           class="hidden mx-4 mt-3 rounded-md bg-emerald-50 border border-emerald-200 px-3 py-2 text-sm text-emerald-700"></div>

      <div class="overflow-y-auto p-4 flex-1" data-whatsapp-us-target="templateList">
        <div class="flex justify-center items-center py-8 text-gray-500 text-sm">Loading templates...</div>
      </div>
    </div>
  </div>
</div>
