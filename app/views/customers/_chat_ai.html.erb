<div data-controller="ai-chat" data-ai-chat-customer-id-value="<%= customer.id %>" class="flex flex-col h-[600px] bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
  <!-- Header -->
  <div class="flex items-center gap-3 px-5 py-3 bg-white border-b border-gray-200">
    <div class="flex items-center justify-center h-9 w-9 rounded-lg bg-emerald-100 text-emerald-600">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
      </svg>
    </div>
    <div>
      <p class="text-sm font-semibold text-gray-900">Chat about <%= customer.name %></p>
      <p class="text-xs text-gray-500">Ask questions, summarise the relationship, or draft outreach — the assistant has this customer's CRM context.</p>
    </div>
  </div>

  <!-- Messages -->
  <div data-ai-chat-target="messages" class="flex-1 overflow-y-auto px-5 py-4 space-y-4">
    <div data-ai-chat-target="empty" class="h-full flex flex-col items-center justify-center text-center px-6">
      <div class="flex items-center justify-center h-12 w-12 rounded-full bg-emerald-100 text-emerald-600 mb-3">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 3v-3z" />
        </svg>
      </div>
      <p class="text-sm font-medium text-gray-700">How can I help with <%= customer.name %>?</p>
      <p class="text-xs text-gray-500 mt-1 mb-4 max-w-sm">I know this lead's profile, deals, calls, messages, emails and notes.</p>
      <div class="flex flex-wrap items-center justify-center gap-2">
        <button type="button" data-action="ai-chat#ask" data-prompt="Give me a quick summary of where this lead stands and what to do next." class="px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs text-gray-700 hover:bg-gray-50 hover:border-gray-300">Summarise this lead</button>
        <button type="button" data-action="ai-chat#ask" data-prompt="Draft a warm, professional follow-up email to this customer based on our history." class="px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs text-gray-700 hover:bg-gray-50 hover:border-gray-300">Draft a follow-up email</button>
        <button type="button" data-action="ai-chat#ask" data-prompt="What are the best talking points for my next call with this customer?" class="px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs text-gray-700 hover:bg-gray-50 hover:border-gray-300">Next call talking points</button>
      </div>
    </div>
  </div>

  <!-- Composer -->
  <div class="border-t border-gray-200 bg-white px-4 py-3">
    <form data-ai-chat-target="form" data-action="submit->ai-chat#send" class="flex items-end gap-2">
      <textarea data-ai-chat-target="input"
                data-action="keydown->ai-chat#handleKeydown input->ai-chat#autoGrow"
                rows="1"
                placeholder="Ask about this customer, or ask me to draft a message…"
                class="flex-1 resize-none rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 max-h-40"></textarea>
      <button type="submit" data-ai-chat-target="sendButton"
              class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-emerald-600 text-white hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed shrink-0">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
      </button>
    </form>
    <p class="mt-1.5 text-[11px] text-gray-400">AI can make mistakes — review drafts before sending. Conversations aren't saved.</p>
  </div>
</div>
