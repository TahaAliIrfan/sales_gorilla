<% content_for :title, "Edit #{@customer.name} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Edit customer</div>
      <div class="pagehead__sub"><%= @customer.name %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to customer_path(@customer), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to customer
      <% end %>
    </div>
  </div>

  <%= render "form", customer: @customer %>
</div>
