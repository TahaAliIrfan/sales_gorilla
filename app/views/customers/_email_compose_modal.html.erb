<!-- Compose Email Modal -->
<div id="compose-modal" 
     data-email-inbox-target="composeModal"
     data-action="click->email-inbox#closeComposeOnBackground keydown@window->email-inbox#closeComposeOnEscape"
     class="compose-modal fixed inset-0 bg-black bg-opacity-50 z-50 items-center justify-center p-4 hidden">
  <div class="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden flex flex-col">
    <!-- Modal Header -->
    <div class="flex items-center justify-between p-4 border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700">
      <h2 class="text-lg font-bold text-white flex items-center">
        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        New Email
      </h2>
      <button type="button" data-action="click->email-inbox#closeCompose" class="text-white hover:text-gray-200 transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- Modal Body -->
    <div class="flex-1 overflow-y-auto" data-controller="email-composer" data-email-composer-placeholder-value="Write your email here...">
      <%= form_with url: customer_emails_path(customer), method: :post, multipart: true, class: "h-full flex flex-col", data: { turbo: false, email_composer_target: "form", action: "submit->email-composer#submit" } do |f| %>
        <!-- To Field -->
        <div class="p-4 border-b border-gray-100">
          <div class="flex items-center space-x-3">
            <label class="text-sm font-medium text-gray-500 w-12">To:</label>
            <div class="flex-1 flex items-center space-x-2 px-3 py-2 bg-gray-50 rounded-lg">
              <div class="h-8 w-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-semibold text-xs">
                <%= customer.name.first.upcase %>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-900"><%= customer.name %></div>
                <div class="text-xs text-gray-500"><%= customer.email %></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Subject Field -->
        <div class="px-4 py-3 border-b border-gray-100">
          <div class="flex items-center space-x-3">
            <label class="text-sm font-medium text-gray-500 w-12">Subject:</label>
            <input type="text" name="subject" data-email-composer-target="subject" required placeholder="Email subject" class="flex-1 border-0 focus:ring-0 text-sm text-gray-900 placeholder-gray-400 bg-transparent">
          </div>
        </div>

        <!-- Rich Text Editor -->
        <div class="flex-1 p-4 flex flex-col">
          <!-- Toolbar -->
          <div class="border border-gray-300 rounded-t-lg bg-gray-50 px-2 py-1.5 flex items-center flex-wrap gap-0.5">
            <!-- Text Formatting -->
            <div class="flex items-center">
              <button type="button" data-action="click->email-composer#bold" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Bold (Ctrl+B)">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z" />
                  <path d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z" />
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#italic" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Italic (Ctrl+I)">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="19" y1="4" x2="10" y2="4"></line>
                  <line x1="14" y1="20" x2="5" y2="20"></line>
                  <line x1="15" y1="4" x2="9" y2="20"></line>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#underline" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Underline (Ctrl+U)">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 3v7a6 6 0 006 6 6 6 0 006-6V3"></path>
                  <line x1="4" y1="21" x2="20" y2="21"></line>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#strikeThrough" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Strikethrough">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 4H9a3 3 0 00-3 3c0 1.5.5 2.5 3 3.5"></path>
                  <path d="M8 17c0 1.5 1.5 3 3.5 3h3a3.5 3.5 0 003.5-3.5c0-1.5-.5-2.5-3-3.5"></path>
                  <line x1="4" y1="12" x2="20" y2="12"></line>
                </svg>
              </button>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Font Size -->
            <div class="flex items-center">
              <select data-action="change->email-composer#fontSize" class="text-xs border-0 bg-transparent text-gray-700 py-1 pr-6 focus:ring-0 cursor-pointer" title="Font Size">
                <option value="1">Small</option>
                <option value="3" selected>Normal</option>
                <option value="5">Large</option>
                <option value="7">Huge</option>
              </select>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Text Color -->
            <div class="flex items-center">
              <label class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors cursor-pointer relative" title="Text Color">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 3L4 21h16L12 3z"></path>
                  <line x1="8" y1="17" x2="16" y2="17" stroke-width="3"></line>
                </svg>
                <input type="color" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" data-action="change->email-composer#foreColor" value="#000000">
              </label>
              
              <label class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors cursor-pointer relative" title="Highlight Color">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                  <rect x="3" y="14" width="18" height="7" rx="1" fill="#fef08a"></rect>
                  <path d="M12 3L6 17h12L12 3z" fill="none" stroke="currentColor" stroke-width="2"></path>
                </svg>
                <input type="color" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" data-action="change->email-composer#hiliteColor" value="#ffff00">
              </label>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Lists -->
            <div class="flex items-center">
              <button type="button" data-action="click->email-composer#insertUnorderedList" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Bullet List">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="9" y1="6" x2="20" y2="6"></line>
                  <line x1="9" y1="12" x2="20" y2="12"></line>
                  <line x1="9" y1="18" x2="20" y2="18"></line>
                  <circle cx="5" cy="6" r="1.5" fill="currentColor"></circle>
                  <circle cx="5" cy="12" r="1.5" fill="currentColor"></circle>
                  <circle cx="5" cy="18" r="1.5" fill="currentColor"></circle>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#insertOrderedList" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Numbered List">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="10" y1="6" x2="20" y2="6"></line>
                  <line x1="10" y1="12" x2="20" y2="12"></line>
                  <line x1="10" y1="18" x2="20" y2="18"></line>
                  <text x="3" y="8" font-size="7" fill="currentColor" stroke="none">1</text>
                  <text x="3" y="14" font-size="7" fill="currentColor" stroke="none">2</text>
                  <text x="3" y="20" font-size="7" fill="currentColor" stroke="none">3</text>
                </svg>
              </button>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Alignment -->
            <div class="flex items-center">
              <button type="button" data-action="click->email-composer#justifyLeft" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Align Left">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <line x1="3" y1="12" x2="15" y2="12"></line>
                  <line x1="3" y1="18" x2="18" y2="18"></line>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#justifyCenter" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Align Center">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <line x1="6" y1="12" x2="18" y2="12"></line>
                  <line x1="4" y1="18" x2="20" y2="18"></line>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#justifyRight" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Align Right">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <line x1="9" y1="12" x2="21" y2="12"></line>
                  <line x1="6" y1="18" x2="21" y2="18"></line>
                </svg>
              </button>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Insert -->
            <div class="flex items-center">
              <button type="button" data-action="click->email-composer#createLink" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Insert Link">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"></path>
                  <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"></path>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#unlink" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Remove Link">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"></path>
                  <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"></path>
                  <line x1="4" y1="4" x2="20" y2="20" stroke-width="2"></line>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#insertHorizontalRule" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Horizontal Line">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="12" x2="21" y2="12"></line>
                </svg>
              </button>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Indentation -->
            <div class="flex items-center">
              <button type="button" data-action="click->email-composer#indent" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Increase Indent">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <line x1="9" y1="12" x2="21" y2="12"></line>
                  <line x1="9" y1="18" x2="21" y2="18"></line>
                  <polyline points="3 9 6 12 3 15"></polyline>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#outdent" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Decrease Indent">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <line x1="9" y1="12" x2="21" y2="12"></line>
                  <line x1="9" y1="18" x2="21" y2="18"></line>
                  <polyline points="6 9 3 12 6 15"></polyline>
                </svg>
              </button>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Format Block -->
            <div class="flex items-center">
              <select data-action="change->email-composer#formatBlock" class="text-xs border-0 bg-transparent text-gray-700 py-1 pr-6 focus:ring-0 cursor-pointer" title="Paragraph Format">
                <option value="">Format</option>
                <option value="p">Paragraph</option>
                <option value="h1">Heading 1</option>
                <option value="h2">Heading 2</option>
                <option value="h3">Heading 3</option>
                <option value="blockquote">Quote</option>
                <option value="pre">Code</option>
              </select>
            </div>
            
            <div class="w-px h-5 bg-gray-300 mx-1"></div>
            
            <!-- Undo/Redo & Clear -->
            <div class="flex items-center">
              <button type="button" data-action="click->email-composer#undo" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Undo (Ctrl+Z)">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 10h10a5 5 0 015 5v2"></path>
                  <polyline points="3 10 8 5 3 10 8 15"></polyline>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#redo" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Redo (Ctrl+Y)">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10H11a5 5 0 00-5 5v2"></path>
                  <polyline points="21 10 16 5 21 10 16 15"></polyline>
                </svg>
              </button>
              
              <button type="button" data-action="click->email-composer#removeFormat" class="p-1.5 hover:bg-gray-200 rounded text-gray-700 transition-colors" title="Clear Formatting">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10-4.5 10-10 10z"></path>
                  <line x1="8" y1="8" x2="16" y2="16"></line>
                </svg>
              </button>
            </div>
          </div>

          <!-- Editor -->
          <div 
            contenteditable="true" 
            data-email-composer-target="editor"
            data-placeholder="Write your email here..."
            class="flex-1 border border-t-0 border-gray-300 rounded-b-lg p-4 min-h-[280px] focus:outline-none focus:ring-2 focus:ring-blue-500 prose prose-sm max-w-none overflow-y-auto bg-white"
          ></div>
          
          <!-- Hidden input for form submission -->
          <input type="hidden" name="body" data-email-composer-target="body">
          
          <!-- Keyboard Shortcuts Hint -->
          <div class="mt-2 flex flex-wrap gap-3 text-xs text-gray-400">
            <span><kbd class="px-1.5 py-0.5 bg-gray-100 rounded text-gray-600 font-mono">Ctrl+B</kbd> Bold</span>
            <span><kbd class="px-1.5 py-0.5 bg-gray-100 rounded text-gray-600 font-mono">Ctrl+I</kbd> Italic</span>
            <span><kbd class="px-1.5 py-0.5 bg-gray-100 rounded text-gray-600 font-mono">Ctrl+U</kbd> Underline</span>
            <span><kbd class="px-1.5 py-0.5 bg-gray-100 rounded text-gray-600 font-mono">Ctrl+Z</kbd> Undo</span>
          </div>
        </div>

        <!-- Footer Actions -->
        <div class="p-4 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 cursor-pointer transition-colors">
              <svg class="h-4 w-4 mr-2 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
              </svg>
              Attach Files
              <input type="file" name="attachments[]" multiple class="hidden" data-email-composer-target="attachments" data-action="change->email-composer#handleAttachments">
            </label>
            <div data-email-composer-target="attachmentList" class="flex flex-wrap gap-2"></div>
          </div>
          
          <div class="flex items-center space-x-3">
            <button type="button" data-action="click->email-inbox#closeCompose" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors">
              Cancel
            </button>
            <button type="submit" data-email-composer-target="sendButton" class="inline-flex items-center px-5 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium text-sm transition-colors shadow-sm">
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              Send Email
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
/* Rich Text Editor Placeholder */
[data-email-composer-target="editor"]:empty:before {
  content: attr(data-placeholder);
  color: #9CA3AF;
  pointer-events: none;
  display: block;
}

[data-email-composer-target="editor"]:focus:empty:before {
  content: '';
}

/* Prose styling for editor */
[data-email-composer-target="editor"] {
  line-height: 1.6;
}

[data-email-composer-target="editor"] h1 { font-size: 1.75em; font-weight: bold; margin: 0.5em 0; }
[data-email-composer-target="editor"] h2 { font-size: 1.5em; font-weight: bold; margin: 0.5em 0; }
[data-email-composer-target="editor"] h3 { font-size: 1.25em; font-weight: bold; margin: 0.5em 0; }
[data-email-composer-target="editor"] ul, [data-email-composer-target="editor"] ol { padding-left: 1.5em; margin: 0.5em 0; }
[data-email-composer-target="editor"] li { margin: 0.25em 0; }
[data-email-composer-target="editor"] a { color: #2563eb; text-decoration: underline; }
[data-email-composer-target="editor"] blockquote { border-left: 3px solid #d1d5db; padding-left: 1em; margin: 0.5em 0; color: #6b7280; }
[data-email-composer-target="editor"] pre { background: #f3f4f6; padding: 0.75em; border-radius: 0.375rem; font-family: monospace; font-size: 0.875em; overflow-x: auto; }
[data-email-composer-target="editor"] hr { border: none; border-top: 1px solid #e5e7eb; margin: 1em 0; }
</style>
