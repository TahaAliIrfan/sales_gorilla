<div class="min-h-screen bg-gray-50 py-8" data-controller="customer-filter bulk-assign">
  <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="mb-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
          <div class="cb-eyebrow mb-1.5">customers // directory</div>
          <h1 class="text-[26px] sm:text-[30px] font-semibold tracking-tight text-[#0F172A]">Customer Management</h1>
          <p class="mt-1.5 text-sm text-[#64748B]">Manage and track all your customer relationships</p>
    </div>
        <div class="flex flex-col sm:flex-row gap-3">
      <% if current_user&.admin? || current_user&.manager? %>
            <%= link_to new_csv_import_path, class: "inline-flex items-center justify-center px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors shadow-sm" do %>
              <svg class="h-5 w-5 mr-2 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
              </svg>
              Import CSV
            <% end %>
          <% end %>
          <% if current_user&.admin? %>
            <a href="<%= export_csv_customers_path %>"
               data-customer-filter-target="exportLink"
               class="inline-flex items-center justify-center px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors shadow-sm">
              <svg class="h-5 w-5 mr-2 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Export CSV
            </a>
          <% end %>
          <%= link_to new_customer_path, class: "inline-flex items-center justify-center px-4 py-2.5 bg-emerald-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-emerald-700 transition-colors shadow-sm" do %>
            <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            New Customer
      <% end %>
        </div>
      </div>
  </div>

    <!-- Filters Section -->
    <div class="mb-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6">
      <div class="flex flex-col lg:flex-row gap-4">
        <!-- Search Bar - Takes more space -->
        <div class="flex-1">
          <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input type="text"
               placeholder="Search customers..."
                   class="block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
               data-customer-filter-target="search"
               data-action="input->customer-filter#debouncedFilter">
          </div>
      </div>

        <!-- Quick Filters -->
        <div class="flex flex-wrap gap-3">
          <!-- Status Filter -->
          <select id="status-filter"
                  class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
                  data-customer-filter-target="status"
                  data-action="change->customer-filter#filter">
            <option value="">All Statuses</option>
            <% Customer::STATUSES.each do |key, value| %>
              <option value="<%= value %>" <%= 'selected' if params[:status] == value %>><%= value %></option>
            <% end %>
          </select>

          <% if current_user&.admin? || current_user&.manager? %>
            <!-- Assigned To Filter -->
            <select id="user-filter"
                    class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
                    data-customer-filter-target="user"
                  data-action="change->customer-filter#filter">
            <option value="">All Users</option>
            <option value="unassigned">Unassigned</option>
            <% @users.each do |user| %>
              <option value="<%= user.id %>"><%= user.name %></option>
            <% end %>
          </select>
      <% else %>
        <select data-customer-filter-target="user" class="hidden">
          <option value=""></option>
        </select>
      <% end %>

      <!-- Lead Source Filter -->
          <div class="relative" data-controller="multiselect-dropdown" data-customer-filter-target="leadSourceContainer">
        <button type="button"
                    class="inline-flex items-center justify-between min-w-[140px] border border-gray-300 rounded-lg px-3 py-2.5 bg-white shadow-sm hover:bg-gray-50 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
                data-multiselect-dropdown-target="button"
                data-action="click->multiselect-dropdown#toggle">
              <span data-multiselect-dropdown-target="buttonText" class="text-gray-700">Lead Source</span>
              <svg class="h-4 w-4 ml-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
            <div data-multiselect-dropdown-target="menu" class="hidden absolute z-50 mt-2 w-64 bg-white rounded-lg shadow-lg border border-gray-200 max-h-64 overflow-y-auto right-0">
          <div class="py-1">
            <% Customer::LEAD_SOURCES.each do |key, value| %>
                  <label class="flex items-center px-4 py-2 hover:bg-gray-50 cursor-pointer">
                <input type="checkbox"
                       value="<%= value %>"
                       data-label="<%= value %>"
                       data-multiselect-dropdown-target="checkbox"
                       data-customer-filter-target="leadSourceCheckbox"
                       data-action="change->multiselect-dropdown#checkboxChanged change->customer-filter#filter"
                       class="h-4 w-4 text-emerald-600 focus:ring-emerald-500 border-gray-300 rounded">
                    <span class="ml-3 text-sm text-gray-700"><%= value %></span>
              </label>
            <% end %>
          </div>
        </div>
      </div>

          <!-- Customer Type Filter -->
        <select id="customer-type-filter"
                  class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
                data-customer-filter-target="customerType"
                data-action="change->customer-filter#filter">
            <option value="">All Types</option>
          <% Customer::CUSTOMER_TYPES.each do |key, value| %>
            <option value="<%= value %>"><%= value %></option>
          <% end %>
        </select>

      <!-- Date Range Filters -->
          <div class="flex items-center gap-2">
            <input type="date"
                   class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
                   data-customer-filter-target="startDate"
                   data-action="change->customer-filter#filter"
                   title="From date"
                   placeholder="Start date"
                   value="<%= params[:start_date] %>">
            <span class="text-gray-400 text-xs">to</span>
            <input type="date"
                   class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
                   data-customer-filter-target="endDate"
                   data-action="change->customer-filter#filter"
                   title="To date"
                   placeholder="End date"
                   value="<%= params[:end_date] %>">
          </div>

      <!-- Sort Direction -->
        <select id="direction-filter"
                  class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
                data-customer-filter-target="direction"
                data-action="change->customer-filter#filter">
            <option value="desc">Newest</option>
            <option value="asc">Oldest</option>
        </select>
      </div>
    </div>

    <!-- Active Filter Tags -->
      <div data-customer-filter-target="activeFilters" class="hidden mt-4 pt-4 border-t border-gray-200">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-xs font-medium text-gray-500">Active:</span>
          
          <span data-customer-filter-target="searchBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">
        <span data-customer-filter-target="searchText"></span>
            <button type="button" data-action="click->customer-filter#clearSearch" class="ml-1.5 text-emerald-600 hover:text-emerald-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="userBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">
        <span data-customer-filter-target="userText"></span>
            <button type="button" data-action="click->customer-filter#clearUser" class="ml-1.5 text-emerald-600 hover:text-emerald-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="statusBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
        <span data-customer-filter-target="statusText"></span>
            <button type="button" data-action="click->customer-filter#clearStatus" class="ml-1.5 text-green-600 hover:text-green-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="leadSourceBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
        <span data-customer-filter-target="leadSourceText"></span>
            <button type="button" data-action="click->customer-filter#clearLeadSource" class="ml-1.5 text-purple-600 hover:text-purple-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="dateRangeBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-teal-100 text-teal-700">
            <span data-customer-filter-target="dateRangeText"></span>
            <button type="button" data-action="click->customer-filter#clearDateRange" class="ml-1.5 text-teal-600 hover:text-teal-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </span>

          <span data-customer-filter-target="customerTypeBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
        <span data-customer-filter-target="customerTypeText"></span>
            <button type="button" data-action="click->customer-filter#clearCustomerType" class="ml-1.5 text-yellow-600 hover:text-yellow-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

      <button type="button"
              data-action="click->customer-filter#clearAll"
                  class="ml-auto text-xs text-gray-600 hover:text-gray-900 underline font-medium">
        Clear All
      </button>
        </div>
    </div>
  </div>

    <!-- Bulk Actions Bar (Admin/Manager only) -->
      <% if current_user&.admin? || current_user&.manager? %>
      <div id="bulk-actions-bar" class="hidden mb-4 bg-emerald-50 border border-emerald-200 rounded-lg px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <span class="text-sm font-medium text-emerald-900" id="selected-count">0 selected</span>
            <button id="select-all" class="text-sm text-emerald-700 hover:text-emerald-900 font-medium">Select all</button>
            <button id="clear-selection" class="text-sm text-red-600 hover:text-red-800 font-medium">Clear selection</button>
          </div>
          <div class="flex space-x-3">
            <button id="bulk-assign-btn" class="inline-flex items-center px-4 py-2 bg-emerald-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-emerald-700 transition-colors shadow-sm">
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              Bulk Assign
            </button>
            <button id="bulk-status-change-btn" class="inline-flex items-center px-4 py-2 bg-green-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-green-700 transition-colors shadow-sm">
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              Change Status
            </button>
            <% if current_user&.admin? %>
            <button id="bulk-delete-btn" class="inline-flex items-center px-4 py-2 bg-red-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-red-700 transition-colors shadow-sm">
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Delete Selected
            </button>
            <% end %>
          </div>
          </div>
        </div>

        <!-- Bulk Assign Modal -->
      <div id="bulk-assign-modal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
            <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Bulk Assign Customers</h3>
            <button id="close-modal" class="text-gray-400 hover:text-gray-600">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <%= form_tag bulk_assign_customers_path, method: :post, id: "bulk-assign-form" do %>
              <input type="hidden" name="customer_ids" id="bulk-customer-ids">
              <div class="mb-4">
              <label for="user_id" class="block text-sm font-medium text-gray-700 mb-2">Assign to User</label>
                <% if @users.present? %>
                  <%= select_tag "user_id", options_from_collection_for_select(@users, "id", "name"),
                    class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-emerald-500 focus:border-emerald-500" %>
                <% else %>
                <p class="text-sm text-red-600">No users available for assignment</p>
                <% end %>
              </div>
            <div class="flex justify-end space-x-3">
              <button type="button" id="cancel-bulk-assign" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
              <button type="submit" class="px-4 py-2 bg-emerald-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-emerald-700">
                  Assign
                </button>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Bulk Status Change Modal -->
      <div id="bulk-status-change-modal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
            <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Bulk Status Change</h3>
            <button id="close-status-modal" class="text-gray-400 hover:text-gray-600">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <%= form_tag bulk_status_change_customers_path, method: :post, id: "bulk-status-change-form" do %>
              <input type="hidden" name="customer_ids" id="bulk-status-customer-ids">
              <div class="mb-4">
              <label for="status" class="block text-sm font-medium text-gray-700 mb-2">Change Status To</label>
                <%= select_tag "status", options_for_select(Customer::STATUSES.map {|k,v| [v, v]}),
                  class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-green-500 focus:border-green-500" %>
              </div>
            <div class="flex justify-end space-x-3">
              <button type="button" id="cancel-bulk-status-change" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
              <button type="submit" class="px-4 py-2 bg-green-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-green-700">
                  Update Status
                </button>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Bulk Delete Confirmation Modal -->
        <% if current_user&.admin? %>
        <div id="bulk-delete-modal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center p-4">
          <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
            <div class="flex items-start mb-4">
              <div class="flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100">
                <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-semibold text-gray-900">Delete customers?</h3>
                <p class="mt-1 text-sm text-gray-600">
                  You are about to permanently delete <span id="bulk-delete-count" class="font-semibold">0</span> selected customer(s).
                  This will also remove their deals, recordings, tasks, messages and other related records. This action cannot be undone.
                </p>
              </div>
            </div>
            <%= form_tag bulk_destroy_customers_path, method: :delete, id: "bulk-delete-form" do %>
              <input type="hidden" name="customer_ids" id="bulk-delete-customer-ids">
              <div class="flex justify-end space-x-3">
                <button type="button" id="cancel-bulk-delete" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-red-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-red-700">
                  Delete
                </button>
              </div>
            <% end %>
          </div>
        </div>
        <% end %>
      <% end %>

    <!-- Main Content — split view (compact list + detail pane) -->
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.05fr)] gap-4"
         data-controller="split-view">
      <% if @customers.any? %>
        <!-- LEFT: compact list -->
        <div class="ah-card !p-0 overflow-hidden flex flex-col" style="max-height: calc(100vh - 250px);">
          <div class="flex items-center justify-between px-4 py-3 border-b border-[#E9ECF1]">
            <label class="flex items-center gap-2.5 text-xs font-medium text-[#64748B]">
              <% if current_user&.admin? || current_user&.manager? %>
                <input type="checkbox" id="select-all-checkbox" class="h-4 w-4 text-emerald-600 focus:ring-emerald-500 border-gray-300 rounded">
              <% end %>
              <span class="cb-mono uppercase tracking-wider"><%= @customers.total_count %> customers</span>
            </label>
            <span class="cb-eyebrow">directory</span>
          </div>

          <div class="overflow-y-auto flex-1" data-customer-filter-target="customersList">
            <% @customers.each do |customer| %>
              <div class="split-row group flex items-center gap-3 px-4 py-3 border-b border-[#F1F5F9] transition-colors hover:bg-[#F6FBF8] <%= { 'High Value' => 'bg-amber-50/60', 'Gold' => 'bg-yellow-50/60' }[customer.customer_type] %>"
                   data-split-view-target="row" data-customer-id="<%= customer.id %>">
                <% if current_user&.admin? || current_user&.manager? %>
                  <input type="checkbox" class="customer-checkbox h-4 w-4 text-emerald-600 focus:ring-emerald-500 border-gray-300 rounded shrink-0" data-id="<%= customer.id %>">
                <% end %>
                <%= link_to preview_customer_path(customer),
                      class: "flex items-center gap-3 min-w-0 flex-1",
                      data: { turbo_frame: "customer_preview", action: "split-view#select" } do %>
                  <%= customer_avatar(customer, size: 36, css: "rounded-lg shrink-0 ring-1 ring-[#E9ECF1]") %>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      <span class="text-sm font-medium text-[#0F172A] truncate"><%= customer.name %></span>
                      <% if customer.repeat_lead? %><span class="h-1.5 w-1.5 rounded-full bg-yellow-400 shrink-0" title="Repeat lead"></span><% end %>
                    </div>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium <%= customer_status_color_class(customer.status) %>"><%= customer.status %></span>
                      <span class="cb-mono text-[10.5px] text-[#94A3B8] truncate"><%= customer.company.presence || customer.phone %></span>
                    </div>
                  </div>
                  <% if customer.lead_score.present? %>
                    <span class="hidden sm:inline-flex flex-col items-center justify-center shrink-0 h-9 w-9 rounded-lg cb-mono text-sm font-semibold <%= customer.lead_score_color %>" style="background:rgba(5,150,105,.07)" title="Lead score: <%= customer.lead_score %>/100 (<%= customer.lead_score_badge %>)"><%= customer.lead_score %></span>
                  <% end %>
                  <div class="hidden md:flex flex-col items-end shrink-0 cb-mono text-[10.5px] text-[#94A3B8]">
                    <span><%= customer.total_call_attempts %>c · <%= customer.messages.where(direction: 'outbound').count %>m</span>
                    <span class="truncate max-w-[90px]"><%= customer.user&.name || '—' %></span>
                  </div>
                  <svg class="h-4 w-4 text-[#CBD5E1] shrink-0 group-hover:text-emerald-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="px-4 py-3 border-t border-[#E9ECF1] flex items-center justify-between">
            <span class="text-xs text-[#64748B]"><%= @customers.offset_value + 1 %>–<%= @customers.offset_value + @customers.size %> of <%= @customers.total_count %></span>
            <nav class="inline-flex" aria-label="Pagination"><%= paginate @customers %></nav>
          </div>
        </div>

        <!-- RIGHT: detail pane -->
        <div class="lg:sticky lg:top-[84px] self-start w-full" data-split-view-target="pane">
          <turbo-frame id="customer_preview">
            <div class="ah-card grid place-items-center text-center min-h-[440px]">
              <div>
                <div class="mx-auto h-14 w-14 rounded-2xl bg-[#F1F5F9] grid place-items-center mb-4">
                  <svg class="h-6 w-6 text-[#94A3B8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7M5 12h14"/></svg>
                </div>
                <div class="cb-eyebrow mb-1">customer // profile</div>
                <p class="text-sm text-[#64748B]">Select a customer to preview their details here.</p>
              </div>
            </div>
          </turbo-frame>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="ah-card lg:col-span-2 text-center py-16 px-4">
          <svg class="h-16 w-16 mx-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900">No customers yet</h3>
          <p class="mt-2 text-sm text-gray-500">Get started by creating your first customer.</p>
          <%= link_to new_customer_path, class: "mt-6 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-emerald-600 hover:bg-emerald-700" do %>
            <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Add your first customer
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function calculateLeadScore(customerId) {
  if (!confirm('Calculate lead score for this customer?')) return;
  
  fetch(`/customers/${customerId}/calculate_lead_score`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      window.location.reload();
    } else {
      alert('Failed to calculate lead score: ' + (data.error || 'Unknown error'));
    }
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Failed to calculate lead score');
  });
}
</script>
