<div class="min-h-screen bg-gray-50 py-8" data-controller="customer-filter bulk-assign">
  <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
          <h1 class="text-3xl font-bold text-gray-900">Customer Management</h1>
          <p class="mt-2 text-sm text-gray-600">Manage and track all your customer relationships</p>
    </div>
        <div class="flex flex-col sm:flex-row gap-3">
      <% if current_user&.admin? || current_user&.manager? %>
            <%= link_to new_csv_import_path, class: "inline-flex items-center justify-center px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors shadow-sm" do %>
              <svg class="h-5 w-5 mr-2 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
              </svg>
              Import CSV
            <% end %>
          <% end %>
          <% if current_user&.admin? %>
            <a href="<%= export_csv_customers_path %>"
               data-customer-filter-target="exportLink"
               class="inline-flex items-center justify-center px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors shadow-sm">
              <svg class="h-5 w-5 mr-2 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Export CSV
            </a>
          <% end %>
          <%= link_to new_customer_path, class: "inline-flex items-center justify-center px-4 py-2.5 bg-blue-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm" do %>
            <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            New Customer
      <% end %>
        </div>
      </div>
  </div>

    <!-- Filters Section -->
    <div class="mb-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6">
      <div class="flex flex-col lg:flex-row gap-4">
        <!-- Search Bar - Takes more space -->
        <div class="flex-1">
          <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input type="text"
               placeholder="Search customers..."
                   class="block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
               data-customer-filter-target="search"
               data-action="input->customer-filter#debouncedFilter">
          </div>
      </div>

        <!-- Quick Filters -->
        <div class="flex flex-wrap gap-3">
          <!-- Status Filter -->
          <select id="status-filter"
                  class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                  data-customer-filter-target="status"
                  data-action="change->customer-filter#filter">
            <option value="">All Statuses</option>
            <% Customer::STATUSES.each do |key, value| %>
              <option value="<%= value %>" <%= 'selected' if params[:status] == value %>><%= value %></option>
            <% end %>
          </select>

          <% if current_user&.admin? || current_user&.manager? %>
            <!-- Assigned To Filter -->
            <select id="user-filter"
                    class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                    data-customer-filter-target="user"
                  data-action="change->customer-filter#filter">
            <option value="">All Users</option>
            <option value="unassigned">Unassigned</option>
            <% @users.each do |user| %>
              <option value="<%= user.id %>"><%= user.name %></option>
            <% end %>
          </select>
      <% else %>
        <select data-customer-filter-target="user" class="hidden">
          <option value=""></option>
        </select>
      <% end %>

      <!-- Lead Source Filter -->
          <div class="relative" data-controller="multiselect-dropdown" data-customer-filter-target="leadSourceContainer">
        <button type="button"
                    class="inline-flex items-center justify-between min-w-[140px] border border-gray-300 rounded-lg px-3 py-2.5 bg-white shadow-sm hover:bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                data-multiselect-dropdown-target="button"
                data-action="click->multiselect-dropdown#toggle">
              <span data-multiselect-dropdown-target="buttonText" class="text-gray-700">Lead Source</span>
              <svg class="h-4 w-4 ml-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
            <div data-multiselect-dropdown-target="menu" class="hidden absolute z-50 mt-2 w-64 bg-white rounded-lg shadow-lg border border-gray-200 max-h-64 overflow-y-auto right-0">
          <div class="py-1">
            <% Customer::LEAD_SOURCES.each do |key, value| %>
                  <label class="flex items-center px-4 py-2 hover:bg-gray-50 cursor-pointer">
                <input type="checkbox"
                       value="<%= value %>"
                       data-label="<%= value %>"
                       data-multiselect-dropdown-target="checkbox"
                       data-customer-filter-target="leadSourceCheckbox"
                       data-action="change->multiselect-dropdown#checkboxChanged change->customer-filter#filter"
                       class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                    <span class="ml-3 text-sm text-gray-700"><%= value %></span>
              </label>
            <% end %>
          </div>
        </div>
      </div>

          <!-- Customer Type Filter -->
        <select id="customer-type-filter"
                  class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                data-customer-filter-target="customerType"
                data-action="change->customer-filter#filter">
            <option value="">All Types</option>
          <% Customer::CUSTOMER_TYPES.each do |key, value| %>
            <option value="<%= value %>"><%= value %></option>
          <% end %>
        </select>

      <!-- Date Range Filters -->
          <div class="flex items-center gap-2">
            <input type="date"
                   class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                   data-customer-filter-target="startDate"
                   data-action="change->customer-filter#filter"
                   title="From date"
                   placeholder="Start date"
                   value="<%= params[:start_date] %>">
            <span class="text-gray-400 text-xs">to</span>
            <input type="date"
                   class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                   data-customer-filter-target="endDate"
                   data-action="change->customer-filter#filter"
                   title="To date"
                   placeholder="End date"
                   value="<%= params[:end_date] %>">
          </div>

      <!-- Sort Direction -->
        <select id="direction-filter"
                  class="border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                data-customer-filter-target="direction"
                data-action="change->customer-filter#filter">
            <option value="desc">Newest</option>
            <option value="asc">Oldest</option>
        </select>
      </div>
    </div>

    <!-- Active Filter Tags -->
      <div data-customer-filter-target="activeFilters" class="hidden mt-4 pt-4 border-t border-gray-200">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-xs font-medium text-gray-500">Active:</span>
          
          <span data-customer-filter-target="searchBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
        <span data-customer-filter-target="searchText"></span>
            <button type="button" data-action="click->customer-filter#clearSearch" class="ml-1.5 text-blue-600 hover:text-blue-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="userBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">
        <span data-customer-filter-target="userText"></span>
            <button type="button" data-action="click->customer-filter#clearUser" class="ml-1.5 text-indigo-600 hover:text-indigo-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="statusBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
        <span data-customer-filter-target="statusText"></span>
            <button type="button" data-action="click->customer-filter#clearStatus" class="ml-1.5 text-green-600 hover:text-green-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="leadSourceBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
        <span data-customer-filter-target="leadSourceText"></span>
            <button type="button" data-action="click->customer-filter#clearLeadSource" class="ml-1.5 text-purple-600 hover:text-purple-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

          <span data-customer-filter-target="dateRangeBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-teal-100 text-teal-700">
            <span data-customer-filter-target="dateRangeText"></span>
            <button type="button" data-action="click->customer-filter#clearDateRange" class="ml-1.5 text-teal-600 hover:text-teal-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </span>

          <span data-customer-filter-target="customerTypeBadge" class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
        <span data-customer-filter-target="customerTypeText"></span>
            <button type="button" data-action="click->customer-filter#clearCustomerType" class="ml-1.5 text-yellow-600 hover:text-yellow-800">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

      <button type="button"
              data-action="click->customer-filter#clearAll"
                  class="ml-auto text-xs text-gray-600 hover:text-gray-900 underline font-medium">
        Clear All
      </button>
        </div>
    </div>
  </div>

    <!-- Bulk Actions Bar (Admin/Manager only) -->
      <% if current_user&.admin? || current_user&.manager? %>
      <div id="bulk-actions-bar" class="hidden mb-4 bg-blue-50 border border-blue-200 rounded-lg px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <span class="text-sm font-medium text-blue-900" id="selected-count">0 selected</span>
            <button id="select-all" class="text-sm text-blue-700 hover:text-blue-900 font-medium">Select all</button>
            <button id="clear-selection" class="text-sm text-red-600 hover:text-red-800 font-medium">Clear selection</button>
          </div>
          <div class="flex space-x-3">
            <button id="bulk-assign-btn" class="inline-flex items-center px-4 py-2 bg-blue-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm">
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              Bulk Assign
            </button>
            <button id="bulk-status-change-btn" class="inline-flex items-center px-4 py-2 bg-green-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-green-700 transition-colors shadow-sm">
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              Change Status
            </button>
          </div>
          </div>
        </div>

        <!-- Bulk Assign Modal -->
      <div id="bulk-assign-modal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
            <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Bulk Assign Customers</h3>
            <button id="close-modal" class="text-gray-400 hover:text-gray-600">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <%= form_tag bulk_assign_customers_path, method: :post, id: "bulk-assign-form" do %>
              <input type="hidden" name="customer_ids" id="bulk-customer-ids">
              <div class="mb-4">
              <label for="user_id" class="block text-sm font-medium text-gray-700 mb-2">Assign to User</label>
                <% if @users.present? %>
                  <%= select_tag "user_id", options_from_collection_for_select(@users, "id", "name"),
                    class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
                <% else %>
                <p class="text-sm text-red-600">No users available for assignment</p>
                <% end %>
              </div>
            <div class="flex justify-end space-x-3">
              <button type="button" id="cancel-bulk-assign" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
              <button type="submit" class="px-4 py-2 bg-blue-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-blue-700">
                  Assign
                </button>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Bulk Status Change Modal -->
      <div id="bulk-status-change-modal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
            <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Bulk Status Change</h3>
            <button id="close-status-modal" class="text-gray-400 hover:text-gray-600">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <%= form_tag bulk_status_change_customers_path, method: :post, id: "bulk-status-change-form" do %>
              <input type="hidden" name="customer_ids" id="bulk-status-customer-ids">
              <div class="mb-4">
              <label for="status" class="block text-sm font-medium text-gray-700 mb-2">Change Status To</label>
                <%= select_tag "status", options_for_select(Customer::STATUSES.map {|k,v| [v, v]}),
                  class: "block w-full border-gray-300 rounded-lg shadow-sm focus:ring-green-500 focus:border-green-500" %>
              </div>
            <div class="flex justify-end space-x-3">
              <button type="button" id="cancel-bulk-status-change" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
              <button type="submit" class="px-4 py-2 bg-green-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-green-700">
                  Update Status
                </button>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    <!-- Main Content -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden">
      <% if @customers.any? %>
        <!-- Desktop Table View -->
        <div class="hidden md:block overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 table-fixed">
            <thead class="bg-gray-50">
              <tr>
                <% if current_user&.admin? || current_user&.manager? %>
                  <th scope="col" class="w-12 px-4 py-3 text-center">
                    <input type="checkbox" id="select-all-checkbox" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                  </th>
                <% end %>
                <th scope="col" class="w-[15%] px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Customer</th>
                <th scope="col" class="w-[14%] px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Contact</th>
                <th scope="col" class="w-[11%] px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Lead Info</th>
                <th scope="col" class="w-[12%] px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Calls</th>
                <th scope="col" class="w-[12%] px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Messages</th>
                <th scope="col" class="w-[11%] px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Assigned To</th>
                <th scope="col" class="w-[10%] px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
          <tbody class="bg-white divide-y divide-gray-200" data-customer-filter-target="customersList">
            <% @customers.each do |customer| %>
                <tr class="customer-row hover:bg-gray-50 transition-colors <%= customer.customer_type == 'High Value' ? 'bg-amber-50' : '' %>"
                  data-name="<%= customer.name.downcase %>"
                  data-email="<%= customer.email&.downcase %>"
                  data-company="<%= customer.company&.downcase %>"
                  data-phone="<%= customer.phone %>"
                  data-user-id="<%= customer.user_id %>"
                  data-lead-source="<%= customer.lead_source %>"
                  data-status="<%= customer.status %>"
                  data-customer-type="<%= customer.customer_type %>"
                  data-created-at="<%= customer.created_at.to_i %>"
                  data-updated-at="<%= customer.updated_at.to_i %>"
                  data-customer-id="<%= customer.id %>">
                  <% if current_user&.admin? || current_user&.manager? %>
                    <td class="px-4 py-4 text-center">
                      <input type="checkbox" class="customer-checkbox h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" data-id="<%= customer.id %>">
                    </td>
                  <% end %>
                  <td class="px-6 py-4">
                    <div class="flex items-center">
                      <div class="flex-shrink-0 h-10 w-10">
                        <div class="h-10 w-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-semibold text-sm">
                          <%= customer.name.first.upcase %>
                        </div>
                      </div>
                      <div class="ml-4">
                        <div class="text-sm font-medium text-gray-900">
                          <%= link_to customer.name, customer_path(customer), class: "hover:text-blue-600" %>
                        </div>
                        <% if customer.company.present? %>
                          <div class="text-sm text-gray-500"><%= customer.company %></div>
                        <% end %>
                        <div class="text-xs text-gray-400 mt-1">
                          Added <%= customer.created_at.strftime('%b %d, %Y') %>
                        </div>
                      </div>
                  </div>
                </td>
                  <td class="px-6 py-4">
                    <div class="space-y-1">
                      <% if customer.email.present? %>
                  <div class="text-sm text-gray-900 flex items-center">
                          <svg class="h-4 w-4 mr-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                          </svg>
                          <span class="truncate max-w-[200px]"><%= customer.email %></span>
                        </div>
                      <% end %>
                    <% if customer.phone.present? %>
                        <div class="flex items-center">
                          <svg class="h-4 w-4 mr-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                          </svg>
                          <span class="text-sm text-gray-900"><%= customer.phone %></span>
                          <%= link_to calling_path(customer_id: customer.id, phone: customer.phone), class: "ml-2 text-green-600 hover:text-green-800 transition-colors", title: "Call this customer" do %>
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                          <% end %>
                        </div>
                      <% end %>
                  <% if customer.preferred_calling_time.present? && customer.preferred_calling_time != 'Not Applicable' %>
                        <div class="text-xs text-gray-500 flex items-center mt-1">
                          <svg class="h-3 w-3 mr-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <%= customer.preferred_calling_time %>
                    </div>
                  <% end %>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <div class="space-y-2">
                      <% if customer.lead_source.present? %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                          <%= customer.lead_source %>
                        </span>
                      <% end %>
                      <% if customer.repeat_lead? %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 animate-pulse">
                          <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                          </svg>
                          Repeat
                        </span>
                      <% end %>
                      <% if customer.utm_campaign.present? %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800" title="UTM Campaign">
                          <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />
                          </svg>
                          <%= customer.utm_campaign %>
                        </span>
                      <% end %>
                      <% if customer.utm_term.present? %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800" title="UTM Term">
                          <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
                          </svg>
                          <%= customer.utm_term %>
                        </span>
                      <% end %>
                      <div>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= customer_status_color_class(customer.status) %>">
                          <%= customer.status %>
                        </span>
                      </div>
                    </div>
                  </td>
                  <!-- Calls Column -->
                  <td class="px-6 py-4">
                    <div class="flex items-center text-sm">
                      <svg class="h-5 w-5 mr-2 text-blue-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                      <div>
                        <div class="text-gray-900">
                          <span class="font-semibold"><%= customer.total_call_attempts %></span>
                          <span class="text-gray-500 text-xs">attempts</span>
                        </div>
                        <div class="text-xs text-green-600 font-medium">
                          <%= customer.successful_call_attempts %> connected
                        </div>
                      </div>
                    </div>
                  </td>
                  
                  <!-- Messages Column -->
                  <td class="px-6 py-4">
                    <div class="flex items-center text-sm">
                      <svg class="h-5 w-5 mr-2 text-purple-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                      </svg>
                      <div>
                        <div class="text-gray-900">
                          <span class="font-semibold"><%= customer.messages.where(direction: 'outbound').count %></span>
                          <span class="text-gray-500 text-xs">sent</span>
                        </div>
                        <div class="text-xs text-green-600 font-medium">
                          <%= customer.messages.where(direction: 'inbound').count %> replies
                        </div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <% if customer.user %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                        <%= customer.user.name %>
                      </span>
                    <% else %>
                      <div class="flex flex-col space-y-1">
                        <span class="text-sm text-gray-500">Unassigned</span>
                        <% if policy(customer).assign_to_self? %>
                          <%= link_to "Assign to Me", assign_to_self_customer_path(customer),
                              method: :post,
                              data: { turbo_method: :post, turbo_confirm: "Assign this customer to yourself?" },
                              class: "inline-flex items-center justify-center px-2.5 py-1 text-xs font-medium text-white bg-green-600 border border-green-700 rounded hover:bg-green-700 transition-colors" %>
                        <% end %>
                      </div>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <div class="flex items-center justify-end space-x-2">
                      <%= link_to edit_customer_path(customer), class: "inline-flex items-center px-3 py-1.5 bg-indigo-50 text-indigo-700 rounded-lg hover:bg-indigo-100 transition-colors text-xs font-medium" do %>
                        <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Edit
                      <% end %>
                    <% if current_user.admin? %>
                        <%= button_to customer_path(customer), method: :delete, data: { confirm: "Are you sure you want to delete this customer?" }, class: "inline-flex items-center px-3 py-1.5 bg-red-50 text-red-700 rounded-lg hover:bg-red-100 transition-colors text-xs font-medium" do %>
                          <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                          Delete
                        <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

        <!-- Mobile Card View -->
      <div class="md:hidden">
          <div class="divide-y divide-gray-200" data-customer-filter-target="customersList">
          <% @customers.each do |customer| %>
              <div class="p-6 customer-row <%= customer.customer_type == 'High Value' ? 'bg-amber-50' : '' %>"
                data-name="<%= customer.name.downcase %>"
                data-email="<%= customer.email&.downcase %>"
                data-company="<%= customer.company&.downcase %>"
                data-phone="<%= customer.phone %>"
                data-user-id="<%= customer.user_id %>"
                data-lead-source="<%= customer.lead_source %>"
                data-status="<%= customer.status %>"
                data-customer-type="<%= customer.customer_type %>"
                data-created-at="<%= customer.created_at.to_i %>"
                data-updated-at="<%= customer.updated_at.to_i %>"
                data-customer-id="<%= customer.id %>">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center flex-1">
                    <div class="flex-shrink-0 h-12 w-12">
                      <div class="h-12 w-12 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-semibold">
                        <%= customer.name.first.upcase %>
                      </div>
                    </div>
                    <div class="ml-4 flex-1">
                      <h3 class="text-base font-semibold text-gray-900">
                    <%= link_to customer.name, customer_path(customer), class: "hover:text-blue-600" %>
                  </h3>
                      <% if customer.company.present? %>
                        <p class="text-sm text-gray-500"><%= customer.company %></p>
                      <% end %>
                    </div>
                </div>
                <% if current_user&.admin? || current_user&.manager? %>
                    <input type="checkbox" class="customer-checkbox h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" data-id="<%= customer.id %>">
                <% end %>
                </div>

                <div class="space-y-3">
                  <% if customer.email.present? %>
                    <div class="flex items-center text-sm">
                      <svg class="h-5 w-5 mr-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                      <span class="text-gray-900 truncate"><%= customer.email %></span>
                </div>
                  <% end %>
                  
                  <% if customer.phone.present? %>
                    <div class="flex items-center text-sm">
                      <svg class="h-5 w-5 mr-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                      <span class="text-gray-900"><%= customer.phone %></span>
                    </div>
                  <% end %>

                  <div class="flex flex-wrap gap-2">
                    <% if customer.lead_source.present? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <%= customer.lead_source %>
                      </span>
                    <% end %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= customer_status_color_class(customer.status) %>">
                      <%= customer.status %>
                    </span>
                    <% if customer.repeat_lead? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                        Repeat
                      </span>
                    <% end %>
                    <% if customer.utm_campaign.present? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800" title="UTM Campaign">
                        <%= customer.utm_campaign %>
                      </span>
                    <% end %>
                    <% if customer.utm_term.present? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800" title="UTM Term">
                        <%= customer.utm_term %>
                      </span>
                    <% end %>
                  </div>

                  <!-- Connection Attempts -->
                  <div class="pt-3 border-t border-gray-200 space-y-2">
                    <div class="flex items-center text-sm">
                      <svg class="h-4 w-4 mr-2 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                      <span class="text-gray-700">
                        <span class="font-semibold text-gray-900"><%= customer.total_call_attempts %></span> calls,
                        <span class="font-semibold text-green-600"><%= customer.successful_call_attempts %></span> connected
                  </span>
                </div>

                    <div class="flex items-center text-sm">
                      <svg class="h-4 w-4 mr-2 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                      </svg>
                      <span class="text-gray-700">
                        <span class="font-semibold text-gray-900"><%= customer.messages.count %></span> messages,
                        <span class="font-semibold text-green-600"><%= customer.messages.where(direction: 'inbound').count %></span> replies
                      </span>
                    </div>
                  </div>

                  <div class="flex items-center justify-between pt-3 border-t border-gray-200">
                    <div class="text-sm">
                      <span class="text-gray-500">Assigned:</span>
                      <% if customer.user %>
                        <span class="ml-1 font-medium text-gray-900"><%= customer.user.name %></span>
                      <% else %>
                        <span class="ml-1 text-gray-400">Unassigned</span>
                      <% end %>
                    </div>
                    <div class="flex space-x-2">
                      <%= link_to edit_customer_path(customer), class: "inline-flex items-center px-3 py-1.5 bg-indigo-50 text-indigo-700 rounded-lg hover:bg-indigo-100 text-xs font-medium" do %>
                        Edit
                  <% end %>
                </div>
                  </div>
                </div>
              </div>
          <% end %>
        </div>
      </div>

        <!-- No Results Message -->
      <div data-customer-filter-target="noResults" class="hidden text-center py-12 px-4">
          <svg class="h-16 w-16 mx-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900">No matching customers</h3>
          <p class="mt-2 text-sm text-gray-500">Try adjusting your search criteria or filters</p>
          <button type="button" data-action="click->customer-filter#clearAll" class="mt-6 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700">
            Clear all filters
          </button>
      </div>

        <!-- Pagination -->
      <% if @customers.total_pages > 1 %>
          <div class="bg-white px-6 py-4 border-t border-gray-200">
            <div class="flex items-center justify-between">
          <div class="flex-1 flex justify-between sm:hidden">
                <%= link_to_prev_page @customers, 'Previous', class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50" %>
                <%= link_to_next_page @customers, 'Next', class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50" %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700">
                Showing <span class="font-medium"><%= @customers.offset_value + 1 %></span> to <span class="font-medium"><%= @customers.offset_value + @customers.size %></span> of <span class="font-medium"><%= @customers.total_count %></span> customers
              </p>
            </div>
                <nav class="relative z-0 inline-flex rounded-lg shadow-sm -space-x-px" aria-label="Pagination">
              <%= paginate @customers %>
            </nav>
              </div>
          </div>
        </div>
      <% end %>
    <% else %>
        <!-- Empty State -->
        <div class="text-center py-16 px-4">
          <svg class="h-16 w-16 mx-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900">No customers yet</h3>
          <p class="mt-2 text-sm text-gray-500">Get started by creating your first customer.</p>
          <%= link_to new_customer_path, class: "mt-6 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700" do %>
            <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Add your first customer
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function calculateLeadScore(customerId) {
  if (!confirm('Calculate lead score for this customer?')) return;
  
  fetch(`/customers/${customerId}/calculate_lead_score`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      window.location.reload();
    } else {
      alert('Failed to calculate lead score: ' + (data.error || 'Unknown error'));
    }
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Failed to calculate lead score');
  });
}
</script>
