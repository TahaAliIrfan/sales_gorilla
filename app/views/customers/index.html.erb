<div class="container mx-auto px-4 py-8" data-controller="customer-filter">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold">Customers</h1>
      <p class="text-gray-600 mt-1">Manage your customer relationships</p>
    </div>
    <div>
      <%= link_to "New Customer", new_customer_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <!-- Sleek Filter Bar -->
  <div class="bg-white shadow-sm rounded-lg mb-6 border border-gray-200">
    <div class="flex flex-col md:flex-row">
      <!-- Search Field -->
      <div class="relative flex-grow border-b md:border-b-0 md:border-r border-gray-200">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
          </svg>
        </div>
        <input type="text"
               placeholder="Search customers..."
               class="block w-full pl-10 pr-3 py-5 border-0 focus:ring-0 focus:outline-none text-sm"
               data-customer-filter-target="search"
               data-action="input->customer-filter#debouncedFilter">
      </div>

      <!-- Assigned To Filter -->
      <% if current_user&.admin? || current_user&.manager? %>
        <div class="px-3 py-2 border-b md:border-b-0 md:border-r border-gray-200">
          <label for="user-filter" class="block text-xs font-medium text-gray-500 mb-1">Assigned To</label>
          <select id="user-filter"
                  class="block w-full border-0 focus:ring-0 focus:outline-none text-sm py-1 px-0"
                  data-customer-filter-target="user"
                  data-action="change->customer-filter#filter">
            <option value="">All Users</option>
            <option value="unassigned">Unassigned</option>
            <% @users.each do |user| %>
              <option value="<%= user.id %>"><%= user.name %></option>
            <% end %>
          </select>
        </div>
      <% end %>

      <!-- Status Filter -->
      <div class="px-3 py-2 border-b md:border-b-0 md:border-r border-gray-200">
        <label for="status-filter" class="block text-xs font-medium text-gray-500 mb-1">Status</label>
        <select id="status-filter"
                class="block w-full border-0 focus:ring-0 focus:outline-none text-sm py-1 px-0"
                data-customer-filter-target="status"
                data-action="change->customer-filter#filter">
          <option value="">All Statuses</option>
          <% Customer::STATUSES.each do |key, value| %>
            <option value="<%= value %>" <%= 'selected' if params[:status] == value %>><%= value %></option>
          <% end %>
        </select>
        <% if !current_user&.admin? %>
          <!-- Debug information for non-admin users -->
          <div class="hidden">
            <p>User is not admin. Current filter status: <%= params[:status] %></p>
          </div>
        <% end %>
      </div>

      <!-- Lead Source Filter -->
      <div class="px-3 py-2 border-b md:border-b-0 md:border-r border-gray-200">
        <label for="lead-source-filter" class="block text-xs font-medium text-gray-500 mb-1">Lead Source</label>
        <select id="lead-source-filter"
                class="block w-full border-0 focus:ring-0 focus:outline-none text-sm py-1 px-0"
                data-customer-filter-target="leadSource"
                data-action="change->customer-filter#filter">
          <option value="">All Sources</option>
          <% Customer::LEAD_SOURCES.each do |key, value| %>
            <option value="<%= value %>"><%= value %></option>
          <% end %>
        </select>
      </div>

      <!-- Sort Direction -->
      <div class="px-3 py-2">
        <label for="direction-filter" class="block text-xs font-medium text-gray-500 mb-1">Order</label>
        <select id="direction-filter"
                class="block w-full border-0 focus:ring-0 focus:outline-none text-sm py-1 px-0"
                data-customer-filter-target="direction"
                data-action="change->customer-filter#filter">
          <option value="desc">Descending</option>
          <option value="asc">Ascending</option>
        </select>
      </div>
    </div>

    <!-- Active Filter Tags -->
    <div data-customer-filter-target="activeFilters" class="hidden px-4 py-2 bg-gray-50 border-t border-gray-200 text-xs flex flex-wrap gap-2">
      <span data-customer-filter-target="searchBadge" class="hidden inline-flex items-center px-2 py-1 rounded-full bg-blue-100 text-blue-800">
        <span data-customer-filter-target="searchText"></span>
        <button type="button" data-action="click->customer-filter#clearSearch" class="ml-1 text-blue-500 hover:text-blue-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

      <span data-customer-filter-target="userBadge" class="hidden inline-flex items-center px-2 py-1 rounded-full bg-indigo-100 text-indigo-800">
        <span data-customer-filter-target="userText"></span>
        <button type="button" data-action="click->customer-filter#clearUser" class="ml-1 text-indigo-500 hover:text-indigo-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

      <span data-customer-filter-target="statusBadge" class="hidden inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800">
        <span data-customer-filter-target="statusText"></span>
        <button type="button" data-action="click->customer-filter#clearStatus" class="ml-1 text-green-500 hover:text-green-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

      <span data-customer-filter-target="leadSourceBadge" class="hidden inline-flex items-center px-2 py-1 rounded-full bg-purple-100 text-purple-800">
        <span data-customer-filter-target="leadSourceText"></span>
        <button type="button" data-action="click->customer-filter#clearLeadSource" class="ml-1 text-purple-500 hover:text-purple-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>

      <button type="button"
              data-action="click->customer-filter#clearAll"
              class="ml-auto text-xs text-gray-500 hover:text-gray-700 underline">
        Clear All
      </button>
    </div>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden" data-controller="bulk-assign">
    <% if @customers.any? %>
      <% if current_user&.admin? || current_user&.manager? %>
        <!-- Bulk Actions Bar - Only visible when at least one row is selected -->
        <div id="bulk-actions-bar" class="hidden bg-gray-100 px-6 py-2 flex items-center justify-between border-b border-gray-200">
          <div class="flex items-center space-x-2">
            <span class="text-sm font-medium" id="selected-count">0 selected</span>
            <button id="select-all" class="text-xs text-blue-600 hover:text-blue-800">Select all</button>
            <button id="clear-selection" class="text-xs text-red-600 hover:text-red-800">Clear selection</button>
          </div>
          <div>
            <button id="bulk-assign-btn" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              Bulk Assign
            </button>
          </div>
        </div>

        <!-- Bulk Assign Modal -->
        <div id="bulk-assign-modal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center">
          <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-auto p-6">
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-lg font-medium">Bulk Assign Customers</h3>
              <button id="close-modal" class="text-gray-500 hover:text-gray-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <%= form_tag bulk_assign_customers_path, method: :post, id: "bulk-assign-form" do %>
              <input type="hidden" name="customer_ids" id="bulk-customer-ids">
              <div class="mb-4">
                <label for="user_id" class="block text-sm font-medium text-gray-700 mb-1">Assign to User</label>
                <% if @users.present? %>
                  <%= select_tag "user_id", options_from_collection_for_select(@users, "id", "name"),
                      class: "block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
                <% else %>
                  <p class="text-red-500">No users available for assignment</p>
                <% end %>
              </div>
              <div class="flex justify-end">
                <button type="button" id="cancel-bulk-assign" class="mr-2 inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  Cancel
                </button>
                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  Assign
                </button>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="bg-gray-50">
            <% if current_user&.admin? || current_user&.manager? %>
              <th scope="col" class="px-3 py-3 text-center">
                <input type="checkbox" id="select-all-checkbox" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
              </th>
            <% end %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Name
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Email
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phone/Preferred Time</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Lead Source</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned To</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Date Added
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </thead>
          <tbody class="bg-white" data-customer-filter-target="customersList">
            <% @customers.each do |customer| %>
              <tr class="customer-row <%= customer_status_border_class(customer) %>"
                  data-name="<%= customer.name.downcase %>"
                  data-email="<%= customer.email&.downcase %>"
                  data-company="<%= customer.company&.downcase %>"
                  data-phone="<%= customer.phone %>"
                  data-user-id="<%= customer.user_id %>"
                  data-lead-source="<%= customer.lead_source %>"
                  data-status="<%= customer.status %>"
                  data-created-at="<%= customer.created_at.to_i %>"
                  data-updated-at="<%= customer.updated_at.to_i %>"
                  data-customer-id="<%= customer.id %>">
                <% if current_user&.admin? || current_user&.manager? %>
                  <td class="px-3 py-4 whitespace-nowrap text-center">
                    <input type="checkbox" class="customer-checkbox h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" data-id="<%= customer.id %>" title="Select customer ID: <%= customer.id %>">
                  </td>
                <% end %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-blue-600">
                    <%= link_to customer.name, customer_path(customer) %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900"><%= customer.email %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900 flex items-center">
                    <%= customer.phone %>
                    <% if customer.phone.present? %>
                      <%= link_to calling_path(customer_id: customer.id, phone: customer.phone), class: "ml-2 text-green-600 hover:text-green-800 transition-colors duration-150", title: "Call this customer" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                  <% if customer.preferred_calling_time.present? && customer.preferred_calling_time != 'Not Applicable' %>
                    <div class="text-xs text-gray-500 mt-1">
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <%= customer.preferred_calling_time %>
                      </span>
                    </div>
                  <% end %>
                  <% if current_time = customer.current_time_in_timezone %>
                    <div class="text-xs text-gray-500 mt-1">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-blue-100 text-blue-800 border border-blue-200">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span title="<%= customer.timezone.present? ? customer.timezone : 'Based on country' %>">
                         Current Time:- <%= current_time.strftime("%I:%M %p") %>
                          <span class="text-blue-600 font-normal">(<%= current_time.strftime("%Z") %>)</span>
                        </span>
                      </span>
                      <div class="mt-1 flex items-center space-x-2">
                        <% if customer.preferred_calling_time.present? && customer.preferred_calling_time != 'Not Applicable' %>
                          <% if customer.is_preferred_calling_time? %>
                          <span class="inline-flex items-center ml-1 px-2 py-0.5 rounded-md text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            Within call window
                          </span>
                          <% else %>
                          <span class="inline-flex items-center ml-1 px-2 py-0.5 rounded-md text-xs font-medium bg-red-100 text-red-800 border border-red-200">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Outside call window
                          </span>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div class="text-xs text-gray-500 mt-1">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-gray-100 text-gray-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        No timezone set
                      </span>
                    </div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900">
                    <% if customer.lead_source.present? %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                        <%= customer.lead_source %>
                      </span>
                    <% else %>
                      <span class="text-gray-500">Not specified</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900">
                    <% if customer.user %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                        <%= customer.user.name %>
                      </span>
                    <% else %>
                      <span class="text-gray-500">Unassigned</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= customer.created_at.strftime('%b %d, %Y') %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to "View", customer_path(customer), class: "text-blue-600 hover:text-blue-900" %>
                    <%= link_to "Edit", edit_customer_path(customer), class: "text-indigo-600 hover:text-indigo-900" %>
                    <% if current_user.admin? %>
                      <%= button_to "Delete", customer_path(customer), method: :delete, data: { confirm: "Are you sure you want to delete this customer?" }, class: "text-red-600 hover:text-red-900 bg-transparent border-none p-0 cursor-pointer" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- No Results Message (hidden by default) -->
      <div data-customer-filter-target="noResults" class="hidden text-center py-12 px-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-lg font-medium text-gray-900">No matching customers</h3>
        <p class="mt-1 text-gray-500">Try adjusting your search criteria</p>
        <div class="mt-6">
          <button type="button" data-action="click->customer-filter#clearAll" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
            Clear all filters
          </button>
        </div>
      </div>

      <!-- Pagination Controls -->
      <% if @customers.total_pages > 1 %>
        <div class="px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
          <div class="flex-1 flex justify-between sm:hidden">
            <%= link_to_prev_page @customers, 'Previous', class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
            <%= link_to_next_page @customers, 'Next', class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700">
                Showing <span class="font-medium"><%= @customers.offset_value + 1 %></span> to <span class="font-medium"><%= @customers.offset_value + @customers.size %></span> of <span class="font-medium"><%= @customers.total_count %></span> customers
              </p>
            </div>
            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
              <%= paginate @customers %>
            </nav>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-12 px-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <h3 class="mt-2 text-lg font-medium text-gray-900">No customers yet</h3>
        <p class="mt-1 text-gray-500">Get started by creating your first customer.</p>
        <div class="mt-6">
          <%= link_to "Add your first customer", new_customer_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Results Count -->
  <div class="mt-4 text-sm text-gray-600" data-customer-filter-target="resultsCount">
    <% if @customers.any? %>
      <% if @customers.total_pages > 1 %>
        Showing page <%= @customers.current_page %> of <%= @customers.total_pages %>
      <% else %>
        Showing <%= @customers.count %> customers
      <% end %>
    <% end %>
  </div>
</div>

<style>
  .animate-pulse {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
    100% {
      opacity: 1;
    }
  }
</style>
