<%# Relay "Leads" — dense filterable list with bulk actions + CSV import.
    Mirrors docs/design/relay-app/project/app/view-leads.jsx, honest to the DB. %>
<% content_for :title, "Leads — #{current_organization&.name}" %>
<%
  can_manage  = current_user&.admin? || current_user&.manager?
  total_count = @customers.respond_to?(:total_count) ? @customers.total_count : @customers.size
%>

<div class="page page--wide"
     data-controller="relay--bulk-select"
     data-relay--bulk-select-assign-url-value="<%= bulk_assign_customers_path %>"
     data-relay--bulk-select-status-url-value="<%= bulk_status_change_customers_path %>">
  <%# === Header === %>
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Leads</div>
      <div class="pagehead__sub">
        <b><%= number_with_delimiter(total_count) %></b> <%= "lead".pluralize(total_count) %> · color-coded by status, scored, multi-channel.
      </div>
    </div>
    <div class="pagehead__actions">
      <% if can_manage %>
        <%= link_to new_csv_import_path, class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("upload", size: 15) %>Import CSV
        <% end %>
      <% end %>
      <% if current_user&.admin? %>
        <%= link_to export_csv_customers_path(request.query_parameters), class: "rl-btn rl-btn--secondary" do %>
          <%= relay_icon("download", size: 15) %>Export CSV
        <% end %>
      <% end %>
      <%= link_to new_customer_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("user-plus", size: 15) %>Add lead
      <% end %>
    </div>
  </div>

  <%# === Filter bar (reuses existing query params: search/status/lead_source/user_id) === %>
  <%= form_with url: customers_path, method: :get, data: { turbo_frame: "_top" } do %>
    <div class="filterbar">
      <div class="rl-inputwrap" style="width:280px">
        <span class="rl-affix"><%= relay_icon("search", size: 16) %></span>
        <%= text_field_tag :search, params[:search],
              class: "rl-input", placeholder: "Search name, company, email, phone…",
              onchange: "this.form.requestSubmit()" %>
      </div>

      <%= select_tag :status,
            options_for_select([["All statuses", ""]] + current_organization.taxonomy_options("customer_status"), params[:status]),
            class: "rl-select", style: "width:170px", onchange: "this.form.requestSubmit()" %>

      <%= select_tag :lead_source,
            options_for_select([["All sources", ""]] + current_organization.taxonomy_options("lead_source"), params[:lead_source]),
            class: "rl-select", style: "width:170px", onchange: "this.form.requestSubmit()" %>

      <% if can_manage %>
        <%= select_tag :user_id,
              options_for_select(
                [["All owners", ""], ["Unassigned", "unassigned"]] + @users.to_a.map { |u| [u.name, u.id.to_s] },
                params[:user_id]
              ),
              class: "rl-select", style: "width:170px", onchange: "this.form.requestSubmit()" %>
      <% end %>

      <div class="grow"></div>
      <span class="muted rl-sm nowrap"><%= number_with_delimiter(total_count) %> <%= "lead".pluralize(total_count) %></span>
      <% if params[:search].present? || params[:status].present? || params[:lead_source].present? || params[:user_id].present? %>
        <%= link_to "Clear filters", customers_path, class: "rl-btn rl-btn--ghost rl-btn--sm" %>
      <% end %>
    </div>
  <% end %>

  <div class="rl-table-wrap">
    <% if can_manage %>
      <%# Bulk bar — hidden until rows are selected (driven by relay--bulk-select) %>
      <div class="rl-bulkbar" data-relay--bulk-select-target="bar" hidden>
        <span><b data-relay--bulk-select-target="count">0</b> selected</span>
        <div class="row" style="gap:6px">
          <div data-controller="relay--dropdown" style="position:relative;display:inline-flex">
            <button type="button" class="rl-btn rl-btn--secondary rl-btn--sm"
                    data-action="relay--dropdown#toggle" data-relay--dropdown-target="trigger">
              <%= relay_icon("user-check", size: 14) %>Assign
            </button>
            <div class="menu-float pop" data-relay--dropdown-target="menu" hidden style="top:calc(100% + 6px);left:0">
              <div class="rl-menu" style="min-width:220px">
                <% @users.to_a.each do |u| %>
                  <button type="button" class="rl-menuitem"
                          data-action="relay--bulk-select#assign" data-user-id="<%= u.id %>">
                    <%= relay_icon("user", size: 15) %><%= u.name %>
                  </button>
                <% end %>
              </div>
            </div>
          </div>

          <div data-controller="relay--dropdown" style="position:relative;display:inline-flex">
            <button type="button" class="rl-btn rl-btn--secondary rl-btn--sm"
                    data-action="relay--dropdown#toggle" data-relay--dropdown-target="trigger">
              <%= relay_icon("tag", size: 14) %>Set status
            </button>
            <div class="menu-float pop" data-relay--dropdown-target="menu" hidden style="top:calc(100% + 6px);left:0">
              <div class="rl-menu" style="min-width:200px">
                <% current_organization.taxonomy_values("customer_status").each do |v| %>
                  <button type="button" class="rl-menuitem"
                          data-action="relay--bulk-select#changeStatus" data-status="<%= v %>">
                    <i class="rl-dot" style="background:currentColor"></i><%= v %>
                  </button>
                <% end %>
              </div>
            </div>
          </div>

          <% if current_user&.admin? %>
            <button type="button" class="rl-btn rl-btn--secondary rl-btn--sm"
                    data-action="relay--bulk-select#exportSelected">
              <%= relay_icon("download", size: 14) %>Export
            </button>
          <% end %>
          <button type="button" class="rl-btn rl-btn--ghost rl-btn--sm" data-action="relay--bulk-select#clear">Clear</button>
        </div>
      </div>
    <% end %>

    <% if @customers.any? %>
      <div class="rl-table-scroll">
        <table class="rl-table">
          <thead>
            <tr>
              <% if can_manage %>
                <th style="width:40px">
                  <label class="rl-check">
                    <input type="checkbox" data-relay--bulk-select-target="all" data-action="relay--bulk-select#toggleAll">
                    <span class="rl-box"><%= relay_icon("check", size: 13) %></span>
                  </label>
                </th>
              <% end %>
              <th>Lead</th>
              <th>Channels</th>
              <th>Status</th>
              <th>Score</th>
              <th>Source</th>
              <th>Owner</th>
              <th>Local time</th>
              <th style="width:44px"></th>
            </tr>
          </thead>
          <tbody>
            <% @customers.each do |customer| %>
              <% local_time = customer.current_location_time %>
              <tr data-relay--bulk-select-target="row">
                <% if can_manage %>
                  <td>
                    <label class="rl-check">
                      <input type="checkbox" value="<%= customer.id %>"
                             data-relay--bulk-select-target="checkbox"
                             data-action="relay--bulk-select#toggleRow">
                      <span class="rl-box"><%= relay_icon("check", size: 13) %></span>
                    </label>
                  </td>
                <% end %>

                <%# Lead — avatar + name + title/company %>
                <td class="clickable" onclick="window.location='<%= customer_path(customer) %>'">
                  <div class="row" style="gap:10px">
                    <span class="rl-avatar rl-avatar--sm <%= relay_avatar_class(customer.name) %>"><%= relay_initials(customer.name) %></span>
                    <div style="min-width:0">
                      <div class="rl-cell-strong"><%= customer.name %></div>
                      <div class="muted" style="font-size:12px">
                        <%= [customer.project_type.presence, customer.company.presence].compact.reject { |v| v == "Not Applicable" }.join(" · ").presence || "No company" %>
                      </div>
                    </div>
                  </div>
                </td>

                <%# Channels — pips for channels the lead actually has %>
                <td>
                  <div class="row" style="gap:4px">
                    <% if customer.phone.present? %><span class="chan chan--call"><%= relay_icon("phone", size: 14) %></span><% end %>
                    <% if customer.email.present? %><span class="chan chan--email"><%= relay_icon("mail", size: 14) %></span><% end %>
                    <% if customer.whatsapp_chat_id.present? %><span class="chan chan--whatsapp"><%= relay_icon("message-circle", size: 14) %></span><% end %>
                    <% if customer.linkedin_url.present? %><span class="chan chan--linkedin"><%= relay_icon("linkedin", size: 14) %></span><% end %>
                  </div>
                </td>

                <%# Status pill %>
                <td>
                  <span class="rl-pill <%= relay_status_pill_class(customer.status) %>"><i class="rl-dot"></i><%= customer.status %></span>
                </td>

                <%# Score meter %>
                <td>
                  <% if customer.lead_score.present? %>
                    <span class="score">
                      <span class="score__bar"><i style="width:<%= customer.lead_score.to_i.clamp(0, 100) %>%;background:<%= relay_score_color(customer.lead_score) %>"></i></span>
                      <span class="score__num"><%= customer.lead_score %></span>
                    </span>
                  <% else %>
                    <span class="muted rl-sm">—</span>
                  <% end %>
                </td>

                <%# Source tag %>
                <td>
                  <% if customer.lead_source.present? %>
                    <span class="rl-tag"><i class="rl-tag-dot" style="background:<%= relay_source_color(customer.lead_source) %>"></i><%= customer.lead_source %></span>
                  <% else %>
                    <span class="muted rl-sm">—</span>
                  <% end %>
                </td>

                <%# Owner %>
                <td>
                  <% if customer.user %>
                    <div class="row" style="gap:8px">
                      <span class="rl-avatar rl-avatar--xs <%= relay_avatar_class(customer.user.name) %>"><%= relay_initials(customer.user.name) %></span>
                      <span class="rl-sm"><%= customer.user.name %></span>
                    </div>
                  <% elsif policy(customer).assign_to_self? %>
                    <%= button_to assign_to_self_customer_path(customer), method: :post,
                          form: { class: "shrink-0" }, class: "rl-btn rl-btn--brand-soft rl-btn--sm" do %>
                      Assign to me
                    <% end %>
                  <% else %>
                    <span class="rl-badge rl-badge--warning">Unassigned</span>
                  <% end %>
                </td>

                <%# Local time %>
                <td>
                  <% if local_time %>
                    <div class="row" style="gap:6px">
                      <span class="mono" style="font-size:12px"><%= local_time.strftime("%H:%M") %></span>
                      <span class="muted" style="font-size:11px"><%= local_time.zone %></span>
                    </div>
                  <% else %>
                    <span class="muted rl-sm">—</span>
                  <% end %>
                </td>

                <%# Row actions %>
                <td onclick="event.stopPropagation()">
                  <div data-controller="relay--dropdown" style="position:relative;display:inline-flex">
                    <button type="button" class="rl-iconbtn rl-iconbtn--sm"
                            data-action="relay--dropdown#toggle" data-relay--dropdown-target="trigger">
                      <%= relay_icon("more-horizontal", size: 16) %>
                    </button>
                    <div class="menu-float pop" data-relay--dropdown-target="menu" hidden style="top:calc(100% + 6px);right:0">
                      <div class="rl-menu" style="min-width:200px">
                        <%= link_to customer_path(customer), class: "rl-menuitem" do %>
                          <%= relay_icon("square-arrow-out-up-right", size: 15) %>Open workspace
                        <% end %>
                        <% if customer.phone.present? && feature_enabled?(:calling) %>
                          <%= link_to calling_path(customer_id: customer.id, phone: customer.phone), class: "rl-menuitem" do %>
                            <%= relay_icon("phone", size: 15) %>Call now
                          <% end %>
                        <% end %>
                        <%= link_to edit_customer_path(customer), class: "rl-menuitem" do %>
                          <%= relay_icon("user-check", size: 15) %>Edit lead
                        <% end %>
                        <% if current_user&.admin? %>
                          <div class="rl-menu__sep"></div>
                          <%= button_to customer_path(customer), method: :delete,
                                form: { data: { turbo_confirm: "Delete this lead?" } },
                                class: "rl-menuitem is-danger", style: "width:100%" do %>
                            <%= relay_icon("archive", size: 15) %>Delete
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @customers.respond_to?(:total_pages) && @customers.total_pages > 1 %>
        <div class="rl-pagination">
          <span>
            Showing <%= @customers.offset_value + 1 %>–<%= @customers.offset_value + @customers.size %> of <%= number_with_delimiter(total_count) %>
          </span>
          <div class="rl-pagebtns"><%= paginate @customers, theme: "relay" %></div>
        </div>
      <% end %>
    <% else %>
      <div class="empty">
        <div class="empty__ic"><%= relay_icon("users", size: 26) %></div>
        <div class="rl-h4" style="margin-bottom:4px">No leads match</div>
        <div class="muted rl-sm" style="max-width:360px">Try clearing filters, or import a fresh list to get started.</div>
        <div class="row" style="margin-top:16px;gap:8px">
          <% if can_manage %>
            <%= link_to "Import CSV", new_csv_import_path, class: "rl-btn rl-btn--primary rl-btn--sm" %>
          <% end %>
          <%= link_to "Add lead", new_customer_path, class: "rl-btn rl-btn--secondary rl-btn--sm" %>
        </div>
      </div>
    <% end %>
  </div>

  <% if can_manage %>
    <%# Hidden forms posted by relay--bulk-select for the bulk endpoints. %>
    <%= form_tag bulk_assign_customers_path, method: :post, data: { relay__bulk_select_target: "assignForm" }, style: "display:none" do %>
      <%= hidden_field_tag :customer_ids, "", data: { relay__bulk_select_target: "assignIds" } %>
      <%= hidden_field_tag :user_id, "", data: { relay__bulk_select_target: "assignUser" } %>
    <% end %>
    <%= form_tag bulk_status_change_customers_path, method: :post, data: { relay__bulk_select_target: "statusForm" }, style: "display:none" do %>
      <%= hidden_field_tag :customer_ids, "", data: { relay__bulk_select_target: "statusIds" } %>
      <%= hidden_field_tag :status, "", data: { relay__bulk_select_target: "statusValue" } %>
    <% end %>
  <% end %>
</div>
