<%# locals: customer %>
<div class="rounded-xl bg-panel p-6 shadow-card ring-1 ring-[var(--color-line-2)]">
  <div class="flex flex-wrap items-start gap-6">
    <%# Avatar %>
    <span class="grid h-20 w-20 shrink-0 place-items-center rounded-full font-display text-3xl font-bold text-white shadow-lift"
          style="background: var(--brand-primary)">
      <%= customer.name.first&.upcase %>
    </span>

    <%# Identity + pills %>
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="micro mb-1">Customer</p>
          <h1 class="font-display text-3xl font-bold leading-tight tracking-tight text-ink">
            <%= customer.name %>
          </h1>
          <% if customer.company.present? %>
            <p class="mt-1 text-base text-ink-soft"><%= customer.company %></p>
          <% end %>

          <div class="mt-3 flex flex-wrap gap-2">
            <% if customer.status.present? %>
              <div class="relative inline-flex items-center"
                   data-controller="status-updater"
                   data-status-updater-customer-id-value="<%= customer.id %>">
                <span data-status-updater-target="statusBadge" data-status="<%= customer.status %>">
                  <%= render "shared/status_pill", label: customer.status %>
                </span>
                <button type="button" data-action="click->status-updater#openDropdown"
                        class="ml-1 text-ink-soft transition hover:text-ink"
                        title="Update status">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg>
                </button>

                <div data-status-updater-target="dropdown"
                     class="hidden absolute top-full left-0 z-20 mt-2 max-h-96 w-64 overflow-y-auto rounded-lg bg-panel py-1 shadow-lift ring-1 ring-[var(--color-line-2)]">
                  <p class="micro sticky top-0 border-b border-[var(--color-line)] bg-panel px-3 py-2">Update status</p>
                  <% Customer::STATUSES.values.each do |status| %>
                    <button type="button"
                            data-action="click->status-updater#updateStatus"
                            data-status="<%= status %>"
                            class="flex w-full items-center justify-between px-3 py-2 text-left text-sm transition hover:bg-[var(--color-line)] <%= 'bg-[var(--color-line)] font-semibold' if customer.status == status %>">
                      <span><%= status %></span>
                      <span class="h-1.5 w-1.5 rounded-full" style="background: var(--brand-accent)"></span>
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if customer.lead_source.present? %>
              <span class="inline-flex items-center rounded-full bg-[var(--color-line)] px-2.5 py-0.5 text-xs font-medium text-ink-soft">
                <%= customer.lead_source %>
              </span>
            <% end %>

            <% if customer.customer_type == "High Value" %>
              <span class="mono inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold"
                    style="background: var(--brand-accent-soft); color: var(--brand-accent)">
                ★ High value
              </span>
            <% end %>

            <% if customer.repeat_lead? %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium"
                    style="background: rgba(245,158,11,0.15); color: #92400e">
                Repeat lead
              </span>
            <% end %>

            <% if current_user&.admin? && customer.gclid.present? %>
              <div data-controller="lead-quality" data-lead-quality-customer-id-value="<%= customer.id %>"
                   class="inline-flex items-center">
                <% if customer.lead_quality.present? %>
                  <% q_tone = customer.lead_quality == "good" ? "ok" : "bad" %>
                  <%= render "shared/status_pill",
                        label: (customer.lead_quality == "good" ? "Good lead" : "Bad lead"),
                        tone: q_tone %>
                  <% if customer.google_conversion_sent_at.present? %>
                    <span class="micro ml-1" title="Sent to Google Ads">✓ synced</span>
                  <% end %>
                <% else %>
                  <button data-action="click->lead-quality#markGood"
                          class="mono inline-flex items-center rounded-l-full px-2.5 py-1 text-xs font-semibold text-white transition"
                          style="background: var(--color-accent)">Good</button>
                  <button data-action="click->lead-quality#markBad"
                          class="mono inline-flex items-center rounded-r-full bg-[#c0492f] px-2.5 py-1 text-xs font-semibold text-white transition hover:opacity-90">Bad</button>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <% if customer.lead_score.present? %>
          <div class="text-right">
            <p class="micro">Lead score</p>
            <p class="mono mt-1 text-4xl font-semibold leading-none <%= customer.lead_score_color %>">
              <%= customer.lead_score %>
            </p>
          </div>
        <% end %>
      </div>

      <%# Contact grid %>
      <dl class="mt-6 grid gap-4 border-t border-dashed border-[var(--color-line-2)] pt-5 sm:grid-cols-2 lg:grid-cols-4">
        <div>
          <dt class="micro mb-1">Email</dt>
          <dd class="truncate text-sm font-medium text-ink"><%= customer.email.presence || "—" %></dd>
        </div>
        <div>
          <dt class="micro mb-1">Phone</dt>
          <dd class="mono text-sm font-medium text-ink"><%= customer.phone.presence || "—" %></dd>
        </div>
        <div>
          <dt class="micro mb-1">Assigned to</dt>
          <dd class="text-sm font-medium text-ink"><%= customer.user&.name || "Unassigned" %></dd>
        </div>
        <div>
          <dt class="micro mb-1">Created</dt>
          <dd class="mono text-sm font-medium text-ink"><%= customer.created_at.strftime("%b %-d, %Y") %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
