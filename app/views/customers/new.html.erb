<% content_for :title, "New customer — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">New customer</div>
      <div class="pagehead__sub">Add a new customer to your CRM.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to customers_path, class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to customers
      <% end %>
    </div>
  </div>

  <%= render "form", customer: @customer %>
</div>
