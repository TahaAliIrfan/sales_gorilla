<%# locals: customer, recordings %>
<%
  tabs = [
    { id: "overview",       label: "Overview",        icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z", count: nil },
    { id: "emails",         label: "Emails",          icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",                                                                                                                                                                                                                                                                                                                                                                                              count: customer.emails.count },
    { id: "communications", label: "WhatsApp",        icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",                                                                                                                                                                                                                                                                                                                                       count: nil, badge: (customer.whatsapp_chat_id.present? ? "Active" : nil) },
    { id: "whatsapp-us",    label: "WhatsApp US",     icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",                                                                                                                                                                                                                                                                                                                                       count: nil, badge: (customer.whatsapp_us_window_open? ? "Open" : nil) },
    { id: "recordings",     label: "Call recordings", icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z",                                                                                                                                                                                                            count: recordings.count },
    { id: "deals",          label: "Deals",           icon: "M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6",                                                                                                                                                                                                                                                                                                                                                                                                                                          count: customer.deals.count },
    { id: "tasks",          label: "Tasks",           icon: "M9 11l3 3 8-8M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11",                                                                                                                                                                                                                                                                                                                                                                                                                              count: customer.tasks.count },
    { id: "activities",     label: "Activities",      icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",                                                                                                                                                                                                                                                                                                                                                                                                                                                       count: nil },
    { id: "meta-events",    label: "Meta events",     icon: "M3 3v18h18M7 14l4-4 4 4 6-6",                                                                                                                                                                                                                                                                                                                                                                                                                                                                       count: customer.meta_conversion_logs.count },
    { id: "documents",      label: "Documents",       icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6",                                                                                                                                                                                                                                                                                                                                                                                                                              count: nil },
    { id: "invoices",       label: "Invoices",        icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M16 13H8 M16 17H8",                                                                                                                                                                                                                                                                                                                                                                                                                      count: customer.invoices.count },
    { id: "milestones",     label: "Milestones",      icon: "M12 1v22M5 12h14",                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  count: customer.milestones.count, alert: (customer.unpaid_milestones_count.to_i > 0 ? "#{customer.unpaid_milestones_count} unpaid" : nil) }
  ]
%>
<nav class="flex overflow-x-auto border-b border-[var(--color-line)]" aria-label="Tabs">
  <% tabs.each_with_index do |t, i| %>
    <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="<%= t[:id] %>"
            class="tab-button <%= 'active' if i.zero? %> inline-flex items-center gap-2 whitespace-nowrap border-b-2 px-5 py-3.5 text-sm font-medium transition <%= i.zero? ? 'border-[var(--brand-primary)] text-ink' : 'border-transparent text-ink-soft hover:border-[var(--color-line-2)] hover:text-ink' %>">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="<%= t[:icon] %>"/></svg>
      <%= t[:label] %>
      <% if t[:count].present? %>
        <span class="mono ml-1 inline-flex items-center rounded-full bg-[var(--color-line)] px-1.5 py-0.5 text-[10px] font-semibold text-ink-soft">
          <%= t[:count] %>
        </span>
      <% end %>
      <% if t[:badge].present? %>
        <span class="mono ml-1 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold"
              style="background: var(--brand-accent-soft); color: var(--brand-accent)">
          <%= t[:badge] %>
        </span>
      <% end %>
      <% if t[:alert].present? %>
        <span class="mono ml-1 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold"
              style="background: rgba(245,158,11,0.15); color: #92400e">
          <%= t[:alert] %>
        </span>
      <% end %>
    </button>
  <% end %>
</nav>
