<%# Email card (emails table): subject, direction, expandable body + reply.
    locals: email, customer %>
<% out = email.sent? %>
<div class="cevent">
  <details class="emailcard" open>
    <summary class="emailcard__head" style="list-style:none;cursor:pointer">
      <span class="iccircle" style="background:color-mix(in oklch, var(--channel-email) 16%, transparent);color:var(--channel-email)">
        <%= relay_icon("mail", size: 18) %>
      </span>
      <div class="grow" style="min-width:0">
        <div class="rl-sm" style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= email.subject.presence || "(no subject)" %></div>
        <div class="muted" style="font-size:12px">
          <% if out %>You → <%= email.to_email.presence || customer.email %><% else %><%= email.from_email.presence || customer.email %> → you<% end %>
          · <%= relay_conv_time(email.sent_at || email.received_at || email.created_at) %>
        </div>
      </div>
      <span class="rl-badge"><%= out ? "Sent" : "Received" %></span>
    </summary>
    <div style="padding:12px 16px;font-size:var(--text-sm);line-height:1.6;color:var(--color-fg-2);white-space:pre-wrap"><%= truncate(relay_email_body(email), length: 1200) %></div>
    <div style="padding:0 16px 12px" class="row">
      <%= link_to customer_path(customer, anchor: "emails"), class: "rl-btn rl-btn--secondary rl-btn--sm" do %>
        <%= relay_icon("reply", size: 14) %>Reply
      <% end %>
      <%= link_to export_pdf_customer_email_path(customer, email), class: "rl-btn rl-btn--ghost rl-btn--sm" do %>
        <%= relay_icon("download", size: 14) %>Export PDF
      <% end %>
    </div>
  </details>
</div>
