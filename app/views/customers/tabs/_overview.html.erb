<%# locals: customer %>
<div data-tabs-target="content" data-tab-id="overview" class="tab-content">
  <div class="grid gap-6 lg:grid-cols-2">

    <%# Unpaid milestones banner === %>
    <% if customer.unpaid_milestones_count.to_i > 0 %>
      <div class="rounded-lg p-4 ring-1 lg:col-span-2"
           style="background: rgba(245,158,11,0.10); --tw-ring-color: rgba(245,158,11,0.30)">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium" style="color: #92400e">
            <%= pluralize(customer.unpaid_milestones_count, "unpaid milestone") %>
          </p>
          <%= link_to "View milestones →", customer_milestones_path(customer),
                class: "text-sm font-semibold underline",
                style: "color: #92400e" %>
        </div>
      </div>
    <% end %>

    <%# Stats === %>
    <div class="grid grid-cols-2 overflow-hidden rounded-xl bg-panel shadow-card ring-1 ring-[var(--color-line-2)]">
      <% [
        [ "Call attempts", customer.total_call_attempts ],
        [ "Connected",     customer.successful_call_attempts ],
        [ "Messages",      customer.messages.count ],
        [ "Emails",        customer.emails.count ]
      ].each_with_index do |(label, val), i| %>
        <div class="border-[var(--color-line)] p-4 <%= 'border-l' if i.odd? %> <%= 'border-t' if i >= 2 %>">
          <p class="micro"><%= label %></p>
          <p class="mono mt-2 text-2xl font-semibold text-ink"><%= val %></p>
        </div>
      <% end %>
    </div>

    <%# Location + time === %>
    <% if customer.customer_location.present? || customer.current_time_in_timezone %>
      <%= render "shared/panel", eyebrow: "Location & time",
            actions: (customer.phone.present? ? (button_to(analyze_phone_customer_path(customer), method: :post,
                        form: { class: "inline-block" },
                        class: "mono inline-flex items-center rounded-md px-3 py-1.5 text-xs font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]") { "Re-analyze" }) : nil) do %>
        <dl class="space-y-3 text-sm">
          <% if customer.customer_location.present? %>
            <% if customer.customer_location.city.present? %>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="text-ink-soft">Location</dt>
                <dd class="text-right font-medium text-ink"><%= [ customer.customer_location.city, customer.customer_location.state_province, customer.customer_location.country_name ].compact.join(", ") %></dd>
              </div>
            <% end %>
            <% if customer.customer_location.timezone.present? %>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="text-ink-soft">Timezone</dt>
                <dd class="mono text-right font-medium text-ink"><%= customer.customer_location.timezone %></dd>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="text-ink-soft">Current time</dt>
                <dd class="mono text-right text-lg font-semibold" style="color: var(--brand-primary)">
                  <%= Time.current.in_time_zone(customer.customer_location.timezone).strftime("%I:%M %p") %>
                </dd>
              </div>
            <% end %>
          <% elsif customer.current_time_in_timezone %>
            <div class="flex items-baseline justify-between gap-3">
              <dt class="text-ink-soft">Current time</dt>
              <dd class="mono text-lg font-semibold" style="color: var(--brand-primary)">
                <%= customer.current_time_in_timezone.strftime("%I:%M %p") %>
              </dd>
            </div>
          <% end %>
          <% if customer.preferred_calling_time.present? && customer.preferred_calling_time != "Not Applicable" %>
            <div class="flex items-baseline justify-between gap-3">
              <dt class="text-ink-soft">Best time to call</dt>
              <dd class="text-right font-medium text-ink"><%= customer.preferred_calling_time %></dd>
            </div>
          <% end %>
        </dl>
      <% end %>
    <% elsif customer.phone.present? %>
      <div class="rounded-xl border-2 border-dashed border-[var(--color-line-2)] bg-panel p-6 text-center">
        <p class="font-display text-sm font-semibold text-ink">No location data</p>
        <p class="mt-1 text-sm text-ink-soft">Analyze the phone number for location & timezone info.</p>
        <%= button_to analyze_phone_customer_path(customer), method: :post,
              form: { class: "mt-4 inline-block" },
              class: "inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5",
              style: "background: var(--brand-primary)" do %>
          Analyze phone
        <% end %>
      </div>
    <% end %>

    <%# Project info === %>
    <% if customer.project_type.present? || customer.idea_description.present? %>
      <%= render "shared/panel", eyebrow: "Project information" do %>
        <div class="grid gap-4 text-sm md:grid-cols-2">
          <% if customer.project_type.present? %>
            <div>
              <p class="micro mb-1">Project type</p>
              <p class="font-medium text-ink"><%= customer.project_type %></p>
            </div>
          <% end %>
          <% if customer.project_scope.present? && customer.project_scope != "Not Applicable" %>
            <div>
              <p class="micro mb-1">Scope</p>
              <p class="font-medium text-ink"><%= customer.project_scope %></p>
            </div>
          <% end %>
          <% if customer.project_estimated_cost.present? %>
            <div>
              <p class="micro mb-1">Estimated cost</p>
              <p class="mono text-lg font-semibold" style="color: var(--brand-accent)"><%= number_to_currency(customer.project_estimated_cost) %></p>
            </div>
          <% end %>
        </div>
        <% if customer.idea_description.present? %>
          <div class="mt-5 border-t border-dashed border-[var(--color-line-2)] pt-4">
            <p class="micro mb-2">Description</p>
            <p class="whitespace-pre-wrap text-sm leading-relaxed text-ink"><%= customer.idea_description %></p>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <%# Notes editor === %>
    <div class="rounded-xl p-5 ring-1 ring-[var(--color-line-2)] lg:col-span-2"
         style="background: rgba(245,158,11,0.07)"
         data-controller="notes-editor"
         data-notes-editor-customer-id-value="<%= customer.id %>">
      <div class="flex items-center justify-between">
        <p class="micro" style="color: #92400e">Notes</p>
        <% if policy(customer).update? %>
          <button type="button"
                  data-action="click->notes-editor#toggleEdit"
                  data-notes-editor-target="editButton"
                  class="inline-flex items-center gap-1.5 rounded-md bg-paper px-3 py-1.5 text-xs font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg>
            <span data-notes-editor-target="editButtonText">Edit</span>
          </button>
        <% end %>
      </div>

      <div data-notes-editor-target="viewMode" class="mt-3">
        <% if customer.notes.present? %>
          <p class="whitespace-pre-wrap text-sm leading-relaxed text-ink"><%= customer.notes %></p>
        <% else %>
          <p class="text-sm italic text-ink-soft">No notes yet. Click "Edit" to add one.</p>
        <% end %>
      </div>

      <div data-notes-editor-target="editMode" class="mt-3 hidden">
        <textarea data-notes-editor-target="textarea"
                  rows="6"
                  class="block w-full rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)]"
                  placeholder="Add notes about this customer…"><%= customer.notes %></textarea>
        <div class="mt-3 flex items-center justify-end gap-2">
          <button type="button" data-action="click->notes-editor#cancel"
                  class="rounded-md px-3.5 py-1.5 text-sm font-medium text-ink ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
            Cancel
          </button>
          <button type="button" data-action="click->notes-editor#save"
                  data-notes-editor-target="saveButton"
                  class="inline-flex items-center gap-1.5 rounded-md px-3.5 py-1.5 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5"
                  style="background: var(--brand-primary)">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
            Save
          </button>
        </div>
      </div>

      <div data-notes-editor-target="loadingState" class="mt-3 hidden text-center text-sm text-ink-soft">
        Saving notes…
      </div>
    </div>

    <%# Ads / UTM (admin only) === %>
    <% if current_user&.admin? %>
      <% has_google_ads   = customer.gclid.present? || customer.gbraid.present? || customer.wbraid.present? %>
      <% has_facebook_ads = customer.fbclid.present? || customer.facebook_click_id.present? || customer.meta_lead_id.present? || customer.meta_campaign_id.present? %>
      <% has_utm          = customer.utm_source.present? || customer.utm_medium.present? || customer.utm_campaign.present? %>
      <% if has_google_ads || has_facebook_ads || has_utm %>
        <%= render "shared/panel", eyebrow: "Ads conversion data",
              actions: tag.span("Admin only", class: "mono inline-flex items-center rounded-full bg-[var(--color-line)] px-2.5 py-0.5 text-[10px] font-semibold text-ink-soft") do %>
          <% if has_google_ads %>
            <div class="mb-5">
              <p class="mono mb-3 inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold"
                 style="background: var(--brand-primary-soft); color: var(--brand-primary)">Google Ads</p>
              <% if customer.google_conversion_status.present? %>
                <%= render "shared/status_pill", label: customer.google_conversion_status.capitalize %>
              <% end %>
              <dl class="mt-3 grid gap-2 text-sm md:grid-cols-2">
                <% [ [ "GCLID", customer.gclid ], [ "GBRAID", customer.gbraid ], [ "WBRAID", customer.wbraid ] ].each do |k, v| %>
                  <% next if v.blank? %>
                  <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
                    <dt class="text-ink-soft"><%= k %></dt>
                    <dd class="mono truncate text-xs text-ink" title="<%= v %>"><%= v %></dd>
                  </div>
                <% end %>
                <% if customer.google_conversion_sent_at.present? %>
                  <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
                    <dt class="text-ink-soft">Conversion sent</dt>
                    <dd class="mono text-xs text-ink"><%= customer.google_conversion_sent_at.strftime("%b %-d, %Y %H:%M") %></dd>
                  </div>
                <% end %>
              </dl>
            </div>
          <% end %>

          <% if has_facebook_ads %>
            <% if has_google_ads %><hr class="my-5 border-[var(--color-line)]"><% end %>
            <div class="mb-5">
              <p class="mono mb-3 inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold"
                 style="background: var(--brand-primary-soft); color: var(--brand-primary)">Facebook / Meta Ads</p>
              <% if customer.meta_events_sent.to_i > 0 %>
                <%= render "shared/status_pill", label: "#{customer.meta_events_sent} event(s) sent", tone: "ok" %>
              <% end %>
              <dl class="mt-3 grid gap-2 text-sm md:grid-cols-2">
                <% [ [ "FBCLID", customer.fbclid ], [ "Facebook click ID", customer.facebook_click_id ], [ "Meta lead ID", customer.meta_lead_id ], [ "Campaign ID", customer.meta_campaign_id ], [ "Adset ID", customer.meta_adset_id ], [ "Ad ID", customer.meta_ad_id ], [ "Browser ID", customer.browser_id ] ].each do |k, v| %>
                  <% next if v.blank? %>
                  <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
                    <dt class="text-ink-soft"><%= k %></dt>
                    <dd class="mono truncate text-xs text-ink" title="<%= v %>"><%= v %></dd>
                  </div>
                <% end %>
                <% if customer.last_meta_event_sent_at.present? %>
                  <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
                    <dt class="text-ink-soft">Last event</dt>
                    <dd class="mono text-xs text-ink"><%= customer.last_meta_event_sent_at.strftime("%b %-d, %Y %H:%M") %></dd>
                  </div>
                <% end %>
              </dl>
            </div>
          <% end %>

          <% if has_utm %>
            <% if has_google_ads || has_facebook_ads %><hr class="my-5 border-[var(--color-line)]"><% end %>
            <div>
              <p class="mono mb-3 inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold"
                 style="background: var(--brand-primary-soft); color: var(--brand-primary)">UTM parameters</p>
              <dl class="mt-3 grid gap-2 text-sm md:grid-cols-2">
                <% [ [ "Source", customer.utm_source ], [ "Medium", customer.utm_medium ], [ "Campaign", customer.utm_campaign ], [ "Term", customer.utm_term ], [ "Content", customer.utm_content ] ].each do |k, v| %>
                  <% next if v.blank? %>
                  <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
                    <dt class="text-ink-soft"><%= k %></dt>
                    <dd class="text-right font-medium text-ink"><%= v %></dd>
                  </div>
                <% end %>
              </dl>
            </div>
          <% end %>

          <% if customer.landing_page.present? || customer.traffic_source.present? || customer.msclkid.present? %>
            <hr class="my-5 border-[var(--color-line)]">
            <div>
              <p class="mono mb-3 inline-flex items-center rounded-md bg-[var(--color-line)] px-2.5 py-1 text-xs font-semibold text-ink-soft">Traffic info</p>
              <dl class="mt-3 grid gap-2 text-sm md:grid-cols-2">
                <% if customer.traffic_source.present? %>
                  <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
                    <dt class="text-ink-soft">Traffic source</dt>
                    <dd class="text-right font-medium text-ink"><%= customer.traffic_source %></dd>
                  </div>
                <% end %>
                <% if customer.landing_page.present? %>
                  <div class="flex items-center justify-between gap-3 rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)] md:col-span-2">
                    <dt class="shrink-0 text-ink-soft">Landing page</dt>
                    <dd class="truncate text-xs font-medium" style="color: var(--brand-primary)" title="<%= customer.landing_page %>"><%= customer.landing_page %></dd>
                  </div>
                <% end %>
                <% if customer.msclkid.present? %>
                  <div class="flex items-center justify-between rounded-md bg-paper px-3 py-2 ring-1 ring-[var(--color-line)]">
                    <dt class="text-ink-soft">Microsoft click ID</dt>
                    <dd class="mono truncate text-xs text-ink" title="<%= customer.msclkid %>"><%= customer.msclkid %></dd>
                  </div>
                <% end %>
              </dl>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <%# CCR cost estimates === %>
    <% if customer.lead_source == "CCR" && customer.cost_estimates.any? %>
      <div class="lg:col-span-2">
        <%= render "shared/panel",
              eyebrow: "Cost estimates",
              title: pluralize(customer.cost_estimates.count, "estimate") do %>
          <div class="space-y-3">
            <% customer.cost_estimates.order(created_at: :desc).each do |estimate| %>
              <div class="rounded-lg bg-paper p-4 ring-1 ring-[var(--color-line-2)] transition hover:bg-[var(--color-line)]">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      <p class="font-display font-bold text-ink">
                        <%= estimate.application_types.present? ? estimate.application_types_array.join(", ") : estimate.app_type_display %>
                      </p>
                      <%= render "shared/status_pill", label: estimate.status.titleize %>
                    </div>
                    <p class="mt-1 line-clamp-2 text-sm text-ink-soft"><%= estimate.description %></p>

                    <div class="mt-3 grid grid-cols-2 gap-3 text-sm md:grid-cols-4">
                      <div><p class="micro">Scale</p><p class="mono mt-1 font-medium text-ink"><%= estimate.scale_display %></p></div>
                      <div><p class="micro">Hours</p><p class="mono mt-1 font-medium text-ink"><%= estimate.total_hours %>h</p></div>
                      <div><p class="micro">Rate</p><p class="mono mt-1 font-medium text-ink">$<%= estimate.hourly_rate %>/h</p></div>
                      <div><p class="micro">Total</p><p class="mono mt-1 text-lg font-semibold" style="color: var(--brand-accent)"><%= number_to_currency(estimate.total_cost) %></p></div>
                    </div>

                    <div class="mt-3 flex flex-wrap items-center gap-4">
                      <% if estimate.pdf_file.attached? %>
                        <%= link_to rails_blob_path(estimate.pdf_file, disposition: "attachment"),
                              class: "inline-flex items-center gap-1.5 text-xs font-semibold transition hover:underline",
                              style: "color: var(--brand-primary)" do %>
                          ↓ Download PDF
                        <% end %>
                      <% end %>
                      <%= button_to resend_cost_estimate_path(estimate), method: :post,
                            data: { turbo_confirm: "Resend this estimate to #{customer.email.presence || 'the customer'}?" },
                            form: { class: "inline-block" },
                            class: "inline-flex items-center gap-1.5 text-xs font-semibold transition hover:underline disabled:opacity-50",
                            style: "color: var(--brand-accent)",
                            disabled: customer.email.blank? do %>
                        ↗ Resend
                      <% end %>
                    </div>
                  </div>
                  <p class="mono shrink-0 text-xs text-ink-soft/80"><%= estimate.created_at.strftime("%b %-d, %Y") %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
