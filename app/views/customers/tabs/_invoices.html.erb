<%# locals: customer %>
<div data-tabs-target="content" data-tab-id="invoices" class="tab-content hidden">
  <div class="mb-5 flex items-center justify-between">
    <p class="font-display text-lg font-bold text-ink">Invoices</p>
    <%= link_to new_customer_invoice_path(customer),
          class: "inline-flex items-center gap-2 rounded-md px-3.5 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5",
          style: "background: var(--brand-primary)" do %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
      New invoice
    <% end %>
  </div>

  <% if customer.invoices.any? %>
    <div class="overflow-hidden rounded-xl bg-panel shadow-card ring-1 ring-[var(--color-line-2)]">
      <ul class="divide-y divide-[var(--color-line)]">
        <% customer.invoices.order(created_at: :desc).each do |invoice| %>
          <li class="flex items-center justify-between gap-3 p-4">
            <div class="min-w-0">
              <p class="mono text-sm font-semibold text-ink"><%= invoice.invoice_number %></p>
              <p class="mt-0.5 truncate text-xs text-ink-soft">
                <%= invoice.project_name.presence || invoice.milestone.name %>
                · <span class="mono" style="color: var(--brand-accent)"><%= number_to_currency(invoice.total) %></span>
              </p>
            </div>
            <div class="flex items-center gap-3">
              <%= link_to "Edit", edit_customer_invoice_path(customer, invoice),
                    class: "text-xs font-semibold transition hover:underline",
                    style: "color: var(--brand-primary)" %>
              <%= link_to "PDF", download_pdf_customer_invoice_path(customer, invoice),
                    class: "text-xs font-semibold transition hover:underline",
                    style: "color: var(--brand-accent)" %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="rounded-xl border-2 border-dashed border-[var(--color-line-2)] py-12 text-center">
      <p class="font-display text-base font-semibold text-ink">No invoices yet</p>
      <p class="mt-1 text-sm text-ink-soft">Create an invoice from a milestone.</p>
      <%= link_to "New invoice", new_customer_invoice_path(customer),
            class: "mt-5 inline-flex items-center rounded-md px-4 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5",
            style: "background: var(--brand-primary)" %>
    </div>
  <% end %>
</div>
