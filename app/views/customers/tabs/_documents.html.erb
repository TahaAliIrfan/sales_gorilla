<%# locals: customer %>
<div data-tabs-target="content" data-tab-id="documents" class="tab-content hidden"
     data-controller="document-manager"
     data-document-manager-customer-id-value="<%= customer.id %>">
  <div class="mb-5 flex items-center justify-between">
    <p class="font-display text-lg font-bold text-ink">Documents</p>
    <% if policy(customer).update? %>
      <label class="inline-flex cursor-pointer items-center gap-2 rounded-md px-3.5 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5"
             style="background: var(--brand-primary)">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
        Upload document
        <input type="file"
               data-action="change->document-manager#uploadDocument"
               data-document-manager-target="fileInput"
               accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.jpg,.jpeg,.png,.gif"
               multiple
               class="hidden">
      </label>
    <% end %>
  </div>

  <div data-document-manager-target="documentsList">
    <% if customer.documents.attached? %>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <% customer.documents.each do |document| %>
          <div class="rounded-lg bg-panel p-4 shadow-card ring-1 ring-[var(--color-line-2)] transition hover:-translate-y-0.5 hover:shadow-lift"
               data-document-id="<%= document.signed_id %>">
            <div class="flex items-start gap-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg"
                    style="background: var(--brand-primary-soft); color: var(--brand-primary)">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6"/></svg>
              </span>
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-ink" title="<%= document.filename %>"><%= document.filename %></p>
                <p class="mono mt-0.5 text-xs text-ink-soft"><%= number_to_human_size(document.byte_size) %></p>
                <div class="mt-2 flex items-center gap-2.5">
                  <%= link_to rails_blob_path(document, disposition: "attachment"),
                        class: "text-xs font-semibold transition hover:underline",
                        style: "color: var(--brand-primary)" do %>
                    ↓ Download
                  <% end %>
                  <% if policy(customer).remove_document? %>
                    <button type="button"
                            data-action="click->document-manager#deleteDocument"
                            data-document-id="<%= document.signed_id %>"
                            data-document-name="<%= document.filename %>"
                            class="text-xs font-semibold text-[#c0492f] transition hover:underline">
                      ✕ Delete
                    </button>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-xl border-2 border-dashed border-[var(--color-line-2)] py-12 text-center">
        <p class="font-display text-base font-semibold text-ink">No documents</p>
        <p class="mt-1 text-sm text-ink-soft">Upload documents to keep them organized here.</p>
      </div>
    <% end %>
  </div>

  <div data-document-manager-target="uploadProgress" class="mt-4 hidden rounded-lg p-4 ring-1 ring-[var(--color-line-2)]"
       style="background: var(--brand-primary-soft)">
    <p class="text-sm font-medium" style="color: var(--brand-primary)">Uploading documents…</p>
  </div>
</div>
