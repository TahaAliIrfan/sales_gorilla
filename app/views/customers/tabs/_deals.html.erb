<%# locals: customer %>
<div data-tabs-target="content" data-tab-id="deals" class="tab-content hidden">
  <div class="mb-5 flex items-center justify-between">
    <p class="font-display text-lg font-bold text-ink">Deals</p>
    <%= link_to new_deal_path(customer_id: customer.id),
          class: "inline-flex items-center gap-2 rounded-md px-3.5 py-2 text-sm font-semibold text-white shadow-card transition hover:-translate-y-0.5",
          style: "background: var(--brand-primary)" do %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
      New deal
    <% end %>
  </div>

  <% if customer.deals.any? %>
    <div class="grid gap-4 md:grid-cols-2">
      <% customer.deals.each do |deal| %>
        <% deal_tone = deal.status == "won" ? "ok" : (deal.status == "lost" ? "bad" : "info") %>
        <div class="rounded-xl bg-panel p-5 shadow-card ring-1 ring-[var(--color-line-2)] transition hover:-translate-y-0.5 hover:shadow-lift">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="truncate font-display text-base font-bold text-ink">
                <%= link_to (deal.title.presence || "Untitled"), deal_path(deal),
                      class: "transition hover:text-accent" %>
              </p>
              <p class="mt-1 text-xs text-ink-soft"><%= deal.deal_stage&.name || "No stage" %></p>
            </div>
            <%= render "shared/status_pill", label: (deal.status || "active").titleize, tone: deal_tone %>
          </div>
          <p class="mono mt-3 text-2xl font-semibold" style="color: var(--brand-accent)">
            <%= number_to_currency(deal.amount, precision: 0) %>
          </p>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border-2 border-dashed border-[var(--color-line-2)] py-12 text-center">
      <p class="font-display text-base font-semibold text-ink">No deals</p>
      <p class="mt-1 text-sm text-ink-soft">Create a deal to start tracking sales for this customer.</p>
    </div>
  <% end %>
</div>
