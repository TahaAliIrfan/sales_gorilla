<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="cb-eyebrow mb-1.5">billing // invoices</div>
  <h1 class="text-[26px] font-semibold tracking-tight text-[#0F172A]">Invoices</h1>
  <p class="text-[#64748B] mt-1.5 text-sm">Manage and track all invoices</p>

  <!-- Quick Create: Select Customer → Create Milestone or Invoice -->
  <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Create for Customer</h2>
    <div class="flex flex-wrap gap-3 items-end">
      <div class="min-w-[220px]">
        <label for="quick-create-customer" class="block text-sm font-medium text-gray-700 mb-1">Select Customer</label>
        <select id="quick-create-customer" class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500">
          <option value="">Choose a customer...</option>
          <%= options_from_collection_for_select(@customers, :id, :name) %>
        </select>
      </div>
      <div class="flex gap-2">
        <%= link_to "Create Milestone", "#", id: "quick-create-milestone", class: "inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium text-sm" %>
        <%= link_to "Create Invoice", "#", id: "quick-create-invoice", class: "inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium text-sm" %>
      </div>
    </div>
    <p id="quick-create-hint" class="mt-2 text-xs text-gray-500">Select a customer above, then create a milestone or generate an invoice.</p>
  </div>

  <!-- Filters -->
  <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <%= form_with url: invoices_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end" do |f| %>
      <div class="min-w-[200px]">
        <%= f.label :search, "Search Customer", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :search, value: params[:search], placeholder: "Customer name...", class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div class="min-w-[140px]">
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :status,
            options_for_select([["All", ""], ["Pending", "pending"], ["Paid", "paid"]], params[:status]),
            {},
            { class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" } %>
      </div>
      <div class="min-w-[140px]">
        <%= f.label :from_date, "From Date", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :from_date, value: params[:from_date], class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div class="min-w-[140px]">
        <%= f.label :to_date, "To Date", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :to_date, value: params[:to_date], class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div>
        <%= f.submit "Filter", class: "px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium text-sm cursor-pointer" %>
        <%= link_to "Clear", invoices_path, class: "ml-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 font-medium text-sm" %>
      </div>
    <% end %>
  </div>

  <% if @invoices.any? %>
    <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invoice #</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Project</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Issue Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @invoices.each do |invoice| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= invoice.invoice_number %></td>
              <td class="px-6 py-4 text-sm text-gray-700">
                <%= link_to invoice.customer.name, customer_path(invoice.customer), class: "text-emerald-600 hover:text-emerald-800" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= invoice.project_name.presence || invoice.milestone.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= invoice.issue_date.strftime('%b %d, %Y') %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900"><%= number_to_currency(invoice.total) %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= invoice.paid? ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800' %>">
                  <%= invoice.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <%= link_to "View", customer_invoice_path(invoice.customer, invoice), class: "text-emerald-600 hover:text-emerald-800 font-medium mr-2" %>
                <%= link_to "Edit", edit_customer_invoice_path(invoice.customer, invoice), class: "text-gray-600 hover:text-gray-800 font-medium mr-2" %>
                <%= link_to "PDF", download_pdf_customer_invoice_path(invoice.customer, invoice), class: "text-purple-600 hover:text-purple-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div class="px-4 py-3 border-t border-gray-200">
        <%= paginate @invoices %>
      </div>
    </div>
  <% else %>
    <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No invoices found</h3>
      <p class="mt-1 text-sm text-gray-500">Select a customer above to create a milestone or invoice.</p>
      <div class="mt-6">
        <%= link_to customers_path, class: "inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium text-sm" do %>
          Go to Customers
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<script>
(function() {
  const select = document.getElementById('quick-create-customer');
  const milestoneBtn = document.getElementById('quick-create-milestone');
  const invoiceBtn = document.getElementById('quick-create-invoice');

  function goTo(path) {
    const customerId = select && select.value;
    if (!customerId) {
      alert('Please select a customer first.');
      return false;
    }
    window.location.href = path.replace(':id', customerId);
    return false;
  }

  if (milestoneBtn) milestoneBtn.addEventListener('click', function(e) {
    e.preventDefault();
    goTo('/customers/:id/milestones/new');
  });
  if (invoiceBtn) invoiceBtn.addEventListener('click', function(e) {
    e.preventDefault();
    goTo('/customers/:id/invoices/new');
  });
})();
</script>
