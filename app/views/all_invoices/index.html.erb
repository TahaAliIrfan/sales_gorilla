<%# All invoices — relay DS. Ported (not redirected) because this page carries
    filters (search / status / from_date / to_date) and a quick-create-for-customer
    flow that the /billing invoices tab does not have. Mirrors AllInvoicesController:
    policy_scope, pagination, and the per-row View / Edit / PDF actions. %>
<% content_for :title, "Invoices — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Invoices</div>
      <div class="pagehead__sub">Manage and track all invoices across your book.</div>
    </div>
  </div>

  <%# Quick create — select a customer, then jump to its milestone/invoice form %>
  <div class="sect" style="margin-bottom:var(--space-4)">
    <div class="sect__head"><div class="sect__title">Create for customer</div></div>
    <div class="sect__body">
      <div class="row" style="gap:12px;flex-wrap:wrap;align-items:flex-end">
        <div class="rl-field" style="min-width:240px;margin:0">
          <label for="quick-create-customer" class="rl-label">Select customer</label>
          <select id="quick-create-customer" class="rl-select">
            <option value="">Choose a customer…</option>
            <%= options_from_collection_for_select(@customers, :id, :name) %>
          </select>
        </div>
        <div class="row" style="gap:8px">
          <%= link_to "Create milestone", "#", id: "quick-create-milestone", class: "rl-btn rl-btn--secondary" %>
          <%= link_to "Create invoice", "#", id: "quick-create-invoice", class: "rl-btn rl-btn--primary" %>
        </div>
      </div>
      <p id="quick-create-hint" class="rl-help" style="margin-top:8px">Select a customer above, then create a milestone or generate an invoice.</p>
    </div>
  </div>

  <%# Filters %>
  <div class="sect" style="margin-bottom:var(--space-4)">
    <div class="sect__body">
      <%= form_with url: invoices_path, method: :get, class: "row", html: { style: "gap:12px;flex-wrap:wrap;align-items:flex-end" } do |f| %>
        <div class="rl-field" style="min-width:200px;margin:0">
          <%= f.label :search, "Search customer", class: "rl-label" %>
          <%= f.text_field :search, value: params[:search], placeholder: "Customer name…", class: "rl-input" %>
        </div>
        <div class="rl-field" style="min-width:150px;margin:0">
          <%= f.label :status, "Status", class: "rl-label" %>
          <%= f.select :status, options_for_select([["All", ""], ["Pending", "pending"], ["Paid", "paid"]], params[:status]), {}, class: "rl-select" %>
        </div>
        <div class="rl-field" style="min-width:150px;margin:0">
          <%= f.label :from_date, "From date", class: "rl-label" %>
          <%= f.date_field :from_date, value: params[:from_date], class: "rl-input mono" %>
        </div>
        <div class="rl-field" style="min-width:150px;margin:0">
          <%= f.label :to_date, "To date", class: "rl-label" %>
          <%= f.date_field :to_date, value: params[:to_date], class: "rl-input mono" %>
        </div>
        <div class="row" style="gap:8px">
          <%= f.submit "Filter", class: "rl-btn rl-btn--primary" %>
          <%= link_to "Clear", invoices_path, class: "rl-btn rl-btn--secondary" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @invoices.any? %>
    <div class="sect">
      <div class="sect__body--flush">
        <div class="rl-table-scroll">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Invoice</th>
                <th>Customer</th>
                <th>Project</th>
                <th>Issued</th>
                <th style="text-align:right">Total</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @invoices.each do |invoice| %>
                <tr>
                  <td class="rl-cell-strong mono"><%= invoice.invoice_number %></td>
                  <td><%= link_to invoice.customer.name, customer_path(invoice.customer), class: "rl-cell-strong", style: "color:inherit" %></td>
                  <td class="muted"><%= invoice.project_name.presence || invoice.milestone&.name %></td>
                  <td class="mono rl-sm"><%= invoice.issue_date&.strftime("%b %-d, %Y") %></td>
                  <td class="rl-cell-num"><%= relay_money(invoice.total) %></td>
                  <td>
                    <% if invoice.paid? %>
                      <span class="rl-badge rl-badge--success"><%= relay_icon("check-circle-2", size: 11) %>Paid</span>
                    <% else %>
                      <span class="rl-badge rl-badge--info"><%= relay_icon("hourglass", size: 11) %>Pending</span>
                    <% end %>
                  </td>
                  <td>
                    <div class="row" style="gap:6px;justify-content:flex-end">
                      <%= link_to "View", customer_invoice_path(invoice.customer, invoice), class: "rl-btn rl-btn--ghost rl-btn--sm" %>
                      <%= link_to "Edit", edit_customer_invoice_path(invoice.customer, invoice), class: "rl-btn rl-btn--ghost rl-btn--sm" %>
                      <%= link_to download_pdf_customer_invoice_path(invoice.customer, invoice), class: "rl-iconbtn rl-iconbtn--sm", title: "Download PDF" do %>
                        <%= relay_icon("download", size: 15) %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="rl-pagebtns" style="margin-top:var(--space-4)"><%= paginate @invoices, theme: "relay" %></div>
  <% else %>
    <div class="sect"><div class="sect__body" style="text-align:center;padding:48px 16px">
      <span class="iccircle" style="width:48px;height:48px;margin:0 auto 12px;background:var(--color-surface-2);color:var(--color-fg-3)"><%= relay_icon("receipt", size: 22) %></span>
      <div class="rl-h4">No invoices found</div>
      <div class="muted rl-sm" style="margin-top:6px">Select a customer above to create a milestone or invoice.</div>
      <div style="margin-top:16px"><%= link_to "Go to customers", customers_path, class: "rl-btn rl-btn--primary rl-btn--sm" %></div>
    </div></div>
  <% end %>
</div>

<script>
(function() {
  const select = document.getElementById('quick-create-customer');
  const milestoneBtn = document.getElementById('quick-create-milestone');
  const invoiceBtn = document.getElementById('quick-create-invoice');

  function goTo(path) {
    const customerId = select && select.value;
    if (!customerId) {
      alert('Please select a customer first.');
      return false;
    }
    window.location.href = path.replace(':id', customerId);
    return false;
  }

  if (milestoneBtn) milestoneBtn.addEventListener('click', function(e) {
    e.preventDefault();
    goTo('/customers/:id/milestones/new');
  });
  if (invoiceBtn) invoiceBtn.addEventListener('click', function(e) {
    e.preventDefault();
    goTo('/customers/:id/invoices/new');
  });
})();
</script>
