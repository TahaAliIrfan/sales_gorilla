<%# Public, token-based, unauthenticated "invoice unavailable" page. Standalone
    relay_public layout + DS — no Tailwind. Branding ramp comes from the layout via
    public_invoice_organization. Keeps the @reason branching untouched. %>
<% org = (public_invoice_organization if respond_to?(:public_invoice_organization)) %>
<% content_for :title, "Invoice unavailable#{" — #{org.name}" if org&.name.present?}" %>

<div class="pis-wrap">
  <div class="sect pis-card">
    <div class="sect__body" style="text-align:center;padding:48px 32px">
      <span class="iccircle pis-ic"><%= relay_icon("lock", size: 26) %></span>
      <div class="rl-h4" style="margin-top:16px">Information not available</div>
      <p class="muted rl-sm" style="margin-top:8px;line-height:1.6">
        <% case @reason %>
        <% when :paid %>
          This invoice has been marked as paid. Thank you for your payment.
        <% when :expired %>
          This invoice link has expired. Please contact us for a new payment link if you still need to pay.
        <% else %>
          This invoice is no longer accessible. If you believe this is an error, please contact us.
        <% end %>
      </p>
      <p class="muted" style="margin-top:24px;font-size:var(--text-xs)"><%= org&.name || "Sales Gorilla" %></p>
    </div>
  </div>
</div>

<style>
  .pis-wrap { max-width: 480px; margin: 0 auto; padding: 80px 24px; }
  .pis-card { box-shadow: var(--shadow-lg); }
  .pis-ic { width: 56px; height: 56px; margin: 0 auto; background: var(--color-surface-2); color: var(--color-fg-3); }
</style>
