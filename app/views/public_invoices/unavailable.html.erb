<div class="max-w-lg mx-auto">
  <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-10 sm:p-12 text-center">
    <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-slate-100 flex items-center justify-center">
      <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
      </svg>
    </div>
    <h1 class="text-xl font-bold text-slate-900 mb-2">Information Not Available</h1>
    <p class="text-slate-600 text-sm leading-relaxed">
      <% case @reason %>
      <% when :paid %>
        This invoice has been marked as paid. Thank you for your payment.
      <% when :expired %>
        This invoice link has expired. Please contact us for a new payment link if you still need to pay.
      <% else %>
        This invoice is no longer accessible. If you believe this is an error, please contact us.
      <% end %>
    </p>
    <p class="mt-6 text-xs text-slate-400">Tecaudex</p>
  </div>
</div>
