<%# Public, token-based "invoice not found" page. Standalone relay_public + DS. %>
<% org = (public_invoice_organization if respond_to?(:public_invoice_organization)) %>
<% content_for :title, "Invoice not found#{" — #{org.name}" if org&.name.present?}" %>

<div class="pis-wrap">
  <div class="sect pis-card">
    <div class="sect__body" style="text-align:center;padding:48px 32px">
      <span class="iccircle pis-ic"><%= relay_icon("frown", size: 26) %></span>
      <div class="rl-h4" style="margin-top:16px">Invoice not found</div>
      <p class="muted rl-sm" style="margin-top:8px;line-height:1.6">
        The link you followed may be invalid or has been removed. Please check the URL or contact us for assistance.
      </p>
      <p class="muted" style="margin-top:24px;font-size:var(--text-xs)"><%= org&.name || "Relay" %></p>
    </div>
  </div>
</div>

<style>
  .pis-wrap { max-width: 480px; margin: 0 auto; padding: 80px 24px; }
  .pis-card { box-shadow: var(--shadow-lg); }
  .pis-ic { width: 56px; height: 56px; margin: 0 auto; background: var(--color-surface-2); color: var(--color-fg-3); }
</style>
