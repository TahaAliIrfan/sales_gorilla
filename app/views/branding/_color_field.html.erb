<%#
  Paired color picker + hex input bound to the branding-preview Stimulus controller.
  locals: f, field, label, target, hex_target, action, hex_action, value
%>
<div>
  <%= f.label field, label, class: "micro", style: "color: var(--color-ink-soft)" %>
  <div class="mt-1 flex items-center gap-2">
    <input type="color" value="<%= value %>"
           data-branding-preview-target="<%= target %>"
           data-action="input->branding-preview#<%= action %>"
           class="h-11 w-12 cursor-pointer rounded-md bg-paper p-1 ring-1 ring-[var(--color-line-2)]">
    <%= f.text_field field, value: value,
          data: { "branding-preview-target": hex_target, action: "input->branding-preview##{hex_action}" },
          class: "mono block w-full rounded-md border-0 bg-paper px-3.5 py-2.5 text-sm text-ink uppercase ring-1 ring-[var(--color-line-2)] transition focus:bg-panel focus:outline-none focus:ring-2 focus:ring-accent" %>
  </div>
</div>
