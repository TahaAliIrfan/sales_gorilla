<%# Standalone branding page — relay DS. Settings → Branding is the primary
    surface; this page is the fallback that BrandingController#update re-renders
    on validation failure, so it reuses the canonical settings/_branding partial
    (same relay--branding-preview controller, same form/params, same
    settings/errors rendering for @organization). %>
<% content_for :title, "Branding — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Branding</div>
      <div class="pagehead__sub">Customize how <%= current_organization&.name %>'s workspace looks for everyone.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to settings_path(tab: "branding"), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to settings
      <% end %>
    </div>
  </div>

  <%= render "settings/branding" %>
</div>
