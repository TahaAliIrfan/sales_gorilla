<% content_for :title, "Role: #{@role.name} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Role: <%= @role.name %></div>
      <div class="pagehead__sub">Role details and assigned users.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to roles_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back to roles
      <% end %>
      <%= link_to edit_role_path(@role), class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>

  <div class="sect" style="margin-bottom:var(--space-5)">
    <div class="sect__head"><div class="sect__title">Role details</div></div>
    <div class="sect__body">
      <div class="kvline"><dt>Name</dt><dd><%= @role.name %></dd></div>
      <div class="kvline"><dt>Key</dt><dd class="mono"><%= @role.key %></dd></div>
      <div class="kvline"><dt>Hierarchy level</dt><dd class="mono"><%= @role.hierarchy_level %></dd></div>
      <div class="kvline"><dt>Description</dt><dd><%= @role.description.presence || content_tag(:span, "—", class: "muted") %></dd></div>
    </div>
  </div>

  <div class="sect">
    <div class="sect__head"><div class="sect__title">Users with this role (<%= @users.count %>)</div></div>
    <div class="sect__body--flush">
      <% if @users.any? %>
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Assigned by</th>
                <th>Assigned at</th>
                <th style="text-align:right"></th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <% assignment = user.role_assignments.find_by(role: @role) %>
                <tr>
                  <td class="rl-cell-strong"><%= link_to user.name, user_path(user), style: "color:var(--color-primary-text)" %></td>
                  <td class="rl-sm"><%= user.email %></td>
                  <td class="rl-sm">
                    <% if assignment&.assigned_by %>
                      <%= link_to assignment.assigned_by.name, user_path(assignment.assigned_by), style: "color:var(--color-primary-text)" %>
                    <% else %>
                      <span class="muted">System</span>
                    <% end %>
                  </td>
                  <td class="muted rl-sm"><%= assignment ? "#{time_ago_in_words(assignment.created_at)} ago" : "-" %></td>
                  <td style="text-align:right">
                    <% if assignment && (current_user.admin? || assignment.assigned_by == current_user) %>
                      <%= link_to role_assignment_path(assignment),
                            data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to remove this role from #{user.name}?" },
                            class: "rl-btn rl-btn--destructive-ghost rl-btn--sm" do %>Remove role<% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="muted rl-sm" style="text-align:center;padding:var(--space-6)">No users have been assigned this role yet.</div>
      <% end %>
    </div>
  </div>
</div>
