<div class="container mx-auto px-4 py-6">
  <div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold">Role: <%= @role.name %></h1>
    <div>
      <%= link_to "Edit", edit_role_path(@role), class: "bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded mr-2" %>
      <%= link_to "Back to Roles", roles_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-3 py-1 rounded" %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= notice %>
    </div>
  <% end %>

  <div class="bg-white shadow-md rounded-lg overflow-hidden p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Role Details</h2>
    <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
      <div class="sm:col-span-1">
        <dt class="text-sm font-medium text-gray-500">Name</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @role.name %></dd>
      </div>

      <div class="sm:col-span-1">
        <dt class="text-sm font-medium text-gray-500">Key</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @role.key %></dd>
      </div>

      <div class="sm:col-span-1">
        <dt class="text-sm font-medium text-gray-500">Hierarchy Level</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @role.hierarchy_level %></dd>
      </div>

      <div class="sm:col-span-2">
        <dt class="text-sm font-medium text-gray-500">Description</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @role.description %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-xl font-semibold">Users with this role (<%= @users.count %>)</h2>
    </div>
    
    <% if @users.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned By</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned At</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @users.each do |user| %>
            <% assignment = user.role_assignments.find_by(role: @role) %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= link_to user.name, user_path(user), class: "text-blue-600 hover:text-blue-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if assignment&.assigned_by %>
                  <%= link_to assignment.assigned_by.name, user_path(assignment.assigned_by), class: "text-blue-600 hover:text-blue-900" %>
                <% else %>
                  <span class="text-gray-400">System</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= assignment ? time_ago_in_words(assignment.created_at) + " ago" : "-" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <% if assignment && (current_user.admin? || assignment.assigned_by == current_user) %>
                  <%= link_to "Remove Role", role_assignment_path(assignment), 
                      data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to remove this role from #{user.name}?" }, 
                      class: "text-red-600 hover:text-red-900" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-4 text-gray-500">
        No users have been assigned this role yet.
      </div>
    <% end %>
  </div>
</div> 