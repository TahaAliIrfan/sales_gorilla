<% content_for :title, "#{@role.name} — #{current_organization&.name}" %>
<% is_owner = @role.key == "owner" %>

<div class="page">
  <div class="pagehead">
    <div class="row" style="gap:12px;align-items:center">
      <span class="rl-badge <%= settings_role_badge(@role.key) %>" style="text-transform:capitalize;font-size:14px"><%= @role.name %></span>
      <% if @role.system? %><span class="rl-badge rl-badge--neutral">System</span><% end %>
    </div>
    <div class="pagehead__actions">
      <%= link_to edit_role_path(@role), class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit
      <% end %>
      <%= link_to roles_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>

  <div class="grid" style="grid-template-columns:1.4fr 1fr;align-items:start;gap:var(--space-5)">
    <div class="sect">
      <div class="sect__head">
        <div class="sect__title">Granted permissions</div>
        <div class="muted rl-sm"><%= is_owner ? "All #{Permission::ALL_KEYS.size}" : "#{@role.permissions.size} of #{Permission::ALL_KEYS.size}" %></div>
      </div>
      <div class="sect__body col" style="gap:var(--space-4)">
        <%= content_tag(:div, @role.description, class: "muted rl-sm") if @role.description.present? %>
        <% Permission::CATALOG.each do |category, perms| %>
          <% granted_here = perms.select { |key, _| is_owner || @role.permissions.include?(key) } %>
          <% next if granted_here.empty? %>
          <div class="col" style="gap:6px">
            <div class="rl-sm" style="font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:var(--color-fg-3)"><%= category %></div>
            <div class="col" style="gap:4px">
              <% granted_here.each do |key, label| %>
                <div class="row rl-sm" style="gap:8px;align-items:center">
                  <%= relay_icon("check", size: 14) %><span><%= label %></span>
                  <span class="muted" style="font-size:10px"><code><%= key %></code></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
        <% if !is_owner && @role.permissions.empty? %>
          <div class="muted rl-sm">No elevated permissions. Members can act on their own assigned records only.</div>
        <% end %>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head">
        <div class="sect__title">Members</div>
        <div class="muted rl-sm"><%= @members.size %> with this role</div>
      </div>
      <div class="sect__body--flush">
        <% if @members.any? %>
          <div class="rl-table-wrap">
            <table class="rl-table">
              <tbody>
                <% @members.each do |member| %>
                  <tr>
                    <td>
                      <%= link_to (member.name.presence || member.email), user_path(member), style: "color:var(--color-primary-text)" %>
                      <div class="muted" style="font-size:11px"><%= member.email %></div>
                    </td>
                    <td style="text-align:right">
                      <% if member.active? %><span class="rl-pill rl-pill--success"><i class="rl-dot"></i>Active</span>
                      <% else %><span class="rl-pill"><i class="rl-dot" style="background:var(--color-fg-4)"></i>Inactive</span><% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="muted rl-sm" style="text-align:center;padding:var(--space-6)">No members have this role yet.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
