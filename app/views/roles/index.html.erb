<% content_for :title, "Roles — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Roles</div>
      <div class="pagehead__sub">Define roles and their hierarchy levels.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_role_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>New role
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="rl-sm" style="background:var(--color-success-subtle);border:1px solid var(--color-success-border);color:var(--color-success-text);border-radius:var(--radius-lg);padding:10px 14px;margin-bottom:var(--space-4)"><%= notice %></div>
  <% end %>

  <div class="sect">
    <div class="sect__body--flush">
      <div class="rl-table-wrap">
        <table class="rl-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Key</th>
              <th>Hierarchy level</th>
              <th>Description</th>
              <th>Users</th>
              <th style="text-align:right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @roles.each do |role| %>
              <tr>
                <td class="rl-cell-strong"><%= role.name %></td>
                <td class="mono rl-sm"><%= role.key %></td>
                <td class="mono"><%= role.hierarchy_level %></td>
                <td class="muted rl-sm"><%= role.description %></td>
                <td class="mono"><%= role.users.count %></td>
                <td style="text-align:right">
                  <div class="row" style="gap:6px;justify-content:flex-end">
                    <%= link_to "View", role_path(role), class: "rl-btn rl-btn--ghost rl-btn--sm" %>
                    <%= link_to "Edit", edit_role_path(role), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                    <%= link_to role_path(role),
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this role?" },
                          class: "rl-btn rl-btn--destructive-ghost rl-btn--sm" do %>Delete<% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
