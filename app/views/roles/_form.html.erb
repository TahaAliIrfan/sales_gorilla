<%= form_with(model: role, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if role.errors.any? %>
    <%= render "settings/errors", record: role %>
  <% end %>

  <div class="sect">
    <div class="sect__body">
      <div class="grid grid-2">
        <%= render "shared/relay_field", f: form, field: :name, required: true %>
        <%= render "shared/relay_field", f: form, field: :key, required: true,
              hint: %(Use a simple identifier like "admin", "manager", etc.) %>
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :description, type: "textarea", rows: 3 %>
        </div>
        <%= render "shared/relay_field", f: form, field: :hierarchy_level, type: "number", min: 0,
              hint: "Higher numbers indicate higher privileges (e.g. 100 Admin, 50 Manager, 10 Associate)." %>
      </div>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", roles_path, class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (role.new_record? ? "Create role" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
