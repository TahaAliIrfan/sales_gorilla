<%# Shared form for creating/editing a per-org role. System roles lock identity
    (name/key/level) but keep permissions editable; the owner role always has all. %>
<% locked   = @role.system? %>
<% is_owner = @role.key == "owner" %>

<%= form_with model: @role, class: "col", style: "gap:var(--space-5);max-width:860px" do |f| %>
  <% if @role.errors.any? %>
    <div class="rl-sm" style="background:var(--color-danger-subtle);border:1px solid var(--color-danger-border);color:var(--color-danger-text);border-radius:var(--radius-lg);padding:10px 14px">
      <%= @role.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="sect">
    <div class="sect__head"><div class="sect__title">Role details</div></div>
    <div class="sect__body col" style="gap:var(--space-4)">
      <% if locked %>
        <div class="muted rl-sm" style="background:var(--color-bg-2);border-radius:var(--radius-lg);padding:8px 12px">
          <%= relay_icon("lock", size: 13) %> This is a built-in system role. You can adjust its permissions and description, but not its name or rank.
        </div>
      <% end %>

      <div class="grid" style="grid-template-columns:2fr 1fr;gap:var(--space-4)">
        <label class="col" style="gap:4px">
          <span class="rl-sm" style="font-weight:600">Name</span>
          <%= f.text_field :name, class: "rl-input", disabled: locked, placeholder: "e.g. Sales Lead" %>
        </label>
        <label class="col" style="gap:4px">
          <span class="rl-sm" style="font-weight:600">Level</span>
          <%= f.number_field :hierarchy_level, class: "rl-input", disabled: locked, min: 0, max: 100 %>
        </label>
      </div>

      <% unless locked %>
        <label class="col" style="gap:4px">
          <span class="rl-sm" style="font-weight:600">Key</span>
          <%= f.text_field :key, class: "rl-input", placeholder: "lowercase-unique-key, e.g. sales_lead" %>
          <span class="muted" style="font-size:11px">Used internally; lowercase letters, numbers and underscores. Can't change after members are assigned.</span>
        </label>
      <% end %>

      <label class="col" style="gap:4px">
        <span class="rl-sm" style="font-weight:600">Description</span>
        <%= f.text_area :description, class: "rl-input", rows: 2, placeholder: "What this role is for" %>
      </label>
    </div>
  </div>

  <div class="sect">
    <div class="sect__head">
      <div class="sect__title">Permissions</div>
      <div class="muted rl-sm">What members with this role can do across the organization.</div>
    </div>
    <div class="sect__body col" style="gap:var(--space-5)">
      <% if is_owner %>
        <div class="muted rl-sm" style="background:var(--color-bg-2);border-radius:var(--radius-lg);padding:8px 12px">
          <%= relay_icon("shield", size: 13) %> The Owner role always has every permission and can't be restricted.
        </div>
      <% end %>

      <%# Ensures unchecking every box submits an empty set. %>
      <%= hidden_field_tag "role[permissions][]", "" %>

      <% Permission::CATALOG.each do |category, perms| %>
        <div class="col" style="gap:8px">
          <div class="rl-sm" style="font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:var(--color-fg-3)"><%= category %></div>
          <div class="grid grid-2" style="gap:8px">
            <% perms.each do |key, label| %>
              <% granted = is_owner || @role.permissions.include?(key) %>
              <label class="row" style="gap:8px;align-items:flex-start;padding:8px 10px;border:1px solid var(--color-border);border-radius:var(--radius-lg);<%= "opacity:.7" if is_owner %>">
                <%= check_box_tag "role[permissions][]", key, granted, disabled: is_owner, id: "perm_#{key.parameterize(separator: '_')}", style: "margin-top:2px" %>
                <span class="col" style="gap:1px">
                  <span class="rl-sm" style="font-weight:600"><%= label %></span>
                  <span class="muted" style="font-size:10px"><code><%= key %></code></span>
                </span>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="row" style="gap:8px;justify-content:flex-end">
    <%= link_to "Cancel", roles_path, class: "rl-btn rl-btn--ghost" %>
    <%= f.submit (@role.persisted? ? "Save role" : "Create role"), class: "rl-btn rl-btn--primary" %>
  </div>
<% end %>
