<% content_for :title, "#{@pipeline.name} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title"><%= @pipeline.name %></div>
      <div class="pagehead__sub">Pipeline stages and user assignment.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to pipelines_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
      <%= link_to new_pipeline_deal_stage_path(@pipeline), class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("plus", size: 15) %>Add stage
      <% end %>
      <%= link_to edit_pipeline_path(@pipeline), class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("pencil", size: 15) %>Edit pipeline
      <% end %>
    </div>
  </div>

  <div class="grid" style="grid-template-columns:1.4fr 1fr;align-items:start;gap:var(--space-5);margin-bottom:var(--space-5)">
    <div class="col" style="gap:var(--space-5)">
      <div class="sect">
        <div class="sect__head"><div class="sect__title">Description</div></div>
        <div class="sect__body">
          <% if @pipeline.description.present? %>
            <div class="rl-sm" style="white-space:pre-wrap;line-height:1.6"><%= @pipeline.description %></div>
          <% else %>
            <div class="muted rl-sm">No description provided.</div>
          <% end %>
        </div>
      </div>

      <div class="sect">
        <div class="sect__head"><div class="sect__title">Statistics</div></div>
        <div class="sect__body">
          <div class="kvline"><dt>Total deals</dt><dd class="mono"><%= @deals_count %></dd></div>
          <div class="kvline"><dt>Assigned users</dt><dd class="mono"><%= @assigned_users.count %></dd></div>
          <div class="kvline">
            <dt>Status</dt>
            <dd>
              <% if @pipeline.active? %>
                <span class="rl-pill rl-pill--success"><i class="rl-dot"></i>Active</span>
              <% else %>
                <span class="rl-pill"><i class="rl-dot" style="background:var(--color-fg-4)"></i>Inactive</span>
              <% end %>
            </dd>
          </div>
        </div>
      </div>
    </div>

    <div class="sect">
      <div class="sect__head"><div class="sect__title"><%= relay_icon("users", size: 18) %>User assignment</div></div>
      <div class="sect__body">
        <%= form_with url: assign_users_pipeline_path(@pipeline), method: :patch, class: "col", html: { style: "gap:var(--space-4)" } do |form| %>
          <div class="col" style="gap:8px;max-height:240px;overflow-y:auto">
            <% current_organization.users.order(:name).each do |user| %>
              <label class="rl-check">
                <%= check_box_tag "user_ids[]", user.id, @assigned_users.include?(user) %>
                <span class="rl-box"><%= relay_icon("check", size: 13) %></span>
                <span><%= user.name.presence || user.email %></span>
              </label>
            <% end %>
          </div>
          <%= form.submit "Update assignments", class: "rl-btn rl-btn--primary rl-btn--sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="sect">
    <div class="sect__head"><div class="sect__title"><%= relay_icon("columns-2", size: 18) %>Pipeline stages</div></div>
    <div class="sect__body">
      <% if @deal_stages.any? %>
        <div class="row row--wrap" style="gap:12px;align-items:stretch">
          <% @deal_stages.each_with_index do |stage, index| %>
            <div class="rl-card" style="width:240px;padding:14px">
              <div class="spread" style="margin-bottom:6px">
                <b><%= stage.name %></b>
                <span class="rl-badge rl-badge--neutral">Pos <%= stage.position %></span>
              </div>
              <% if stage.description.present? %>
                <p class="muted rl-sm" style="margin:0 0 10px"><%= truncate(stage.description, length: 100) %></p>
              <% end %>
              <div class="muted rl-xs" style="margin-bottom:10px"><%= stage.deals.count %> deals</div>
              <div class="row" style="gap:6px">
                <%= link_to "Edit", edit_pipeline_deal_stage_path(@pipeline, stage), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                <%= button_to pipeline_deal_stage_path(@pipeline, stage), method: :delete,
                      form: { data: { turbo_confirm: "Are you sure?" } },
                      class: "rl-btn rl-btn--destructive-ghost rl-btn--sm" do %>Delete<% end %>
              </div>
            </div>
            <% unless index == @deal_stages.length - 1 %>
              <div class="row" style="align-items:center;color:var(--color-fg-4)"><%= relay_icon("chevron-right", size: 18) %></div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="muted rl-sm" style="text-align:center;padding:var(--space-6)">
          No stages found. <%= link_to "Add your first stage", new_pipeline_deal_stage_path(@pipeline), style: "color:var(--color-primary-text)" %>.
        </div>
      <% end %>
    </div>
  </div>
</div>
