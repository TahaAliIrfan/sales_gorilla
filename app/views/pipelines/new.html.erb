<% content_for :title, "New pipeline — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">New pipeline</div>
      <div class="pagehead__sub">Create a new sales pipeline.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to pipelines_path, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
    </div>
  </div>

  <div style="max-width:680px"><%= render "form", pipeline: @pipeline %></div>
</div>
