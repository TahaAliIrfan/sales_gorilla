<% content_for :title, "Edit #{@pipeline.name} — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Edit pipeline</div>
      <div class="pagehead__sub"><%= @pipeline.name %></div>
    </div>
    <div class="pagehead__actions">
      <%= link_to @pipeline, class: "rl-btn rl-btn--ghost" do %>
        <%= relay_icon("eye", size: 15) %>View pipeline
      <% end %>
      <%= link_to pipelines_path, class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("arrow-left", size: 15) %>Back
      <% end %>
    </div>
  </div>

  <div style="max-width:680px"><%= render "form", pipeline: @pipeline %></div>
</div>
