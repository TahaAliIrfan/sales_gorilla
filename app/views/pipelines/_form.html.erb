<%= form_with(model: pipeline, class: "col", html: { style: "gap:var(--space-5)" }) do |form| %>
  <% if pipeline.errors.any? %>
    <%= render "settings/errors", record: pipeline %>
  <% end %>

  <div class="sect">
    <div class="sect__body">
      <div class="grid grid-2">
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :name, required: true,
                placeholder: "e.g. Sales Pipeline" %>
        </div>
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :description, type: "textarea", rows: 4,
                placeholder: "Describe what this pipeline is used for…" %>
        </div>
        <div style="grid-column:1 / -1">
          <%= render "shared/relay_field", f: form, field: :active, type: "checkbox",
                hint: "Inactive pipelines are hidden from the deals board." %>
        </div>
      </div>
    </div>
  </div>

  <div class="row" style="justify-content:flex-end;gap:8px">
    <%= link_to "Cancel", pipelines_path, class: "rl-btn rl-btn--secondary" %>
    <%= form.submit (pipeline.new_record? ? "Create pipeline" : "Save changes"),
          class: "rl-btn rl-btn--primary", data: { turbo_submits_with: "Saving…" } %>
  </div>
<% end %>
