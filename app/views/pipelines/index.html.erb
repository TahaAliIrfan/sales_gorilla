<% content_for :title, "Pipelines — #{current_organization&.name}" %>

<div class="page">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Pipelines</div>
      <div class="pagehead__sub">Configure your sales pipelines and their stages.</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to new_pipeline_path, class: "rl-btn rl-btn--primary" do %>
        <%= relay_icon("plus", size: 15) %>New pipeline
      <% end %>
    </div>
  </div>

  <div class="sect">
    <div class="sect__body--flush">
      <% if @pipelines.any? %>
        <div class="rl-table-wrap">
          <table class="rl-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Stages</th>
                <th>Assigned users</th>
                <th>Active deals</th>
                <th>Status</th>
                <th style="text-align:right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @pipelines.each do |pipeline| %>
                <tr>
                  <td>
                    <%= link_to pipeline.name, pipeline, class: "rl-cell-strong", style: "color:var(--color-primary-text)" %>
                  </td>
                  <td class="muted rl-sm"><%= truncate(pipeline.description, length: 80) %></td>
                  <td class="mono"><%= pipeline.deal_stages.count %></td>
                  <td class="mono"><%= pipeline.users.count %></td>
                  <td class="mono"><%= pipeline.active_deals_count %></td>
                  <td>
                    <% if pipeline.active? %>
                      <span class="rl-pill rl-pill--success"><i class="rl-dot"></i>Active</span>
                    <% else %>
                      <span class="rl-pill"><i class="rl-dot" style="background:var(--color-fg-4)"></i>Inactive</span>
                    <% end %>
                  </td>
                  <td style="text-align:right">
                    <div class="row" style="gap:6px;justify-content:flex-end">
                      <%= link_to "View", pipeline, class: "rl-btn rl-btn--ghost rl-btn--sm" %>
                      <%= link_to "Edit", edit_pipeline_path(pipeline), class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                      <%= button_to pipeline, method: :delete,
                            form: { data: { turbo_confirm: "Are you sure? This will remove the pipeline and all its stages." } },
                            class: "rl-btn rl-btn--destructive-ghost rl-btn--sm" do %>
                        Delete
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty">
          <span class="empty__ic"><%= relay_icon("layers", size: 26) %></span>
          <div class="rl-h4" style="margin-bottom:4px">No pipelines yet</div>
          <div class="muted rl-sm" style="max-width:360px">Create your first pipeline to start organizing deals into stages.</div>
          <div style="margin-top:16px"><%= link_to "Create pipeline", new_pipeline_path, class: "rl-btn rl-btn--primary rl-btn--sm" %></div>
        </div>
      <% end %>
    </div>
  </div>
</div>
