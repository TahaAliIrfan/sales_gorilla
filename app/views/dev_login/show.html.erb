<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title>Development Login · Relay</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8">
      <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
            </svg>
            <strong>Development Mode Only</strong>
          </div>
          <p class="text-sm mt-1">This login gateway is only available in development environment.</p>
        </div>

        <div class="text-center">
          <h2 class="text-3xl font-extrabold text-gray-900">
            Development Login
          </h2>
          <p class="mt-2 text-sm text-gray-600">
            Enter any user email to login instantly
          </p>
        </div>
      </div>

      <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
          <%= form_with url: dev_login_path, method: :post, local: true, class: "space-y-6" do |form| %>
            <% if flash[:error] %>
              <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded">
                <%= flash[:error] %>
              </div>
            <% end %>

            <div>
              <%= form.label :email, "Email Address", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= form.email_field :email, 
                    required: true,
                    autofocus: true,
                    autocomplete: "email",
                    placeholder: "user@example.com",
                    class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
              </div>
            </div>

            <div>
              <%= form.submit "Login", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            </div>
          <% end %>

          <div class="mt-6">
            <div class="relative">
              <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-gray-300" />
              </div>
              <div class="relative flex justify-center text-sm">
                <span class="px-2 bg-white text-gray-500">Available Users</span>
              </div>
            </div>

            <div class="mt-6">
              <div class="bg-gray-50 px-4 py-3 rounded-md">
                <h4 class="text-sm font-medium text-gray-700 mb-2">Quick Login Options:</h4>
                <div class="space-y-2 text-xs">
                  <% begin %>
                    <% User.includes(memberships: :access_role).group_by { |u| u.best_membership_role&.key || 'no_role' }.each do |role, users| %>
                      <div>
                        <span class="font-medium text-gray-600 capitalize"><%= role.humanize %>s:</span>
                        <div class="ml-2 space-y-1">
                          <% users.each do |user| %>
                            <div class="flex items-center justify-between">
                              <span class="text-gray-800"><%= user.email %></span>
                              <button type="button" 
                                      onclick="document.querySelector('#email').value='<%= user.email %>'"
                                      class="text-blue-600 hover:text-blue-800 text-xs underline">
                                Use
                              </button>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  <% rescue => e %>
                    <div class="text-red-600">
                      Error loading users: <%= e.message %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-6 text-center">
            <%= link_to "← Back to Home", root_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>