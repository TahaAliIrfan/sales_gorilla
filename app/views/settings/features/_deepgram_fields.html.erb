<%# Deepgram credentials for the Transcription module. Same secrecy pattern as
    the Twilio fields: existing values are masked, blank submits keep them.
    Restyled with the Relay DS — field names, ids and params are unchanged. %>
<% s = feature.settings_hash %>

<div class="col" style="gap:14px;background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:16px">
  <p class="rl-label" style="margin:0">Deepgram credentials</p>

  <div class="rl-field">
    <%= label_tag "organization_feature_settings_api_key", "API key", class: "rl-label" %>
    <%= password_field_tag "organization_feature[settings][api_key]", "",
          id: "organization_feature_settings_api_key",
          autocomplete: "new-password",
          placeholder: s["api_key"].present? ? "•••••• (saved)" : "Required",
          class: "rl-input" %>
  </div>

  <p class="muted" style="font-size:12px;margin:0">
    Find or create a Deepgram API key at
    <a href="https://console.deepgram.com/" target="_blank" rel="noopener">console.deepgram.com</a>.
    Leave blank to keep the saved value.
  </p>
</div>
