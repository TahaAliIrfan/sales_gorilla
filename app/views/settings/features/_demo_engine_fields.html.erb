<% s = feature.settings_hash %>
<div class="col" style="gap:14px;background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:16px">
  <p class="rl-label" style="margin:0">Demo server</p>
  <div class="rl-field">
    <%= label_tag "organization_feature_settings_server_url", "Server URL", class: "rl-label" %>
    <%= text_field_tag "organization_feature[settings][server_url]", s["server_url"],
          id: "organization_feature_settings_server_url", placeholder: "https://demo.tecaudex.pk", class: "rl-input" %>
  </div>
  <div class="rl-field">
    <%= label_tag "organization_feature_settings_api_key", "Build API key", class: "rl-label" %>
    <%= password_field_tag "organization_feature[settings][api_key]", "",
          id: "organization_feature_settings_api_key", autocomplete: "new-password",
          placeholder: s["api_key"].present? ? "•••••• (saved)" : "Demo build key", class: "rl-input" %>
  </div>
</div>
