<%# Meta Conversions API editor: credentials, test event code, event toggles,
    eligible lead sources, status/stage→event mapping, source→action_source
    mapping with match quality preview, plus a "Send test event" diagnostic.
    Restyled with the Relay DS — field names, ids and params are unchanged. %>
<%
  s = feature.settings_hash
  service = MetaConversionsApiService.new(organization: current_organization)

  # Sample the most recent customer per lead_source so the match quality
  # preview reflects real data (vs an unscoped theoretical "all identifiers").
  enabled_sources_for_preview = Array(s["eligible_sources"]).presence ||
                                OrganizationFeature::META_DEFAULT_ELIGIBLE_SOURCES
  recent_samples = Customer.where(lead_source: enabled_sources_for_preview)
                            .order(created_at: :desc)
                            .limit(50)
                            .group_by(&:lead_source)
                            .transform_values(&:first)

  status_mappings = (s["customer_status_mappings"] || {}).presence ||
                    OrganizationFeature::META_DEFAULT_CUSTOMER_STATUS_MAPPINGS
  stage_mappings  = s["deal_stage_mappings"] || {}
  source_actions  = (s["source_action_sources"] || {}).presence ||
                    OrganizationFeature::META_DEFAULT_SOURCE_ACTION_SOURCES

  pipelines = Pipeline.includes(:deal_stages).order(:name)

  quality_palette = {
    "Great" => [ "var(--color-success-text)", "Strong match" ],
    "Good"  => [ "var(--color-warning-text)", "Decent match" ],
    "Poor"  => [ "var(--color-danger-text)",  "Weak match" ]
  }
%>

<div data-controller="meta-test"
     data-meta-test-url-value="<%= test_settings_feature_path(key: feature.key) %>"
     data-meta-test-verify-url-value="<%= verify_settings_feature_path(key: feature.key) %>"
     data-meta-test-events-manager-url-value="<%= service.events_manager_url.to_s %>"
     class="col" style="gap:var(--space-5);background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:16px">

  <%# ── Credentials ─────────────────────────────────────────────────────── %>
  <div class="col" style="gap:12px">
    <p class="rl-label" style="margin:0">Credentials</p>

    <div class="rl-field">
      <%= label_tag "organization_feature_settings_pixel_id", "Pixel ID", class: "rl-label" %>
      <%= text_field_tag "organization_feature[settings][pixel_id]", s["pixel_id"],
            id: "organization_feature_settings_pixel_id",
            placeholder: "e.g. 123456789012345",
            class: "rl-input" %>
    </div>

    <div class="rl-field">
      <%= label_tag "organization_feature_settings_access_token", "Access token", class: "rl-label" %>
      <%= password_field_tag "organization_feature[settings][access_token]", "",
            id: "organization_feature_settings_access_token",
            autocomplete: "new-password",
            placeholder: s["access_token"].present? ? "•••••• (saved)" : "Required",
            class: "rl-input" %>
      <p class="muted" style="font-size:11px;margin-top:4px">
        Generate a system-user token in Meta Business Manager. Leave blank to keep the saved value.
      </p>
    </div>
  </div>

  <%# ── Test event code ────────────────────────────────────────────────── %>
  <div class="col" style="gap:8px;border-top:1px solid var(--color-border);padding-top:16px">
    <p class="rl-label" style="margin:0">Test event code <span class="muted">(optional)</span></p>
    <%= text_field_tag "organization_feature[settings][test_event_code]", s["test_event_code"],
          id: "organization_feature_settings_test_event_code",
          placeholder: "e.g. TEST12345",
          class: "rl-input" %>
    <p class="muted" style="font-size:11px;margin:0">
      While set, events are routed to Meta's <b>Events Manager → Test events</b> tab instead of going live.
      Remove this value when ready to ship.
    </p>
  </div>

  <%# ── Events to fire ─────────────────────────────────────────────────── %>
  <div class="col" style="gap:8px;border-top:1px solid var(--color-border);padding-top:16px">
    <p class="rl-label" style="margin:0">Events to fire</p>
    <%= hidden_field_tag "organization_feature[settings][events_enabled][]", "" %>
    <div class="grid grid-2" style="gap:8px">
      <% enabled_events = Array(s["events_enabled"]).presence || OrganizationFeature::META_DEFAULT_EVENTS %>
      <% OrganizationFeature::META_DEFAULT_EVENTS.each do |evt| %>
        <label class="row" style="gap:8px;cursor:pointer;border:1px solid var(--color-border);border-radius:var(--radius-md);padding:8px 12px">
          <%= check_box_tag "organization_feature[settings][events_enabled][]", evt,
                enabled_events.include?(evt),
                style: "accent-color: var(--color-primary); width:16px; height:16px" %>
          <span class="rl-sm"><%= evt %></span>
        </label>
      <% end %>
    </div>
    <p class="muted" style="font-size:11px;margin:0">
      Unchecked events won't be sent to Meta regardless of customer activity.
    </p>
  </div>

  <%# ── Eligible lead sources ───────────────────────────────────────────── %>
  <div class="col" style="gap:8px;border-top:1px solid var(--color-border);padding-top:16px">
    <p class="rl-label" style="margin:0">Eligible lead sources</p>
    <%= hidden_field_tag "organization_feature[settings][eligible_sources][]", "" %>
    <div class="grid grid-3" style="gap:8px">
      <% enabled_sources = Array(s["eligible_sources"]).presence || OrganizationFeature::META_DEFAULT_ELIGIBLE_SOURCES %>
      <% current_organization.taxonomy_values("lead_source").each do |src| %>
        <label class="row" style="gap:8px;cursor:pointer;border:1px solid var(--color-border);border-radius:var(--radius-md);padding:8px 12px">
          <%= check_box_tag "organization_feature[settings][eligible_sources][]", src,
                enabled_sources.include?(src),
                style: "accent-color: var(--color-primary); width:16px; height:16px" %>
          <span class="rl-sm"><%= src %></span>
        </label>
      <% end %>
    </div>
    <p class="muted" style="font-size:11px;margin:0">
      Only customers with a checked lead source can trigger Meta events.
      Inbound sources also require a <code>meta_lead_id</code> (set by the Meta Lead Ads webhook).
    </p>
  </div>

  <%# ── Source → action_source + match quality ──────────────────────────── %>
  <div class="col" style="gap:12px;border-top:1px solid var(--color-border);padding-top:16px">
    <div>
      <p class="rl-label" style="margin:0">Source routing &amp; match quality</p>
      <p class="muted" style="font-size:11px;margin-top:4px">
        For each eligible source, pick the Meta <code>action_source</code> that matches the ad type
        (Lead Ads webhook → <code>system_generated</code>, click-to-call → <code>phone_call</code>,
        Messenger/WA → <code>business_messaging</code>, etc.). Require <code>lead_id</code> for
        sources that come through Meta's Lead Ads webhook — events without it will be skipped.
      </p>
    </div>

    <%# One blank hidden field anchors the hash key in params even if no rows render. %>
    <%= hidden_field_tag "organization_feature[settings][source_action_sources][__anchor__][action_source]", "" %>

    <div class="rl-table-wrap">
      <table class="rl-table">
        <thead>
          <tr>
            <th>Lead source</th>
            <th>action_source</th>
            <th>Requires lead_id</th>
            <th>Match quality (recent)</th>
          </tr>
        </thead>
        <tbody>
          <% enabled_sources_for_preview.each do |src| %>
            <%
              config = source_actions[src] || {}
              current_as = config["action_source"]
              current_lead_id_required = !!config["require_lead_id"]
              sample = recent_samples[src]
              quality = service.match_quality_summary(sample_customer: sample)
              q_color, q_label = quality_palette[quality[:quality]] || quality_palette["Poor"]
            %>
            <tr>
              <td style="font-weight:500"><%= src %></td>
              <td>
                <%= select_tag "organization_feature[settings][source_action_sources][#{src}][action_source]",
                      options_for_select(OrganizationFeature::META_ACTION_SOURCES.map { |a| [ a, a ] }, current_as),
                      include_blank: "—",
                      class: "rl-select" %>
              </td>
              <td>
                <%= hidden_field_tag "organization_feature[settings][source_action_sources][#{src}][require_lead_id]", "0" %>
                <%= check_box_tag "organization_feature[settings][source_action_sources][#{src}][require_lead_id]", "1",
                      current_lead_id_required,
                      style: "accent-color: var(--color-primary); width:16px; height:16px" %>
              </td>
              <td>
                <div class="row" style="gap:6px;flex-wrap:wrap">
                  <span class="row" style="gap:5px;border-radius:var(--radius-pill);padding:1px 8px;font-size:11px;font-weight:500;color:<%= q_color %>;background:color-mix(in srgb, <%= q_color %> 12%, transparent)"
                        title="<%= q_label %> · sample: <%= sample ? "customer ##{sample.id}" : "no recent customers" %>">
                    <span style="width:6px;height:6px;border-radius:50%;background:<%= q_color %>"></span>
                    <%= quality[:quality] %>
                  </span>
                  <% quality[:identifiers].each do |id, present| %>
                    <span class="mono" style="font-size:10px;color:var(--color-fg-2)">
                      <span style="color:<%= present ? "var(--color-success-text)" : "var(--color-fg-2)" %>"><%= present ? "✓" : "·" %></span>
                      <%= id %>
                    </span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# ── Customer status → event mapping ─────────────────────────────────── %>
  <div class="col" style="gap:12px;border-top:1px solid var(--color-border);padding-top:16px">
    <div>
      <p class="rl-label" style="margin:0">Customer status → Meta event</p>
      <p class="muted" style="font-size:11px;margin-top:4px">
        When a customer transitions to a status, fire the mapped Meta event.
        Leave <em>None</em> to skip. Events also need to be checked in <strong>Events to fire</strong> above.
      </p>
    </div>

    <%= hidden_field_tag "organization_feature[settings][customer_status_mappings][__anchor__]", "" %>

    <div class="rl-table-wrap">
      <table class="rl-table">
        <thead>
          <tr>
            <th>Customer status</th>
            <th>Meta event</th>
          </tr>
        </thead>
        <tbody>
          <% current_organization.taxonomy_values("customer_status").each do |status| %>
            <% current = status_mappings[status] %>
            <tr>
              <td style="font-weight:500"><%= status %></td>
              <td>
                <%= select_tag "organization_feature[settings][customer_status_mappings][#{status}]",
                      options_for_select([ [ "None", "" ] ] + OrganizationFeature::META_AVAILABLE_EVENTS.map { |e| [ e, e ] }, current),
                      class: "rl-select" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# ── Deal stage → event mapping (grouped by pipeline) ────────────────── %>
  <div class="col" style="gap:12px;border-top:1px solid var(--color-border);padding-top:16px">
    <div>
      <p class="rl-label" style="margin:0">Deal stage → Meta event</p>
      <p class="muted" style="font-size:11px;margin-top:4px">
        When a deal moves into a stage, fire the mapped Meta event. <code>Purchase</code> events
        automatically include the deal's <code>amount</code> as the conversion value.
      </p>
    </div>

    <%= hidden_field_tag "organization_feature[settings][deal_stage_mappings][__anchor__]", "" %>

    <% if pipelines.empty? %>
      <div class="muted rl-sm" style="border:1px solid var(--color-border);border-radius:var(--radius-md);padding:16px">
        No pipelines configured yet. Create one in <%= link_to "Pipelines", pipelines_path %> to map deal stages.
      </div>
    <% else %>
      <div class="col" style="gap:12px">
        <% pipelines.each do |pipeline| %>
          <% stages = pipeline.deal_stages.ordered %>
          <% next if stages.empty? %>

          <div class="rl-table-wrap">
            <div style="background:var(--color-surface-2);padding:8px 12px">
              <p style="font-weight:600;font-size:var(--text-sm)"><%= pipeline.name %></p>
            </div>
            <table class="rl-table">
              <tbody>
                <% stages.each do |stage| %>
                  <% current = stage_mappings[stage.id.to_s] %>
                  <tr>
                    <td>
                      <span class="row" style="gap:8px">
                        <span class="mono muted" style="font-size:11px">#<%= stage.position %></span>
                        <%= stage.name %>
                      </span>
                    </td>
                    <td>
                      <%= select_tag "organization_feature[settings][deal_stage_mappings][#{stage.id}]",
                            options_for_select([ [ "None", "" ] ] + OrganizationFeature::META_AVAILABLE_EVENTS.map { |e| [ e, e ] }, current),
                            class: "rl-select" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Diagnostics ─────────────────────────────────────────────────────── %>
  <div class="col" style="gap:12px;border-top:1px solid var(--color-border);padding-top:16px">
    <p class="rl-label" style="margin:0">Diagnostics</p>

    <div class="row" style="gap:8px;flex-wrap:wrap">
      <button type="button"
              data-action="meta-test#verify"
              data-meta-test-target="verifyButton"
              class="rl-btn rl-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        Verify pixel
      </button>

      <button type="button"
              data-action="meta-test#send"
              data-meta-test-target="button"
              class="rl-btn rl-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 2L11 13M22 2l-7 20-4-9-9-4z"/>
        </svg>
        Send test event
      </button>

      <% if service.credentials_configured? && service.events_manager_url.present? %>
        <a href="<%= service.events_manager_url %>" target="_blank" rel="noopener"
           class="rl-btn rl-btn--ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Open in Events Manager
        </a>
      <% end %>
    </div>

    <%# Result panel — populated by the meta-test Stimulus controller. %>
    <div data-meta-test-target="result"
         class="hidden rl-sm" style="border:1px solid var(--color-border);border-radius:var(--radius-md);padding:12px">
    </div>

    <p class="muted" style="font-size:11px;margin:0">
      <b>Verify pixel</b> confirms the access token actually owns this pixel ID.
      <b>Send test event</b> posts a synthetic <code>Lead</code> with dummy user data —
      if a <em>Test event code</em> is set, watch the event arrive in Events Manager's
      <b>Test events</b> tab.
    </p>
  </div>
</div>
