<%# Renders one feature module (e.g. Calling, Transcription, Meta Conversions)
    with on/off toggle, provider selector, and the provider-specific credentials
    form. Restyled with the Relay DS — form fields, names, params and the
    controller contract are unchanged from the original Tailwind version. %>
<%
  meta = {
    "calling" => {
      title: "Calling",
      blurb: "Browser-based phone calls and call recording.",
      icon:  "phone"
    },
    "transcription" => {
      title: "Transcription",
      blurb: "Automatic speaker-diarized transcripts for every call recording.",
      icon:  "rec"
    },
    "meta_conversions" => {
      title: "Meta Conversions API",
      blurb: "Server-side conversion tracking for Meta Lead Ads, CCR, and website signups.",
      icon:  "megaphone"
    }
  }.fetch(feature.key, { title: feature.key.titleize, blurb: "", icon: "grid" })

  # 7-day activity stats only relevant for meta_conversions today.
  stats =
    if feature.key == "meta_conversions"
      since = 7.days.ago
      logs  = MetaConversionLog.where("created_at >= ?", since)
      { ok: logs.where(success: true).count, fail: logs.where(success: false).count, window: "7d" }
    end
%>

<div class="sect">
  <div class="sect__body">
    <%= form_with model: feature,
          url: settings_feature_path(key: feature.key),
          method: :patch,
          class: "col", html: { style: "gap:var(--space-5)" } do |f| %>

      <% if feature.errors.any? %>
        <%= render "settings/errors", record: feature %>
      <% end %>

      <div class="spread" style="gap:24px;align-items:flex-start">
        <div>
          <h3 style="font-size:var(--text-h4);font-weight:700"><%= meta[:title] %></h3>
          <p class="muted rl-sm" style="margin-top:2px"><%= meta[:blurb] %></p>
          <% if stats %>
            <p class="muted rl-sm" style="margin-top:6px">
              Last <%= stats[:window] %>:
              <span style="color:var(--color-success-text)"><%= stats[:ok] %> ok</span>
              <% if stats[:fail].positive? %>
                · <span style="color:var(--color-danger-text)"><%= stats[:fail] %> failed</span>
              <% end %>
            </p>
          <% end %>
        </div>

        <div class="row" style="gap:10px">
          <span class="muted" style="font-size:12px">
            <%= feature.enabled? ? "Enabled" : "Disabled" %>
          </span>
          <%= f.hidden_field :enabled, value: "0" %>
          <label class="rl-switch">
            <%= f.check_box :enabled, { checked: feature.enabled? }, "1", "0" %>
            <span class="rl-track"></span>
          </label>
        </div>
      </div>

      <div class="rl-field">
        <%= f.label :provider, class: "rl-label" %>
        <%= f.select :provider,
              OrganizationFeature::PROVIDERS[feature.key].map { |p| [ p.titleize, p ] },
              { include_blank: "Select a provider" },
              class: "rl-select" %>
      </div>

      <% case feature.key %>
      <% when "calling" %>
        <%= render "settings/features/twilio_fields", f: f, feature: feature %>
      <% when "transcription" %>
        <%= render "settings/features/deepgram_fields", f: f, feature: feature %>
      <% when "meta_conversions" %>
        <%= render "settings/features/meta_fields", f: f, feature: feature %>
      <% end %>

      <div class="row">
        <%= f.submit "Save #{meta[:title]}",
              data: { turbo_submits_with: "Saving…" },
              class: "rl-btn rl-btn--primary" %>
      </div>
    <% end %>
  </div>
</div>
