<%# Inline DS-styled validation error block (no rl-alert component exists; uses
    the danger color tokens directly, matching the prototype's inline approach). %>
<div class="rl-sm" style="background:var(--color-danger-subtle);border:1px solid var(--color-danger-border);color:var(--color-danger-text);border-radius:var(--radius-lg);padding:12px 14px">
  <ul style="margin:0;padding-left:18px">
    <% record.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
  </ul>
</div>
