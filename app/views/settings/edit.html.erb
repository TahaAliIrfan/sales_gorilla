<%# Relay Settings workspace — profile, branding (white-label live reskin),
    team & roles, integrations. Ports docs/design/relay-app/project/app/view-settings.jsx.
    Tabs are server-side links (?tab=…); features is its own route. %>
<% content_for :title, "Settings — #{current_organization&.name}" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__title">Settings</div>
      <div class="pagehead__sub">Manage your profile, your workspace, branding and integrations.</div>
    </div>
  </div>

  <%= render "settings/tabbar", active: @tab %>

  <% case @tab
     when "profile"      %><%= render "settings/profile" %>
  <% when "branding"     %><%= render "settings/branding" %>
  <% when "team"         %><%= render "settings/team" %>
  <% when "integrations" %><%= render "settings/integrations" %>
  <% end %>
</div>
