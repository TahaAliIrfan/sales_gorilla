<%# Integrations tab — Google connection (real state + connect/disconnect) plus
    pointers to the provider-credential modules that live under Features. %>
<div class="col" style="gap:var(--space-4);max-width:760px">
  <div>
    <b style="font-size:var(--text-h4);font-weight:700">Integrations</b>
    <div class="muted rl-sm">Connect the tools <%= current_organization&.name %> runs on.</div>
  </div>

  <%= render "settings/google_card" %>

  <% if admin_tabs? %>
    <div class="sect">
      <div class="sect__body">
        <div class="spread">
          <div class="row" style="gap:12px">
            <span class="iccircle" style="width:40px;height:40px;background:color-mix(in oklch, var(--color-danger) 14%, transparent);color:var(--color-danger)">
              <%= relay_icon("phone", size: 19) %>
            </span>
            <div>
              <b style="font-weight:700">Calling &amp; voice</b>
              <div class="muted rl-sm">Browser calling, recordings and transcription via Twilio.</div>
            </div>
          </div>
          <%= link_to "Configure", settings_features_path, class: "rl-btn rl-btn--secondary rl-btn--sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
