<%# Team & roles tab — user list with role badge, active status, inline role
    change and activate/deactivate. Role/active changes POST to the existing
    UsersController#update_role / #toggle_active JSON endpoints via the
    relay--user-admin Stimulus controller (same contract as users/index). %>
<div class="col" style="gap:var(--space-5);max-width:920px"
     data-controller="relay--user-admin">
  <div class="spread">
    <div>
      <b style="font-size:var(--text-h4);font-weight:700">Team &amp; roles</b>
      <div class="muted rl-sm">Admin → manager → associate. Managers oversee their assigned associates.</div>
    </div>
    <%= link_to managers_users_path, class: "rl-btn rl-btn--secondary rl-btn--sm" do %>
      <%= relay_icon("git-fork", size: 14) %>Manage associates
    <% end %>
  </div>

  <%# Invite a teammate by email. New emails get a set-password invitation;
      existing Sales Gorilla accounts are added to this org and notified. %>
  <form action="<%= invite_users_path %>" method="post" data-turbo="false"
        class="rl-card" style="padding:var(--space-4);display:flex;flex-wrap:wrap;align-items:flex-end;gap:var(--space-3)">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <div class="col" style="gap:4px;flex:1 1 240px;min-width:220px">
      <label class="muted rl-sm" for="invite_email">Invite a teammate</label>
      <input type="email" name="email" id="invite_email" required placeholder="name@company.com"
             class="rl-input" style="width:100%">
    </div>
    <div class="col" style="gap:4px">
      <label class="muted rl-sm" for="invite_role">Role</label>
      <select name="role_key" id="invite_role" class="rl-select" style="width:auto">
        <% @roles.each do |r| %>
          <option value="<%= r[:key] %>" <%= "selected" if r[:key] == "member" %>><%= r[:name] %></option>
        <% end %>
      </select>
    </div>
    <button type="submit" class="rl-btn rl-btn--primary rl-btn--sm">
      <%= relay_icon("mail", size: 14) %>Send invite
    </button>
  </form>

  <div class="rl-table-wrap">
    <table class="rl-table">
      <thead>
        <tr>
          <th>User</th>
          <th>Role</th>
          <th>Status</th>
          <th style="text-align:right"></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each_with_index do |user, i| %>
          <% role_key = user.highest_role&.key || "associate" %>
          <tr>
            <td>
              <div class="row" style="gap:10px">
                <span class="rl-avatar rl-avatar--sm rl-avatar--c<%= (i % 6) + 1 %>">
                  <%= user.name.to_s.split.map(&:first).join[0, 2].upcase %>
                </span>
                <div>
                  <div class="rl-cell-strong"><%= user.name %></div>
                  <div class="muted" style="font-size:11px"><%= user.email %></div>
                </div>
              </div>
            </td>
            <td>
              <% if user == current_user %>
                <span class="rl-badge <%= settings_role_badge(role_key) %>" style="text-transform:capitalize"><%= role_key %></span>
              <% else %>
                <select class="rl-select" style="width:auto;height:32px;padding-top:0;padding-bottom:0"
                        data-action="change->relay--user-admin#changeRole"
                        data-relay--user-admin-id-param="<%= user.id %>"
                        data-current="<%= role_key %>">
                  <% @roles.each do |r| %>
                    <option value="<%= r[:key] %>" <%= "selected" if r[:key] == role_key %>><%= r[:name] %></option>
                  <% end %>
                </select>
              <% end %>
            </td>
            <td>
              <% if user.sign_in_count.to_i.zero? %>
                <span class="rl-pill rl-pill--warning" title="Invitation sent — not accepted yet"><i class="rl-dot"></i>Pending invite</span>
              <% elsif user.active? %>
                <span class="rl-pill rl-pill--success"><i class="rl-dot"></i>Active</span>
              <% else %>
                <span class="rl-pill"><i class="rl-dot" style="background:var(--color-fg-4)"></i>Inactive</span>
              <% end %>
            </td>
            <td style="text-align:right">
              <div class="row" style="gap:6px;justify-content:flex-end">
                <% if user.sign_in_count.to_i.zero? %>
                  <%= button_to "Resend invite", resend_invite_user_path(user),
                        method: :post, form: { data: { turbo: false } },
                        class: "rl-btn rl-btn--secondary rl-btn--sm" %>
                <% end %>
                <% unless user == current_user %>
                  <button type="button" class="rl-btn rl-btn--ghost rl-btn--sm"
                          data-action="relay--user-admin#toggleActive"
                          data-relay--user-admin-id-param="<%= user.id %>"
                          data-active="<%= user.active? %>">
                    <%= user.active? ? "Deactivate" : "Activate" %>
                  </button>
                  <button type="button" class="rl-btn rl-btn--destructive rl-btn--sm"
                          data-action="relay--user-admin#removeMember"
                          data-relay--user-admin-id-param="<%= user.id %>"
                          data-name="<%= user.name %>"
                          title="Remove from organization">
                    <%= relay_icon("trash-2", size: 14) %>Remove
                  </button>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
