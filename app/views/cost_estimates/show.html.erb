<%# Cost estimate detail — relay DS. Keeps Generate-proposal-PDF and Delete
    (existing endpoints) and the cost summary + grouped features breakdown. %>
<% content_for :title, "#{@cost_estimate.app_type_display} — estimate" %>

<div class="page page--wide">
  <div class="pagehead">
    <div>
      <div class="pagehead__sub" style="margin-bottom:6px">
        <%= link_to cost_estimates_path, class: "row", style: "gap:4px;color:var(--color-fg-2)" do %>
          <%= relay_icon("arrow-left", size: 14) %>Cost estimates
        <% end %>
      </div>
      <div class="pagehead__title"><%= @cost_estimate.app_type_display %></div>
      <div class="pagehead__sub">Created <%= time_ago_in_words(@cost_estimate.created_at) %> ago</div>
    </div>
    <div class="pagehead__actions">
      <%= link_to generate_proposal_cost_estimate_path(@cost_estimate), target: "_blank", class: "rl-btn rl-btn--secondary" do %>
        <%= relay_icon("file-text", size: 15) %>Generate proposal PDF
      <% end %>
      <%= button_to @cost_estimate, method: :delete,
            form: { data: { turbo_confirm: "Are you sure you want to delete this estimate?" } },
            class: "rl-btn rl-btn--destructive" do %>
        <%= relay_icon("trash-2", size: 15) %>Delete
      <% end %>
    </div>
  </div>

  <div class="sect">
    <div class="sect__head"><div class="sect__title">Project description</div></div>
    <div class="sect__body"><p><%= @cost_estimate.description %></p></div>
  </div>

  <div class="sect">
    <div class="sect__head"><div class="sect__title">Cost summary</div></div>
    <div class="sect__body--flush">
      <div class="rl-table-scroll">
        <table class="rl-table">
          <tbody>
            <tr><td class="muted">Application type</td><td class="rl-cell-strong"><%= @cost_estimate.app_type_display %></td></tr>
            <tr><td class="muted">Project scale</td><td><%= @cost_estimate.scale_display %></td></tr>
            <tr><td class="muted">Total hours</td><td class="mono"><%= @cost_estimate.total_hours %> hours</td></tr>
            <tr><td class="muted">Hourly rate</td><td class="mono">$<%= @cost_estimate.hourly_rate %>/hour</td></tr>
            <tr><td class="muted">Total cost</td><td class="rl-cell-num" style="text-align:left"><span class="rl-h4"><%= @cost_estimate.formatted_total_cost %></span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <% if @cost_estimate.features.any? %>
    <div class="sect">
      <div class="sect__head"><div class="sect__title">Features breakdown</div></div>
      <div class="sect__body col" style="gap:var(--space-4)">
        <% @cost_estimate.features.group_by { |f| f["category"] || "General" }.each do |category, features| %>
          <div>
            <div class="micro" style="margin-bottom:8px"><%= category %></div>
            <div style="padding:14px;background:var(--color-surface-2);border-radius:var(--radius-md)">
              <div class="col" style="gap:10px">
                <% features.each do |feature| %>
                  <div class="spread" style="align-items:flex-start">
                    <div class="grow">
                      <div class="rl-sm" style="font-weight:600"><%= feature["name"] %></div>
                      <% if feature["description"].present? %>
                        <div class="muted rl-sm" style="margin-top:2px"><%= feature["description"] %></div>
                      <% end %>
                    </div>
                    <div class="row" style="gap:10px;align-items:center">
                      <% variant = { "low" => "rl-badge--success", "high" => "rl-badge--danger" }[feature["complexity"]&.downcase] || "rl-badge--warning" %>
                      <span class="rl-badge <%= variant %>"><%= feature["complexity"] %></span>
                      <span class="mono rl-sm" style="font-weight:600"><%= feature["hours"] %>h</span>
                    </div>
                  </div>
                <% end %>
              </div>
              <div class="spread" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--color-border)">
                <span class="rl-sm" style="font-weight:600"><%= category %> total</span>
                <span class="mono rl-sm" style="font-weight:600"><%= features.sum { |f| f["hours"] } %>h</span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
