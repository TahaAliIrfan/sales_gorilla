<div class="max-w-4xl mx-auto">
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="flex-1 min-w-0">
      <nav class="flex" aria-label="Breadcrumb">
        <ol role="list" class="flex items-center space-x-4">
          <li>
            <%= link_to cost_estimates_path, class: "text-gray-400 hover:text-gray-500" do %>
              <span>Cost Estimates</span>
            <% end %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="ml-4 text-sm font-medium text-gray-500" aria-current="page">Estimate Details</span>
            </div>
          </li>
        </ol>
      </nav>
      <h2 class="mt-2 text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        <%= @cost_estimate.app_type_display %>
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        Created <%= time_ago_in_words(@cost_estimate.created_at) %> ago
      </p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4 space-x-3">
      <%= link_to generate_proposal_cost_estimate_path(@cost_estimate), target: "_blank",
          class: "inline-flex items-center px-4 py-2 border border-purple-300 shadow-sm text-sm font-medium rounded-md text-purple-700 bg-white hover:bg-purple-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" do %>
        <svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Generate Proposal PDF
      <% end %>
      <%= link_to @cost_estimate, method: :delete, 
          confirm: "Are you sure you want to delete this estimate?",
          class: "inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
        <svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        Delete
      <% end %>
    </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <!-- Project Description -->
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Project Description</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        Detailed requirements and scope
      </p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
      <p class="text-gray-900"><%= @cost_estimate.description %></p>
    </div>

    <!-- Cost Summary -->
    <div class="border-t border-gray-200">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Cost Summary</h3>
      </div>
      <div class="border-t border-gray-200">
        <dl>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Application Type</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @cost_estimate.app_type_display %></dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Project Scale</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @cost_estimate.scale_display %></dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Total Hours</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @cost_estimate.total_hours %> hours</dd>
          </div>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Hourly Rate</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">$<%= @cost_estimate.hourly_rate %>/hour</dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Total Cost</dt>
            <dd class="mt-1 text-lg font-semibold text-blue-600 sm:mt-0 sm:col-span-2"><%= @cost_estimate.formatted_total_cost %></dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Features Breakdown -->
    <% if @cost_estimate.features.any? %>
      <div class="border-t border-gray-200">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Features Breakdown</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">
            Detailed breakdown of features and estimated hours
          </p>
        </div>
        <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
          <% grouped_features = @cost_estimate.features.group_by { |f| f['category'] || 'General' } %>
          <% grouped_features.each do |category, features| %>
            <div class="mb-6">
              <h4 class="text-md font-semibold text-gray-800 mb-3"><%= category %></h4>
              <div class="bg-gray-50 rounded-lg p-4">
                <div class="space-y-3">
                  <% features.each do |feature| %>
                    <div class="flex justify-between items-start">
                      <div class="flex-1">
                        <p class="text-sm font-medium text-gray-900"><%= feature['name'] %></p>
                        <% if feature['description'].present? %>
                          <p class="text-sm text-gray-600 mt-1"><%= feature['description'] %></p>
                        <% end %>
                      </div>
                      <div class="flex items-center space-x-3 ml-4">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= complexity_color(feature['complexity']) %>">
                          <%= feature['complexity'] %>
                        </span>
                        <span class="text-sm font-semibold text-gray-900"><%= feature['hours'] %>h</span>
                      </div>
                    </div>
                  <% end %>
                </div>
                <div class="border-t border-gray-200 mt-3 pt-3">
                  <div class="flex justify-between items-center">
                    <span class="text-sm font-medium text-gray-700"><%= category %> Total:</span>
                    <span class="text-sm font-semibold text-gray-900"><%= features.sum { |f| f['hours'] } %>h</span>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>