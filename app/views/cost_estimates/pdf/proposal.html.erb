  icon = ->(name, size = 12) {
    body = iconsax[name.to_s.tr('-', '_')]
    body ? %(<svg class="ic" width="#{size}" height="#{size}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">#{body}</svg>).html_safe : ''.html_safe
  }

  est      = @cost_estimate
  customer = est.customer_display_name
  date     = Date.current.strftime('%d %B %Y')
  year     = Date.current.year
  fmt      = ->(n) { ActiveSupport::NumberHelper.number_to_delimited(n.to_i) }

  app_name  = est.app_name.presence || est.project_name.presence || "#{customer}'s App"
  exec      = est.executive_summary_data
  apps      = est.similar_apps_data
  prio      = est.feature_prioritization_data
  tech      = est.technical_info_data
  research  = est.market_research_data
  booking_url = 'https://cal.com/tecaudex/discovery-call?duration=30'
  booking_display = 'cal.com/tecaudex/discovery-call'

  scale_text = est.scale_display.to_s.gsub('-', ' ').split.map(&:capitalize).join(' ')

  platform_labels = est.platforms.map { |t|
    CostEstimate::APP_TYPES[t] || t.to_s.humanize.gsub(/\bios\b/i, 'iOS')
  }.uniq

  timeline_text = tech['estimated_timeline'].presence ||
                  "~#{[(est.total_hours / 160.0).ceil, 1].max} months"
  timeline_short = timeline_text[/\d+[\s–-]*\d*\s*(weeks?|months?)/i] || timeline_text

  score = research['validation_score'].presence&.to_i&.clamp(0, 100)
  band  = if score
            score >= 80 ? 'Strong validation' :
            score >= 65 ? 'Promising market'  :
            score >= 50 ? 'Emerging opportunity' : 'Focused niche play'
          end

  # AI-generated concept screens (attached by MockupGenerationService)
  mockup_shots = []
  if est.persisted?
    est.mockup_images.attachments.first(2).each_with_index do |att, i|
      begin
        label = File.basename(att.filename.to_s, '.*').sub(/\A\d+[-_]?/, '').tr('-_', ' ').strip
        mockup_shots << {
          src:   "data:#{att.content_type};base64,#{Base64.strict_encode64(att.download)}",
          label: label.presence || "Concept #{i + 1}"
        }
      rescue => e
        Rails.logger.warn("Proposal PDF: skipping mockup attachment: #{e.message}")
      end
    end
  end

  grouped_features = est.features.group_by { |f| f['category'].presence || 'General' }

  # ── Third-party & operational costs (paid directly to providers) ──
  ft  = est.feature_text
  ops = []
  if est.requires_ios_store?
    ops << { item: 'Apple Developer Program', detail: 'Required to publish on the Apple App Store',
             provider: 'Apple', cadence: 'Per year', cost: '$99', low: 99 }
  end
  if est.requires_android_store?
    ops << { item: 'Google Play Console', detail: 'One-time developer registration to publish on Google Play',
             provider: 'Google', cadence: 'One-time', cost: '$25', low: 25 }
  end
  ops << { item: 'Cloud Hosting & Infrastructure', detail: 'Servers, database & storage (AWS / DigitalOcean)',
           provider: 'Cloud provider', cadence: 'Per month', cost: '$20–80', low: 240 }
  ops << { item: 'Domain Name', detail: 'Your custom web address (e.g. .com)',
           provider: 'Registrar', cadence: 'Per year', cost: '~$15', low: 15 }
  ops << { item: 'SSL Certificate', detail: "Encrypted connections — provisioned via Let's Encrypt",
           provider: 'Included', cadence: 'Included', cost: 'Free', low: 0 }
  ops << { item: 'Transactional Email', detail: 'Sign-up & notification emails (SendGrid / Amazon SES)',
           provider: 'SendGrid / AWS', cadence: 'Per month', cost: 'Free–$15', low: 0 }
  if est.mobile_app?
    ops << { item: 'Push Notifications', detail: 'Firebase Cloud Messaging for iOS & Android',
             provider: 'Google', cadence: 'Included', cost: 'Free', low: 0 }
  end
  if ft.match?(/payment|checkout|subscription|billing|stripe|wallet|purchase|e-?commerce/)
    ops << { item: 'Payment Processing', detail: 'Stripe (or similar) — deducted per successful transaction',
             provider: 'Stripe', cadence: 'Usage-based', cost: '2.9% + $0.30 / txn', low: 0 }
  end
  if ft.match?(/\bmaps?\b|location|geolocation|\bgps\b|route|navigation/)
    ops << { item: 'Maps & Geolocation', detail: 'Google Maps Platform — generous monthly free tier',
             provider: 'Google', cadence: 'Usage-based', cost: 'Free tier', low: 0 }
  end
  if ft.match?(/\bsms\b|\botp\b|phone verification|text message/)
    ops << { item: 'SMS & Phone Verification', detail: 'Twilio (or similar) — charged per message sent',
             provider: 'Twilio', cadence: 'Usage-based', cost: '~$0.01–0.05 / SMS', low: 0 }
  end
  ops_year1_from = ops.sum { |o| o[:low] }

  # Tecaudex mark (red kept only here and in small accents)
  logo_svg = <<~SVG.html_safe
    <svg viewBox="0 0 301 300" xmlns="http://www.w3.org/2000/svg" class="mark">
      <rect x="0.236816" width="300" height="300" rx="150" fill="white"/>
      <path d="M202.544 133.219L189.464 155.491L204.901 182.892H173.099L160.104 206.382H244.237L202.544 133.219Z" fill="black"/>
      <path d="M97.9295 133.219L111.009 155.491L95.5727 182.892H127.374L140.37 206.382H56.2368L97.9295 133.219Z" fill="black"/>
      <path d="M84.7654 93.6182H215.509L199.82 120.784H163.696V182.802L150.369 206.382L136.524 182.892L136.53 120.784H100.654L84.7654 93.6182Z" fill="#ED1A3B"/>
    </svg>
  SVG

  sec_idx = 0
  next_section = ->{ sec_idx += 1; format('%02d', sec_idx) }
%>

