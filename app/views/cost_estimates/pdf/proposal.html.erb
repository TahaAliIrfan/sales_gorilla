<!-- ═══════════════════════════════════════════════════════════════════
     MARKET RESEARCH — validation score + constructive feedback
     ═══════════════════════════════════════════════════════════════════ -->
<% if score %>
<%
  signals = Array(research['market_signals'])
  refines = Array(research['refinements']).select { |r| r.is_a?(Hash) }

  # Speedometer geometry: semicircle centred at (110,110), radius 84.
  arc_r    = 84
  arc_len  = Math::PI * arc_r
  angle    = Math::PI * (1 - score / 100.0)
  needle_x = 110 + 58 * Math.cos(angle)
  needle_y = 110 - 58 * Math.sin(angle)
%>
<section class="page">
  <% n = next_section.call %>
  <div class="sec-head">
    <div class="kicker">
      <span class="chip-no"><%= n %></span>
      <span class="eyebrow">Market research</span>
    </div>
    <h2>How the idea scores</h2>
    <p class="lead">An honest research pass on <%= app_name %> — what the market is signalling, and how we'd sharpen the idea to win it.</p>
  </div>

  <div class="research-top">
    <div class="gauge-card">
      <svg class="gauge" viewBox="0 0 220 120" xmlns="http://www.w3.org/2000/svg">
        <% (0..4).each do |i| %>
          <% ta = Math::PI * (1 - i / 4.0) %>
          <line x1="<%= (110 + 68 * Math.cos(ta)).round(1) %>" y1="<%= (110 - 68 * Math.sin(ta)).round(1) %>"
                x2="<%= (110 + 74 * Math.cos(ta)).round(1) %>" y2="<%= (110 - 74 * Math.sin(ta)).round(1) %>"
                stroke="#D9D8D0" stroke-width="2" stroke-linecap="round"/>
        <% end %>
        <path d="M 26 110 A 84 84 0 0 1 194 110" fill="none" stroke="#EFEEE8" stroke-width="12" stroke-linecap="round"/>
        <path d="M 26 110 A 84 84 0 0 1 194 110" fill="none" stroke="#177A4C" stroke-width="12" stroke-linecap="round"
              stroke-dasharray="<%= (arc_len * score / 100.0).round(1) %> <%= arc_len.ceil + 10 %>"/>
        <line x1="110" y1="110" x2="<%= needle_x.round(1) %>" y2="<%= needle_y.round(1) %>"
              stroke="#191917" stroke-width="3.5" stroke-linecap="round"/>
        <circle cx="110" cy="110" r="5.5" fill="#191917"/>
        <circle cx="110" cy="110" r="2" fill="#F7F6F2"/>
      </svg>
      <div class="score"><%= score %><span class="sm">/100</span></div>
      <div class="glabel">Idea validation score</div>
    </div>
    <div class="verdict-card">
      <span class="chip g" style="align-self:flex-start;"><%= band %></span>
      <% if research['verdict'].present? %>
        <p><%= research['verdict'] %></p>
      <% end %>
    </div>
  </div>

  <% if signals.any? %>
    <div class="card vgap">
      <div class="card-label"><%= icon.call('trend-up') %> What the market is telling us</div>
      <% signals.each_with_index do |sig, i| %>
        <div class="row">
          <div class="idx"><%= format('%02d', i + 1) %></div>
          <div class="body"><%= sig %></div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if refines.any? %>
    <div class="card vgap">
      <div class="card-label"><%= icon.call('lamp-on') %> How we'd sharpen the idea</div>
      <% refines.each do |r| %>
        <div class="refine">
          <div class="col">
            <div class="tag">What we noticed</div>
            <div class="txt"><%= r['observation'] %></div>
          </div>
          <div class="arrow"><%= icon.call('arrow-right', 13) %></div>
          <div class="col dir">
            <div class="tag">Direction we recommend</div>
            <div class="txt"><%= r['direction'] %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
<% end %>

