<div class="px-4 sm:px-6 lg:px-8 py-8 min-h-screen max-w-[1240px] mx-auto">

  <!-- Header -->
  <div class="mb-7 flex items-end justify-between">
    <div>
      <div class="cb-eyebrow mb-1">integrations // lead_webhooks</div>
      <h1 class="text-[26px] font-bold tracking-tight text-[#0F172A]">Lead Webhooks</h1>
      <p class="text-[13px] text-[#64748B] mt-1.5 max-w-xl">
        Self-service intake endpoints for Zapier / Meta Lead Ads. Create a webhook,
        paste its URL into your Zap &mdash; no code changes needed per campaign.
      </p>
    </div>
    <%= link_to new_lead_webhook_path, class: "inline-flex items-center gap-2 rounded-lg bg-[#4F46E5] px-4 py-2.5 text-[13px] font-medium text-white hover:bg-[#4338CA] transition-colors" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      New Webhook
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="mb-5 cb-panel px-4 py-3 text-[13px]" style="border-color:rgba(79,70,229,.35);color:#4F46E5;"><%= notice %></div>
  <% end %>

  <!-- Stats strip -->
  <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    <div class="cb-panel p-5">
      <div class="cb-eyebrow">webhooks</div>
      <div class="cb-mono text-[30px] font-semibold text-[#0F172A] mt-1.5 leading-none"><%= @lead_webhooks.size %></div>
    </div>
    <div class="cb-panel p-5">
      <div class="cb-eyebrow">active</div>
      <div class="cb-mono text-[30px] font-semibold text-[#0D9488] mt-1.5 leading-none"><%= @lead_webhooks.count(&:active?) %></div>
    </div>
    <div class="cb-panel p-5">
      <div class="cb-eyebrow">leads_received</div>
      <div class="cb-mono text-[30px] font-semibold text-[#4F46E5] mt-1.5 leading-none"><%= @lead_webhooks.sum(&:leads_count) %></div>
    </div>
  </div>

  <!-- Webhook table -->
  <div class="cb-panel overflow-hidden">
    <div class="px-5 py-4 border-b border-[#E9ECF1] flex items-center justify-between">
      <span class="cb-eyebrow">endpoints // zapier_intake</span>
    </div>

    <% if @lead_webhooks.empty? %>
      <div class="px-5 py-12 text-center">
        <p class="text-[13.5px] text-[#64748B]">No webhooks yet. Create one and paste its URL into Zapier as the action URL.</p>
      </div>
    <% else %>
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead>
            <tr class="border-b border-[#E9ECF1] bg-[#F8FAFC] text-left">
              <th class="px-5 py-3 text-[#94A3B8]">Webhook</th>
              <th class="px-5 py-3 text-[#94A3B8]">Endpoint URL</th>
              <th class="px-5 py-3 text-[#94A3B8]">Leads</th>
              <th class="px-5 py-3 text-[#94A3B8]">Last Received</th>
              <th class="px-5 py-3 text-[#94A3B8]">Status</th>
              <th class="px-5 py-3 text-[#94A3B8] text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @lead_webhooks.each do |webhook| %>
              <% url = api_v1_lead_intake_url(token: webhook.token) %>
              <tr class="border-b border-[#EEF0F3] last:border-0 hover:bg-[#4F46E5]/[.03] transition-colors">
                <td class="px-5 py-4 whitespace-nowrap">
                  <div class="text-[13.5px] font-medium text-[#0F172A]"><%= webhook.name %></div>
                  <div class="cb-mono text-[10.5px] text-[#94A3B8] mt-0.5">source: <%= webhook.lead_source %></div>
                </td>
                <td class="px-5 py-4">
                  <div class="flex items-center gap-2">
                    <code class="cb-mono text-[11px] text-[#334155] bg-[#F1F5F9] rounded px-2 py-1 max-w-[280px] truncate inline-block align-middle" title="<%= url %>"><%= url %></code>
                    <button type="button" class="copy-webhook-url shrink-0 rounded-md border border-[#DCE0E6] px-2 py-1 text-[11px] text-[#64748B] hover:border-[#4F46E5] hover:text-[#4F46E5] transition-colors" data-url="<%= url %>">Copy</button>
                  </div>
                  <% if webhook.last_error.present? %>
                    <div class="cb-mono text-[10.5px] text-[#E11D48] mt-1 max-w-[340px] truncate" title="<%= webhook.last_error %>">last_error: <%= webhook.last_error %></div>
                  <% end %>
                </td>
                <td class="px-5 py-4 whitespace-nowrap">
                  <span class="cb-mono text-[12px] text-[#0D9488]"><%= webhook.leads_count %></span>
                </td>
                <td class="px-5 py-4 whitespace-nowrap">
                  <span class="cb-mono text-[11px] text-[#64748B]">
                    <%= webhook.last_received_at ? "#{time_ago_in_words(webhook.last_received_at)} ago" : '—' %>
                  </span>
                </td>
                <td class="px-5 py-4 whitespace-nowrap">
                  <% if webhook.active? %>
                    <span class="cb-pill" style="color:#4F46E5;border-color:rgba(79,70,229,.35)">● ACTIVE</span>
                  <% else %>
                    <span class="cb-pill" style="color:#E11D48;border-color:rgba(225,29,72,.3)">○ PAUSED</span>
                  <% end %>
                </td>
                <td class="px-5 py-4 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to 'Edit', edit_lead_webhook_path(webhook), class: "rounded-md border border-[#DCE0E6] px-2.5 py-1 text-[11.5px] text-[#64748B] hover:border-[#4F46E5] hover:text-[#4F46E5] transition-colors" %>
                    <%= button_to webhook.active? ? 'Pause' : 'Activate', toggle_active_lead_webhook_path(webhook), method: :patch, class: "rounded-md border border-[#DCE0E6] px-2.5 py-1 text-[11.5px] text-[#64748B] hover:border-[#D97706] hover:text-[#D97706] transition-colors" %>
                    <%= button_to 'Delete', lead_webhook_path(webhook), method: :delete, form: { data: { turbo_confirm: "Delete \"#{webhook.name}\"? Zaps posting to this URL will start failing." } }, class: "rounded-md border border-[#DCE0E6] px-2.5 py-1 text-[11.5px] text-[#64748B] hover:border-[#E11D48] hover:text-[#E11D48] transition-colors" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

  <!-- Field reference for Zapier mapping -->
  <div class="cb-panel mt-6 p-5">
    <div class="cb-eyebrow mb-3">zapier // accepted_fields</div>
    <p class="text-[12.5px] text-[#64748B] mb-3">
      POST JSON or form data to the endpoint URL. <code class="cb-mono text-[11px] bg-[#F1F5F9] rounded px-1.5 py-0.5">email</code> or
      <code class="cb-mono text-[11px] bg-[#F1F5F9] rounded px-1.5 py-0.5">phone</code> is required; everything else is optional.
      The lead source is set by the webhook config, not the payload.
    </p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-1 cb-mono text-[11px] text-[#334155]">
      <% {
        'Contact' => %w[name email phone country description],
        'Meta lead' => %w[meta_lead_id meta_campaign_id meta_adset_id meta_ad_id browser_id],
        'Click IDs' => %w[fbclid gclid gbraid wbraid msclkid],
        'Attribution' => %w[utm_source utm_medium utm_campaign utm_term utm_content landing_page traffic_source]
      }.each do |group, fields| %>
        <div>
          <div class="cb-eyebrow mt-2 mb-1"><%= group.downcase.tr(' ', '_') %></div>
          <% fields.each do |f| %><div><%= f %></div><% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.copy-webhook-url');
    if (!btn) return;
    navigator.clipboard.writeText(btn.dataset.url).then(function() {
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = original; }, 1500);
    });
  });
</script>
